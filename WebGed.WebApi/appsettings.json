{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "gedophir.sistemasld.com.br;localhost",
  "SystemSeed": {
    "Enabled": false,
    "AllowPoC": false,
    "FailFastOnSeedError": false,
    "UpdateExistingPasswords": false,
    "NormalizeLegacyRoles": true
  },
  "Auth": {
    "AllowInternalSelfSignedCertificates": false
  },
  "Operations": {
    "WorkerEnabled": false
  },
  "Backup": {
    "Enabled": false,
    "RootPath": "",
    "PostgresBinPath": "",
    "MaxParallelJobs": 1,
    "DefaultRetentionDays": 30,
    "VerificationEnabled": true
  },
  "Portability": {
    "Enabled": false,
    "RootPath": "",
    "PackageExpirationDays": 7,
    "MaxParallelJobs": 1,
    "IncludeAuditByDefault": false
  },
  "DigitalSignature": {
    "Enabled": false,
    "AllowServerSidePfxUpload": false
  }
}
