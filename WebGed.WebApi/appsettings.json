{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "gedophir.sistemasld.com.br;localhost",
  "SystemSeed": {
    "Enabled": false,
    "AllowPoC": false,
    "FailFastOnSeedError": false,
    "UpdateExistingPasswords": false,
    "NormalizeLegacyRoles": true
  },
  "Auth": {
    "AllowInternalSelfSignedCertificates": false
  },
  "Operations": {
    "WorkerEnabled": false
  },
  "Backup": {
    "Enabled": false,
    "RootPath": "",
    "PostgresBinPath": "",
    "MaxParallelJobs": 1,
    "DefaultRetentionDays": 30,
    "VerificationEnabled": true
  },
  "Portability": {
    "Enabled": false,
    "RootPath": "",
    "PackageExpirationDays": 7,
    "MaxParallelJobs": 1,
    "IncludeAuditByDefault": false
  },
  "DigitalSignature": {
    "Enabled": false,
    "Mode": "AgentCms",
    "SessionTtlSeconds": 300,
    "ContentTokenTtlSeconds": 120,
    "CompletionTokenTtlSeconds": 300,
    "MaxDocumentSizeMb": 100,
    "HashAlgorithm": "SHA256",
    "RequireCertificateIdentityMatch": true,
    "AllowServerSidePfxUpload": false,
    "AllowInternalTestCertificates": false,
    "Agent": {
      "BaseUrl": "https://127.0.0.1:17891",
      "RequireHttps": true,
      "AllowedOrigins": [],
      "AllowedServerHosts": [],
      "PairingTtlSeconds": 300,
      "OperationTtlSeconds": 600
    },
    "RequireLoopbackHttps": true,
    "AgentBaseUrl": "https://127.0.0.1:17891",
    "AllowedAgentOrigins": []
  }
}
