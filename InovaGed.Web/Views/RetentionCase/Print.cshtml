@model (InovaGed.Application.RetentionCases.RetentionCaseRow Case, IReadOnlyList<InovaGed.Application.RetentionCases.RetentionCaseItemRow> Items)
@{
    Layout = null;
}

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Caso #@Model.Case.CaseNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        media print {
            .no-print

        {
            display: none;
        }

        }
    </style>
</head>
<body class="p-4">
    <div class="no-print d-flex justify-content-between mb-3">
        <div class="text-muted">Evidência do Caso</div>
        <button class="btn btn-primary" onclick="window.print()">Imprimir</button>
    </div>

    <h3 class="mb-1">Caso de Destinação #@Model.Case.CaseNo</h3>
    <div class="text-muted mb-3">@Model.Case.Title • Status: <strong>@Model.Case.Status</strong> • Criado: @Model.Case.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>

    <table class="table table-bordered table-sm align-middle">
        <thead>
            <tr>
                <th>Doc</th>
                <th>Classificação</th>
                <th>Venc.</th>
                <th>Status</th>
                <th>Destino sugerido</th>
                <th>Decisão</th>
                <th>Obs.</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model.Items)
            {
                <tr>
                    <td>@i.DocCode<br /><small class="text-muted">@i.DocTitle</small></td>
                    <td>@i.ClassificationCode<br /><small class="text-muted">@i.ClassificationName</small></td>
                    <td>@(i.RetentionDueAt.ToString("dd/MM/yyyy") ?? "—")</td>
                    <td>@i.RetentionStatus</td>
                    <td>@i.SuggestedDestination</td>
                    <td>@i.Decision</td>
                    <td>@i.DecisionNotes</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>