@model InovaGed.Application.Ged.Protocols.ProtocolWorkQueueVm
@{ ViewData["Title"] = "Fila de Protocolos"; }
<h1 class="h3 mb-3">Fila de Manuseio / Processamento</h1>
<form class="row g-2 mb-3" method="get"><div class="col-md-3"><input asp-for="Filter.Q" name="Q" class="form-control" placeholder="Buscar" /></div><div class="col-md-2"><select asp-for="Filter.Status" name="Status" class="form-select"><option value="">Status</option><option>REQUESTED</option><option>IN_REVIEW</option><option>RETURNED_FOR_ADJUSTMENT</option><option>ADJUSTMENT_ANSWERED</option><option>APPROVED</option><option>REJECTED</option><option>FINISHED</option></select></div><div class="col-md-2"><select asp-for="Filter.Priority" name="Priority" class="form-select"><option value="">Prioridade</option><option>NORMAL</option><option>LOW</option><option>HIGH</option><option>URGENT</option></select></div><div class="col-md-2 form-check pt-2"><input asp-for="Filter.OnlyMine" name="OnlyMine" class="form-check-input" /> <label class="form-check-label">Somente meus</label></div><div class="col-md-2 form-check pt-2"><input asp-for="Filter.Overdue" name="Overdue" class="form-check-input" /> <label class="form-check-label">Vencidos</label></div><div class="col-md-1"><button class="btn btn-primary">Filtrar</button></div></form>
<div class="card shadow-sm"><div class="table-responsive"><table class="table table-hover mb-0"><thead><tr><th>Protocolo</th><th>Título</th><th>Solicitante</th><th>Origem</th><th>Destino</th><th>Status</th><th>Prioridade</th><th>Prazo</th><th>Responsável</th><th>Ações</th></tr></thead><tbody>
@foreach (var x in Model.Rows) { <tr class="@(x.IsOverdue ? "table-warning" : "")"><td class="fw-semibold">@x.ProtocolNo</td><td>@x.Title</td><td>@x.RequesterName</td><td>@x.RequesterSectorName</td><td>@x.AssignedSectorName</td><td>@x.StatusLabel</td><td>@x.Priority</td><td>@(x.DueAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td><td>@(x.AssignedUserName ?? "-")</td><td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@x.Id">Ver detalhes</a></td></tr> }
</tbody></table></div></div>
