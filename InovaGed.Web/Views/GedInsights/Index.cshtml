@model InovaGed.Application.Audit.AuditDashboardVM
@{
    ViewData["Title"] = "Central GED";
}
<section class="container-fluid py-3">
    <h2>Central de KPIs e Inteligência</h2>
    <p class="text-muted">Visão consolidada com busca avançada (full-text + OCR), notificações e indicadores de pendências.</p>
    <div class="alert alert-info" role="status" aria-live="polite">
        Duplicidades detectadas nas últimas análises: <strong>@ViewBag.DuplicatesCount</strong>
    </div>
</section>
