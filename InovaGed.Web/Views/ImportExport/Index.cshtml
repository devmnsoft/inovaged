@using InovaGed.Web.Controllers
@model ImportExportController.ImportIndexVM

@{
    ViewData["Title"] = "Importação de Documentos";

    var total = Model?.RecentImports?.Count ?? 0;
    var success = Model?.RecentImports?.Count(x => x.Status == "SUCCESS") ?? 0;
    var failed = Model?.RecentImports?.Count(x => x.Status == "FAILED" || x.Status == "ERROR") ?? 0;
    var signed = Model?.RecentImports?.Count(x => x.SigDetected) ?? 0;

    string StatusBadge(string status) => status switch
    {
        "SUCCESS" => "text-bg-success",
        "FAILED" => "text-bg-danger",
        "ERROR" => "text-bg-danger",
        _ => "text-bg-secondary"
    };

    string StatusLabel(string status) => status switch
    {
        "SUCCESS" => "Importado",
        "FAILED" => "Falhou",
        "ERROR" => "Erro",
        _ => status
    };

    string SigBadge(string status) => status switch
    {
        "VALID" => "text-bg-success",
        "INVALID" => "text-bg-danger",
        "UNKNOWN" => "text-bg-warning text-dark",
        "NOT_VERIFIABLE" => "text-bg-warning text-dark",
        "NOT_SIGNED" => "text-bg-secondary",
        _ => "text-bg-light text-dark border"
    };

    string SigLabel(string status) => status switch
    {
        "VALID" => "Válida",
        "INVALID" => "Inválida",
        "UNKNOWN" => "Detectada",
        "NOT_VERIFIABLE" => "Não verificável",
        "NOT_SIGNED" => "Não assinada",
        _ => string.IsNullOrWhiteSpace(status) ? "—" : status
    };
}

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2">
        <i class="bi bi-check-circle-fill"></i>
        <div>@ok</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>@err</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-cloud-upload me-2"></i>
            @ViewData["Title"]
        </h3>
        <div class="text-muted">
            Importe documentos para o GED, registre histórico, detecte assinatura digital e mantenha rastreabilidade.
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">
            <i class="bi bi-box-seam me-1"></i>
            Lotes
        </a>

        <a class="btn btn-outline-primary" asp-controller="ImportExport" asp-action="ExportCenter">
            <i class="bi bi-cloud-download me-1"></i>
            Central de Exportação
        </a>
    </div>
</div>

<div class="alert alert-primary border-0 shadow-sm mb-4">
    <div class="d-flex gap-3">
        <div class="fs-3">
            <i class="bi bi-info-circle"></i>
        </div>
        <div>
            <strong>Para que serve esta tela?</strong>
            <div class="small mt-1">
                Esta central permite importar arquivos para o GED, vincular os documentos a uma pasta,
                detectar assinatura digital em PDFs e registrar logs de auditoria. Registros excluídos ou
                documentos inativos não aparecem mais nesta listagem.
            </div>

            <div class="d-flex flex-wrap gap-2 mt-2">
                <span class="badge text-bg-success">
                    <i class="bi bi-check-circle me-1"></i>
                    Importação com feedback
                </span>
                <span class="badge text-bg-primary">
                    <i class="bi bi-shield-check me-1"></i>
                    Auditoria automática
                </span>
                <span class="badge text-bg-warning text-dark">
                    <i class="bi bi-patch-check me-1"></i>
                    Detecção de assinatura
                </span>
                <span class="badge text-bg-secondary">
                    <i class="bi bi-trash me-1"></i>
                    Exclusão lógica do histórico
                </span>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Importações listadas</div>
                <div class="fs-4 fw-bold">@total</div>
                <div class="small text-muted">últimos registros ativos</div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Sucesso</div>
                <div class="fs-4 fw-bold">@success</div>
                <span class="badge text-bg-success">SUCCESS</span>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Falhas / Erros</div>
                <div class="fs-4 fw-bold">@failed</div>
                <span class="badge text-bg-danger">FAILED / ERROR</span>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Assinaturas detectadas</div>
                <div class="fs-4 fw-bold">@signed</div>
                <span class="badge text-bg-warning text-dark">PDF assinado</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <strong>
                    <i class="bi bi-cloud-upload me-1"></i>
                    Nova importação
                </strong>
            </div>

            <div class="card-body">
                <form asp-action="Import"
                      asp-controller="ImportExport"
                      method="post"
                      enctype="multipart/form-data"
                      id="frmImport">

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Arquivo <span class="text-danger">*</span>
                        </label>
                        <input type="file"
                               name="file"
                               class="form-control"
                               accept=".pdf,.xml,.docx,.xlsx,.zip,.p7s,.p7m,.jpg,.jpeg,.png"
                               required
                               id="fileInput" />
                        <div class="form-text">
                            Formatos aceitos: PDF, XML, DOCX, XLSX, ZIP, P7S, P7M, JPG e PNG.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Título do documento</label>
                        <input type="text"
                               name="title"
                               class="form-control"
                               placeholder="Opcional — se vazio, usa o nome do arquivo"
                               maxlength="200" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Pasta de destino <span class="text-danger">*</span>
                        </label>

                        <select name="folderId" class="form-select" required>
                            <option value="">— selecione uma pasta —</option>

                            @foreach (var f in Model.Folders)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>

                        <div class="form-text">
                            O documento será criado dentro da pasta selecionada.
                        </div>
                    </div>

                    <div id="filePreview" class="d-none mb-3">
                        <div class="border rounded p-3 bg-light small d-flex align-items-center gap-3">
                            <i class="bi bi-file-earmark fs-2 text-primary"></i>
                            <div>
                                <div id="previewName" class="fw-semibold"></div>
                                <div id="previewSize" class="text-muted"></div>
                            </div>
                        </div>

                        <div id="pdfWarning" class="d-none mt-2 alert alert-warning small py-2 mb-0">
                            <i class="bi bi-shield-check me-1"></i>
                            PDF detectado. O sistema tentará identificar assinatura digital.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" id="btnImport">
                        <i class="bi bi-cloud-upload me-1"></i>
                        Importar documento
                    </button>
                </form>
            </div>

            <div class="card-footer bg-white">
                <div class="small text-muted">
                    Ao importar, o sistema registra usuário, data, arquivo, status e evidências no log operacional.
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <strong>
                        <i class="bi bi-clock-history me-1"></i>
                        Histórico de importações
                    </strong>
                    <div class="small text-muted">
                        Exibe apenas registros ativos e documentos ainda válidos no GED.
                    </div>
                </div>

                <span class="badge text-bg-secondary">@total registro(s)</span>
            </div>

            <div class="card-body p-0">
                @if (Model.RecentImports is null || !Model.RecentImports.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                        <h5 class="mb-1">Nenhuma importação encontrada</h5>
                        <div>Importe um documento para iniciar o histórico desta central.</div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Arquivo</th>
                                    <th style="width: 145px;">Data</th>
                                    <th style="width: 115px;">Status</th>
                                    <th style="width: 145px;">Assinatura</th>
                                    <th style="width: 125px;" class="text-end">Ações</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var r in Model.RecentImports)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold text-truncate" style="max-width: 260px;" title="@r.FileName">
                                                @r.FileName
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(r.DocumentCode))
                                            {
                                                <div class="small text-muted">
                                                    <span class="font-monospace">@r.DocumentCode</span> — @r.DocumentTitle
                                                </div>
                                            }
                                            else if (r.DocumentId.HasValue)
                                            {
                                                <div class="small text-muted">Documento vinculado: @r.DocumentId</div>
                                            }
                                            else
                                            {
                                                <div class="small text-muted">Sem documento vinculado.</div>
                                            }
                                        </td>

                                        <td>
                                            <div>@r.ImportedAt.ToString("dd/MM/yyyy")</div>
                                            <div class="small text-muted">@r.ImportedAt.ToString("HH:mm")</div>
                                        </td>

                                        <td>
                                            <span class="badge @StatusBadge(r.Status)">
                                                @StatusLabel(r.Status)
                                            </span>
                                        </td>

                                        <td>
                                            <span class="badge @SigBadge(r.SigStatus)" title="@r.SigDetails">
                                                @SigLabel(r.SigStatus)
                                            </span>
                                        </td>

                                        <td class="text-end">
                                            <div class="btn-group">
                                                @if (r.DocumentId.HasValue)
                                                {
                                                    <a asp-controller="Ged"
                                                       asp-action="Details"
                                                       asp-route-id="@r.DocumentId"
                                                       class="btn btn-sm btn-outline-primary"
                                                       title="Ver documento">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                }

                                                <form asp-controller="ImportExport"
                                                      asp-action="HideLog"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('Deseja excluir este registro do histórico de importação? O documento no GED não será apagado.');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@r.Id" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger"
                                                            title="Excluir registro do histórico">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const fileInput = document.getElementById('fileInput');
            const preview = document.getElementById('filePreview');
            const previewName = document.getElementById('previewName');
            const previewSize = document.getElementById('previewSize');
            const pdfWarning = document.getElementById('pdfWarning');
            const frmImport = document.getElementById('frmImport');
            const btnImport = document.getElementById('btnImport');

            fileInput?.addEventListener('change', function () {
                const file = this.files?.[0];

                if (!file) {
                    preview?.classList.add('d-none');
                    return;
                }

                previewName.textContent = file.name;
                previewSize.textContent = (file.size / 1024 / 1024).toFixed(2) + ' MB';

                preview?.classList.remove('d-none');

                const isPdf = file.name.toLowerCase().endsWith('.pdf') || file.type === 'application/pdf';

                pdfWarning?.classList.toggle('d-none', !isPdf);
            });

            frmImport?.addEventListener('submit', function () {
                btnImport.disabled = true;
                btnImport.innerHTML = `
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    Importando...
                `;
            });
        })();
    </script>
}