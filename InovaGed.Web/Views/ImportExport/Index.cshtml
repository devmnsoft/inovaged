@using InovaGed.Web.Controllers
@model ImportExportController.ImportIndexVM
@{
    ViewData["Title"] = "Importar / Exportar";
    ViewData["Subtitle"] = "Importação de documentos com verificação de assinatura digital — PoC (Item 22)";

    string SigBadgeCss(string s) => s switch
    {
        "VALID" => "text-bg-success",
        "INVALID" => "text-bg-danger",
        "UNKNOWN" => "text-bg-warning text-dark",
        _ => "text-bg-secondary"
    };
    string SigBadgeIcon(string s) => s switch
    {
        "VALID" => "bi-patch-check-fill",
        "INVALID" => "bi-x-octagon-fill",
        "UNKNOWN" => "bi-question-circle-fill",
        _ => "bi-dash-circle"
    };
    string SigBadgeLabel(string s) => s switch
    {
        "VALID" => "Válida",
        "INVALID" => "Inválida",
        "UNKNOWN" => "Sem verificação",
        "NOT_SIGNED" => "Não assinado",
        _ => s
    };

    string StatusBadge(string s) => s switch
    {
        "SUCCESS" => "text-bg-success",
        "FAILED" => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-1"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Err"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-1"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    <!-- Painel de importação -->
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                <strong><i class="bi bi-cloud-upload me-1"></i>Importar Documento</strong>
                <span class="badge text-bg-primary ms-2 small">PoC (22)</span>
            </div>
            <div class="card-body">

                <div class="alert alert-info small mb-3">
                    <i class="bi bi-info-circle me-1"></i>
                    No momento da importação, o sistema verifica automaticamente se o arquivo
                    possui <strong>assinatura digital</strong> e registra o estado de validade
                    conforme exigido pelo item 22 da PoC.
                </div>

                <form asp-action="Import" asp-controller="ImportExport"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Arquivo <span class="text-danger">*</span></label>
                        <input type="file" name="file" class="form-control"
                               accept=".pdf,.xml,.docx,.xlsx,.zip,.p7s,.p7m"
                               required id="fileInput" />
                        <div class="form-text">Formatos aceitos: PDF, XML, DOCX, XLSX, ZIP, P7S, P7M</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Título</label>
                        <input type="text" name="title" class="form-control"
                               placeholder="(opcional — usa nome do arquivo)" maxlength="200" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Pasta de destino <span class="text-danger">*</span></label>
                        <select name="folderId" class="form-select" required>
                            <option value="">— selecione —</option>
                            @foreach (var f in Model.Folders)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Preview do arquivo selecionado -->
                    <div id="filePreview" class="d-none mb-3">
                        <div class="border rounded p-2 bg-light small d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark fs-4 text-primary"></i>
                            <div>
                                <div id="previewName" class="fw-semibold"></div>
                                <div id="previewSize" class="text-muted"></div>
                            </div>
                        </div>
                        <div id="pdfWarning" class="d-none mt-2 alert alert-warning small py-2 mb-0">
                            <i class="bi bi-shield-check me-1"></i>
                            Arquivo PDF detectado — a assinatura digital será verificada automaticamente.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-cloud-upload me-1"></i> Importar e Verificar Assinatura
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Histórico de importações -->
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center gap-2">
                <strong><i class="bi bi-clock-history me-1"></i>Importações Recentes</strong>
                <span class="badge text-bg-secondary ms-auto">@Model.RecentImports.Count</span>
            </div>

            <div class="card-body p-0">
                @if (!Model.RecentImports.Any())
                {
                    <div class="p-4 text-muted text-center">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        Nenhuma importação registrada ainda.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Arquivo</th>
                                    <th>Importado em</th>
                                    <th>Resultado</th>
                                    <th>Assinatura</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.RecentImports)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold small text-truncate" style="max-width:180px"
                                                 title="@r.FileName">
                                                @r.FileName
                                            </div>
                                            @if (r.DocumentCode != null)
                                            {
                                                <div class="text-muted small font-monospace">@r.DocumentCode</div>
                                            }
                                        </td>
                                        <td class="text-nowrap small">
                                            @r.ImportedAt.ToString("dd/MM/yyyy HH:mm")
                                        </td>
                                        <td>
                                            <span class="badge @StatusBadge(r.Status)">
                                                @r.Status
                                            </span>
                                        </td>
                                        <td>
                                            @if (r.SigDetected)
                                            {
                                                <span class="badge @SigBadgeCss(r.SigStatus) d-inline-flex align-items-center gap-1"
                                                      title="@r.SigDetails">
                                                    <i class="bi @SigBadgeIcon(r.SigStatus)"></i>
                                                    @SigBadgeLabel(r.SigStatus)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Validado</span>
                                            }
                                        </td>

                                        <td class="text-end">
                                            @if (r.DocumentId.HasValue)
                                            {
                                                <a asp-controller="Ged" asp-action="Details"
                                                   asp-route-id="@r.DocumentId"
                                                   class="btn btn-xs btn-outline-secondary"
                                                   title="Ver documento">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Link para exportação -->
        <div class="mt-3">
            <a asp-controller="ImportExport" asp-action="ExportCenter"
               class="btn btn-outline-secondary">
                <i class="bi bi-cloud-download me-1"></i> Central de Exportação
                <span class="badge text-bg-secondary ms-1 small">PoC (23)</span>
            </a>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.getElementById('fileInput')?.addEventListener('change', function () {
            const file = this.files?.[0];
            const preview = document.getElementById('filePreview');
            const warning = document.getElementById('pdfWarning');
            if (!file) { preview?.classList.add('d-none'); return; }

            document.getElementById('previewName').textContent = file.name;
            document.getElementById('previewSize').textContent =
                (file.size / 1024 / 1024).toFixed(2) + ' MB';
            preview?.classList.remove('d-none');

            const isPdf = file.name.toLowerCase().endsWith('.pdf')
                       || file.type === 'application/pdf';
            warning?.classList.toggle('d-none', !isPdf);
        });
    </script>
}
