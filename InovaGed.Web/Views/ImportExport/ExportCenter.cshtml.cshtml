@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Exportar Documentos";
    ViewData["Subtitle"] = "PoC 23 (exportação ZIP)";
}

<div class="container py-3">
    <div class="alert alert-info">
        Clique em “Exportar” para baixar um ZIP com metadados e arquivo.
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Título</th>
                    <th>Arquivo</th>
                    <th style="width:200px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model ?? Enumerable.Empty<dynamic>())
                {
                    <tr>
                        <td class="font-monospace">@d.code</td>
                        <td>@d.title</td>
                        <td class="text-muted">@d.file_name</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-primary"
                               asp-controller="ImportExport" asp-action="Export"
                               asp-route-docId="@d.id">
                                Exportar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="ImportExport" asp-action="Index">Voltar</a>
</div>