@model IReadOnlyList<InovaGed.Application.ClassificationPlans.ClassificationVersionItemRow>
@{
    Layout = null;
    var ver = (InovaGed.Application.ClassificationPlans.ClassificationVersionDetailsVM)ViewBag.Version!;
    string Indent(int level) => new string('—', Math.Max(0, level));
}

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>PCD/TTD - V@ver.VersionNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        media print {
            .no-print

        {
            display: none;
        }

        }

        .mono {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
        }
    </style>
</head>
<body class="p-4">
    <div class="no-print d-flex justify-content-between align-items-center mb-3">
        <div class="text-muted">Impressão da versão publicada</div>
        <button class="btn btn-primary" onclick="window.print()">Imprimir</button>
    </div>

    <h3 class="mb-1">PCD/TTD — Versão V@ver.VersionNo</h3>
    <div class="text-muted mb-2"><strong>Título:</strong> @ver.Title</div>
    <div class="text-muted mb-3"><strong>Publicado:</strong> @ver.PublishedAt.ToString("dd/MM/yyyy HH:mm")</div>

    @{
        var children = Model.GroupBy(x => x.ParentCode)
        .ToDictionary(g => g.Key, g => g.OrderBy(x => x.Code).ToList());

        void Render(string? parentCode, int level)
        {
            if (!children.TryGetValue(parentCode, out var list)) return;

            foreach (var n in list)
            {
                <div class="border-bottom py-2">
                    <div class="d-flex justify-content-between">
                        <div>
                            <span class="mono text-secondary">@Indent(level)</span>
                            <span class="mono fw-semibold">@n.Code</span>
                            <span class="ms-2">@n.Name</span>
                        </div>
                        <div class="text-muted">
                            <small>@n.RetentionStartEvent • Destino: @n.FinalDestination</small>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(n.RetentionNotes))
                    {
                        <div class="text-muted"><small><strong>Obs:</strong> @n.RetentionNotes</small></div>
                    }
                </div>
                Render(n.Code, level + 1);
            }
        }

        Render(null, 0);
    }
</body>
</html>