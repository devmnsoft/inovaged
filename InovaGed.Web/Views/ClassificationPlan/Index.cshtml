@model IReadOnlyList<InovaGed.Application.ClassificationPlans.ClassificationNodeRow>
@{
    ViewData["Title"] = "PCD/TTD";
    var nodesJson = System.Text.Json.JsonSerializer.Serialize(Model);
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-0">PCD/TTD</h2>
        <div class="text-muted">Arraste itens para mover na árvore. Publique versões para evidência e impressão.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/ClassificationPlan/Versions">
            <i class="bi bi-clock-history"></i> Versões
        </a>
        <a class="btn btn-outline-secondary" target="_blank" href="/ClassificationPlan/PrintCurrent">
            <i class="bi bi-printer"></i> Imprimir atual
        </a>
        <button class="btn btn-primary" type="button" onclick="cp.openCreate(null)">
            <i class="bi bi-plus-lg"></i> Nova classe
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div id="cpTree"></div>
    </div>
</div>

<div class="modal fade" id="cpEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Classe do Plano (PCD/TTD)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body" id="cpEditBody">
                <div class="text-muted">Carregando...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>window.__cp_nodes = @Html.Raw(nodesJson);</script>
    <script src="~/js/classification-plan.js"></script>
}