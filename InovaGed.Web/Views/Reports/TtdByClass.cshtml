@{
    ViewData["Title"] = "Imprimir TTD por Classe";
    ViewData["Subtitle"] = "Filtro por código (inclui filhos)";
    var err = TempData["err"] as string;
}

@if (!string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<form method="post" asp-action="TtdByClass" class="card card-body">
    @Html.AntiForgeryToken()
    <label class="form-label">Código da Classe</label>
    <input name="code" class="form-control" placeholder="Ex.: 02.01" />
    <div class="mt-3">
        <button class="btn btn-primary"><i class="bi bi-funnel me-1"></i>Gerar</button>
    </div>
</form>