@{
    ViewData["Title"] = "PLC/PCD por Classe";
    ViewData["Subtitle"] = "Filtrar e imprimir por código";
    var err = TempData["err"] as string;
}

@if (!string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" asp-action="PcdByClass">
            @Html.AntiForgeryToken()
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Código</label>
                    <input name="code" class="form-control" placeholder="PCD-001" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary">
                        <i class="bi bi-search me-1"></i> Gerar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>