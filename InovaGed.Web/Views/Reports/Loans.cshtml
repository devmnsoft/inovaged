@using InovaGed.Web.Controllers
@model List<LoanReportRow>

@{
    ViewData["Title"] = "Relatório de Empréstimos";
    ViewData["Subtitle"] = "Por solicitante/período/tipo (PoC)";
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Protocolo</th>
                        <th>Solicitante</th>
                        <th>Solicitado em</th>
                        <th>Vence em</th>
                        <th>Status</th>
                        <th>Documento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.ProtocolNo</td>
                            <td>@r.RequesterName</td>
                            <td>@r.RequestedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@r.DueAt.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge text-bg-secondary">@r.Status</span></td>
                            <td>
                                <div class="fw-semibold">@r.DocumentCode</div>
                                <div class="text-muted small">@r.DocumentTitle</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>