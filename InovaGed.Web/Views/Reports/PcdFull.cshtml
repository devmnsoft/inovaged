@model List<InovaGed.Web.Models.Reports.TtdRow>
@{
    ViewData["Title"] = "PLC/PCD — Plano de Classificação de Documentos";
    ViewData["Subtitle"] = "Impressão/relatório completo";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted small">Total: <b>@Model.Count</b> classes</div>
    <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
        <i class="bi bi-printer me-1"></i> Imprimir
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Classe</th>
                        <th>Ativo (meses)</th>
                        <th>Arquivo (meses)</th>
                        <th>Destinação</th>
                        <th>Evento início</th>
                        <th>Observações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold font-monospace">@r.ClassCode</td>
                            <td>@r.ClassName</td>
                            <td>@(r.ActiveMonths?.ToString() ?? "—")</td>
                            <td>@(r.ArchiveMonths?.ToString() ?? "—")</td>
                            <td><span class="badge text-bg-secondary">@(r.FinalDestination ?? "—")</span></td>
                            <td class="text-muted small">@(r.StartEvent ?? "—")</td>
                            <td class="text-muted small">@r.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
