@using InovaGed.Web.Controllers
@model List<SignatureValidationRow>

@{
    ViewData["Title"] = "Validação de Assinaturas";
    ViewData["Subtitle"] = "ICP-Brasil: status e dados básicos (PoC)";
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Documento</th>
                        <th>Assinante</th>
                        <th>CPF</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th>Detalhes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@r.DocumentCode</div>
                                <div class="text-muted small">@r.DocumentTitle</div>
                            </td>
                            <td>@r.SignedByName</td>
                            <td>@r.Cpf</td>
                            <td>@(r.SigningTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td><span class="badge text-bg-secondary">@r.Status</span></td>
                            <td class="text-muted small">@r.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>