@{
    ViewData["Title"] = "Validação de Assinatura";
    ViewData["Subtitle"] = "Relatórios";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="text-muted small">Faça upload de um PDF assinado para validar (estrutura inicial da PoC).</div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label">Arquivo (PDF)</label>
                <input class="form-control" type="file" name="file" accept="application/pdf" />
                <div class="form-text">Envie um documento assinado digitalmente para validar certificado, integridade e cadeia.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-shield-check me-1"></i> Validar assinatura
                </button>
                <a class="btn btn-outline-secondary" href="/Reports/Index">
                    Voltar
                </a>
            </div>
        </form>
    </div>
</div>