@model List<InovaGed.Web.Controllers.ReportsController.TtdRow>
@{
    ViewData["Title"] = "Tabela de Temporalidade (TTD)";
    ViewData["Subtitle"] = "Impressão/relatório";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="text-muted small">Total: <b>@Model.Count</b></div>
    <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
        <i class="bi bi-printer me-1"></i> Imprimir
    </button>
</div>

<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th style="width:160px">Classe</th>
            <th style="width:160px">Corrente (dias)</th>
            <th style="width:200px">Intermediária (dias)</th>
            <th>Destinação</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td><code>@r.ClassCode</code></td>
                <td>@(r.CurrentDays.ToString() ?? "-")</td>
                <td>@(r.IntermediateDays.ToString() ?? "-")</td>
                <td>@(r.FinalDestination ?? "-")</td>
            </tr>
        }
    </tbody>
</table>