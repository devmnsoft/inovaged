@model InovaGed.Web.Models.Administration.AdministrationPageVm
@{ ViewData["Title"] = "Administração"; ViewData["Subtitle"] = Model.Section; }
<partial name="_AdminNav" />
<h1 class="h4 mb-3">@Model.Section</h1>
@if (Model.IdentitySummary is not null) { <div class="row g-3"><div class="col-md-3"><div class="card"><div class="card-body"><span>Total de usuários</span><div class="fs-3 fw-bold">@Model.IdentitySummary.TotalUsers</div></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><span>CPFs migrados</span><div class="fs-3 fw-bold">@Model.IdentitySummary.AlreadyMigrated</div></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><span>Sem CPF</span><div class="fs-3 fw-bold">@Model.IdentitySummary.WithoutCpf</div></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><span>Dependência legada</span><div class="fs-3 fw-bold">@Model.IdentitySummary.LegacyDependent</div></div></div></div></div><div class="alert alert-info mt-3">CPFs completos não são exibidos. A migração usa hash HMAC com chave externa e valor protegido.</div> }
@if (Model.SecurityConfigurations.Any() || Model.PermissionCatalog.Any()) { <h2 class="h5">Modos por tenant</h2><table class="table table-sm"><thead><tr><th>Tenant</th><th>Modo</th><th>Alterado em</th><th>Justificativa</th></tr></thead><tbody>@foreach(var c in Model.SecurityConfigurations){<tr><td>@c.TenantId</td><td><span class="badge bg-primary">@c.PermissionMode</span></td><td>@c.ChangedAt</td><td>@c.ChangeReason</td></tr>}</tbody></table><h2 class="h5">Catálogo de permissões</h2><table class="table table-sm"><thead><tr><th>Código</th><th>Descrição</th><th>Módulo</th><th>Roles</th><th>Usuários</th><th>Status</th></tr></thead><tbody>@foreach(var p in Model.PermissionCatalog){<tr><td>@p.Code</td><td>@p.Description</td><td>@p.Module</td><td>@p.Roles</td><td>@p.UsersAffected</td><td>@p.Status</td></tr>}</tbody></table> }
@if (Model.Items.Any()) { <table class="table table-hover"><thead><tr><th>Nome</th><th>Status</th><th>Detalhe seguro</th><th>Tenant</th><th>Última atividade</th></tr></thead><tbody>@foreach(var i in Model.Items){<tr><td>@i.Name</td><td>@i.Status</td><td>@i.Detail</td><td>@i.Tenant</td><td>@i.LastActivity</td></tr>}</tbody></table> }
@if (Model.Compliance.Any()) { <div class="list-group">@foreach(var c in Model.Compliance){<div class="list-group-item"><div class="d-flex justify-content-between"><strong>@c.Title</strong><span class="badge bg-secondary">@c.State</span></div><div class="small text-muted">@c.Code — @c.Evidence</div><div>@c.Guidance</div></div>}</div> }
@if (!Model.Items.Any() && !Model.Compliance.Any() && !Model.PermissionCatalog.Any() && !Model.SecurityConfigurations.Any() && Model.IdentitySummary is null) { <div class="alert alert-warning">Não disponível: nenhuma estrutura compatível foi encontrada. Verifique o painel de Migrações e Compatibilidade.</div> }
