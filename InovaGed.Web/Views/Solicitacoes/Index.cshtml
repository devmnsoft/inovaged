@using InovaGed.Application.Ged.Loans
@using InovaGed.Web.Security
@model IReadOnlyList<SolicitacaoRowDto>
@{
    ViewData["Title"] = "Solicitações";
    var isAdmin = RolePolicyHelper.IsFullAdmin(User);
    var pendentes = (int?)ViewBag.PendentesCount ?? 0;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Solicitações @(isAdmin ? "(visão administrativa)" : "")</h4>
    @if (isAdmin)
    {
        <span class="badge text-bg-danger"><i class="bi bi-bell-fill"></i> @pendentes pendentes</span>
    }
    @if (isAdmin)
    {
        <form method="post" action="/Solicitacoes/ExcluirAntigas" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="number" min="1" max="3650" class="form-control form-control-sm" name="dias" value="90" style="width:110px" />
            <button class="btn btn-outline-danger btn-sm">Excluir antigas</button>
        </form>
    }

</div>
<form method="post" action="/Solicitacoes/Criar" class="card card-body mb-3">
    @Html.AntiForgeryToken()
    <div class="row g-2">
        <div class="col-md-4 position-relative">
            <input id="arquivoBusca" class="form-control" placeholder="Buscar arquivo digitalizado..." autocomplete="off" />
            <input id="arquivoId" type="hidden" name="ArquivoId" />
            <div id="arquivoSugestoes" class="list-group position-absolute w-100 shadow-sm" style="z-index:10;"></div>
        </div>
        <div class="col-md-6"><textarea class="form-control" name="Descricao" rows="2" placeholder="Descrição detalhada"></textarea></div>
        <div class="col-md-2 d-grid"><button class="btn btn-primary">Solicitar</button></div>
    </div>
</form>
<table class="table table-striped table-sm align-middle"><thead><tr><th>Data</th><th>Solicitante</th><th>Setor</th><th>Arquivo</th><th>Descrição</th><th>Status</th><th>Feedback</th></tr></thead><tbody>
@foreach(var item in Model)
{
<tr><td>@item.DataSolicitacao.ToString("dd/MM/yyyy HH:mm")</td><td>@item.UsuarioNome</td><td>@item.SetorNome</td><td>@item.ArquivoCodigo - @item.ArquivoTitulo</td><td>@item.Descricao</td><td><span class="badge text-bg-secondary">@item.StatusLabel</span></td><td>
@if (isAdmin)
{
<form method="post" action="/Solicitacoes/@item.Id/Status" class="d-flex gap-1">@Html.AntiForgeryToken()<input class="form-control form-control-sm" name="Comentario" placeholder="Comentário" /><button class="btn btn-success btn-sm" name="Status" value="DEFERIDO">Deferir</button><button class="btn btn-danger btn-sm" name="Status" value="INDEFERIDO">Indeferir</button><button class="btn btn-warning btn-sm" name="Status" value="AGUARDAR">Aguardar</button></form>
}
else
{
<small class="text-muted">@item.AdminNome</small>
}
</td></tr>
}
</tbody></table>

<script>
(() => {
    const input = document.getElementById('arquivoBusca');
    const hidden = document.getElementById('arquivoId');
    const box = document.getElementById('arquivoSugestoes');
    if (!input || !hidden || !box) return;
    let timer = null;
    input.addEventListener('input', () => {
        hidden.value = '';
        clearTimeout(timer);
        const q = input.value.trim();
        if (q.length < 2) { box.innerHTML = ''; return; }
        timer = setTimeout(async () => {
            try {
                const res = await fetch('/Loans/DocSearch?q=' + encodeURIComponent(q));
                const data = await res.json();
                box.innerHTML = (data || []).slice(0, 8).map(item =>
                    `<button type="button" class="list-group-item list-group-item-action" data-id="${item.id}" data-label="${item.code} - ${item.title}">${item.code} - ${item.title}</button>`
                ).join('');
            } catch {
                box.innerHTML = '';
            }
        }, 250);
    });
    box.addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-id]');
        if (!btn) return;
        hidden.value = btn.getAttribute('data-id') || '';
        input.value = btn.getAttribute('data-label') || '';
        box.innerHTML = '';
    });
    document.addEventListener('click', (e) => { if (!box.contains(e.target) && e.target !== input) box.innerHTML = ''; });
    const pendentes = @pendentes;
    if (@(isAdmin ? "true" : "false") && pendentes > 0 && window.bootstrap) {
        const host = document.createElement('div');
        host.className = 'toast-container position-fixed top-0 end-0 p-3';
        host.innerHTML = `<div class="toast text-bg-warning border-0" role="alert"><div class="d-flex"><div class="toast-body"><i class="bi bi-bell-fill me-1"></i>${pendentes} nova(s) solicitação(ões) pendente(s).</div><button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button></div></div>`;
        document.body.appendChild(host);
        const toastEl = host.querySelector('.toast');
        if (toastEl) new bootstrap.Toast(toastEl, { delay: 5000 }).show();
    }
    setInterval(() => { window.location.reload(); }, 45000);
})();
</script>
