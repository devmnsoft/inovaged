@model IReadOnlyList<InovaGed.Application.Continuity.BackupPolicyDto>
<h1>Políticas de Backup</h1><p>Cadastro por tenant/global. Incremental real permanece não suportado sem WAL/PITR.</p><table class="table table-sm"><thead><tr><th>Nome</th><th>Escopo</th><th>Tipo</th><th>Frequência</th><th>Retenção</th><th>RPO</th><th>RTO</th><th>Status</th></tr></thead><tbody>@foreach(var p in Model){<tr><td>@p.Name</td><td>@p.Scope</td><td>@p.BackupType</td><td>@p.Frequency</td><td>@p.RetentionDays dias</td><td>@p.RpoMinutes</td><td>@p.RtoMinutes</td><td>@p.Status</td></tr>}</tbody></table>
