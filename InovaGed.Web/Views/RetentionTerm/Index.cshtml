@using InovaGed.Application.RetentionTerms
@model IReadOnlyList<RetentionTermRow>

@{
    ViewData["Title"] = "Termos de Destinação";
    ViewData["Subtitle"] = "Listagem e ações (ReadyToSign, Assinar, Execução Final, PDF)";
    var from = ViewBag.From as DateTimeOffset?;
    var to = ViewBag.To as DateTimeOffset?;
    var status = ViewBag.Status as string;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="text-muted">@ViewData["Subtitle"]</div>
    </div>
</div>

@if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end" asp-controller="RetentionTerm" asp-action="Index">
            <div class="col-12 col-md-3">
                <label class="form-label">De</label>
                <input class="form-control" type="datetime-local" name="from"
                       value="@(from.HasValue ? from.Value.LocalDateTime.ToString("yyyy-MM-ddTHH:mm") : "")" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">Até</label>
                <input class="form-control" type="datetime-local" name="to"
                       value="@(to.HasValue ? to.Value.LocalDateTime.ToString("yyyy-MM-ddTHH:mm") : "")" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(status))">Todos</option>
                    <option value="DRAFT" selected="@(status=="DRAFT")">DRAFT</option>
                    <option value="READY_TO_SIGN" selected="@(status=="READY_TO_SIGN")">READY_TO_SIGN</option>
                    <option value="SIGNED" selected="@(status=="SIGNED")">SIGNED</option>
                    <option value="EXECUTED" selected="@(status=="EXECUTED")">EXECUTED</option>
                    <option value="CANCELLED" selected="@(status=="CANCELLED")">CANCELLED</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>
                <a class="btn btn-outline-secondary w-100" href="/RetentionTerms">
                    <i class="bi bi-x-circle me-1"></i> Limpar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nº</th>
                    <th>Tipo</th>
                    <th>Status</th>
                    <th>Criado em</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Nenhum termo encontrado.</td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td class="text-nowrap">@r.TermNo</td>
                            <td class="text-nowrap">@r.TermType</td>
                            <td class="text-nowrap">
                                <span class="badge text-bg-secondary">@r.Status</span>
                            </td>
                            <td class="text-nowrap">@r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-primary"
                                   href="/RetentionTerms/Details?id=@r.Id">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a class="btn btn-sm btn-outline-secondary"
                                   href="/RetentionTerms/Pdf?id=@r.Id" target="_blank">
                                    <i class="bi bi-filetype-pdf"></i>
                                </a>

                                <form class="d-inline" method="post" action="/RetentionTerms/ReadyToSign">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="termId" value="@r.Id" />
                                    <button class="btn btn-sm btn-outline-warning" type="submit"
                                            title="Marcar READY_TO_SIGN">
                                        <i class="bi bi-pen"></i>
                                    </button>
                                </form>

                                <form class="d-inline" method="post" action="/RetentionTerms/ExecuteFinal">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="termId" value="@r.Id" />
                                    <button class="btn btn-sm btn-outline-success" type="submit"
                                            title="Executar destinação final">
                                        <i class="bi bi-check2-circle"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>