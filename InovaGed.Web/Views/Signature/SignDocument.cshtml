@model InovaGed.Web.Controllers.SignatureController.SignDocumentVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Assinar Documento";
    ViewData["Subtitle"] = $"Assinatura ICP-Brasil — {Model.Code}";
}

<div class="row justify-content-center">
    <div class="col-lg-7">

        @if (TempData["Err"] is string err)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle me-1"></i> @err
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Info do documento -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <strong><i class="bi bi-file-earmark-text me-1"></i> Documento</strong>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Código</dt>
                    <dd class="col-sm-9 fw-semibold">@Model.Code</dd>

                    <dt class="col-sm-3">Título</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        <span class="badge @(Model.DocStatus == "IN_SIGNATURE" ? "text-bg-warning" : "text-bg-secondary")">
                            @Model.DocStatus
                        </span>
                    </dd>
                </dl>
            </div>
        </div>

        <!-- Assinatura atual (se existir) -->
        @if (Model.SignatureStatus != null)
        {
            <div class="card shadow-sm mb-4 border-@(Model.SignatureStatus == "VALID" ? "success" : "danger")">
                <div class="card-header bg-white">
                    <strong><i class="bi bi-patch-check me-1"></i> Assinatura Atual</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            <span class="badge @(Model.SignatureStatus == "VALID" ? "text-bg-success" : "text-bg-danger")">
                                @Model.SignatureStatus
                            </span>
                        </dd>
                        <dt class="col-sm-3">Assinado por</dt>
                        <dd class="col-sm-9">@(Model.SignedByName ?? "—")</dd>
                        <dt class="col-sm-3">CPF</dt>
                        <dd class="col-sm-9">@(Model.Cpf ?? "—")</dd>
                        <dt class="col-sm-3">Data</dt>
                        <dd class="col-sm-9">@(Model.SigningTime?.ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>
                        @if (!string.IsNullOrWhiteSpace(Model.StatusDetails))
                        {
                            <dt class="col-sm-3">Detalhes</dt>
                            <dd class="col-sm-9 text-muted small">@Model.StatusDetails</dd>
                        }
                    </dl>
                </div>
            </div>
        }

        <!-- Formulário de assinatura -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>
                    <i class="bi bi-pen me-1"></i>
                    @(Model.SignatureStatus == null ? "Registrar Assinatura" : "Reassinar Documento")
                </strong>
            </div>
            <div class="card-body">
                <form asp-action="SignDocument" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            CPF do Certificado ICP-Brasil <span class="text-danger">*</span>
                        </label>
                        <input name="cpf" type="text" class="form-control"
                               placeholder="000.000.000-00"
                               required maxlength="18"
                               pattern="\d{3}\.?\d{3}\.?\d{3}-?\d{2}" />
                        <div class="form-text">
                            Informe o CPF vinculado ao certificado digital utilizado para assinar.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Observações (opcional)</label>
                        <textarea name="notes" class="form-control" rows="2"
                                  placeholder="Observações sobre esta assinatura..."></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-pen me-1"></i>
                            @(Model.SignatureStatus == null ? "Assinar Documento" : "Reassinar")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>