@using InovaGed.Web.Models.Instruments
@model InstrumentsIndexVM

@{
    ViewData["Title"] = "Instrumentos Arquivísticos";
    string type = Model.Type;
    string Active(string t) => string.Equals(type, t, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h2 class="mb-1"><i class="bi bi-diagram-3"></i> Instrumentos Arquivísticos</h2>
        <div class="text-muted">PCD / TTD / POP com versionamento e impressão (PoC Itens 1–4).</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="@Url.Action("Index","Instruments", new { type })">
            <i class="bi bi-arrow-clockwise"></i> Atualizar
        </a>
    </div>
</div>

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @Active("PCD")" href="@Url.Action("Index","Instruments", new { type="PCD" })">PCD</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @Active("TTD")" href="@Url.Action("Index","Instruments", new { type="TTD" })">TTD</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @Active("POP")" href="@Url.Action("Index","Instruments", new { type="POP" })">POP</a>
    </li>
</ul>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <strong>@type</strong> — Versões publicadas
        </div>

        <form method="post" asp-action="Publish" asp-controller="Instruments" class="d-flex gap-2 align-items-center">
            @Html.AntiForgeryToken()
            <input type="hidden" name="type" value="@type" />

            <input class="form-control form-control-sm" style="min-width:260px" name="notes" placeholder="Observação da versão (opcional)" />
            <button class="btn btn-primary btn-sm" type="submit">
                <i class="bi bi-upload"></i> Publicar nova versão
            </button>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:120px;">Versão</th>
                        <th style="width:220px;">Publicada em</th>
                        <th>Publicado por</th>
                        <th>Hash</th>
                        <th style="width:220px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Versions == null || Model.Versions.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="p-4 text-muted">
                                Nenhuma versão publicada ainda. Clique em <strong>Publicar nova versão</strong> para iniciar.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var v in Model.Versions)
                        {
                            <tr>
                                <td><span class="badge bg-dark">V@v.VersionNo</span></td>
                                <td>@v.PublishedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@v.PublishedByName</td>
                                <td class="text-muted" style="font-family:monospace; font-size:12px;">
                                    @v.HashSha256
                                </td>
                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a class="btn btn-outline-primary btn-sm"
                                           href="@Url.Action("Nodes","Instruments", new { type = type, versionId = v.Id })">
                                            <i class="bi bi-pencil-square"></i> Editar árvore
                                        </a>

                                        <a class="btn btn-outline-secondary btn-sm"
                                           href="@Url.Action("Print","Instruments", new { type = type, versionId = v.Id })"
                                           target="_blank">
                                            <i class="bi bi-printer"></i> Imprimir
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>