@model IEnumerable<InovaGed.Web.Models.Users.UserListVM>

@{
    ViewData["Title"] = "Usuários";
}

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people me-2"></i>@ViewData["Title"]</h4>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Usuário</th>
            <th>E-mail</th>
            <th>Perfil</th>
            <th>Status</th>
            <th class="text-end">Ações</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="5" class="text-center text-muted">Nenhum usuário encontrado.</td></tr>
        }
        else
        {
            foreach (var user in Model)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>
                        @if (user.Locked)
                        {
                            <span class="badge text-bg-danger">Bloqueado</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">Ativo</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (user.Locked)
                        {
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger js-unlock-user"
                                    data-user-id="@user.Id"
                                    data-user-name="@user.Username">
                                <i class="bi bi-unlock me-1"></i>Desbloquear
                            </button>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div id="unlockToast" class="position-fixed bottom-0 end-0 p-3" style="z-index:1080"></div>

@section Scripts {
    <script>
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const showToast = (message, ok) => {
            const host = document.getElementById('unlockToast');
            if (!host) return;
            host.innerHTML = `<div class="toast align-items-center text-bg-${ok ? 'success' : 'danger'} border-0" role="alert"><div class="d-flex"><div class="toast-body">${message}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>`;
            const toastEl = host.querySelector('.toast');
            if (toastEl) new bootstrap.Toast(toastEl).show();
        };

        document.querySelectorAll('.js-unlock-user').forEach(btn => {
            btn.addEventListener('click', async () => {
                const userId = btn.getAttribute('data-user-id');
                const userName = btn.getAttribute('data-user-name') ?? 'usuário';
                if (!userId) return;

                const response = await fetch(`/Users/Unlock/${userId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': antiForgeryToken ?? ''
                    }
                });

                if (!response.ok) {
                    showToast(`Erro ao desbloquear ${userName}.`, false);
                    return;
                }

                showToast(`Usuário ${userName} desbloqueado com sucesso.`, true);

                const row = btn.closest('tr');
                const statusCell = row?.querySelector('td:nth-child(4)');
                if (statusCell) statusCell.innerHTML = '<span class="badge text-bg-success">Ativo</span>';
                btn.remove();
            });
        });
    </script>
}
