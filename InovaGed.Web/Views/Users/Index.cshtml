@model InovaGed.Web.Models.Users.UserListVM

@{
    ViewData["Title"] = "Usuários e Servidores";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">
            <i class="bi bi-people me-2"></i>@ViewData["Title"]
        </h4>
        <div class="text-muted small">
            Controle de servidores, usuários, perfis, sigilo, ICP-Brasil e status de acesso.
        </div>
    </div>

    <a class="btn btn-primary" href="@Url.Action("Create", "Users")">
        <i class="bi bi-person-plus me-1"></i> Novo Cadastro
    </a>
</div>

@if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}

@if (TempData["Error"] is string erro && !string.IsNullOrWhiteSpace(erro))
{
    <div class="alert alert-danger">@erro</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" asp-action="Index" asp-controller="Users" class="row g-2">
            <div class="col-md-6">
                <input name="q"
                       value="@Model.Q"
                       class="form-control"
                       placeholder="Pesquisar por nome, CPF, matrícula, e-mail, setor ou cargo" />
            </div>

            <div class="col-md-3">
                <select name="active" class="form-select">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.Active == true)">Ativos</option>
                    <option value="false" selected="@(Model.Active == false)">Inativos</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-outline-primary" type="submit">
                    <i class="bi bi-search me-1"></i> Pesquisar
                </button>

                <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Users")">
                    Limpar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Servidor / Usuário</th>
                    <th>CPF / Matrícula</th>
                    <th>Lotação</th>
                    <th>Perfis</th>
                    <th>Segurança</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Nenhum usuário encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.Name</div>
                                <div class="small text-muted">@item.Email</div>

                                @if (!string.IsNullOrWhiteSpace(item.Cargo) || !string.IsNullOrWhiteSpace(item.Funcao))
                                {
                                    <div class="small">
                                        @item.Cargo

                                        @if (!string.IsNullOrWhiteSpace(item.Funcao))
                                        {
                                            <span> / @item.Funcao</span>
                                        }
                                    </div>
                                }
                            </td>

                            <td>
                                <div>@item.Cpf</div>
                                <div class="small text-muted">@item.Matricula</div>
                            </td>

                            <td>
                                <div>@item.Setor</div>
                                <div class="small text-muted">@item.Lotacao</div>
                            </td>

                            <td>
                                @if (item.Roles.Any())
                                {
                                    foreach (var role in item.Roles)
                                    {
                                        <span class="badge text-bg-secondary me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Sem perfil</span>
                                }
                            </td>

                            <td>
                                @switch (item.SecurityLevel)
                                {
                                    case "CONFIDENTIAL":
                                        <span class="badge text-bg-danger">Confidencial</span>
                                        break;

                                    case "RESTRICTED":
                                        <span class="badge text-bg-warning">Restrito</span>
                                        break;

                                    default:
                                        <span class="badge text-bg-success">Público</span>
                                        break;
                                }

                                <div class="small mt-1">
                                    @if (item.MfaEnabled)
                                    {
                                        <span class="badge text-bg-info me-1">MFA</span>
                                    }

                                    @if (item.CertificateRequired)
                                    {
                                        <span class="badge text-bg-primary me-1">Certificado</span>
                                    }

                                    @if (item.CanSignWithIcp)
                                    {
                                        <span class="badge text-bg-dark me-1">ICP</span>
                                    }
                                </div>
                            </td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge text-bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Inativo</span>
                                }

                                @if (item.IsLocked)
                                {
                                    <span class="badge text-bg-danger">Bloqueado</span>
                                }

                                @if (item.MustChangePassword)
                                {
                                    <div class="small text-warning">Troca de senha pendente</div>
                                }

                                @if (item.LastLoginAt.HasValue)
                                {
                                    <div class="small text-muted">
                                        Último login: @item.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                }
                            </td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        Ações
                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end">

                                        <li>
                                            <a class="dropdown-item"
                                               asp-action="Edit"
                                               asp-controller="Users"
                                               asp-route-id="@item.Id">
                                                <i class="bi bi-pencil-square me-1"></i>
                                                Editar cadastro
                                            </a>
                                        </li>

                                        <li>
                                            <button type="button"
                                                    class="dropdown-item"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#resetPasswordModal"
                                                    data-user-id="@item.Id"
                                                    data-user-name="@item.Name">
                                                <i class="bi bi-key me-1"></i>
                                                Redefinir senha
                                            </button>
                                        </li>

                                        <li><hr class="dropdown-divider" /></li>

                                        <li>
                                            <form method="post" asp-action="SetActive" asp-controller="Users">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="active" value="@(!item.IsActive)" />

                                                <button class="dropdown-item" type="submit">
                                                    @if (item.IsActive)
                                                    {
                                                        <span>
                                                            <i class="bi bi-person-x me-1"></i>
                                                            Inativar usuário
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span>
                                                            <i class="bi bi-person-check me-1"></i>
                                                            Ativar usuário
                                                        </span>
                                                    }
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer d-flex justify-content-between align-items-center">
        <div class="text-muted small">
            Total: @Model.Total registro(s)
        </div>

        <div class="small">
            Página @Model.Page de @Model.TotalPages
        </div>
    </div>
</div>

<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" asp-action="ResetPassword" asp-controller="Users" class="modal-content">
            @Html.AntiForgeryToken()

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-key me-1"></i>
                    Redefinir senha
                </h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" name="id" id="resetUserId" />

                <div class="alert alert-warning">
                    A senha será redefinida administrativamente e o evento será registrado em auditoria.
                </div>

                <div class="mb-3">
                    <label class="form-label">Usuário</label>
                    <input id="resetUserName" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Nova senha</label>
                    <input name="newPassword"
                           type="password"
                           class="form-control"
                           minlength="8"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirmar nova senha</label>
                    <input name="confirmPassword"
                           type="password"
                           class="form-control"
                           minlength="8"
                           required />
                </div>

                <div class="form-check">
                    <input name="mustChangePassword"
                           value="true"
                           class="form-check-input"
                           type="checkbox"
                           checked />

                    <label class="form-check-label">
                        Obrigar troca de senha no próximo acesso
                    </label>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle me-1"></i>
                    Redefinir senha
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const resetModal = document.getElementById('resetPasswordModal');

        if (resetModal) {
            resetModal.addEventListener('show.bs.modal', event => {
                const button = event.relatedTarget;

                if (!button) {
                    return;
                }

                const userId = button.getAttribute('data-user-id');
                const userName = button.getAttribute('data-user-name');

                document.getElementById('resetUserId').value = userId;
                document.getElementById('resetUserName').value = userName;
            });
        }
    </script>
}