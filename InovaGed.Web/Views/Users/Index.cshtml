@model InovaGed.Web.Controllers.UserListVM

@{
    ViewData["Title"] = "Usuários";

    var total = Model.Total < 0 ? 0 : Model.Total;
    var pageSize = Model.PageSize <= 0 ? 10 : Model.PageSize;
    var currentPage = Model.Page <= 0 ? 1 : Model.Page;

    var totalPages = (int)Math.Ceiling(total / (double)pageSize);
    if (totalPages < 1) totalPages = 1;

    string? q = Model.Q;
    bool? active = Model.Active;
}

@if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input name="q" value="@q" class="form-control" style="min-width:260px" placeholder="Buscar por nome ou e-mail..." />

        <select name="active" class="form-select" style="width:180px">
            <option value="" selected="@(active is null ? "selected" : null)">Status: Todos</option>
            <option value="true" selected="@(active == true ? "selected" : null)">Ativos</option>
            <option value="false" selected="@(active == false ? "selected" : null)">Inativos</option>
        </select>

        <input type="hidden" name="pageSize" value="@pageSize" />

        <button class="btn btn-primary" type="submit">
            <i class="bi bi-search me-1"></i> Filtrar
        </button>

        <a class="btn btn-outline-secondary" href="@Url.Action("Index","Users")">
            Limpar
        </a>
    </form>

    <a class="btn btn-success" asp-controller="Users" asp-action="Create">
        <i class="bi bi-person-plus me-1"></i> Novo usuário
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="min-width:220px;">Nome</th>
                        <th style="min-width:220px;">E-mail</th>
                        <th style="min-width:220px;">Perfis</th>
                        <th>Status</th>
                        <th style="min-width:160px;">Criado em</th>
                        <th style="min-width:220px;">Usuario</th>
                        <th style="width:360px;" class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Nenhum usuário encontrado.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var u in Model.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@u.Name</td>

                                <td>@u.Email</td>

                                <td>
                                    @if (u.Roles.Count == 0)
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var r in u.Roles)
                                            {
                                                <span class="badge bg-light text-dark">@r</span>
                                            }
                                        </div>
                                    }
                                </td>

                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge text-bg-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Inativo</span>
                                    }
                                </td>

                                <td class="text-muted small">
                                    @u.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td class="text-muted small">
                                    Administrador
                                </td>


                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">

                                        <!-- CERTIFICADOS ICP -->
                                        <a class="btn btn-sm btn-outline-success"
                                           asp-controller="UserCertificates"
                                           asp-action="Index"
                                           asp-route-userId="@u.Id"
                                           title="Gerenciar certificados ICP-Brasil">
                                            <i class="bi bi-patch-check me-1"></i> Certificados
                                        </a>

                                        <!-- ATIVAR / INATIVAR -->
                                        <form asp-controller="Users" asp-action="ToggleActive" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />
                                            <input type="hidden" name="makeActive" value="@(!u.IsActive)" />

                                            <button class="btn btn-sm btn-outline-primary" type="submit">
                                                <i class="bi bi-toggle-@(u.IsActive ? "on" : "off") me-1"></i>
                                                @(u.IsActive ? "Inativar" : "Ativar")
                                            </button>
                                        </form>

                                        <!-- RESET SENHA -->
                                        <form asp-controller="Users" asp-action="ResetPassword" method="post" class="m-0"
                                              onsubmit="return window.confirm('Resetar a senha deste usuário? Será gerada uma senha temporária e exibida na tela.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.Id" />

                                            <button class="btn btn-sm btn-outline-danger" type="submit">
                                                <i class="bi bi-key me-1"></i> Reset senha
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<nav class="mt-3">
    <ul class="pagination">
        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("Index","Users", new { q = q, active = active, page = currentPage - 1, pageSize = pageSize })">
                Anterior
            </a>
        </li>

        <li class="page-item disabled">
            <span class="page-link">
                Página @currentPage de @totalPages (@total)
            </span>
        </li>

        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
            <a class="page-link"
               href="@Url.Action("Index","Users", new { q = q, active = active, page = currentPage + 1, pageSize = pageSize })">
                Próxima
            </a>
        </li>
    </ul>
</nav>