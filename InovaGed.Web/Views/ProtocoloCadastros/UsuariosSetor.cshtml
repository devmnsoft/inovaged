@model InovaGed.Web.Models.Protocolo.ProtocoloUsuarioSetorIndexVM
@{ ViewData["Title"] = "Usuários por Setor"; }
<div class="d-flex justify-content-between mb-3"><h4>Usuários x Setor</h4><a asp-action="NovoUsuarioSetor" class="btn btn-primary">Novo vínculo</a></div>
<div class="card border-0 shadow-sm"><table class="table table-hover mb-0"><thead><tr><th>Usuário ID</th><th>Nome</th><th>Setor</th><th>Ativo</th><th></th></tr></thead><tbody>@foreach(var i in Model.Itens){<tr><td><code>@i.UsuarioId</code></td><td>@i.UsuarioNome</td><td>@i.SetorNome @i.SetorSigla</td><td>@(i.Ativo?"Sim":"Não")</td><td class="text-end"><a asp-action="EditarUsuarioSetor" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">Editar</a><form asp-action="ExcluirUsuarioSetor" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@i.Id"/><button class="btn btn-sm btn-outline-danger">Remover</button></form></td></tr>}@if(!Model.Itens.Any()){<tr><td colspan="5" class="text-center text-muted">Nenhum vínculo.</td></tr>}</tbody></table></div>
