@model InovaGed.Web.Models.Protocolo.ProtocoloUsuarioSetorFormVM
@{ ViewData["Title"] = "Vínculo Usuário x Setor"; }
<div class="d-flex justify-content-between mb-3"><h4>Vínculo Usuário x Setor</h4><a asp-action="UsuariosSetor" class="btn btn-outline-secondary">Voltar</a></div>
<form asp-action="SalvarUsuarioSetor" method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="Id"/><div class="card border-0 shadow-sm"><div class="card-body row g-3"><div class="col-md-5"><label>ID do Usuário</label><input asp-for="UsuarioId" class="form-control"/><small class="text-muted">Use o ID/claim NameIdentifier do usuário.</small></div><div class="col-md-4"><label>Nome</label><input asp-for="UsuarioNome" class="form-control"/></div><div class="col-md-3"><label>Setor</label><select asp-for="SetorId" asp-items="Model.Setores" class="form-select"><option value="">Selecione</option></select></div><div class="col-md-12"><div class="form-check"><input asp-for="Ativo" class="form-check-input"/><label>Ativo</label></div></div></div><div class="card-footer bg-white text-end"><button class="btn btn-primary">Salvar</button></div></div></form>
