@model InovaGed.Web.Models.Protocolo.ProtocoloCadastrosIndexVM
@{ ViewData["Title"] = "Cadastros do Protocolo"; }
<div class="d-flex justify-content-between mb-3"><h4>@Model.Titulo</h4><a asp-action="Novo" asp-route-tipo="@Model.Tipo" class="btn btn-primary">Novo</a></div>
@if(TempData["ok"]!=null){<div class="alert alert-success">@TempData["ok"]</div>}
<div class="card border-0 shadow-sm mb-3"><div class="card-body"><div class="d-flex flex-wrap gap-2 mb-3"><a class="btn btn-sm btn-outline-primary" asp-route-tipo="setores">Setores</a><a class="btn btn-sm btn-outline-primary" asp-route-tipo="tipos">Tipos</a><a class="btn btn-sm btn-outline-primary" asp-route-tipo="assuntos">Assuntos</a><a class="btn btn-sm btn-outline-primary" asp-route-tipo="prioridades">Prioridades</a><a class="btn btn-sm btn-outline-primary" asp-route-tipo="tipos-documento">Tipos Documento</a><a class="btn btn-sm btn-outline-primary" asp-route-tipo="canais-entrada">Canais</a><a class="btn btn-sm btn-outline-primary" asp-route-tipo="motivos-arquivamento">Motivos</a><a class="btn btn-sm btn-outline-secondary" asp-action="UsuariosSetor">Usuários x Setor</a></div><form method="get" class="row g-2"><input type="hidden" name="tipo" value="@Model.Tipo" /><div class="col-md-10"><input name="q" value="@Model.Q" class="form-control" placeholder="Pesquisar" /></div><div class="col-md-2"><button class="btn btn-outline-primary w-100">Pesquisar</button></div></form></div></div>
<div class="card border-0 shadow-sm"><table class="table table-hover mb-0"><thead><tr><th>Código</th><th>Nome</th><th>Sigla</th><th>Ordem</th><th>Ativo</th><th></th></tr></thead><tbody>@foreach(var i in Model.Itens){<tr><td>@i.Codigo</td><td><b>@i.Nome</b><div class="small text-muted">@i.Descricao</div></td><td>@i.Sigla</td><td>@i.Ordem</td><td>@(i.Ativo?"Sim":"Não")</td><td class="text-end"><a asp-action="Editar" asp-route-tipo="@Model.Tipo" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">Editar</a><form asp-action="Excluir" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="tipo" value="@Model.Tipo"/><input type="hidden" name="id" value="@i.Id"/><button class="btn btn-sm btn-outline-danger">Excluir</button></form></td></tr>}@if(!Model.Itens.Any()){<tr><td colspan="6" class="text-center text-muted">Nenhum cadastro.</td></tr>}</tbody></table></div>
