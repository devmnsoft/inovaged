@model InovaGed.Web.Models.Protocolo.ProtocoloCadastroFormVM

@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Editar Cadastro de Protocolo" : "Novo Cadastro de Protocolo";
    ViewData["Subtitle"] = Model.Tipo;
}

<div class="container-fluid">
    @if (TempData["erro"] is not null)
    {
        <div class="alert alert-danger">@TempData["erro"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="@(isEdit ? "Editar" : "Novo")" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Tipo" />

                <div class="row g-3">
                    <div class="col-md-7">
                        <label asp-for="Nome" class="form-label">Nome</label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    @if (Model.Tipo == "setores")
                    {
                        <div class="col-md-3">
                            <label asp-for="Sigla" class="form-label">Sigla</label>
                            <input asp-for="Sigla" class="form-control" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-3">
                            <label asp-for="Codigo" class="form-label">Código</label>
                            <input asp-for="Codigo" class="form-control" />
                        </div>
                    }

                    <div class="col-md-2">
                        <label class="form-label d-block">Situação</label>
                        <div class="form-check form-switch mt-2">
                            <input asp-for="Ativo" class="form-check-input" />
                            <label asp-for="Ativo" class="form-check-label">Ativo</label>
                        </div>
                    </div>

                    @if (Model.Tipo == "assuntos")
                    {
                        <div class="col-md-6">
                            <label asp-for="TipoProtocoloId" class="form-label">Tipo de Protocolo</label>
                            <select asp-for="TipoProtocoloId" class="form-select">
                                <option value="">Selecione...</option>
                                @foreach (var item in Model.TiposProtocolo)
                                {
                                    <option value="@item.Id">@item.Nome</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SetorPadraoId" class="form-label">Setor padrão</label>
                            <select asp-for="SetorPadraoId" class="form-select">
                                <option value="">Selecione...</option>
                                @foreach (var item in Model.Setores)
                                {
                                    <option value="@item.Id">@item.Nome</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label asp-for="PrazoDias" class="form-label">Prazo em dias</label>
                            <input asp-for="PrazoDias" type="number" min="0" class="form-control" />
                        </div>
                    }

                    @if (Model.Tipo == "prioridades")
                    {
                        <div class="col-md-3">
                            <label asp-for="Ordem" class="form-label">Ordem</label>
                            <input asp-for="Ordem" type="number" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="PrazoDias" class="form-label">Prazo em dias</label>
                            <input asp-for="PrazoDias" type="number" min="0" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Cor" class="form-label">Cor Bootstrap</label>
                            <select asp-for="Cor" class="form-select">
                                <option value="secondary">secondary</option>
                                <option value="primary">primary</option>
                                <option value="success">success</option>
                                <option value="warning">warning</option>
                                <option value="danger">danger</option>
                                <option value="info">info</option>
                            </select>
                        </div>
                    }

                    @if (Model.Tipo == "tipos-documento")
                    {
                        <div class="col-md-3">
                            <label class="form-label d-block">Obrigatório</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="Obrigatorio" class="form-check-input" />
                                <label asp-for="Obrigatorio" class="form-check-label">Sim</label>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label d-block">Permite múltiplos</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="PermiteMultiplos" class="form-check-input" />
                                <label asp-for="PermiteMultiplos" class="form-check-label">Sim</label>
                            </div>
                        </div>
                    }

                    @if (Model.Tipo == "tipos")
                    {
                        <div class="col-md-3">
                            <label class="form-label d-block">Exige interessado</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="ExigeInteressado" class="form-check-input" />
                                <label asp-for="ExigeInteressado" class="form-check-label">Sim</label>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label d-block">Exige documento inicial</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="ExigeDocumentoInicial" class="form-check-input" />
                                <label asp-for="ExigeDocumentoInicial" class="form-check-label">Sim</label>
                            </div>
                        </div>
                    }

                    <div class="col-12">
                        <label asp-for="Descricao" class="form-label">Descrição</label>
                        <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a class="btn btn-outline-secondary"
                       asp-action="Index"
                       asp-route-tipo="@Model.Tipo">
                        Voltar
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i>
                        Salvar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
