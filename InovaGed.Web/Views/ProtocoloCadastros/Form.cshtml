@model InovaGed.Web.Models.Protocolo.ProtocoloCadastroFormVM
@{ ViewData["Title"] = "Cadastro do Protocolo"; }
<div class="d-flex justify-content-between mb-3"><h4>@Model.Titulo</h4><a asp-action="Index" asp-route-tipo="@Model.Tipo" class="btn btn-outline-secondary">Voltar</a></div>
<form asp-action="Salvar" method="post">@Html.AntiForgeryToken()<input type="hidden" asp-for="Id"/><input type="hidden" asp-for="Tipo"/><div class="card border-0 shadow-sm"><div class="card-body row g-3"><div class="col-md-3"><label>Código</label><input asp-for="Codigo" class="form-control"/></div><div class="col-md-6"><label>Nome</label><input asp-for="Nome" class="form-control"/></div><div class="col-md-3"><label>Sigla</label><input asp-for="Sigla" class="form-control"/></div><div class="col-md-12"><label>Descrição</label><textarea asp-for="Descricao" rows="4" class="form-control"></textarea></div><div class="col-md-3"><label>Ordem</label><input asp-for="Ordem" type="number" class="form-control"/></div><div class="col-md-3"><label>Prazo dias</label><input asp-for="PrazoDias" type="number" class="form-control"/></div><div class="col-md-3"><label>Cor</label><input asp-for="Cor" class="form-control"/></div><div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="Ativo" class="form-check-input"/><label>Ativo</label></div></div></div><div class="card-footer bg-white text-end"><button class="btn btn-primary">Salvar</button></div></div></form>
