@model dynamic
@{
    ViewData["Title"] = "Histórico da Caixa";
    var boxId = (Guid?)Model?.boxId;
    var rows = Model?.rows as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    ViewData["Subtitle"] = "Trilha de movimentação física (PoC 17/18)";
}

<div class="container py-3">

    @if (boxId == null || boxId == Guid.Empty)
    {
        <div class="alert alert-secondary">
            Informe um BoxId para visualizar o histórico.
        </div>

        <form method="get" class="row g-2">
            <div class="col-md-8">
                <input name="boxId" class="form-control" placeholder="boxId (UUID)" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-primary w-100" type="submit">Ver Histórico</button>
            </div>
        </form>

        return;
    }

    <div class="alert alert-info">
        Aqui prova “incluir / retirar / mover” com registro de auditoria física (PoC 17).
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Ação</th>
                    <th>Documento</th>
                    <th>Título</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in rows)
                {
                    <tr>
                        <td class="small text-muted">@h.changed_at</td>
                        <td><span class="badge text-bg-secondary">@h.action</span></td>
                        <td class="font-monospace">@h.code</td>
                        <td>@h.title</td>
                        <td>@h.notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>