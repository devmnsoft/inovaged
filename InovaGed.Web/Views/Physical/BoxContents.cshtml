@model IReadOnlyList<InovaGed.Application.Ged.Physical.BoxContentItemDto>
@using InovaGed.Application.Ged.Physical
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] ??= "Conteúdo da Caixa";

    var boxes = (ViewBag.Boxes as IReadOnlyList<BoxRowDto>) ?? Array.Empty<BoxRowDto>();
    var selectedBoxId = ViewBag.SelectedBoxId as Guid?;
    var q = (ViewBag.Q as string) ?? "";
    var availableDocuments = (ViewBag.AvailableDocuments as IReadOnlyList<AvailableDocumentForBoxDto>)
                             ?? Array.Empty<AvailableDocumentForBoxDto>();

    var subtitle = ViewData["Subtitle"] as string ?? "Selecione uma caixa para ver os documentos armazenados.";
    var selectedBox = selectedBoxId.HasValue ? boxes.FirstOrDefault(x => x.Id == selectedBoxId.Value) : null;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="text-uppercase text-muted small fw-semibold">Guarda Física</div>
        <h3 class="mb-1">@ViewData["Title"]</h3>
        <div class="text-muted">@subtitle</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Physical" asp-action="Boxes">
            <i class="bi bi-arrow-left me-1"></i>Caixas
        </a>
        @if (selectedBoxId.HasValue && selectedBoxId.Value != Guid.Empty)
        {
            <a class="btn btn-outline-info"
               asp-controller="Physical"
               asp-action="BoxHistory"
               asp-route-boxId="@selectedBoxId">
                <i class="bi bi-clock-history me-1"></i>Histórico
            </a>
            <a class="btn btn-outline-dark"
               asp-controller="Labels"
               asp-action="BoxLabel"
               asp-route-boxId="@selectedBoxId"
               target="_blank">
                <i class="bi bi-qr-code me-1"></i>Etiqueta
            </a>
        }
    </div>
</div>

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success d-flex align-items-center gap-2 shadow-sm">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@ok</div>
    </div>
}

@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger d-flex align-items-center gap-2 shadow-sm">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@err</div>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <label class="form-label fw-semibold">
            <i class="bi bi-archive me-1"></i>Selecione a caixa de trabalho
        </label>

        <select class="form-select form-select-lg"
                onchange="if(this.value) window.location='/Physical/BoxContents?boxId=' + this.value; else window.location='/Physical/BoxContents';">
            <option value="">-- selecione uma caixa --</option>

            @foreach (var b in boxes)
            {
                var locPart = !string.IsNullOrWhiteSpace(b.LocationLabel)
                    ? " · " + b.LocationLabel
                    : " · sem localização";

                if (selectedBoxId.HasValue && b.Id == selectedBoxId.Value)
                {
                    <option value="@b.Id" selected="selected">
                        Caixa #@b.BoxNo — @b.LabelCode@locPart
                    </option>
                }
                else
                {
                    <option value="@b.Id">
                        Caixa #@b.BoxNo — @b.LabelCode@locPart
                    </option>
                }
            }
        </select>
    </div>
</div>

@if (!selectedBoxId.HasValue || selectedBoxId.Value == Guid.Empty)
{
    <div class="alert alert-info d-flex align-items-start gap-2">
        <i class="bi bi-info-circle-fill fs-5"></i>
        <div>
            <strong>Comece selecionando uma caixa.</strong>
            Depois disso, o sistema exibirá os documentos armazenados, documentos disponíveis para vínculo e ações de movimentação.
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Caixa selecionada</div>
                    <div class="h4 mb-1">#@selectedBox?.BoxNo</div>
                    <code>@selectedBox?.LabelCode</code>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Documentos na caixa</div>
                    <div class="display-6 fw-semibold">@Model.Count</div>
                    <div class="small text-muted">itens vinculados</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Localização</div>
                    @if (!string.IsNullOrWhiteSpace(selectedBox?.LocationLabel))
                    {
                        <div class="fw-semibold"><i class="bi bi-geo-alt-fill text-success me-1"></i>@selectedBox.LocationLabel</div>
                    }
                    else
                    {
                        <span class="badge text-bg-warning">Caixa sem localização</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <div>
                        <strong><i class="bi bi-files me-2"></i>Documentos atualmente na caixa</strong>
                        <div class="small text-muted">Remova documentos apenas quando houver movimentação física correspondente.</div>
                    </div>
                    <span class="badge text-bg-primary rounded-pill">@Model.Count documento(s)</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Documento</th>
                                <th>Lote</th>
                                <th>Fase</th>
                                <th>Inserido em</th>
                                <th class="text-end" style="width:140px;"></th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <i class="bi bi-inbox display-5 text-muted d-block mb-2"></i>
                                        <div class="fw-semibold">Caixa vazia</div>
                                        <div class="text-muted small">Use a busca ao lado para vincular ou mover documentos para esta caixa.</div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    var statusText = item.BatchStatus switch
                                    {
                                        "RECEIVED" => "Recebido",
                                        "TRIAGE" => "Triagem",
                                        "DIGITIZATION" => "Digitalização",
                                        "INDEXING" => "Indexação",
                                        "ARCHIVED" => "Arquivado",
                                        _ => item.BatchStatus
                                    };

                                    var statusCss = item.BatchStatus switch
                                    {
                                        "RECEIVED" => "secondary",
                                        "TRIAGE" => "info",
                                        "DIGITIZATION" => "primary",
                                        "INDEXING" => "warning",
                                        "ARCHIVED" => "success",
                                        _ => "secondary"
                                    };

                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.DocumentTitle</div>
                                            <div class="small text-muted"><code>@item.DocumentCode</code></div>
                                        </td>
                                        <td>
                                            <a asp-controller="Batches" asp-action="Details" asp-route-id="@item.BatchId">
                                                Lote #@item.BatchNo
                                            </a>
                                        </td>
                                        <td><span class="badge text-bg-@statusCss">@statusText</span></td>
                                        <td class="text-muted text-nowrap">@item.AddedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="text-end">
                                            <form method="post"
                                                  asp-controller="Physical"
                                                  asp-action="RemoveDocumentFromBox"
                                                  onsubmit="return confirm('Remover este documento da caixa? Confirme apenas se a retirada física já ocorreu.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="BoxId" value="@selectedBoxId.Value" />
                                                <input type="hidden" name="DocumentId" value="@item.DocumentId" />
                                                <input type="hidden" name="BatchId" value="@item.BatchId" />
                                                <input type="hidden" name="Notes" value="Remoção manual pelo módulo Conteúdo da Caixa" />
                                                <button class="btn btn-sm btn-outline-danger" type="submit">
                                                    <i class="bi bi-box-arrow-up"></i> Remover
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <strong><i class="bi bi-plus-circle me-2"></i>Incluir ou mover documento</strong>
                    <div class="small text-muted">Pesquise por código, título ou lote para vincular o documento à caixa selecionada.</div>
                </div>

                <div class="card-body">
                    <form method="get" asp-controller="Physical" asp-action="BoxContents" class="mb-3">
                        <input type="hidden" name="boxId" value="@selectedBoxId.Value" />
                        <label class="form-label fw-semibold">Buscar documento ou lote</label>
                        <div class="input-group input-group-lg">
                            <input name="q" value="@q" class="form-control" placeholder="Código, título ou lote..." />
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    @if (availableDocuments.Count == 0)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            Nenhum documento encontrado para vincular. Refine a busca ou confira se há documentos cadastrados em lotes.
                        </div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var d in availableDocuments.Take(20))
                            {
                                var alreadyInThisBox = d.CurrentBoxId.HasValue && d.CurrentBoxId.Value == selectedBoxId.Value;

                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between gap-2">
                                        <div>
                                            <div class="fw-semibold">@d.DocumentTitle</div>
                                            <div class="small text-muted">
                                                <code>@d.DocumentCode</code> · Lote #@d.BatchNo · @d.BatchStatus
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(d.CurrentBoxLabel))
                                            {
                                                <div class="small text-muted">
                                                    Localização atual: @d.CurrentBoxLabel
                                                </div>
                                            }
                                        </div>

                                        @if (alreadyInThisBox)
                                        {
                                            <span class="badge text-bg-success align-self-start">Nesta caixa</span>
                                        }
                                        else
                                        {
                                            <form method="post" asp-controller="Physical" asp-action="MoveDocumentToBox"
                                                  onsubmit="return confirm('Confirma vincular/mover este documento para a caixa selecionada?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="BoxId" value="@selectedBoxId.Value" />
                                                <input type="hidden" name="DocumentId" value="@d.DocumentId" />
                                                <input type="hidden" name="BatchId" value="@d.BatchId" />
                                                <input type="hidden" name="Notes" value="Inclusão/movimentação manual pelo módulo Conteúdo da Caixa" />
                                                <button class="btn btn-sm btn-primary" type="submit">
                                                    <i class="bi bi-arrow-right-circle"></i> Vincular
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
