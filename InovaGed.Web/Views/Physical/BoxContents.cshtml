@model IReadOnlyList<InovaGed.Application.Ged.Physical.BoxContentItemDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] ??= "Conteúdo da Caixa";
    var boxes          = (ViewBag.Boxes as IReadOnlyList<InovaGed.Application.Ged.Physical.BoxRowDto>)
                         ?? Array.Empty<InovaGed.Application.Ged.Physical.BoxRowDto>();
    var selectedBoxId  = ViewBag.SelectedBoxId as Guid?;
    var subtitle       = ViewData["Subtitle"] as string ?? "Selecione uma caixa para ver os documentos armazenados.";

    var statusLabel = new Dictionary<string, (string Label, string Css)>
    {
        ["RECEIVED"]     = ("Recebido",       "secondary"),
        ["TRIAGE"]       = ("Triagem",         "info"),
        ["DIGITIZATION"] = ("Digitalização",   "primary"),
        ["INDEXING"]     = ("Indexação",        "warning"),
        ["ARCHIVED"]     = ("Arquivado",        "dark"),
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <div class="text-muted small">@subtitle</div>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-action="Boxes">
        <i class="bi bi-arrow-left me-1"></i>Caixas
    </a>
</div>

@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

@*Seletor de caixa*@
<div class="card mb-3">
    <div class="card-body d-flex align-items-center gap-3">
        <label class="form-label mb-0 text-nowrap fw-semibold">
            <i class="bi bi-archive me-1"></i>Caixa:
        </label>
        <select class="form-select"
                onchange="if(this.value) window.location='/Physical/BoxContents?boxId='+this.value; else window.location='/Physical/BoxContents';">
            <option value="">-- selecione uma caixa --</option>
            @foreach (var b in boxes)
            {
                var locPart = !string.IsNullOrWhiteSpace(b.LocationLabel) ? $" · {b.LocationLabel}" : "";
                var isSelected = (b.Id == selectedBoxId);
                if (isSelected)
                {
                    <option value="@b.Id" selected="selected">Caixa #@b.BoxNo — @b.LabelCode@locPart</option>
                }
                else
                {
                    <option value="@b.Id">Caixa #@b.BoxNo — @b.LabelCode@locPart</option>
                }
            }
        </select>
        @if (selectedBoxId.HasValue)
        {
            <a class="btn btn-outline-secondary btn-sm text-nowrap"
               asp-action="BoxHistory" asp-route-boxId="@selectedBoxId">
                <i class="bi bi-clock-history me-1"></i>Ver Histórico
            </a>
        }
    </div>
</div>

@if (selectedBoxId == null || selectedBoxId == Guid.Empty)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Selecione uma caixa acima para visualizar os documentos armazenados.
    </div>
}
else if (Model == null || Model.Count == 0)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>Nenhum documento vinculado a esta caixa no momento.
    </div>
}
else
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong><i class="bi bi-files me-2"></i>Documentos na Caixa</strong>
            <span class="badge text-bg-primary">@Model.Count documento(s)</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Título</th>
                        <th>Lote</th>
                        <th>Fase do Lote</th>
                        <th>Inserido em</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var s = statusLabel.TryGetValue(item.BatchStatus, out var sv)
                                    ? sv : (item.BatchStatus, "secondary");
                        <tr>
                            <td><code>@item.DocumentCode</code></td>
                            <td>@item.DocumentTitle</td>
                            <td>
                                <a asp-controller="Batches" asp-action="Details" asp-route-id="@item.BatchId">
                                    <i class="bi bi-collection me-1"></i>Lote #@item.BatchNo
                                </a>
                            </td>
                            <td>
                                <span class="badge text-bg-@s.Item2">@s.Item1</span>
                            </td>
                            <td class="text-muted text-nowrap">@item.AddedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
