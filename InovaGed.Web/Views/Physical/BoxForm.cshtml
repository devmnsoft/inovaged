@{
    ViewData["Title"] = "Cadastro de Caixa";
}

<h3 class="mb-3">@ViewData["Title"]</h3>

<form method="post" class="card card-body">
    <div class="row g-3">

        <div class="col-md-3">
            <label class="form-label">Nº da Caixa</label>
            <input name="BoxNo" class="form-control" type="number" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Código/Identificação (Etiqueta)</label>
            <input name="LabelCode" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Localização (LocationId)</label>
            <input name="LocationId" class="form-control" />
        </div>

        <div class="col-12">
            <label class="form-label">Observações</label>
            <textarea name="Notes" class="form-control" rows="3"></textarea>
        </div>

    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Salvar</button>
        <a class="btn btn-outline-secondary" href="/Physical/Index">Voltar</a>
    </div>
</form>