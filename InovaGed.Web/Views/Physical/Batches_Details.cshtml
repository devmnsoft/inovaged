@using InovaGed.Application.Ged.Batches

@{
    var header = ViewBag.Header as BatchRowDto;
    var items = ViewBag.Items as List<BatchItemDto> ?? new List<BatchItemDto>();
    var history = ViewBag.History as List<BatchHistoryDto> ?? new List<BatchHistoryDto>();
    var allowedStatus = ViewBag.AllowedStatus as string[] ?? Array.Empty<string>();

    ViewData["Title"] = header is null ? "Lote" : $"Lote #{header.BatchNo}";
}

@if (header is null)
{
    <div class="alert alert-danger">Não foi possível carregar o lote.</div>
    <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">Voltar</a>
    return;
}

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show">@ok<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Err"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">@err<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="text-muted small">Itens do lote, fases do tratamento documental e rastreio de caixas.</div>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>
</div>

<div class="row g-3">
    {{!-- Coluna esquerda: info + mudar status --}}
    <div class="col-lg-4">

        {{!-- Info do lote --}}
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white"><strong><i class="bi bi-box-seam me-1"></i>Informações</strong></div>
            <div class="card-body">
                <div class="mb-2">
                    <div class="text-muted small">Status atual</div>
                    @{
                        var (badgeCls, badgeLbl) = header.Status switch
                        {
                            "RECEIVED"     => ("text-bg-secondary", "Recebido"),
                            "TRIAGE"       => ("text-bg-info",      "Triagem"),
                            "DIGITIZATION" => ("text-bg-primary",   "Digitalização"),
                            "INDEXING"     => ("text-bg-warning",   "Indexação"),
                            "ARCHIVED"     => ("text-bg-dark",      "Arquivado"),
                            _              => ("text-bg-light border", header.Status)
                        };
                    }
                    <span class="badge @badgeCls fs-6">@badgeLbl</span>
                </div>
                <div class="mb-2">
                    <div class="text-muted small">Criado em</div>
                    <div class="fw-semibold">@header.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="mb-2">
                    <div class="text-muted small">Itens</div>
                    <div class="fw-semibold">@header.ItemsCount</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(header.Notes))
                {
                    <div>
                        <div class="text-muted small">Observações</div>
                        <div class="border rounded p-2 bg-light small">@header.Notes</div>
                    </div>
                }
            </div>
        </div>
         
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white">
                <strong><i class="bi bi-arrow-repeat me-1"></i>Avançar Fase (Item 18)</strong>
            </div>
            <div class="card-body">
                <form method="post" asp-action="ChangeStatus" asp-route-id="@header.Id">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">Nova fase do tratamento</label>
                        <select class="form-select" name="status">
                            <option value="">— Selecione —</option>
                            @foreach (var s in allowedStatus)
                            {
                                var lbl = s switch
                                {
                                    "RECEIVED"     => "Recebido",
                                    "TRIAGE"       => "Triagem",
                                    "DIGITIZATION" => "Digitalização",
                                    "INDEXING"     => "Indexação",
                                    "ARCHIVED"     => "Arquivado",
                                    _              => s
                                };
                                <option value="@s" selected="@(header.Status == s)">
                                    @lbl
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Observação (opcional)</label>
                        <input class="form-control form-control-sm" name="notes" placeholder="Ex.: concluída triagem em 05/03" />
                    </div>
                    <button class="btn btn-sm btn-primary w-100" type="submit">
                        <i class="bi bi-check-circle me-1"></i> Salvar fase
                    </button>
                </form>
            </div>
        </div>

        {{!-- Item 18: Histórico de fases --}}
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-clock-history me-1"></i>Histórico de Fases</strong>
                <span class="text-muted small">@history.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Data</th>
                                <th>Fase</th>
                                <th>Obs.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (history.Count == 0)
                            {
                                <tr><td colspan="3" class="text-center text-muted py-3">Sem histórico.</td></tr>
                            }
                            else
                            {
                                @foreach (var h in history)
                                {
                                    var (hBadge, hLbl) = h.ToStatus switch
                                    {
                                        "RECEIVED"     => ("text-bg-secondary", "Recebido"),
                                        "TRIAGE"       => ("text-bg-info",      "Triagem"),
                                        "DIGITIZATION" => ("text-bg-primary",   "Digital."),
                                        "INDEXING"     => ("text-bg-warning",   "Indexação"),
                                        "ARCHIVED"     => ("text-bg-dark",      "Arquivado"),
                                        "CREATE"       => ("text-bg-light border","Criação"),
                                        _              => ("text-bg-light border", h.ToStatus)
                                    };
                                    <tr>
                                        <td class="text-nowrap small">@h.ChangedAt.ToString("dd/MM HH:mm")</td>
                                        <td><span class="badge @hBadge">@hLbl</span></td>
                                        <td class="text-muted small text-truncate" style="max-width:140px;" title="@h.Notes">@(string.IsNullOrWhiteSpace(h.Notes) ? "—" : h.Notes)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    {{!-- Coluna direita: itens e adicionar --}}
    <div class="col-lg-8">

        {{!-- Item 17: Itens do lote com caixa, mover, remover --}}
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <strong><i class="bi bi-files me-1"></i>Itens do Lote (Item 17)</strong>
                <span class="text-muted small">@items.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:160px;">Código</th>
                                <th>Título</th>
                                <th style="width:160px;">Caixa</th>
                                <th style="width:200px;" class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (items.Count == 0)
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4">Nenhum item no lote.</td></tr>
                            }
                            else
                            {
                                foreach (var it in items)
                                {
                                    <tr>
                                        <td class="fw-semibold small">@(it.DocumentCode ?? "—")</td>
                                        <td>@(it.DocumentTitle ?? "—")</td>
                                        <td>
                                            @if (it.BoxId is null || it.BoxId == Guid.Empty)
                                            {
                                                <span class="text-muted small"><i class="bi bi-inbox text-warning me-1"></i>Sem caixa</span>
                                            }
                                            else
                                            {
                                              
                                                <a href="/Physical/BoxHistory?boxId=@it.BoxId"
                                                   class="text-decoration-none small d-flex align-items-center gap-1"
                                                   title="Ver histórico físico da caixa">
                                                    <i class="bi bi-inbox-fill text-success"></i>
                                                    @(it.BoxLabel ?? it.BoxId!.ToString())
                                                </a>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex gap-1 justify-content-end">
                                                {{!-- Item 17: Mover para outra caixa --}}
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        type="button"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#modalMoverCaixa"
                                                        data-doc-id="@it.DocumentId"
                                                        data-doc-title="@it.DocumentTitle"
                                                        title="Mover para outra caixa">
                                                    <i class="bi bi-arrow-left-right"></i>
                                                </button>
                                                {{!-- Item 17: Remover do lote --}}
                                                <form class="d-inline m-0" method="post"
                                                      asp-action="RemoveItem" asp-route-id="@header.Id"
                                                      onsubmit="return confirm('Remover documento do lote?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@it.DocumentId" />
                                                    <button class="btn btn-sm btn-outline-danger" type="submit" title="Remover do lote">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {{!-- Item 17: Adicionar item ao lote --}}
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong><i class="bi bi-plus-circle me-1"></i>Adicionar Documento ao Lote (Item 17)</strong>
            </div>
            <div class="card-body">
                <form method="post" asp-action="AddItem" asp-route-id="@header.Id">
                    @Html.AntiForgeryToken()
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label">GUID do Documento</label>
                            <input class="form-control" name="documentId" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" required />
                            <div class="form-text">Cole o ID do documento a adicionar ao lote.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">GUID da Caixa (opcional)</label>
                            <input class="form-control" name="boxId" placeholder="Deixe em branco para sem caixa" />
                            <div class="form-text">Vincule já a uma caixa para rastreio físico.</div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-plus-circle me-1"></i> Adicionar
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

{{!-- Modal: Mover item para outra caixa (Item 17) --}}
<div class="modal fade" id="modalMoverCaixa" tabindex="-1" aria-labelledby="modalMoverCaixaLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="MoveItem" asp-route-id="@header.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" name="documentId" id="moveDocId" />

                <div class="modal-header">
                    <h5 class="modal-title" id="modalMoverCaixaLabel">
                        <i class="bi bi-arrow-left-right me-1"></i> Mover Documento para Caixa
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3" id="moveDocTitle"></p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nova Caixa (GUID)</label>
                        <input class="form-control" name="newBoxId" id="moveNewBoxId"
                               placeholder="Deixe vazio para retirar da caixa" />
                        <div class="form-text">
                            Informe o GUID da caixa de destino, ou deixe vazio para retirar o documento de qualquer caixa.
                            O rastreio físico será registrado automaticamente.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i> Confirmar Movimentação
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Popula o modal de mover caixa com os dados do item clicado
    document.getElementById('modalMoverCaixa')?.addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        document.getElementById('moveDocId').value = btn.dataset.docId ?? '';
        document.getElementById('moveDocTitle').textContent = 'Documento: ' + (btn.dataset.docTitle ?? '');
        document.getElementById('moveNewBoxId').value = '';
    });
</script>
}
