@model InovaGed.Application.Ged.Physical.PhysicalLocationFormVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var isEdit = Model != null && Model.Id != Guid.Empty;
    ViewData["Title"] ??= isEdit ? "Editar Localização Física" : "Nova Localização Física";
    ViewData["Subtitle"] ??= "Cadastre o endereço físico onde caixas e documentos ficam armazenados.";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="mb-0">
            <i class="bi bi-geo-alt me-2"></i>@ViewData["Title"]
        </h4>
        <div class="text-muted small">@ViewData["Subtitle"]</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/Physical/Locations">
            <i class="bi bi-arrow-left me-1"></i>Voltar
        </a>
    </div>
</div>

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<form asp-action="SaveLocation" method="post" class="card shadow-sm">
    @Html.AntiForgeryToken()

    <div class="card-body">
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Prédio</label>
                <input asp-for="Building" class="form-control" placeholder="Ex.: Prédio A" />
                <span asp-validation-for="Building" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Sala</label>
                <input asp-for="Room" class="form-control" placeholder="Ex.: Sala 02" />
                <span asp-validation-for="Room" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Corredor</label>
                <input asp-for="Aisle" class="form-control" placeholder="Ex.: Corredor 1" />
                <span asp-validation-for="Aisle" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Estante</label>
                <input asp-for="Rack" class="form-control" placeholder="Ex.: Estante 03" />
                <span asp-validation-for="Rack" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Prateleira</label>
                <input asp-for="Shelf" class="form-control" placeholder="Ex.: Prateleira B" />
                <span asp-validation-for="Shelf" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Palete</label>
                <input asp-for="Pallet" class="form-control" placeholder="Ex.: Palete 10" />
                <span asp-validation-for="Pallet" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label class="form-label">Observações</label>
                <textarea asp-for="Notes" class="form-control" rows="3"
                          placeholder="Informações adicionais..."></textarea>
                <span asp-validation-for="Notes" class="text-danger small"></span>
            </div>
        </div>

        <div class="mt-3 text-muted small">
            Dica: preencha o que fizer sentido. Campos vazios podem ser usados como “não aplicável”.
        </div>
    </div>

    <div class="card-footer d-flex gap-2 justify-content-end">
        <a class="btn btn-outline-secondary" href="/Physical/Locations">
            <i class="bi bi-x-lg me-1"></i>Cancelar
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-1"></i>Salvar
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}