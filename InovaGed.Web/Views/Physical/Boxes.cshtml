@model IReadOnlyList<InovaGed.Application.Ged.Physical.BoxRowDto>

@{
    ViewData["Title"] = "Caixas";
    ViewData["Subtitle"] = "Cadastro e vínculo das caixas a uma localização física.";

    var q = (ViewBag.Q as string) ?? "";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="mb-0">Caixas</h4>
        <div class="text-muted small">Controle de caixas físicas e seus endereços (localização).</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-primary" href="/Physical/Boxes/New">
            <i class="bi bi-plus-lg me-1"></i>Nova Caixa
        </a>
    </div>
</div>

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger">@err</div>
}

<form method="get" class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-2 align-items-center">
        <div class="flex-grow-1">
            <input name="q" value="@q" class="form-control"
                   placeholder="Buscar por nº da caixa, etiqueta (label_code) ou observações..." />
        </div>
        <button class="btn btn-outline-secondary" type="submit">
            <i class="bi bi-search me-1"></i>Pesquisar
        </button>
        <a class="btn btn-outline-secondary" href="/Physical/Boxes">
            <i class="bi bi-x-lg me-1"></i>Limpar
        </a>
    </div>
</form>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Resultados</strong>
        <span class="text-muted small">Total: @Model.Count</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nº</th>
                    <th>Etiqueta</th>
                    <th>Localização</th>
                    <th>Observações</th>
                    <th style="width: 170px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            Nenhuma caixa encontrada.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.BoxNo</td>
                            <td><code>@r.LabelCode</code></td>
                            <td>@(string.IsNullOrWhiteSpace(r.LocationLabel) ? "-" : r.LocationLabel)</td>
                            <td class="text-muted">@((string.IsNullOrWhiteSpace(r.Notes)) ? "-" : r.Notes)</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/Physical/Boxes/@r.Id"
                                       title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form method="post" action="/Physical/Boxes/@r.Id/Delete" class="m-0"
                                          onsubmit="return confirm('Confirma excluir esta caixa?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" type="submit" title="Excluir">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>