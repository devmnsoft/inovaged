@model IReadOnlyList<InovaGed.Application.Ged.Physical.BoxRowDto>

@{
    ViewData["Title"] = "Caixas";
    ViewData["Subtitle"] = "Cadastro, endereçamento, rastreio e manutenção das caixas físicas.";

    var q = (ViewBag.Q as string) ?? "";
    var total = Model?.Count ?? 0;
    var semLocalizacao = Model?.Count(x => string.IsNullOrWhiteSpace(x.LocationLabel)) ?? 0;
    var comLocalizacao = total - semLocalizacao;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="text-uppercase text-muted small fw-semibold">Guarda Física</div>
        <h3 class="mb-1">Caixas</h3>
        <div class="text-muted">Controle as caixas, seus endereços físicos, etiquetas, conteúdo e histórico de movimentação.</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="/Physical/BoxContents">
            <i class="bi bi-box-seam me-1"></i>Conteúdo da Caixa
        </a>
        <a class="btn btn-outline-secondary" href="/Physical/PhysicalMap">
            <i class="bi bi-map me-1"></i>Mapa
        </a>
        <a class="btn btn-primary" href="/Physical/Boxes/New">
            <i class="bi bi-plus-lg me-1"></i>Nova Caixa
        </a>
    </div>
</div>

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success d-flex align-items-center gap-2 shadow-sm">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@ok</div>
    </div>
}
@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger d-flex align-items-center gap-2 shadow-sm">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@err</div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Caixas cadastradas</div>
                <div class="display-6 fw-semibold">@total</div>
                <div class="small text-muted">registros ativos no acervo físico</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Com localização</div>
                <div class="display-6 fw-semibold">@comLocalizacao</div>
                <div class="small text-muted">rastreáveis no mapa físico</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Sem localização</div>
                <div class="display-6 fw-semibold text-warning">@semLocalizacao</div>
                <div class="small text-muted">precisam de endereçamento</div>
            </div>
        </div>
    </div>
</div>

@if (semLocalizacao > 0)
{
    <div class="alert alert-warning d-flex align-items-start gap-2">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>
            <strong>Atenção:</strong> existem caixas sem localização física. Isso dificulta a coleta, auditoria, empréstimo e conferência do acervo.
        </div>
    </div>
}

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-lg">
                <label class="form-label fw-semibold">Pesquisar caixa</label>
                <input name="q" value="@q" class="form-control form-control-lg"
                       placeholder="Busque por nº da caixa, etiqueta, observação ou localização..." />
                <div class="form-text">Use a busca para localizar uma caixa antes de imprimir etiqueta, editar ou ver conteúdo.</div>
            </div>
            <div class="col-12 col-lg-auto d-flex gap-2">
                <button class="btn btn-primary btn-lg" type="submit">
                    <i class="bi bi-search me-1"></i>Pesquisar
                </button>
                <a class="btn btn-outline-secondary btn-lg" href="/Physical/Boxes">
                    <i class="bi bi-x-lg me-1"></i>Limpar
                </a>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2 py-3">
        <div>
            <strong>Caixas do acervo</strong>
            <div class="small text-muted">Ações rápidas para manutenção, etiqueta, conteúdo e rastreio.</div>
        </div>
        <span class="badge text-bg-primary rounded-pill">@total resultado(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Caixa</th>
                    <th>Localização Física</th>
                    <th>Observações</th>
                    <th class="text-end" style="width: 420px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (total == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <i class="bi bi-archive display-5 text-muted d-block mb-2"></i>
                            <div class="fw-semibold">Nenhuma caixa encontrada</div>
                            <div class="text-muted small mb-3">Crie uma caixa e vincule-a a uma localização física.</div>
                            <a class="btn btn-primary" href="/Physical/Boxes/New">Cadastrar caixa</a>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">Caixa #@r.BoxNo</div>
                                <code>@r.LabelCode</code>
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(r.LocationLabel))
                                {
                                    <span class="badge text-bg-warning">
                                        <i class="bi bi-geo-alt me-1"></i>Sem localização
                                    </span>
                                }
                                else
                                {
                                    <div class="d-flex align-items-start gap-2">
                                        <i class="bi bi-geo-alt-fill text-success mt-1"></i>
                                        <span>@r.LocationLabel</span>
                                    </div>
                                }
                            </td>
                            <td class="text-muted">@(string.IsNullOrWhiteSpace(r.Notes) ? "Sem observações" : r.Notes)</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 flex-wrap justify-content-end">
                                    <a class="btn btn-sm btn-outline-primary" href="/Physical/BoxContents?boxId=@r.Id">
                                        <i class="bi bi-folder2-open"></i> Conteúdo
                                    </a>
                                    <a class="btn btn-sm btn-outline-info" href="/Physical/BoxHistory?boxId=@r.Id">
                                        <i class="bi bi-clock-history"></i> Rastreio
                                    </a>
                                    <a class="btn btn-sm btn-outline-dark" href="/Labels/BoxLabel?boxId=@r.Id" target="_blank">
                                        <i class="bi bi-qr-code"></i> Etiqueta
                                    </a>
                                    <a class="btn btn-sm btn-outline-secondary" href="/Physical/Boxes/@r.Id">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <form method="post" action="/Physical/Boxes/@r.Id/Delete" class="m-0"
                                          onsubmit="return confirm('Confirma excluir a caixa #@r.BoxNo? Use exclusão apenas quando não houver documentos vinculados.');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" type="submit" title="Excluir caixa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
