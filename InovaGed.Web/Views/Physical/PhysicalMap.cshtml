@model IReadOnlyList<InovaGed.Application.Ged.Physical.PhysicalMapRowDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] ??= "Mapa de Guarda Física";
    var q = (ViewBag.Q as string) ?? "";

    var total = Model?.Count ?? 0;
    var semCaixa = Model?.Count(x => !x.BoxId.HasValue) ?? 0;
    var semLocalizacao = Model?.Count(x => string.IsNullOrWhiteSpace(x.FullLocation)) ?? 0;
    var localizados = total - semLocalizacao;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="text-uppercase text-muted small fw-semibold">Guarda Física</div>
        <h3 class="mb-1">@ViewData["Title"]</h3>
        <div class="text-muted">@ViewData["Subtitle"]</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Physical" asp-action="Boxes">
            <i class="bi bi-archive me-1"></i>Caixas
        </a>
        <a class="btn btn-outline-secondary" asp-controller="Physical" asp-action="Locations">
            <i class="bi bi-geo-alt me-1"></i>Localizações
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Registros no mapa</div>
                <div class="display-6 fw-semibold">@total</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Localizados</div>
                <div class="display-6 fw-semibold text-success">@localizados</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Sem caixa</div>
                <div class="display-6 fw-semibold text-warning">@semCaixa</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Sem localização</div>
                <div class="display-6 fw-semibold text-danger">@semLocalizacao</div>
            </div>
        </div>
    </div>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-lg">
                <label class="form-label fw-semibold">Pesquisar no mapa de guarda</label>
                <input name="q" value="@q" class="form-control form-control-lg"
                       placeholder="Documento, prontuário, lote, caixa, etiqueta ou localização..." />
                <div class="form-text">Ideal para localizar rapidamente onde o documento físico está guardado.</div>
            </div>

            <div class="col-12 col-lg-auto d-flex gap-2">
                <button class="btn btn-primary btn-lg" type="submit">
                    <i class="bi bi-search me-1"></i>Pesquisar
                </button>
                <a class="btn btn-outline-secondary btn-lg" asp-action="PhysicalMap">
                    <i class="bi bi-x-lg me-1"></i>Limpar
                </a>
            </div>
        </div>
    </div>
</form>

@if (semCaixa > 0 || semLocalizacao > 0)
{
    <div class="alert alert-warning d-flex align-items-start gap-2">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>
            <strong>Pontos de atenção:</strong> documentos sem caixa ou sem localização prejudicam a rastreabilidade física, empréstimos, auditoria e localização operacional.
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2 py-3">
        <div>
            <strong>Resultado do Mapa de Guarda Física</strong>
            <div class="small text-muted">Visão consolidada de documento, lote, caixa e endereço físico.</div>
        </div>
        <span class="badge text-bg-primary rounded-pill">@total registro(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Documento</th>
                    <th>Lote</th>
                    <th>Caixa</th>
                    <th>Localização Física</th>
                    <th>Vinculado em</th>
                </tr>
            </thead>

            <tbody>
                @if (total == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-map display-5 text-muted d-block mb-2"></i>
                            <div class="fw-semibold">Nenhum registro encontrado</div>
                            <div class="text-muted small">Ajuste a busca ou vincule documentos às caixas para formar o mapa físico.</div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@r.DocumentTitle</div>
                                <div class="text-muted small"><code>@r.DocumentCode</code></div>
                            </td>

                            <td>
                                <a asp-controller="Batches" asp-action="Details" asp-route-id="@r.BatchId">
                                    Lote #@r.BatchNo
                                </a>
                                <div class="text-muted small">@r.BatchStatus</div>
                            </td>

                            <td>
                                @if (r.BoxId.HasValue)
                                {
                                    <a asp-controller="Physical" asp-action="BoxContents" asp-route-boxId="@r.BoxId">
                                        Caixa #@r.BoxNo — @r.LabelCode
                                    </a>
                                }
                                else
                                {
                                    <span class="badge text-bg-warning">Sem caixa</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(r.FullLocation))
                                {
                                    <span><i class="bi bi-geo-alt-fill text-success me-1"></i>@r.FullLocation</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-danger">Sem localização</span>
                                }
                            </td>

                            <td class="text-muted text-nowrap">
                                @(r.LinkedAt.HasValue ? r.LinkedAt.Value.ToString("dd/MM/yyyy HH:mm") : "—")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
