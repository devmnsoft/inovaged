@model InovaGed.Application.Ged.Dashboard.GedDashboardVm
@{
  ViewData["Title"] = "Painel Operacional do GED";
  var vm = Model ?? new InovaGed.Application.Ged.Dashboard.GedDashboardVm { PartialFailure = true };
  var recentLoans = vm.RecentLoanRequests ?? new List<InovaGed.Application.Ged.Dashboard.RecentLoanRequestDto>();
  var recentAudit = vm.RecentAuditEvents ?? new List<InovaGed.Application.Ged.Dashboard.RecentAuditEventDto>();
}
<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="mb-1">Painel Operacional do GED</h2>
      <p class="text-muted mb-0">Visão consolidada de documentos, OCR, solicitações e auditoria</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="GedDashboard" asp-action="Index"><i class="bi bi-arrow-clockwise"></i> Atualizar agora</a>
  </div>

  @if (vm.PartialFailure)
  {
    <div class="alert alert-warning py-2">Alguns indicadores não puderam ser carregados. Verifique os logs técnicos.</div>
  }

  <div class="row g-3 mb-4">
    @foreach (var c in new[] {
      new {T="Total de documentos ativos",V=vm.ActiveDocuments,I="bi-files",C="text-primary",L="/Ged"},
      new {T="Documentos sem classificação",V=vm.UnclassifiedDocuments,I="bi-tags",C="text-warning",L="/Ged"},
      new {T="Documentos confidenciais",V=vm.ConfidentialDocuments,I="bi-shield-lock",C="text-danger",L="/Ged"},
      new {T="OCR pendente",V=vm.OcrPending,I="bi-hourglass-split",C="text-secondary",L="/Ged/Processing"},
      new {T="OCR processando",V=vm.OcrProcessing,I="bi-cpu",C="text-info",L="/Ged/Processing"},
      new {T="OCR com erro",V=vm.OcrError,I="bi-exclamation-triangle",C="text-danger",L="/Ged/Processing"},
      new {T="Solicitações pendentes",V=vm.LoanRequested,I="bi-journal-arrow-up",C="text-warning",L="/Loans"},
      new {T="Empréstimos vencidos",V=vm.LoanOverdue,I="bi-calendar2-x",C="text-danger",L="/Loans/Overdue"},
      new {T="Movimentações hoje",V=vm.FolderMovesToday,I="bi-arrow-left-right",C="text-info",L="/Ged/Folders"},
      new {T="Acessos negados 24h",V=vm.AccessDenied24h,I="bi-shield-x",C="text-danger",L="/Audit/AccessDenied"},
      new {T="Usuários bloqueados",V=vm.LockedUsers,I="bi-person-lock",C="text-danger",L="/Users"},
      new {T="Temporalidade vencida",V=vm.RetentionExpired,I="bi-clock-history",C="text-warning",L="/Retention"}
    }) {
      <div class="col-12 col-sm-6 col-xl-3"><a class="text-decoration-none" href="@c.L"><div class="card h-100 shadow-sm"><div class="card-body"><div class="d-flex justify-content-between"><small class="text-muted">@c.T</small><i class="bi @c.I @c.C"></i></div><div class="display-6 fw-bold">@c.V</div></div></div></a></div>
    }
  </div>

  <div class="row g-3">
    <div class="col-12 col-xl-6">
      <div class="card h-100 shadow-sm">
        <div class="card-header"><strong>Solicitações de empréstimo recentes</strong></div>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead><tr><th>Data</th><th>Solicitante</th><th>Documento</th><th>Status</th></tr></thead>
            <tbody>
            @if (recentLoans.Count == 0)
            {
              <tr><td colspan="4" class="text-muted">Sem registros recentes.</td></tr>
            }
            else
            {
              foreach (var item in recentLoans)
              {
                <tr>
                  <td>@(item.RequestedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                  <td>@(item.Requester ?? "-")</td>
                  <td>@(item.Document ?? "-")</td>
                  <td>@(item.Status ?? "-")</td>
                </tr>
              }
            }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card h-100 shadow-sm">
        <div class="card-header"><strong>Eventos de auditoria recentes</strong></div>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead><tr><th>Data</th><th>Ação</th><th>Entidade</th><th>Usuário</th></tr></thead>
            <tbody>
            @if (recentAudit.Count == 0)
            {
              <tr><td colspan="4" class="text-muted">Sem registros recentes.</td></tr>
            }
            else
            {
              foreach (var item in recentAudit)
              {
                <tr>
                  <td>@(item.EventTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                  <td>@(item.Action ?? "-")</td>
                  <td>@(item.EntityName ?? "-")</td>
                  <td>@(item.UserName ?? "-")</td>
                </tr>
              }
            }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
