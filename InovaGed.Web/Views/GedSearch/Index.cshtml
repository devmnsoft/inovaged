@{
    ViewData["Title"] = "Busca Avançada de Documentos";
}
<div class="container py-4">
    <h2>Busca Avançada de Documentos</h2>
    <p class="text-muted">Localize documentos por nome, OCR, pasta, classificação, tipo documental e metadados.</p>
    <form method="post" action="/Ged/Search/Results">
        @Html.AntiForgeryToken()
        <input class="form-control form-control-lg" name="Term" placeholder="Pesquise por nome, prontuário, protocolo, CPF, OCR, pasta ou tipo documental..." />
        <div class="mt-3"><button class="btn btn-primary">Pesquisar</button></div>
    </form>
</div>
