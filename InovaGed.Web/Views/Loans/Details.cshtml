@using InovaGed.Application.Ged.Loans
@using InovaGed.Web.Security
@model LoanDetailsVM

@functions {
    string StatusPt(string? status) => (status ?? "").ToUpperInvariant() switch
    {
        "REQUESTED" => "Solicitado",
        "TRIAGE" => "Em triagem",
        "NEEDS_INFO" => "Precisa de informações",
        "APPROVED" => "Aprovado",
        "PREPARING_PHYSICAL" => "Preparando físico",
        "WAITING_PICKUP" => "Aguardando retirada",
        "DIGITAL_LINK_SENT" => "Link digital enviado",
        "REJECTED" => "Rejeitado",
        "DELIVERED" => "Entregue",
        "RETURNED" => "Devolvido",
        "OVERDUE" => "Vencido",
        "CANCELLED" => "Cancelado",
        "RETURNED_FOR_ADJUSTMENT" => "Devolvido para ajuste",
        _ => status ?? "-"
    };
}

@{
    ViewData["Title"] = "Detalhes do Empréstimo";
    var h = Model.Header;
    var itemCount = Model.Items.Count;
    var canManageLoans = AppMenuPolicy.CanSeeLoansManage(User);
    var canRequestLoans = AppMenuPolicy.CanSeeLoansRequest(User);
    var canCancelOwn = !canManageLoans && canRequestLoans && new[] { "REQUESTED", "RETURNED_FOR_ADJUSTMENT" }.Contains((h.Status ?? string.Empty).ToUpperInvariant());
    var canRespondAdjustment = !canManageLoans && canRequestLoans && string.Equals(h.Status, "RETURNED_FOR_ADJUSTMENT", StringComparison.OrdinalIgnoreCase);
    var canOpenSchemaHealth = AppMenuPolicy.IsFullAdmin(User);
    var defaultSecureLinkExpiration = DateTime.UtcNow.AddHours(24).ToString("yyyy-MM-ddTHH:mm");
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <div class="text-muted small">Protocolo</div>
        <h2 class="mb-1">@h.ProtocolNo</h2>
        <div><span class="badge bg-secondary">@StatusPt(h.Status)</span> <span class="text-muted">@h.RequesterName</span></div><div class="text-muted small">Pedido @(h.RequestNo ?? h.ProtocolNo.ToString()) • Entrega: @(h.DeliveryMode ?? "PHYSICAL")</div>
    </div>
    <div class="d-flex gap-2"><a class="btn btn-outline-secondary" href="/Loans">Voltar</a><button class="btn btn-outline-dark" type="button" onclick="window.print()"><i class="bi bi-printer me-1"></i>Imprimir protocolo</button></div>
</div>

@if (TempData["Ok"] is not null) { <div class="alert alert-success">@TempData["Ok"]</div> }
@if (TempData["Err"] is not null) { <div class="alert alert-danger">@TempData["Err"]</div> }
@if (Model.HistorySchemaMissing)
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center gap-3">
        <span>Histórico de empréstimos ainda não configurado. Execute as migrations.</span>
        @if (canOpenSchemaHealth)
        {
            <a class="btn btn-sm btn-outline-dark" href="/SystemHealth/Schema">Abrir Schema Health</a>
        }
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Solicitado em</div><div class="fw-semibold">@h.RequestedAt.ToString("dd/MM/yyyy HH:mm")</div></div></div>
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Aprovado em</div><div class="fw-semibold">@(h.ApprovedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div></div>
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Entregue em</div><div class="fw-semibold">@(h.DeliveredAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div></div>
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Devolvido em</div><div class="fw-semibold">@(h.ReturnedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div></div>
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Vencimento</div><div class="fw-semibold">@h.DueAt.ToString("dd/MM/yyyy")</div></div></div>
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Itens</div><div class="fw-semibold">@itemCount</div></div></div>
    <div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">SLA</div><div class="fw-semibold">@(h.SlaDueAt?.ToString("dd/MM/yyyy HH:mm") ?? "A definir")</div></div></div><div class="col-md-3"><div class="card card-body h-100"><div class="small text-muted">Responsável atual</div><div class="fw-semibold">@(Model.History.FirstOrDefault()?.ByUserName ?? h.RequesterName ?? "Sistema")</div></div></div><div class="col-md-6"><div class="card card-body h-100"><div class="small text-muted">Resposta/entrega</div><div class="fw-semibold">@(h.AdminResponse ?? h.DeliveryInstructions ?? "Aguardando análise")</div></div></div>
</div>

<div class="card card-body mb-3">
    <div class="d-flex gap-2 flex-wrap">
        @if (canManageLoans)
        {
            <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#approveModal">Aprovar</button>
            <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">Rejeitar</button>
            <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#deliverModal">Entregar</button>
            <button class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#returnModal">Devolver</button>
            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#adjustModal">Devolver para ajuste</button>
            <button class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#respondModal">Responder/Definir SLA</button>
            <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#physicalModal">Entrega física</button>
            <button class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#secureLinkModal">Gerar link seguro</button>
        }
        @if (canCancelOwn)
        {
            <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#cancelModal">Cancelar solicitação</button>
        }
        @if (canRespondAdjustment)
        {
            <a class="btn btn-outline-primary" href="/Loans/New">Responder ajuste</a>
        }
        <button class="btn btn-light border" onclick="window.print()">Gerar recibo</button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Mensagens e acompanhamento</strong></div>
    <div class="list-group list-group-flush">
        @foreach (var m in Model.Messages.Where(x => canManageLoans || !x.IsInternal))
        {
            <div class="list-group-item"><div class="d-flex justify-content-between"><strong>@m.SenderName</strong><span class="text-muted">@m.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div><div>@m.Message</div><div class="text-muted small">@m.MessageType</div></div>
        }
        @if (!Model.Messages.Any()) { <div class="list-group-item text-muted">Nenhuma mensagem registrada.</div> }
    </div>
    @if (!canManageLoans && string.Equals(h.Status, "NEEDS_INFO", StringComparison.OrdinalIgnoreCase))
    {
        <div class="card-footer"><form method="post" action="/Loans/@h.Id/RequesterReply">@Html.AntiForgeryToken()<label class="form-label">Responder com mais informações</label><textarea class="form-control" name="message" rows="2" required></textarea><button class="btn btn-primary mt-2">Enviar complemento</button></form></div>
    }
</div>


@if (canManageLoans)
{
<div class="card mb-3">
    <div class="card-header"><strong>Documentos associados ao pedido</strong></div>
    <div class="card-body">
        <form class="row g-2 mb-3" method="get" action="/Loans/@h.Id/DocumentSearch">
            <div class="col"><input class="form-control" name="q" placeholder="Buscar por paciente, prontuário, OCR, pasta ou título" /></div>
            <div class="col-auto"><button class="btn btn-outline-primary" type="submit">Pesquisar</button></div>
        </form>
        <div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Título</th><th>Arquivo/código</th><th>Pasta/local</th><th>Ações</th></tr></thead><tbody>
        @foreach (var i in Model.Items.Where(x => x.DocumentId.HasValue))
        {
            <tr><td>@(i.DocumentTitle ?? i.Description)</td><td>@(i.DocumentCode ?? i.DocumentId.ToString())</td><td>@(i.PhysicalLocation ?? "GED")</td><td class="d-flex gap-1"><button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#secureLinkModal" type="button">Gerar link seguro</button><form method="post" action="/Loans/@h.Id/RemoveAssociatedDocument">@Html.AntiForgeryToken()<input type="hidden" name="documentId" value="@i.DocumentId" /><button class="btn btn-sm btn-outline-danger">Remover associação</button></form></td></tr>
        }
        @if (!Model.Items.Any(x => x.DocumentId.HasValue)) { <tr><td colspan="4" class="text-muted">Nenhum documento associado. Use a busca contextual e associe o documento correto antes de gerar link.</td></tr> }
        </tbody></table></div>
        <form method="post" action="/Loans/@h.Id/AssociateDocument" class="border rounded p-2 bg-light">
            @Html.AntiForgeryToken()<div class="row g-2"><div class="col-md-4"><input class="form-control" name="DocumentId" placeholder="UUID do documento encontrado" required /></div><div class="col-md-4"><input class="form-control" name="VersionId" placeholder="UUID da versão (opcional)" /></div><div class="col-md-3"><input class="form-control" name="MatchReason" placeholder="Motivo/score da associação" /></div><div class="col-md-1"><button class="btn btn-primary w-100">Associar</button></div></div>
        </form>
    </div>
</div>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><strong>Itens</strong></div>
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead><tr><th>Origem</th><th>Documento</th><th>Tipo</th><th>Localização</th><th>Observações</th></tr></thead>
                    <tbody>
                    @foreach (var i in Model.Items)
                    {
                        <tr>
                            <td><span class="badge @(i.IsManual ? "text-bg-warning text-dark" : "text-bg-primary")">@(i.IsManual ? "Documento físico/manual" : "Documento digitalizado")</span></td>
                            <td><div class="fw-semibold">@(i.DocumentTitle ?? i.Description ?? i.ReferenceCode ?? i.DocumentId?.ToString())</div><div class="text-muted small">@(i.ReferenceCode ?? i.DocumentCode)</div><div class="text-muted small">@(i.PatientName) @(i.MedicalRecordNumber)</div></td>
                            <td>@(i.DocumentType ?? "-")</td>
                            @{ var location = string.Join(" / ", new[] { i.BoxCode, i.PhysicalLocation }.Where(x => !string.IsNullOrWhiteSpace(x))); }
                            <td>@(string.IsNullOrWhiteSpace(location) ? "-" : location)</td>
                            <td>@(i.Notes ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Items.Any()) { <tr><td colspan="5" class="text-muted">Sem itens.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><strong>Histórico operacional</strong></div>
            <div class="list-group list-group-flush">
                @foreach (var ev in Model.History)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between"><strong>@StatusPt(ev.EventType)</strong><span class="text-muted">@ev.EventTime.ToString("dd/MM/yyyy HH:mm")</span></div>
                        <div class="text-muted small">@ev.ByUserName @(string.IsNullOrWhiteSpace(ev.Sector) ? "" : $"• {ev.Sector}")</div>
                        @if (!string.IsNullOrWhiteSpace(ev.OldStatus) || !string.IsNullOrWhiteSpace(ev.NewStatus)) { <div class="small">@StatusPt(ev.OldStatus) → @StatusPt(ev.NewStatus)</div> }
                        @if (!string.IsNullOrWhiteSpace(ev.Notes)) { <div>@ev.Notes</div> }
                        @if (!string.IsNullOrWhiteSpace(ev.InternalNotes)) { <div class="text-muted small">Interno: @ev.InternalNotes</div> }
                        @if (!string.IsNullOrWhiteSpace(ev.CorrelationId)) { <div class="text-muted small font-monospace">@ev.CorrelationId</div> }
                    </div>
                }
                @if (Model.HistorySchemaMissing) { <div class="list-group-item text-warning">Histórico de empréstimos ainda não configurado.</div> }
                else if (Model.History.Count == 0) { <div class="list-group-item text-muted">Nenhuma movimentação registrada ainda.</div> }
            </div>
        </div>
    </div>
</div>


@if (canManageLoans)
{
<div class="modal fade" id="respondModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><form method="post" action="/Loans/@h.Id/Respond">@Html.AntiForgeryToken()<div class="modal-header"><h5>Responder ao solicitante</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><textarea class="form-control" name="message" rows="4" required placeholder="Documento físico estará disponível até... / Documento digital será enviado por link seguro..."></textarea></div><div class="modal-footer"><button class="btn btn-primary">Enviar resposta</button></div></form><form method="post" action="/Loans/@h.Id/SetSla" class="border-top p-3">@Html.AntiForgeryToken()<label class="form-label">SLA em horas</label><input class="form-control" type="number" name="slaHours" value="24" min="1" /><button class="btn btn-outline-primary mt-2">Definir SLA</button></form></div></div></div>
<div class="modal fade" id="physicalModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><form method="post" action="/Loans/@h.Id/SetPhysicalDelivery">@Html.AntiForgeryToken()<div class="modal-header"><h5>Localização física e retirada</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><input class="form-control mb-2" name="location" placeholder="unidade / setor / sala / estante / pasta física" /><input class="form-control mb-2" name="boxCode" placeholder="caixa/código de localização" /><textarea class="form-control" name="instructions" rows="3" required placeholder="Instruções de entrega/retirada"></textarea></div><div class="modal-footer"><button class="btn btn-dark">Salvar localização</button></div></form></div></div></div>
<div class="modal fade" id="secureLinkModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><form method="post" action="/Loans/@h.Id/GenerateSecureLink">@Html.AntiForgeryToken()<div class="modal-header"><h5>Gerar link seguro digital</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><select class="form-select mb-2" name="documentId">@foreach (var i in Model.Items.Where(x => x.DocumentId.HasValue)) { <option value="@i.DocumentId">@i.DocumentTitle</option> }</select><label class="form-label">Expira em (UTC, obrigatório se temporário)</label><input class="form-control mb-2" type="datetime-local" id="loanExpiresAt" value="@defaultSecureLinkExpiration" /><input type="hidden" name="ExpiresAtUtc" id="loanExpiresAtUtc" /> <div class="form-check mb-2"><input class="form-check-input" type="checkbox" name="IsPermanent" value="true" id="permanentLink" /><label class="form-check-label" for="permanentLink">Link permanente</label></div><input class="form-control mb-2" type="number" name="MaxAccessCount" value="5" min="1" placeholder="Limite de acessos (vazio = ilimitado)" /><div class="form-check"><input class="form-check-input" type="checkbox" name="AllowDownload" value="true" checked id="allowDownload" /><label class="form-check-label" for="allowDownload">Permitir download</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="AllowSmartSearch" value="true" checked id="allowSearch" /><label class="form-check-label" for="allowSearch">Permitir busca dentro do documento</label></div><textarea class="form-control mt-2" name="MessageToRequester" rows="2" placeholder="Mensagem opcional ao solicitante"></textarea></div><div class="modal-footer"><button class="btn btn-success">Gerar link</button></div></form></div></div></div>
}


<script>
document.getElementById('permanentLink')?.addEventListener('change', e => { const input=document.getElementById('loanExpiresAt'); input.disabled=e.target.checked; if (e.target.checked) input.value=''; });
document.querySelector('#secureLinkModal form')?.addEventListener('submit', e => { const permanent=document.getElementById('permanentLink')?.checked; const local=document.getElementById('loanExpiresAt')?.value; if (!permanent && !local) { e.preventDefault(); alert('Informe a expiração do link temporário.'); return; } document.getElementById('loanExpiresAtUtc').value = permanent || !local ? '' : new Date(local).toISOString(); });
</script>

@{
    var modals = new[]
    {
        new { Id = "approveModal", Title = "Aprovar solicitação", Action = "Approve", Help = "Informe uma observação de aprovação ou orientação para retirada.", Button = "btn-primary" },
        new { Id = "rejectModal", Title = "Rejeitar solicitação", Action = "Reject", Help = "Informe o motivo da rejeição.", Button = "btn-danger" },
        new { Id = "deliverModal", Title = "Registrar entrega", Action = "Deliver", Help = "Informe quem retirou, documento de identificação ou observação da entrega.", Button = "btn-warning" },
        new { Id = "returnModal", Title = "Registrar devolução", Action = "Return", Help = "Informe as condições da devolução e observações.", Button = "btn-success" },
        new { Id = "adjustModal", Title = "Devolver para ajuste", Action = "ReturnForAdjustment", Help = "Informe a devolutiva para ajuste da solicitação.", Button = "btn-secondary" },
        new { Id = "cancelModal", Title = "Cancelar solicitação", Action = "Cancel", Help = "Informe o motivo do cancelamento.", Button = "btn-dark" }
    };
}
@if (canManageLoans || canCancelOwn)
{
    foreach (var modal in modals.Where(m => canManageLoans || m.Action == "Cancel"))
    {
    <div class="modal fade" id="@modal.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog"><div class="modal-content">
            <form method="post" action="/Loans/@h.Id/@modal.Action">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h5 class="modal-title">@modal.Title</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <p class="text-muted">@modal.Help</p>
                    <label class="form-label">Justificativa/devolutiva</label><textarea class="form-control" name="notes" rows="3" required></textarea>
                    <label class="form-label mt-2">Observação interna</label><textarea class="form-control" name="internalNotes" rows="2"></textarea>
                    <div class="form-check mt-2"><input class="form-check-input" type="checkbox" name="notifyRequester" value="true" id="notify_@modal.Id" checked /><label class="form-check-label" for="notify_@modal.Id">notificar solicitante</label></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-light border" data-bs-dismiss="modal">Fechar</button><button class="btn @modal.Button" type="submit">Confirmar</button></div>
            </form>
        </div></div>
    </div>
    }
}
