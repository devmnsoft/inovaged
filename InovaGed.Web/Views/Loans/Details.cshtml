@using InovaGed.Application.Ged.Loans
@model LoanDetailsVM

@{
    ViewData["Title"] = "Detalhes do Empréstimo";
    var h = Model.Header;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">@h.ProtocolNo</h2>
        <div class="text-muted">@h.RequesterName — <span class="badge bg-secondary">@h.Status</span></div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/Loans">Voltar</a>
    </div>
</div>

@if (TempData["Ok"] is not null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Err"] is not null)
{
    <div class="alert alert-danger">@TempData["Err"]</div>
}

<div class="card card-body mb-3">
    <div class="row g-2">
        <div class="col-md-3"><strong>Solicitado:</strong><div>@h.RequestedAt.ToString("dd/MM/yyyy HH:mm")</div></div>
        <div class="col-md-3"><strong>Vencimento:</strong><div>@(h.DueAt.ToString("dd/MM/yyyy") ?? "-")</div></div>
        <div class="col-md-2"><strong>Aprovado:</strong><div>@(h.ApprovedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div>
        <div class="col-md-2"><strong>Entregue:</strong><div>@(h.DeliveredAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div>
        <div class="col-md-2"><strong>Devolvido:</strong><div>@(h.ReturnedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div>
    </div>

    <hr />

    <div class="d-flex gap-2 flex-wrap">
        <form method="post" action="/Loans/@h.Id/Approve">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-primary" type="submit">Aprovar</button>
        </form>
        <form method="post" action="/Loans/@h.Id/Deliver">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-warning" type="submit">Entregar</button>
        </form>
        <form method="post" action="/Loans/@h.Id/Return">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-success" type="submit">Devolver</button>
        </form>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><strong>Itens</strong></div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead><tr><th>Documento</th><th>Tipo</th><th>Físico</th></tr></thead>
                    <tbody>
                        @foreach (var i in Model.Items)
                        {
                            <tr>
                                <td>@(i.DocumentTitle ?? i.DocumentId.ToString())</td>
                                <td>@(i.DocumentType ?? "-")</td>
                                <td>@(i.IsPhysical ? "Sim" : "Não")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><strong>Histórico</strong></div>
            <div class="list-group list-group-flush">
                @foreach (var ev in Model.History)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <strong>@ev.EventType</strong>
                            <span class="text-muted">@ev.EventTime.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="text-muted small">@ev.ByUserName</div>
                        @if (!string.IsNullOrWhiteSpace(ev.Notes))
                        {
                            <div>@ev.Notes</div>
                        }
                    </div>
                }
                @if (Model.History.Count == 0)
                {
                    <div class="list-group-item text-muted">Sem eventos.</div>
                }
            </div>
        </div>
    </div>
</div>