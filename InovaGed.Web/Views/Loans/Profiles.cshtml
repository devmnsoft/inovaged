@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Perfis de Aprovação de Empréstimos";
}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">Perfis de aprovação</h4>
  <a class="btn btn-sm btn-outline-secondary" href="/Loans">Voltar</a>
</div>
<div class="alert alert-info">Controle de perfis autorizados para aprovar solicitações de empréstimo.</div>
<div class="card">
<table class="table mb-0">
<thead><tr><th>Perfil</th><th>Role</th></tr></thead>
<tbody>
@foreach (var r in Model)
{
  <tr><td>@r.profile_name</td><td>@r.role_name</td></tr>
}
</tbody>
</table>
</div>
