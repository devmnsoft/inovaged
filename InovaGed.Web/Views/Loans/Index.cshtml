@using InovaGed.Application.Ged.Loans
@model IReadOnlyList<LoanRowDto>

@{
    ViewData["Title"] = "Empréstimos";
    ViewData["Subtitle"] = "Solicitação e controle de empréstimos (físico e digital)";
    var q = (string?)ViewBag.Q ?? "";
    var status = (string?)ViewBag.Status ?? "";
    var stats = ViewBag.Stats as LoanStatsDto;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-0">Empréstimos</h4>
        <div class="text-muted small">Até 200 registros</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-danger" href="/Loans/Overdue">
            <i class="bi bi-alarm me-1"></i>Vencidos
        </a>

        <!-- ✅ AGORA CLICA -->
        <a class="btn btn-sm btn-primary" href="/Loans/New">
            <i class="bi bi-plus-lg me-1"></i>Novo (PoC)
        </a>
    </div>
</div>

@if (stats != null)
{
    <div class="row g-2 mb-3">
        <div class="col-md-2"><div class="card card-body p-2"><div class="small text-muted">Total</div><div class="fw-bold fs-5">@stats.Total</div></div></div>
        <div class="col-md-2"><div class="card card-body p-2"><div class="small text-muted">Em aberto</div><div class="fw-bold fs-5">@stats.Open</div></div></div>
        <div class="col-md-2"><div class="card card-body p-2"><div class="small text-muted">Vencidos</div><div class="fw-bold fs-5 text-danger">@stats.Overdue</div></div></div>
        <div class="col-md-2"><div class="card card-body p-2"><div class="small text-muted">Solicitados</div><div class="fw-bold fs-5">@stats.Requested</div></div></div>
        <div class="col-md-2"><div class="card card-body p-2"><div class="small text-muted">Entregues</div><div class="fw-bold fs-5">@stats.Delivered</div></div></div>
        <div class="col-md-2"><div class="card card-body p-2"><div class="small text-muted">Devolvidos</div><div class="fw-bold fs-5">@stats.Returned</div></div></div>
    </div>
}

<form class="card mb-3" method="get" action="/Loans">
    <div class="card-body d-flex flex-wrap gap-2 align-items-end">
        <div>
            <label class="form-label small text-muted mb-1">Busca</label>
            <input class="form-control form-control-sm" name="q" value="@q" placeholder="Protocolo, solicitante, status..." />
        </div>

        <div>
            <label class="form-label small text-muted mb-1">Status</label>
            <select class="form-select form-select-sm" name="status">
                <option value="">(Todos)</option>
                <option value="REQUESTED" selected="@(status=="REQUESTED")">REQUESTED</option>
                <option value="APPROVED" selected="@(status=="APPROVED")">APPROVED</option>
                <option value="DELIVERED" selected="@(status=="DELIVERED")">DELIVERED</option>
                <option value="RETURNED" selected="@(status=="RETURNED")">RETURNED</option>
            </select>
        </div>

        <div class="ms-auto d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" type="submit">
                <i class="bi bi-search me-1"></i>Filtrar
            </button>
            <a class="btn btn-sm btn-light border" href="/Loans">
                Limpar
            </a>
        </div>
    </div>
</form>

<div class="card">
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Protocolo</th>
                    <th>Status</th>
                    <th>Solicitante</th>
                    <th>Solicitado</th>
                    <th>Vencimento</th>
                    <th class="text-center">Itens</th>
                    <th style="width:120px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr><td colspan="7" class="text-muted p-3">Nenhum registro.</td></tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.ProtocolNo</td>
                            <td><span class="badge bg-secondary">@r.Status</span></td>
                            <td>@r.RequesterName</td>
                            <td>@r.RequestedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@r.DueAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-center"><span class="badge bg-dark">@r.ItemsCount</span></td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="/Loans/@r.Id">
                                    <i class="bi bi-eye me-1"></i>Ver
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>