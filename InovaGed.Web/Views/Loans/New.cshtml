@using InovaGed.Application.Ged.Loans
@model LoanCreateVM

@{
    ViewData["Title"] = "Novo Empréstimo";
    ViewData["Subtitle"] = "Solicitação com documento GED ou referência manual";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-0">Novo Empréstimo</h4>
        <div class="text-muted small">Solicitação + itens + protocolo automático</div>
    </div>
    <a class="btn btn-sm btn-light border" href="/Loans"><i class="bi bi-arrow-left me-1"></i>Voltar</a>
</div>

@if (TempData["Err"] is not null)
{
    <div class="alert alert-danger">@TempData["Err"]</div>
}

<form method="post" class="card shadow-sm" onsubmit="return validateBeforeSubmit();">
    @Html.AntiForgeryToken()

    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Solicitante (nome)</label>
                <input class="form-control" name="RequesterName" value="@Model.RequesterName" placeholder="Nome do solicitante, equipe ou setor" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Vencimento</label>
                <input type="date" class="form-control" name="DueAt" value="@(Model.DueAt?.ToString("yyyy-MM-dd"))" />
                <div class="form-text">A devolução será cobrada automaticamente após o vencimento.</div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tipo de empréstimo</label>
                <select class="form-select" name="IsPhysical">
                    <option value="true" selected="@(Model.IsPhysical)">Físico (retirada)</option>
                    <option value="false" selected="@(!Model.IsPhysical)">Digital (visualização)</option>
                </select>
            </div>

            <div class="col-12">
                <h5 class="mb-2">Adicionar documentos ao pedido</h5>
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#gedTab" type="button">Buscar no GED</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#manualTab" type="button">Informar manualmente</button></li>
                </ul>
                <div class="tab-content border border-top-0 rounded-bottom p-3">
                    <div class="tab-pane fade show active" id="gedTab">
                        <p class="text-muted small mb-2">Use quando o documento já está digitalizado.</p>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input class="form-control" id="docSearch" placeholder="Buscar por título, prontuário, OCR, pasta ou arquivo" />
                            <button class="btn btn-outline-secondary" type="button" onclick="searchDocs()">Buscar</button>
                        </div>
                        <div id="docResultsWrap" class="mt-2 d-none">
                            <div class="card border">
                                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                    <strong class="small">Resultados</strong>
                                    <button type="button" class="btn btn-sm btn-light border" onclick="hideResults()">Fechar</button>
                                </div>
                                <div id="docResults" class="list-group list-group-flush"></div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="manualTab">
                        <p class="text-muted small mb-2">Use quando o documento ainda não está digitalizado ou será localizado fisicamente.</p>
                        <div class="row g-2">
                            <div class="col-md-3"><label class="form-label">Referência/código</label><input id="manualReference" class="form-control" placeholder="0105, caixa, guia..." /></div>
                            <div class="col-md-5"><label class="form-label">Descrição <span class="text-danger">*</span></label><input id="manualDescription" class="form-control" placeholder="Descreva o documento solicitado" /></div>
                            <div class="col-md-4"><label class="form-label">Tipo documental</label><input id="manualType" class="form-control" placeholder="Prontuário, exame, caixa..." /></div>
                            <div class="col-md-4"><label class="form-label">Paciente</label><input id="manualPatient" class="form-control" /></div>
                            <div class="col-md-3"><label class="form-label">Prontuário</label><input id="manualRecord" class="form-control" /></div>
                            <div class="col-md-2"><label class="form-label">Caixa</label><input id="manualBox" class="form-control" /></div>
                            <div class="col-md-3"><label class="form-label">Localização física</label><input id="manualLocation" class="form-control" /></div>
                            <div class="col-12"><label class="form-label">Observação</label><textarea id="manualNotes" class="form-control" rows="2"></textarea></div>
                            <div class="col-12"><button type="button" class="btn btn-outline-primary" onclick="addManualItem()"><i class="bi bi-plus-lg me-1"></i>Adicionar item manual</button></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div><div class="fw-semibold">Itens selecionados / solicitados</div><div class="text-muted small">A lista aceita documentos GED e referências manuais.</div></div>
                    <span id="selCount" class="badge text-bg-dark">0</span>
                </div>
                <div class="card mt-2"><div id="selectedDocs" class="list-group list-group-flush"><div id="emptySel" class="list-group-item text-muted">Nenhum item adicionado.</div></div></div>
                <div id="hidden"></div>
            </div>

            <div class="col-12">
                <label class="form-label">Observações gerais</label>
                <textarea class="form-control" name="Notes" rows="3" placeholder="Urgência, orientação para retirada, justificativa...">@Model.Notes</textarea>
            </div>
        </div>
    </div>

    <div class="card-footer bg-white d-flex gap-2">
        <button class="btn btn-primary" type="submit"><i class="bi bi-check-lg me-1"></i>Salvar e gerar protocolo</button>
        <a class="btn btn-outline-secondary" href="/Loans">Cancelar</a>
        <div class="ms-auto text-muted small d-none d-md-flex align-items-center"><i class="bi bi-info-circle me-1"></i>O protocolo pode nascer sem documento digitalizado.</div>
    </div>
</form>

@section Scripts {
<script>
    const selectedGed = new Map();
    const manualItems = [];

    function setCount() {
        const n = selectedGed.size + manualItems.length;
        document.getElementById('selCount').textContent = n.toString();
        document.getElementById('emptySel').classList.toggle('d-none', n > 0);
    }

    function renderSelected() {
        const list = document.getElementById('selectedDocs');
        const hidden = document.getElementById('hidden');
        list.querySelectorAll('.sel-row').forEach(x => x.remove());
        hidden.innerHTML = '';
        let docIdx = 0;
        selectedGed.forEach(v => {
            list.insertAdjacentHTML('beforeend', `<div class="list-group-item d-flex justify-content-between align-items-center sel-row"><div><span class="badge text-bg-primary me-1">GED</span><strong>${escapeHtml(v.code)}</strong><div class="text-muted small">${escapeHtml(v.title)}</div></div><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeDoc('${v.id}')"><i class="bi bi-x-lg"></i></button></div>`);
            hidden.insertAdjacentHTML('beforeend', `<input type="hidden" name="DocumentIds[${docIdx++}]" value="${escapeHtml(v.id)}" />`);
        });
        manualItems.forEach((v, idx) => {
            list.insertAdjacentHTML('beforeend', `<div class="list-group-item d-flex justify-content-between align-items-center sel-row"><div><span class="badge text-bg-warning text-dark me-1">Manual</span><strong>${escapeHtml(v.referenceCode || 'Sem referência')}</strong><div>${escapeHtml(v.description)}</div><div class="text-muted small">${escapeHtml([v.documentType, v.patientName, v.medicalRecordNumber, v.boxCode, v.physicalLocation].filter(Boolean).join(' • '))}</div></div><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeManual(${idx})"><i class="bi bi-x-lg"></i></button></div>`);
            Object.entries(v).forEach(([key, value]) => hidden.insertAdjacentHTML('beforeend', `<input type="hidden" name="ManualItems[${idx}].${pascal(key)}" value="${escapeHtml(value || '')}" />`));
        });
        setCount();
    }

    function addDoc(id, code, title) {
        if (!id || selectedGed.has(id)) return;
        selectedGed.set(id, { id, code: code || '(sem código)', title: title || '(sem título)' });
        renderSelected();
    }
    function removeDoc(id) { selectedGed.delete(id); renderSelected(); }
    function removeManual(idx) { manualItems.splice(idx, 1); renderSelected(); }
    function hideResults() { document.getElementById('docResultsWrap')?.classList.add('d-none'); }

    function addManualItem(seed) {
        const item = seed || {
            referenceCode: val('manualReference'), description: val('manualDescription'), documentType: val('manualType'),
            patientName: val('manualPatient'), medicalRecordNumber: val('manualRecord'), boxCode: val('manualBox'),
            physicalLocation: val('manualLocation'), notes: val('manualNotes')
        };
        if (!item.description && !item.referenceCode) { alert('Informe uma descrição ou referência para o item manual.'); return; }
        manualItems.push(item);
        ['manualReference','manualDescription','manualType','manualPatient','manualRecord','manualBox','manualLocation','manualNotes'].forEach(id => document.getElementById(id).value = '');
        renderSelected();
    }

    async function searchDocs() {
        const q = document.getElementById('docSearch').value.trim();
        if (!q) return;
        const wrap = document.getElementById('docResultsWrap');
        const box = document.getElementById('docResults');
        wrap.classList.remove('d-none');
        box.innerHTML = `<div class="list-group-item text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Buscando...</div>`;
        try {
            const response = await fetch('/Loans/DocSearch?q=' + encodeURIComponent(q), { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const payload = await response.json().catch(() => ({}));
            const items = Array.isArray(payload) ? payload : Array.isArray(payload.items) ? payload.items : Array.isArray(payload.data) ? payload.data : [];
            if (!response.ok || payload.success === false) { box.innerHTML = `<div class="list-group-item text-danger">${escapeHtml(payload.message || 'Não foi possível buscar documentos.')}</div>`; return; }
            if (items.length === 0) {
                box.innerHTML = `<div class="list-group-item text-muted">Nenhum documento digitalizado encontrado. Você pode informar o documento manualmente abaixo.<div class="mt-2"><button type="button" class="btn btn-sm btn-outline-primary" onclick="addManualItem({referenceCode:'${escapeJs(q)}',description:'Solicitação manual: ${escapeJs(q)}'})">Solicitar documento ${escapeHtml(q)} manualmente</button></div></div>`;
                return;
            }
            box.innerHTML = '';
            items.forEach(d => {
                const id = d.id || d.Id, code = d.code || d.Code || '', title = d.title || d.Title || '', status = d.status || d.Status || '';
                const disabled = selectedGed.has(id);
                box.insertAdjacentHTML('beforeend', `<button type="button" class="list-group-item list-group-item-action" ${disabled ? 'disabled' : ''} onclick="addDoc('${escapeHtml(id)}','${escapeJs(code)}','${escapeJs(title)}')"><div class="d-flex justify-content-between"><div><strong>${escapeHtml(code)}</strong><div class="text-muted small">${escapeHtml(title)}</div><div class="text-muted small">${escapeHtml(status)}</div></div><span class="badge text-bg-primary">${disabled ? 'Adicionado' : 'Adicionar'}</span></div></button>`);
            });
        } catch (e) { box.innerHTML = `<div class="list-group-item text-danger">Erro inesperado ao buscar documentos.</div>`; }
    }

    function validateBeforeSubmit() {
        if (selectedGed.size === 0 && manualItems.length === 0) { alert('Adicione pelo menos um documento do GED ou informe um documento manualmente para solicitar.'); return false; }
        renderSelected();
        return true;
    }
    function val(id) { return document.getElementById(id)?.value.trim() || ''; }
    function pascal(s) { return s.charAt(0).toUpperCase() + s.slice(1); }
    function escapeHtml(s) { return (s || '').toString().replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m])); }
    function escapeJs(s) { return (s || '').toString().replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\n/g, ' '); }
    document.addEventListener('DOMContentLoaded', () => { setCount(); document.getElementById('docSearch')?.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); searchDocs(); } }); });
</script>
}
