@using InovaGed.Web.Security
@model InovaGed.Application.Ocr.OcrDashboardVm
@{
    ViewData["Title"] = "Central de OCR";
    var filter = Model.Filter ?? new InovaGed.Application.Ocr.OcrDashboardFilter();
    var canManageAutoSchedule = AppMenuPolicy.IsFullAdmin(User);
    var canSeeTechnicalDiagnostics = AppMenuPolicy.IsFullAdmin(User);

    string FormatBytes(long? bytes)
    {
        if (!bytes.HasValue || bytes.Value <= 0) return "-";
        var units = new[] { "B", "KB", "MB", "GB" };
        var value = (double)bytes.Value;
        var unit = 0;
        while (value >= 1024 && unit < units.Length - 1) { value /= 1024; unit++; }
        return $"{value:N1} {units[unit]}";
    }
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Central de OCR</h1>
        <p class="text-muted mb-0">Acompanhe, execute e corrija o processamento OCR dos documentos do GED.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if (canManageAutoSchedule)
        {
            <button class="btn btn-primary js-ocr-post" data-url="/Ocr/AutoSchedule/RunNow" data-loading="Executando..." type="button"><i class="bi bi-play-fill me-1"></i>Executar OCR automático agora</button>
            <a class="btn btn-outline-primary" href="/Ocr/AutoSchedule"><i class="bi bi-calendar2-check me-1"></i>Configurar agendamento</a>
        }
        <a class="btn btn-outline-secondary" href="/Ocr/Queue"><i class="bi bi-list-task me-1"></i>Revalidar fila</a>
    </div>
</div>

<form id="ocrAntiForgery" class="d-none">@Html.AntiForgeryToken()</form>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["WarningMessage"] is string warningMessage)
{
    <div class="alert alert-warning">@warningMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.AutoScheduleWarning))
{
    <div class="alert alert-warning">@Model.AutoScheduleWarning</div>
}

<div id="ocrToast" class="toast align-items-center border-0 position-fixed top-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true" style="z-index:1080">
    <div class="d-flex">
        <div class="toast-body"></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?OnlyWithoutOcr=true"><div class="card h-100 border-secondary"><div class="card-body"><div class="text-muted small"><i class="bi bi-file-earmark-x me-1"></i>Sem OCR</div><div class="display-6 fw-semibold">@Model.WithoutOcrCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?Status=PENDING"><div class="card h-100 border-warning"><div class="card-body"><div class="text-muted small"><i class="bi bi-hourglass-split me-1"></i>Pendente</div><div class="display-6 fw-semibold">@Model.PendingCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?Status=PROCESSING"><div class="card h-100 border-info"><div class="card-body"><div class="text-muted small"><i class="bi bi-cpu me-1"></i>Em processamento</div><div class="display-6 fw-semibold">@Model.ProcessingCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?Status=COMPLETED"><div class="card h-100 border-success"><div class="card-body"><div class="text-muted small"><i class="bi bi-check2-circle me-1"></i>Concluído</div><div class="display-6 fw-semibold">@Model.CompletedCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?Status=COMPLETED_WITHOUT_TEXT"><div class="card h-100 border-warning"><div class="card-body"><div class="text-muted small"><i class="bi bi-file-earmark-minus me-1"></i>Concluído sem texto</div><div class="display-6 fw-semibold">@Model.CompletedWithoutTextCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?OnlyErrors=true"><div class="card h-100 border-danger"><div class="card-body"><div class="text-muted small"><i class="bi bi-exclamation-octagon me-1"></i>Com erro</div><div class="display-6 fw-semibold">@Model.ErrorCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><a class="text-decoration-none" href="/Ocr?OnlyPartial=true"><div class="card h-100 border-primary"><div class="card-body"><div class="text-muted small"><i class="bi bi-files me-1"></i>OCR parcial</div><div class="display-6 fw-semibold">@Model.PartialOcrCount</div></div></div></a></div>
    <div class="col-6 col-xl-3"><div class="card h-100 border-primary"><div class="card-body"><div class="text-muted small"><i class="bi bi-calendar2-check me-1"></i>Agendamento automático</div><div class="h5 mb-1">@(Model.AutoScheduleEnabled ? "Ativo" : "Inativo")</div><div class="small text-muted">@Model.AutoScheduleRunAt@if (Model.NextAutoRun.HasValue){<span> • Próx. @Model.NextAutoRun.Value.ToLocalTime().ToString("dd/MM HH:mm")</span>}@if (Model.LastAutoRun.HasValue){<span><br />Últ. @Model.LastAutoRun.Value.ToLocalTime().ToString("dd/MM HH:mm") • @Model.LastAutoRunEnqueuedCount enfileirados</span>}</div></div></div></div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold"><i class="bi bi-funnel me-1"></i>Filtros</div>
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2"><label class="form-label">Status OCR</label><select class="form-select" name="Status"><option value="">Todos</option>@foreach (var s in new[] { "NONE", "PENDING", "PROCESSING", "COMPLETED", "COMPLETED_WITHOUT_TEXT", "ERROR", "CANCELLED", "PARTIAL" }) { <option value="@s" selected="@(string.Equals(filter.Status, s, StringComparison.OrdinalIgnoreCase))">@s</option> }</select></div>
            <div class="col-md-2"><label class="form-label">Pasta</label><input class="form-control" name="Folder" value="@filter.Folder" placeholder="Nome da pasta" /></div>
            <div class="col-md-2"><label class="form-label">Tipo documental</label><input class="form-control" name="DocumentType" value="@filter.DocumentType" placeholder="Tipo" /></div>
            <div class="col-md-2"><label class="form-label">Período de upload inicial</label><input class="form-control" type="date" name="From" value="@(filter.From?.ToString("yyyy-MM-dd"))" /></div>
            <div class="col-md-2"><label class="form-label">Período de upload final</label><input class="form-control" type="date" name="To" value="@(filter.To?.ToString("yyyy-MM-dd"))" /></div>
            <div class="col-md-2"><label class="form-label">Texto/documento</label><input class="form-control" name="Search" value="@filter.Search" placeholder="Título ou arquivo" /></div>
            <div class="col-12 d-flex flex-wrap align-items-center gap-3">
                <label class="form-check"><input class="form-check-input" type="checkbox" name="OnlyPartial" value="true" checked="@filter.OnlyPartial" /> Apenas documentos parciais</label>
                <label class="form-check"><input class="form-check-input" type="checkbox" name="OnlyErrors" value="true" checked="@filter.OnlyErrors" /> Apenas erros</label>
                <label class="form-check"><input class="form-check-input" type="checkbox" name="OnlyWithoutOcr" value="true" checked="@filter.OnlyWithoutOcr" /> Apenas sem OCR</label>
                <button class="btn btn-primary ms-auto" type="submit"><i class="bi bi-search me-1"></i>Aplicar</button>
                <a class="btn btn-outline-secondary" href="/Ocr">Limpar filtros</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-table me-1"></i>Fila e documentos sem OCR</span>
        <span class="text-muted small">@Model.Items.Count item(ns) nesta página</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Documento</th>
                    <th>Arquivo</th>
                    <th>Pasta</th>
                    <th>Tipo</th>
                    <th>Status OCR</th>
                    <th>Partes</th>
                    <th>Última tentativa</th>
                    <th>Finalizado em</th>
                    <th>Erro</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="10" class="text-center text-muted py-5">Nenhum documento encontrado para os filtros selecionados.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var rowId = $"ocr-row-{item.VersionId}";
                    <tr id="@rowId">
                        <td><div class="fw-semibold">@item.DocumentTitle</div><div class="small text-muted">@item.DocumentId</div></td>
                        <td>@item.FileName<br /><span class="small text-muted">@FormatBytes(item.SizeBytes)</span></td>
                        <td>@(item.FolderName ?? "-")</td>
                        <td>@(item.DocumentType ?? "-")</td>
                        <td><span class="badge @item.OcrStatusCss js-status-badge">@item.OcrStatusText</span></td>
                        <td>@if (item.IsPartialDocument){<span class="badge bg-light text-dark border">Parte @(item.PartNumber?.ToString() ?? "-")/@(item.TotalParts?.ToString() ?? "-")</span><div class="small text-muted">@(item.PartialSummaryText ?? $"{item.PartsWithOcr ?? 0}/{item.TotalParts ?? 0} com OCR")</div>}else{<span>-</span>}</td>
                        <td>@(item.RequestedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>@(item.FinishedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>@if (item.HasOcrError){<button class="btn btn-link btn-sm p-0" type="button" data-bs-toggle="collapse" data-bs-target="#err-@item.VersionId">Ver erro</button>}else{<span>-</span>}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm flex-wrap">
                                <a class="btn btn-outline-secondary" href="@item.ActionUrl">Ver documento</a>
                                @if (item.VersionId.HasValue)
                                {
                                    <a class="btn btn-outline-info" href="/Ocr/Version/@item.VersionId/Text" target="_blank">Ver OCR</a>
                                    <button class="btn btn-outline-primary js-ocr-post" data-url="/Ocr/RunForVersion/@item.VersionId" data-row="#@rowId" data-loading="Enfileirando..." type="button">Executar OCR</button>
                                    @if (item.HasOcrError && !string.IsNullOrWhiteSpace(item.JobId))
                                    {
                                        <button class="btn btn-outline-warning js-ocr-post" data-url="/Ocr/Retry/@item.JobId" data-row="#@rowId" data-loading="Reprocessando..." type="button">Reprocessar</button>
                                    }
                                    <a class="btn btn-outline-success" href="/Ged/Download?id=@item.VersionId">Baixar</a>
                                }
                            </div>
                        </td>
                    </tr>
                    @if (item.HasOcrError)
                    {
                        var diagnosticMissingMessage = !item.HasTechnicalDiagnostics
                            ? "O OCR falhou e o banco ainda não possui os campos de diagnóstico técnico. Execute as migrations do OCR."
                            : null;
                        <tr class="collapse" id="err-@item.VersionId">
                            <td colspan="10">
                                <div class="alert alert-danger mb-0">
                                    <strong>Falha OCR:</strong> @(string.IsNullOrWhiteSpace(item.ErrorMessage) ? "Falha ao processar OCR." : item.ErrorMessage)
                                    @if (!string.IsNullOrWhiteSpace(diagnosticMissingMessage))
                                    {
                                        <div class="small mt-2">@diagnosticMissingMessage</div>
                                    }
                                    @if (canSeeTechnicalDiagnostics && item.HasTechnicalDiagnostics)
                                    {
                                        <button class="btn btn-sm btn-outline-dark mt-2" type="button" data-bs-toggle="collapse" data-bs-target="#diag-@item.VersionId">Ver diagnóstico técnico</button>
                                        <div class="collapse mt-2" id="diag-@item.VersionId">
                                            @if (!string.IsNullOrWhiteSpace(item.FailureCode))
                                            {
                                                <div><strong>Código:</strong> @item.FailureCode</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.ErrorDetailsJson))
                                            {
                                                <pre class="bg-light border rounded p-2 small mb-0">@item.ErrorDetailsJson</pre>
                                            }
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const token = document.querySelector('#ocrAntiForgery input[name="__RequestVerificationToken"]')?.value || '';
    const toastEl = document.getElementById('ocrToast');
    const showToast = (message, success) => {
        toastEl.classList.remove('text-bg-success', 'text-bg-danger');
        toastEl.classList.add(success ? 'text-bg-success' : 'text-bg-danger');
        toastEl.querySelector('.toast-body').textContent = message;
        bootstrap.Toast.getOrCreateInstance(toastEl).show();
    };

    document.querySelectorAll('.js-ocr-post').forEach(button => {
        button.addEventListener('click', async () => {
            const original = button.innerHTML;
            const loading = button.dataset.loading || 'Processando...';
            button.disabled = true;
            button.innerHTML = `<span class="spinner-border spinner-border-sm me-1"></span>${loading}`;
            try {
                const response = await fetch(button.dataset.url, {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': token },
                    credentials: 'same-origin'
                });
                const data = await response.json().catch(() => ({ success: response.ok, message: response.ok ? 'Operação concluída.' : 'Falha na operação.' }));
                showToast(data.message || (data.success ? 'Operação concluída.' : 'Falha na operação.'), data.success === true);
                if (data.success && button.dataset.row) {
                    const row = document.querySelector(button.dataset.row);
                    row?.querySelector('.js-status-badge')?.classList.remove('bg-secondary', 'bg-danger', 'bg-success', 'bg-info', 'text-dark');
                    const badge = row?.querySelector('.js-status-badge');
                    if (badge) { badge.className = 'badge bg-warning text-dark js-status-badge'; badge.textContent = 'Pendente'; }
                }
            } catch (error) {
                showToast('Não foi possível executar a ação OCR.', false);
            } finally {
                button.disabled = false;
                button.innerHTML = original;
            }
        });
    });
})();
</script>
}
