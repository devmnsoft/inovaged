@model InovaGed.Web.Models.Protocolo.ProtocoloUsuarioBuscaVM
@{ ViewData["Title"] = "Buscar Usuários"; }
<h4>Buscar Usuários</h4>
<form method="get" class="card border-0 shadow-sm mb-3"><div class="card-body row g-2"><div class="col-md-10"><input name="q" value="@Model.Q" class="form-control" placeholder="Nome ou e-mail" /></div><div class="col-md-2"><button class="btn btn-primary w-100">Buscar</button></div></div></form>
<div class="card border-0 shadow-sm"><table class="table mb-0"><thead><tr><th>Nome</th><th>E-mail</th><th>ID</th><th></th></tr></thead><tbody>
@foreach (var u in Model.Usuarios) { <tr><td>@u.Nome</td><td>@u.Email</td><td><code>@u.Id</code></td><td class="text-end"><a class="btn btn-sm btn-primary" href="/Protocolo/UsuariosSetorAvancado/Vincular?usuarioId=@u.Id&usuarioNome=@Uri.EscapeDataString(u.Nome)">Vincular</a></td></tr> }
@if (!Model.Usuarios.Any()) { <tr><td colspan="4" class="text-center text-muted py-4">Nenhum usuário encontrado.</td></tr> }
</tbody></table></div>
