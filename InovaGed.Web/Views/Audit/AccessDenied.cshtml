@using InovaGed.Application.Audit
@model AuditIndexVM

@{
    var s = Model.Search;
    ViewData["Title"] ??= "Falhas de Acesso";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="text-muted small">Total: <strong>@Model.Total</strong></div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Audit" asp-action="Index">
        Voltar ao Log Geral
    </a>
</div>

<form method="get" class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">De</label>
                <input class="form-control" type="date" name="From" value="@s.From?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Até</label>
                <input class="form-control" type="date" name="To" value="@s.To?.ToString("yyyy-MM-dd")" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Busca</label>
                <input class="form-control" name="Q" value="@s.Q" placeholder="Usuário, email, entidade, IP..." />
            </div>

            <input type="hidden" name="EventType" value="ACCESS_DENIED" />
            <input type="hidden" name="Action" value="ACCESS_DENIED" />
            <input type="hidden" name="Page" value="1" />

            <div class="col-12 d-flex gap-2 mt-2">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>
                <a class="btn btn-outline-secondary" asp-controller="Audit" asp-action="AccessDenied">Limpar</a>
            </div>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:170px;">Data/Hora</th>
                        <th style="width:160px;">Ação</th>
                        <th style="width:220px;">Usuário</th>
                        <th style="width:220px;">Entidade</th>
                        <th>Resumo</th>
                        <th style="width:140px;">IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows == null || Model.Rows.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">Sem registros de falha de acesso.</td></tr>
                    }
                    else
                    {
                        foreach (var r in Model.Rows)
                        {
                            <tr>
                                <td>@r.EventTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-semibold">@r.Action</td>
                                <td>
                                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(r.UserName) ? r.UserName : "—")</div>
                                    <div class="text-muted small">@r.UserEmail</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@r.EntityName</div>
                                    <div class="text-muted small">@r.EntityId</div>
                                </td>
                                <td class="text-truncate" style="max-width:520px;" title="@r.Summary">@r.Summary</td>
                                <td>@r.IpAddress</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>