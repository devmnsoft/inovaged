@model InovaGed.Application.DemoReadiness.DemoReadinessReportDto
@{
    ViewData["Title"] = "Central Executiva GED";
    var checks = Model?.Checks ?? new List<InovaGed.Application.DemoReadiness.DemoReadinessCheckDto>();
    var recommendations = Model?.Recommendations ?? new List<InovaGed.Application.DemoReadiness.DemoReadinessRecommendationDto>();
    var indicators = Model?.ExecutiveIndicators ?? new List<InovaGed.Application.DemoReadiness.ExecutiveValueIndicatorDto>();
    var maturity = Model?.DigitalMaturity ?? new List<InovaGed.Application.DemoReadiness.DigitalMaturityItemDto>();
    var modules = Model?.ModuleMap ?? new List<InovaGed.Application.DemoReadiness.DemoModuleStatusDto>();
    var scriptSteps = Model?.ScriptSteps ?? new List<InovaGed.Application.DemoReadiness.DemoScriptStepDto>();
}

<h1>Central Executiva GED</h1>
<p>Status geral: <strong>@(Model?.OverallStatus ?? "N/A")</strong> | Score: <strong>@(Model?.ReadinessScore ?? 0)%</strong></p>

<h2>Checks</h2>
<ul>
@foreach (var c in checks)
{
    <li><strong>@c.Title</strong> (@c.Status) - @c.Message</li>
}
</ul>

<h2>Recomendações</h2>
<ul>
@foreach (var r in recommendations)
{
    <li><strong>@r.Priority</strong> - @r.Title: @r.SuggestedAction</li>
}
</ul>

<h2>Indicadores Executivos</h2>
<ul>
@foreach (var i in indicators)
{
    <li><strong>@i.Title</strong>: @i.Value (@i.Subtitle)</li>
}
</ul>

<h2>Maturidade Digital</h2>
<ul>
@foreach (var m in maturity)
{
    <li>@m.Label - @m.Percentage% - @m.Recommendation</li>
}
</ul>

<h2>Mapa de Módulos</h2>
<ul>
@foreach (var m in modules)
{
    <li>@m.ModuleName - @m.Status - @m.Recommendation</li>
}
</ul>

<h2>Roteiro</h2>
<ol>
@foreach (var s in scriptSteps.OrderBy(x => x.Order))
{
    <li>@s.Title (@s.EstimatedMinutes min) - @s.SuggestedSpeech</li>
}
</ol>
