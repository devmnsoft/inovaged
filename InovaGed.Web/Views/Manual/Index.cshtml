@section Scripts {
    <script>
        (function () {
            const search = document.getElementById('manualSearch');
            const sections = document.querySelectorAll('.section-card');
            const nav = document.getElementById('manualNav');

            function norm(s) { return (s || '').toLowerCase().trim(); }

            function applyFilter(q) {
                q = norm(q);

                sections.forEach(sec => {
                    const tags = norm(sec.getAttribute('data-tags'));
                    const text = norm(sec.innerText);
                    const hit = !q || tags.includes(q) || text.includes(q);
                    sec.style.display = hit ? '' : 'none';
                });

                if (nav) {
                    nav.querySelectorAll('a.item').forEach(a => {
                        const href = a.getAttribute('href') || '';
                        const id = href.startsWith('#') ? href.substring(1) : '';
                        const target = id ? document.getElementById(id) : null;
                        const ok = !q || (target && target.style.display !== 'none');
                        a.style.opacity = ok ? '1' : '.35';
                    });
                }
            }

            if (search) search.addEventListener('input', () => applyFilter(search.value));

            // destaque de item ativo no menu (conforme scroll)
            const links = nav ? Array.from(nav.querySelectorAll('a.item')) : [];
            const obs = ('IntersectionObserver' in window) ? new IntersectionObserver((entries) => {
                entries.forEach(e => {
                    if (!e.isIntersecting) return;
                    const id = e.target.getAttribute('id');
                    links.forEach(l => {
                        const href = l.getAttribute('href') || '';
                        l.classList.toggle('active', href === '#' + id);
                    });
                });
            }, { rootMargin: '-20% 0px -70% 0px', threshold: 0.01 }) : null;

            if (obs) {
                // observa anchors internos (garante highlight mesmo sem pegar section-card)
                ['roteiro-demo','fluxo-geral','principal','usuarios','instrumentos','documentos','importexport','guarda','icp-assinatura','temporalidade','emprestimos','relatorios','auditoria','checklist']
                    .forEach(id => {
                        const el = document.getElementById(id);
                        if (el) obs.observe(el);
                    });
            }
        })();
    </script>
}