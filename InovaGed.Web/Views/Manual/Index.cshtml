                    <span class="arrow"><i class="bi bi-arrow-right"></i></span>
                    <span class="node"><i class="bi bi-send"></i>Encaminhamento</span>
                    <span class="arrow"><i class="bi bi-arrow-right"></i></span>
                    <span class="node"><i class="bi bi-clock-history"></i>Acompanhamento</span>
                </div>

                <div class="accordion" id="accProtocolo">
                    <div class="accordion-item">
                        <h3 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#prot1">
                                <i class="bi bi-plus-circle me-2"></i>Como registrar um novo protocolo
