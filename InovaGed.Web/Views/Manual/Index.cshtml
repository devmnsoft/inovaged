                    <span class="node"><i class="bi bi-upc-scan"></i>Digitalizar/OCR</span>
                    <span class="arrow"><i class="bi bi-arrow-right"></i></span>
                    <span class="node"><i class="bi bi-tags"></i>Classificar</span>
                    <span class="arrow"><i class="bi bi-arrow-right"></i></span>
                    <span class="node"><i class="bi bi-diagram-2"></i>Tramitar</span>
