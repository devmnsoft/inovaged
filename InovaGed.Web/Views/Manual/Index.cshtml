@using Microsoft.AspNetCore.Html
@using Microsoft.AspNetCore.Mvc.Rendering
@using Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_Layout";
    var today = DateTime.Now.ToString("dd/MM/yyyy");

    Func<string, string, string, string, object?, IHtmlContent> Btn = (text, icon, controller, action, route) =>
    {
        var url = Url.Action(action, controller, route) ?? "#";
        var a = new TagBuilder("a");
        a.Attributes["href"] = url;
        a.AddCssClass("btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-2 rounded-pill manual-action");
        a.Attributes["title"] = $"{controller}/{action}";
        a.InnerHtml.AppendHtml($"<i class=\"bi {icon}\"></i><span>{text}</span>");
        return a;
    };

    Func<string, string, string, IHtmlContent> LinkBtn = (text, icon, href) =>
    {
        var a = new TagBuilder("a");
        a.Attributes["href"] = href;
        a.AddCssClass("btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-2 rounded-pill manual-action");
        a.InnerHtml.AppendHtml($"<i class=\"bi {icon}\"></i><span>{text}</span>");
        return a;
    };

    ViewData["Title"] ??= "Manual Operacional — InovaGED";
    ViewData["Subtitle"] ??= "Guia interativo de uso do GED, Protocolo, OCR, Classificação, Assinatura, Guarda, Temporalidade e Auditoria";
}

@section Styles {
    <style>
        :root {
            --ig-primary: #2563eb;
            --ig-primary-soft: rgba(37, 99, 235, .10);
            --ig-success: #16a34a;
            --ig-success-soft: rgba(22, 163, 74, .10);
            --ig-warning-soft: rgba(245, 158, 11, .14);
            --ig-danger-soft: rgba(239, 68, 68, .10);
            --ig-ink: #111827;
            --ig-muted: #6b7280;
            --ig-border: rgba(17, 24, 39, .10);
            --ig-card: #ffffff;
            --ig-soft: #f8fafc;
        }

        .manual-wrap {
            max-width: 1320px;
            margin: 0 auto;
        }

        .manual-hero {
            border: 1px solid var(--ig-border);
            border-radius: 1.5rem;
            background: radial-gradient(circle at top left, rgba(37, 99, 235, .18), transparent 32%), radial-gradient(circle at bottom right, rgba(22, 163, 74, .14), transparent 30%), linear-gradient(180deg, #fff, #f8fafc);
            box-shadow: 0 18px 42px rgba(15, 23, 42, .06);
        }

        .manual-badge {
            border-radius: 999px;
            font-weight: 700;
            letter-spacing: .01em;
        }

        .manual-kpi {
            background: rgba(255,255,255,.86);
            border: 1px solid var(--ig-border);
            border-radius: 1.25rem;
            min-height: 100%;
        }

            .manual-kpi .iconbox,
            .section-icon {
                width: 44px;
                height: 44px;
                border-radius: 1rem;
                display: flex;
                align-items: center;
                justify-content: center;
                background: linear-gradient(135deg, rgba(37,99,235,.16), rgba(22,163,74,.12));
                border: 1px solid var(--ig-border);
                flex: 0 0 auto;
            }

        .manual-sidebar {
            position: sticky;
            top: 88px;
            border: 1px solid var(--ig-border);
            border-radius: 1.35rem;
            background: #fff;
            box-shadow: 0 10px 26px rgba(15, 23, 42, .05);
            padding: .85rem;
        }

        .manual-search {
            border-radius: 999px;
            padding-left: 2.35rem;
        }

        .manual-search-wrap {
            position: relative;
        }

            .manual-search-wrap i {
                position: absolute;
                left: .9rem;
                top: .72rem;
                color: var(--ig-muted);
            }

        .manual-nav a {
            text-decoration: none;
        }

        .manual-nav .nav-itemx {
            display: flex;
            align-items: center;
            gap: .65rem;
            color: var(--ig-ink);
            border: 1px solid transparent;
            padding: .62rem .72rem;
            border-radius: 1rem;
            font-weight: 600;
        }

            .manual-nav .nav-itemx:hover,
            .manual-nav .nav-itemx.active {
                background: var(--ig-primary-soft);
                border-color: rgba(37,99,235,.20);
            }

            .manual-nav .nav-itemx .num {
                width: 26px;
                height: 26px;
                border-radius: .75rem;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: #f3f4f6;
                color: #374151;
                font-size: .78rem;
                font-weight: 900;
            }

        .manual-section {
            border: 1px solid var(--ig-border);
            border-radius: 1.35rem;
            background: #fff;
            box-shadow: 0 10px 26px rgba(15, 23, 42, .045);
        }

        .anchor {
            scroll-margin-top: 92px;
        }

        .muted {
            color: var(--ig-muted);
        }

        .callout {
            border: 1px solid var(--ig-border);
            border-radius: 1.15rem;
            padding: 1rem;
            background: var(--ig-soft);
        }

            .callout.blue {
                background: var(--ig-primary-soft);
            }

            .callout.green {
                background: var(--ig-success-soft);
            }

            .callout.yellow {
                background: var(--ig-warning-soft);
            }

            .callout.red {
                background: var(--ig-danger-soft);
            }

        .stepper {
            display: grid;
            gap: .75rem;
        }

        .step {
            display: flex;
            gap: .85rem;
            align-items: flex-start;
            padding: .95rem;
            border-radius: 1.1rem;
            border: 1px solid var(--ig-border);
            background: rgba(248, 250, 252, .75);
        }

            .step .n {
                width: 34px;
                height: 34px;
                border-radius: .95rem;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #111827;
                color: #fff;
                font-weight: 900;
                flex: 0 0 auto;
            }

        .flow {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: .55rem;
            padding: .9rem;
            border: 1px dashed rgba(37,99,235,.32);
            border-radius: 1.25rem;
            background: rgba(37,99,235,.045);
        }

            .flow .node {
                padding: .55rem .72rem;
                border-radius: 1rem;
                border: 1px solid var(--ig-border);
                background: #fff;
                display: inline-flex;
                gap: .45rem;
                align-items: center;
                font-weight: 700;
            }

            .flow .arrow {
                color: var(--ig-muted);
            }

        .persona-card {
            border: 1px solid var(--ig-border);
            border-radius: 1.15rem;
            background: #fff;
            padding: 1rem;
            min-height: 100%;
        }

            .persona-card .avatar {
                width: 42px;
                height: 42px;
                border-radius: 1rem;
                display: flex;
                align-items: center;
                justify-content: center;
                background: #111827;
                color: #fff;
            }

        .manual-action {
            white-space: nowrap;
        }

        .quick-links {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
        }

        .task-table td,
        .task-table th {
            vertical-align: middle;
        }

        .check-item {
            border: 1px solid var(--ig-border);
            border-radius: 1rem;
            padding: .85rem;
            background: #fff;
            min-height: 100%;
        }

            .check-item .tag {
                font-size: .76rem;
                border-radius: 999px;
                padding: .18rem .5rem;
            }

        .kbdx {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            background: rgba(0,0,0,.06);
            border: 1px solid rgba(0,0,0,.12);
            border-bottom-width: 2px;
            padding: .12rem .35rem;
            border-radius: .45rem;
            font-size: .85rem;
        }

        .hidden-by-search {
            display: none !important;
        }

        @@media (max-width: 991px) {
            .manual-sidebar {
                position: static;
                top: auto;
            }
        }

        @@media print {
            .manual-sidebar, .manual-no-print, .btn, .accordion-button::after {
                display: none !important;
            }

            .manual-section {
                box-shadow: none;
                break-inside: avoid;
            }

            .accordion-collapse {
                display: block !important;
                height: auto !important;
                visibility: visible !important;
            }
        }
    </style>
}

<div id="topo" class="manual-wrap">

