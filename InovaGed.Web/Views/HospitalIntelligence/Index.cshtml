@model InovaGed.Application.HospitalIntelligence.HospitalIntelligenceDashboardDto
@{ ViewData["Title"] = "Inteligência Hospitalar"; }
<div class="d-flex justify-content-between align-items-center mb-3"><div><h2>Inteligência Hospitalar <span class="badge bg-dark">Somente ADMIN</span></h2><p class="text-muted">Indicadores estratégicos gerados a partir dos documentos digitalizados e OCR.</p></div><a class="btn btn-outline-primary" href="/HospitalIntelligence/ExportCsv">Exportar resumo CSV</a></div>
<div class="alert alert-warning">Indicadores gerados a partir de leitura documental/OCR, com finalidade administrativa, estatística e gerencial. Não substitui análise clínica.</div>
<div class="alert alert-info">Painel estatístico baseado em documentos. Verifique o documento original antes de qualquer decisão assistencial ou financeira.</div>
<div class="row g-3">@foreach(var c in Model.Cards){<div class="col-md-3"><div class="card border-@c.Color"><div class="card-body"><div class="small text-muted">@c.Title</div><div class="display-6">@c.Value</div></div></div></div>}</div>
<h4 class="mt-4">Top 10 termos clínicos</h4><table class="table table-sm"><thead><tr><th>Termo</th><th>Categoria</th><th>Contagem</th><th>Risco</th></tr></thead><tbody>@foreach(var t in Model.ClinicalTerms.Take(10)){<tr><td>@t.Term</td><td>@t.Category</td><td>@t.Count</td><td><span class="badge bg-secondary">@t.RiskLevel</span></td></tr>}</tbody></table>
<h4>Sinais Financeiros e Administrativos</h4><table class="table table-sm"><thead><tr><th>Indicador</th><th>Contagem</th><th>Descrição</th></tr></thead><tbody>@foreach(var t in Model.FinancialSignals.Take(10)){<tr><td>@t.Indicator</td><td>@t.Count</td><td>@t.Description</td></tr>}</tbody></table>
<h4>Gargalos Operacionais</h4><table class="table table-sm"><thead><tr><th>Indicador</th><th>Contagem</th><th>Recomendação</th></tr></thead><tbody>@foreach(var o in Model.OperationalSignals){<tr><td>@o.Indicator</td><td>@o.Count</td><td>@o.Recommendation</td></tr>}</tbody></table>
<h4>Alertas Executivos</h4><table class="table table-sm"><thead><tr><th>Título</th><th>Tipo</th><th>Risco</th></tr></thead><tbody>@foreach(var a in Model.Alerts.Take(10)){<tr><td>@a.Title</td><td>@a.AlertType</td><td>@a.RiskLevel</td></tr>}</tbody></table>
