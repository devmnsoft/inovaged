@model InovaGed.Application.SmartSearch.SmartSearchStatistics
@{
    ViewData["Title"] = "Estatísticas da Busca Inteligente";
}
<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3"><i class="bi bi-bar-chart text-primary"></i> Estatísticas da Busca Inteligente</h1>
        <a class="btn btn-outline-secondary" asp-controller="SmartSearch" asp-action="Index">Voltar à busca</a>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted">Buscas hoje</div><div class="display-6">@Model.SearchesToday</div></div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted">Buscas sem resultado</div><div class="display-6">@Model.SearchesWithoutResult</div></div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted">OCR disponível</div><div class="display-6">@Model.OcrAvailablePercent%</div></div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted">Tempo médio</div><div class="display-6">@Model.AverageDurationMs ms</div></div></div></div>
    </div>
    <div class="row g-3">
        <div class="col-lg-4"><partial name="_TopTable" model='@(Tuple.Create("Termos mais buscados", Model.TopTerms))' /></div>
        <div class="col-lg-4"><partial name="_TopTable" model='@(Tuple.Create("Tipos documentais", Model.TopDocumentTypes))' /></div>
        <div class="col-lg-4"><partial name="_TopTable" model='@(Tuple.Create("Documentos mais acessados", Model.MostAccessedDocuments))' /></div>
    </div>
</div>
