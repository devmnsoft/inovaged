@{
    ViewData["Title"] = "Busca Inteligente de Documentos";
}

<div class="container-fluid py-3 smart-search-page">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h3 mb-1"><i class="bi bi-stars text-primary"></i> Busca Inteligente de Documentos</h1>
            <p class="text-muted mb-0">Pesquise de forma natural em OCR, metadados, documentos, prontuários, exames, datas e contexto hospitalar.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="SmartSearch" asp-action="Statistics"><i class="bi bi-bar-chart"></i> Estatísticas</a>
    </div>

    <form id="smartSearchForm" class="card shadow-sm border-0 mb-3">
        @Html.AntiForgeryToken()
        <div class="card-body">
            <label for="Query" class="form-label fw-semibold">Descreva o que procura</label>
            <textarea id="Query" name="Query" class="form-control form-control-lg" rows="3" placeholder="Descreva o que procura. Ex: exame do João, 24 anos, doença renal, internado em 2022."></textarea>
            <div class="row g-2 mt-2 collapse" id="advancedFilters">
                <div class="col-md-3"><input class="form-control" name="DocumentType" placeholder="Tipo documental" /></div>
                <div class="col-md-3"><input class="form-control" name="From" type="date" /></div>
                <div class="col-md-3"><input class="form-control" name="To" type="date" /></div>
                <div class="col-md-3"><input class="form-control" name="PageSize" type="number" min="1" max="50" value="20" /></div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Buscar</button>
                <button type="button" class="btn btn-outline-secondary" id="clearSmartSearch"><i class="bi bi-x-circle"></i> Limpar</button>
                <button type="button" class="btn btn-outline-info" id="examplesSmartSearch"><i class="bi bi-lightbulb"></i> Exemplos</button>
                <button class="btn btn-outline-dark" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFilters"><i class="bi bi-sliders"></i> Busca avançada</button>
            </div>
            <div id="smartExamples" class="alert alert-light border mt-3 d-none">
                <button type="button" class="btn btn-sm btn-outline-primary me-1 mb-1 example-query">exame do João com doença renal em 2022</button>
                <button type="button" class="btn btn-sm btn-outline-primary me-1 mb-1 example-query">laudos de pacientes com suspeita de AVC em 2023</button>
                <button type="button" class="btn btn-sm btn-outline-primary me-1 mb-1 example-query">prontuários de pacientes entre 20 e 30 anos com diabetes</button>
                <button type="button" class="btn btn-sm btn-outline-primary me-1 mb-1 example-query">documentos da Maria que falam de câncer de mama e foram digitalizados no ano passado</button>
            </div>
        </div>
    </form>

    <div id="intentPanel" class="card border-primary-subtle mb-3 d-none">
        <div class="card-body">
            <div class="fw-semibold mb-2">Interpretação</div>
            <div id="intentChips" class="d-flex flex-wrap gap-2 mb-2"></div>
            <div id="intentExplanation" class="text-muted"></div>
        </div>
    </div>

    <div id="smartWarning" class="alert alert-warning d-none"></div>
    <div id="smartLoading" class="alert alert-info d-none"><span class="spinner-border spinner-border-sm"></span> Buscando documentos...</div>
    <div id="smartResults" class="vstack gap-3"></div>
</div>

<div class="modal fade" id="askDocumentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Conversar com este documento</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <form id="askDocumentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DocumentId" id="askDocumentId" />
                    <label class="form-label">Pergunta</label>
                    <input class="form-control" name="Question" id="askQuestion" placeholder="O que este laudo fala sobre doença renal?" />
                    <button class="btn btn-primary mt-2" type="submit">Perguntar</button>
                </form>
                <div id="askAnswer" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const form = document.getElementById('smartSearchForm');
  const results = document.getElementById('smartResults');
  const loading = document.getElementById('smartLoading');
  const warning = document.getElementById('smartWarning');
  const intentPanel = document.getElementById('intentPanel');
  const chips = document.getElementById('intentChips');
  const explanation = document.getElementById('intentExplanation');
  const token = () => document.querySelector('input[name="__RequestVerificationToken"]').value;
  const html = (s) => (s || '').toString().replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));

  document.getElementById('clearSmartSearch').addEventListener('click', () => { form.reset(); results.innerHTML=''; intentPanel.classList.add('d-none'); warning.classList.add('d-none'); });
  document.getElementById('examplesSmartSearch').addEventListener('click', () => document.getElementById('smartExamples').classList.toggle('d-none'));
  document.querySelectorAll('.example-query').forEach(b => b.addEventListener('click', () => { document.getElementById('Query').value = b.textContent; form.requestSubmit(); }));

  form.addEventListener('submit', async e => {
    e.preventDefault();
    results.innerHTML = '';
    warning.classList.add('d-none');
    loading.classList.remove('d-none');
    const body = new FormData(form);
    try {
      const res = await fetch('@Url.Action("Search", "SmartSearch")', { method: 'POST', body, headers: { 'RequestVerificationToken': token() }});
      const json = await res.json();
      if (!json.success) throw new Error(json.message || 'Falha na busca.');
      render(json.result);
    } catch (err) {
      results.innerHTML = `<div class="alert alert-danger">${html(err.message)}</div>`;
    } finally { loading.classList.add('d-none'); }
  });

  function addChip(label, value) { if (value !== null && value !== undefined && value !== '' && !(Array.isArray(value) && value.length === 0)) chips.insertAdjacentHTML('beforeend', `<span class="badge rounded-pill text-bg-primary">${label}: ${html(Array.isArray(value) ? value.join(', ') : value)}</span>`); }
  function render(result) {
    const intent = result.intent || {};
    chips.innerHTML = '';
    addChip('Nome', intent.patientName || intent.personName);
    addChip('Idade', intent.age || (intent.ageFrom ? `${intent.ageFrom}-${intent.ageTo}` : ''));
    addChip('Ano', intent.year);
    addChip('Termos', intent.clinicalTerms);
    addChip('Tipo', intent.documentType);
    addChip('Exame', intent.examType);
    explanation.textContent = intent.explanation || '';
    intentPanel.classList.remove('d-none');
    if (result.warning) { warning.textContent = result.warning; warning.classList.remove('d-none'); }
    if (!result.items || result.items.length === 0) { results.innerHTML = '<div class="alert alert-secondary"><strong>Não encontrei resultados na busca inteligente.</strong><div class="mt-1">Deseja tentar busca ampla no GED?</div><div class="mt-3 d-flex flex-wrap gap-2"><a class="btn btn-sm btn-outline-primary" href="/Ged?scope=all&q=' + encodeURIComponent(form.querySelector('[name=Query]')?.value || '') + '">Buscar em todo o GED</a><a class="btn btn-sm btn-outline-secondary" href="/Ged?fileName=' + encodeURIComponent(form.querySelector('[name=Query]')?.value || '') + '">Buscar por nome de arquivo</a><button type="button" class="btn btn-sm btn-outline-warning" onclick="fetch(\'/SmartSearch/ReindexMissing\',{method:\'POST\'}).then(()=>alert(\'Reindexação solicitada.\'))">Reindexar busca</button><a class="btn btn-sm btn-outline-info" href="/SmartSearch/Diagnostics">Diagnóstico</a></div></div>'; return; }
    results.innerHTML = `<div class="text-muted">${result.total} resultado(s) em ${result.durationMs} ms.</div>` + result.items.map(item => `
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex justify-content-between gap-3">
            <div><h2 class="h5 mb-1">${html(item.title)}</h2><div class="text-muted small">${html(item.fileName)} ${item.folderName ? ' • ' + html(item.folderName) : ''}</div></div>
            <span class="badge text-bg-success align-self-start">Score ${html(item.score)}</span>
          </div>
          <div class="my-2">${item.ocrSnippet ? `<mark>${html(item.ocrSnippet)}</mark>` : '<span class="text-muted">Sem trecho OCR disponível no resultado.</span>'}</div>
          <div class="mb-2"><button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#why-${item.documentId}">Por que apareceu?</button></div>
          <div id="why-${item.documentId}" class="collapse"><ul class="small">${(item.reasons || []).map(r => `<li><strong>${html(r.reason)}</strong>: ${html(r.evidence)} (+${r.weight})</li>`).join('')}</ul></div>
          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm btn-primary" href="/Ged/Details/${item.documentId}"><i class="bi bi-eye"></i> Ver documento</a>
            <a class="btn btn-sm btn-outline-primary" href="/Ged/Details/${item.documentId}#ocr"><i class="bi bi-body-text"></i> Ver OCR</a>
            <button class="btn btn-sm btn-outline-success ask-doc" data-id="${item.documentId}"><i class="bi bi-chat-dots"></i> Conversar com este documento</button>
            <a class="btn btn-sm btn-outline-dark" href="/ProtocolRequests/New?documentId=${item.documentId}&source=SMART_SEARCH">Criar protocolo</a>
            <a class="btn btn-sm btn-outline-dark" href="/Loans/New?documentId=${item.documentId}&source=SMART_SEARCH">Solicitar empréstimo</a>
          </div>
        </div>
      </div>`).join('');
    document.querySelectorAll('.ask-doc').forEach(b => b.addEventListener('click', () => { document.getElementById('askDocumentId').value = b.dataset.id; document.getElementById('askAnswer').innerHTML = ''; bootstrap.Modal.getOrCreateInstance(document.getElementById('askDocumentModal')).show(); }));
  }

  document.getElementById('askDocumentForm').addEventListener('submit', async e => {
    e.preventDefault();
    const body = new FormData(e.target);
    const answerBox = document.getElementById('askAnswer');
    answerBox.innerHTML = '<div class="text-muted">Consultando OCR...</div>';
    const res = await fetch('@Url.Action("AskDocument", "SmartSearch")', { method: 'POST', body, headers: { 'RequestVerificationToken': token() }});
    const json = await res.json();
    const a = json.answer || {};
    answerBox.innerHTML = `<div class="alert ${a.foundInDocument ? 'alert-success' : 'alert-warning'}">${html(a.answer)}<br><small>${html(a.safetyNotice)}</small></div><ul>${(a.evidenceSnippets || []).map(s => `<li>${html(s)}</li>`).join('')}</ul>`;
  });
})();
</script>
}
