@model IReadOnlyList<InovaGed.Application.Retention.RetentionQueueRow>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] ??= "Central Operacional de Temporalidade";

    string? status = ViewBag.Status as string;
    DateTimeOffset? dueUntil = ViewBag.DueUntil as DateTimeOffset?;
    string? q = ViewBag.Q as string;

    status = (status ?? "").Trim().ToUpperInvariant();

    string StatusBadge(string s)
    {
        s = (s ?? "").Trim().ToUpperInvariant();
        return s switch
        {
            "OVERDUE" => "text-bg-danger",
            "DUE_SOON" => "text-bg-warning",
            "SEM_CLASSIFICACAO" => "text-bg-secondary",
            _ => "text-bg-success"
        };
    }

    string StatusLabel(string s)
    {
        s = (s ?? "").Trim().ToUpperInvariant();
        return s switch
        {
            "OVERDUE" => "Vencido",
            "DUE_SOON" => "A vencer",
            "SEM_CLASSIFICACAO" => "Sem classificação",
            _ => "OK"
        };
    }

    string DestBadge(string? dest)
    {
        dest = (dest ?? "").Trim().ToUpperInvariant();
        return dest switch
        {
            "ELIMINAR" => "text-bg-danger",
            "TRANSFERIR" => "text-bg-primary",
            "RECOLHER" => "text-bg-dark",
            "REAVALIAR" => "text-bg-warning",
            _ => "text-bg-secondary"
        };
    }

    string DestLabel(string? dest)
    {
        dest = (dest ?? "").Trim().ToUpperInvariant();
        return dest switch
        {
            "ELIMINAR" => "Eliminar",
            "TRANSFERIR" => "Transferir",
            "RECOLHER" => "Recolher",
            "REAVALIAR" => "Reavaliar",
            "" => "—",
            _ => dest
        };
    }
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h2 class="mb-1">
            <i class="bi bi-list-check me-2"></i>@ViewData["Title"]
        </h2>
        <div class="text-muted">
            Filtros + seleção + exportação CSV (PoC).
        </div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/Temporalidade">
            <i class="bi bi-hourglass-split me-1"></i> Ir para Central (Buckets)
        </a>

        <button type="button" class="btn btn-success" onclick="exportCsv()">
            <i class="bi bi-download me-1"></i> Exportar CSV (selecionados)
        </button>
    </div>
</div>

@if (TempData["Error"] is string e)
{
    <div class="alert alert-danger">@e</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-header">
        <form method="get" asp-controller="Retention" asp-action="Queue" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="">(Todos)</option>
                    <option value="OVERDUE" selected="@(status=="OVERDUE")">OVERDUE (Vencido)</option>
                    <option value="DUE_SOON" selected="@(status=="DUE_SOON")">DUE_SOON (A vencer)</option>
                    <option value="OK" selected="@(status=="OK")">OK</option>
                    <option value="SEM_CLASSIFICACAO" selected="@(status=="SEM_CLASSIFICACAO")">SEM_CLASSIFICACAO</option>
                </select>
            </div>

            <div class="col-12 col-md-3">
                <label class="form-label">Vence até</label>
                <input class="form-control" type="datetime-local" name="dueUntil"
                       value="@(dueUntil.HasValue ? dueUntil.Value.ToLocalTime().ToString("yyyy-MM-ddTHH:mm") : "")" />
                <div class="form-text">Filtra DueAt &lt;= esta data.</div>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Busca</label>
                <input class="form-control" type="text" name="q" value="@(q ?? "")"
                       placeholder="Código / Título / Classe..." />
            </div>

            <div class="col-12 col-md-2 d-grid">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-search me-1"></i> Filtrar
                </button>
            </div>
        </form>
    </div>

    <div class="card-body py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="d-flex align-items-center gap-2">
            <span class="badge text-bg-primary">@(Model?.Count ?? 0)</span>
            <span class="text-muted">itens</span>
            <span id="selCount" class="badge text-bg-secondary d-none">0 selecionados</span>
        </div>

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll(true)">
                <i class="bi bi-check2-square me-1"></i> Marcar todos
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleAll(false)">
                <i class="bi bi-square me-1"></i> Desmarcar
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:40px"></th>
                    <th>Documento</th>
                    <th>Classe</th>
                    <th>Vencimento</th>
                    <th>Status</th>
                    <th>Destino sugerido</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-muted py-4">
                            Nenhum item encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var i in Model)
                    {
                        <tr>
                            <td>
                                <input class="form-check-input js-item"
                                       type="checkbox"
                                       value="@i.DocumentId"
                                       onchange="refreshSelCount()" />
                            </td>

                            <td>
                                <div class="fw-semibold">@i.Code</div>
                                <div class="text-muted small text-truncate" style="max-width:520px">@i.Title</div>
                            </td>

                            <td>
                                <div class="fw-semibold">@i.ClassificationCode</div>
                                @if (!string.IsNullOrWhiteSpace(i.ClassificationName))
                                {
                                    <div class="text-muted small">@i.ClassificationName</div>
                                }
                            </td>

                            <td>@(i.DueAt?.ToString("dd/MM/yyyy") ?? "—")</td>

                            <td>
                                <span class="badge @StatusBadge(i.Status)">@StatusLabel(i.Status)</span>
                                @if (i.DaysToDue.HasValue)
                                {
                                    <span class="text-muted small ms-2">(@i.DaysToDue dias)</span>
                                }
                            </td>

                            <td>
                                <span class="badge @DestBadge(i.SuggestedDestination)">
                                    @DestLabel(i.SuggestedDestination)
                                </span>
                            </td>

                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" href="/Ged/Details?id=@i.DocumentId" title="Abrir documento">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleAll(mark) {
        document.querySelectorAll('.js-item').forEach(cb => cb.checked = mark);
        refreshSelCount();
    }

    function refreshSelCount() {
        const total = Array.from(document.querySelectorAll('.js-item')).filter(x => x.checked).length;
        const el = document.getElementById('selCount');
        if (!el) return;
        el.textContent = total + ' selecionados';
        el.classList.toggle('d-none', total <= 0);
    }

    function selectedIds() {
        return Array.from(document.querySelectorAll('.js-item'))
            .filter(x => x.checked)
            .map(x => x.value);
    }

    async function exportCsv() {
        const ids = selectedIds();
        if (ids.length === 0) {
            alert('Selecione ao menos 1 documento.');
            return;
        }

        try {
            const res = await fetch('/Retention/ExportCsv', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ documentIds: ids })
            });

            if (!res.ok) {
                let msg = 'Falha ao exportar CSV.';
                try {
                    const j = await res.json();
                    if (j && j.error) msg = j.error;
                } catch { }
                alert(msg);
                return;
            }

            // baixa arquivo retornado
            const blob = await res.blob();
            const url = window.URL.createObjectURL(blob);

            const a = document.createElement('a');
            a.href = url;

            // tenta extrair nome do header
            const cd = res.headers.get('content-disposition');
            let fileName = 'temporalidade.csv';
            if (cd && cd.includes('filename=')) {
                fileName = cd.split('filename=')[1].replaceAll('"', '').trim();
            }
            a.download = fileName;

            document.body.appendChild(a);
            a.click();
            a.remove();

            window.URL.revokeObjectURL(url);
        } catch (e) {
            alert('Erro inesperado ao exportar. Ver console/logs.');
            console.error(e);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', refreshSelCount);
    } else {
        refreshSelCount();
    }
</script>