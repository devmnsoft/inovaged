@model InovaGed.Web.Controllers.InstrumentosArquivisticosController.VersionDetailsVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] ??= $"Versão #{Model.Header.VersionNo}";
}

<h2 class="mb-1"><i class="bi bi-file-earmark-ruled me-2"></i>@ViewData["Title"]</h2>
<div class="text-muted mb-3">@Model.Header.Title</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div><b>Publicado em:</b> @Model.Header.PublishedAt.ToString("dd/MM/yyyy HH:mm")</div>
        @if (!string.IsNullOrWhiteSpace(Model.Header.Notes))
        {
            <div class="mt-2"><b>Notas:</b> @Model.Header.Notes</div>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nome</th>
                    <th>Destino</th>
                    <th>Sigilo</th>
                    <th>Assinatura ICP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@i.Code</td>
                        <td>@i.Name</td>
                        <td>@i.FinalDestination</td>
                        <td>@(i.IsConfidential ? "Sim" : "Não")</td>
                        <td>@(i.RequiresDigitalSignature ? "Sim" : "Não")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>