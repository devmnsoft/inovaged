@model InovaGed.Web.Controllers.InstrumentosArquivisticosController.MoveCodeVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] ??= "Movimentar Código (PCD/TTD)";
}

<h2 class="mb-2"><i class="bi bi-arrow-left-right me-2"></i>@ViewData["Title"]</h2>
<div class="text-muted mb-3">Move uma classe e atualiza automaticamente os códigos dos descendentes (tudo acompanha) + histórico.</div>

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<form asp-action="MoveCode" method="post" class="card shadow-sm">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div class="row g-3">
            <div class="col-lg-6">
                <label class="form-label">Classe a movimentar</label>
                <select class="form-select" asp-for="ClassificationId">
                    <option value="">-- selecione --</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id">@c.Code - @c.Name</option>
                    }
                </select>
            </div>

            <div class="col-lg-6">
                <label class="form-label">Novo “Pai” (opcional)</label>
                <select class="form-select" asp-for="NewParentId">
                    <option value="">(Sem pai / raiz)</option>
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Id">@c.Code - @c.Name</option>
                    }
                </select>
                <div class="form-text">Se escolher um pai, o código deve ser coerente com a hierarquia (ex.: 02.01.03).</div>
            </div>

            <div class="col-lg-4">
                <label class="form-label">Novo código</label>
                <input class="form-control" asp-for="NewCode" placeholder="Ex.: 02.01.03" />
            </div>

            <div class="col-lg-8">
                <label class="form-label">Motivo (vai para histórico)</label>
                <input class="form-control" asp-for="Reason" placeholder="Ex.: Reclassificação conforme atualização do PCD" />
            </div>
        </div>
    </div>

    <div class="card-footer d-flex gap-2">
        <button class="btn btn-primary" type="submit">
            <i class="bi bi-check2-circle me-1"></i> Confirmar movimentação
        </button>

        <a class="btn btn-outline-secondary" asp-action="MoveCode">
            <i class="bi bi-arrow-counterclockwise me-1"></i> Limpar
        </a>
    </div>
</form>