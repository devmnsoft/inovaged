@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Etiquetas de Caixa";
    ViewData["Subtitle"] = "Impressão, conferência e rastreabilidade das etiquetas de caixas físicas.";

    var rows = (Model ?? Enumerable.Empty<dynamic>()).ToList();
    var total = rows.Count;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <div class="text-uppercase text-muted small fw-semibold">Guarda Física</div>
        <h3 class="mb-1">Etiquetas de Caixa</h3>
        <div class="text-muted">Imprima etiquetas com rastreabilidade. Cada impressão deve ser registrada no histórico.</div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Labels" asp-action="History">
            <i class="bi bi-clock-history me-1"></i>Histórico
        </a>
        <a class="btn btn-outline-secondary" asp-controller="Physical" asp-action="Boxes">
            <i class="bi bi-archive me-1"></i>Caixas
        </a>
    </div>
</div>

<div class="alert alert-info d-flex align-items-start gap-2">
    <i class="bi bi-info-circle-fill fs-5"></i>
    <div>
        Clique em <strong>Imprimir</strong> para abrir a etiqueta em uma nova aba. A emissão deve ficar registrada para auditoria e conferência futura.
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <strong>Caixas disponíveis para etiqueta</strong>
        <span class="badge text-bg-primary rounded-pill">@total caixa(s)</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Caixa</th>
                    <th>Localização</th>
                    <th>Notas</th>
                    <th>Cadastro</th>
                    <th class="text-end" style="width:360px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (total == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-qr-code display-5 text-muted d-block mb-2"></i>
                            <div class="fw-semibold">Nenhuma caixa encontrada</div>
                            <div class="text-muted small">Cadastre uma caixa antes de imprimir etiquetas.</div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var b in rows)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">Caixa #@b.box_no</div>
                                <code>@b.label_code</code>
                            </td>
                            <td>
                                @if (b.location_code == null && b.building == null && b.room == null)
                                {
                                    <span class="badge text-bg-warning">Sem localização</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-geo-alt-fill text-success me-1"></i>@b.location_code @b.building @b.room</span>
                                }
                            </td>
                            <td class="text-muted">@(b.notes ?? "Sem observações")</td>
                            <td class="small text-muted">@b.reg_date</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 flex-wrap justify-content-end">
                                    <a class="btn btn-sm btn-primary"
                                       asp-controller="Labels" asp-action="BoxLabel"
                                       asp-route-boxId="@b.id" target="_blank">
                                        <i class="bi bi-printer"></i> Imprimir
                                    </a>
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-controller="Physical" asp-action="BoxContents"
                                       asp-route-boxId="@b.id">
                                        Conteúdo
                                    </a>
                                    <a class="btn btn-sm btn-outline-info"
                                       asp-controller="Physical" asp-action="BoxHistory"
                                       asp-route-boxId="@b.id">
                                        Histórico
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
