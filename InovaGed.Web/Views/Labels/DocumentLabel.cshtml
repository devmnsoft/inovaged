@model dynamic
@{
    Layout = null;
    var docId = (Guid)Model.id;
    var url = $"{Context.Request.Scheme}://{Context.Request.Host}/Ged/Index";
}

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Etiqueta Documento</title>
    <style>
        body { font-family: Arial; margin: 18px; }
        .card { border:1px solid #000; padding:16px; width:520px; }
        .big { font-size:22px; font-weight:bold; }
        .small { font-size:12px; }
        .mono { font-family: Consolas, monospace; }
    </style>
</head>
<body>
<div class="card">
    <div class="big">DOC: @Model.code</div>
    <div><strong>Título:</strong> @Model.title</div>
    <div><strong>Status:</strong> @Model.status</div>
    <hr/>
    <div class="small">Sistema: <span class="mono">@url</span></div>
    <div class="small">Código (texto): <span class="mono">DOC-@Model.code</span></div>
</div>

<script>window.print();</script>
</body>
</html>