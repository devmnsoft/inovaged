@model dynamic
@{
    Layout = null;
    var boxId = (Guid)Model.id;
    var url = $"{Context.Request.Scheme}://{Context.Request.Host}/Physical/BoxContents?boxId={boxId}";
}

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Etiqueta Caixa</title>
    <style>
        body {
            font-family: Arial;
            margin: 18px;
        }

        .card {
            border: 1px solid #000;
            padding: 16px;
            width: 520px;
        }

        .big {
            font-size: 28px;
            font-weight: bold;
        }

        .small {
            font-size: 12px;
        }

        .mono {
            font-family: Consolas, monospace;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="big">CAIXA: @Model.box_no</div>
        <div><strong>Label:</strong> <span class="mono">@Model.label_code</span></div>
        <div><strong>Notas:</strong> @Model.notes</div>
        <hr />
        <div class="small">Link: <span class="mono">@url</span></div>
        <div class="small">Código (texto): <span class="mono">BOX-@Model.label_code</span></div>
    </div>

    <script>window.print();</script>
</body>
</html>