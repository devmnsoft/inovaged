@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Histórico de Impressão de Etiquetas";
    ViewData["Subtitle"] = "Auditoria de etiquetas impressas para caixas e documentos.";
    var q = (ViewBag.Q as string) ?? "";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="mb-0">@ViewData["Title"]</h4>
        <div class="text-muted small">@ViewData["Subtitle"]</div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Labels" asp-action="Boxes">
            Etiquetas de Caixas
        </a>

        <a class="btn btn-outline-secondary btn-sm" asp-controller="Labels" asp-action="Documents">
            Etiquetas de Documentos
        </a>
    </div>
</div>

<form method="get" class="card mb-3">
    <div class="card-body d-flex flex-wrap gap-2">
        <div class="flex-grow-1">
            <input name="q"
                   value="@q"
                   class="form-control"
                   placeholder="Buscar por usuário, caixa, documento ou tipo..." />
        </div>

        <button class="btn btn-primary" type="submit">
            <i class="bi bi-search me-1"></i>Pesquisar
        </button>

        <a class="btn btn-outline-secondary" asp-action="History">Limpar</a>
    </div>
</form>

<div class="card">
    <div class="card-header">
        <strong>Impressões registradas</strong>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Data/Hora</th>
                    <th>Tipo</th>
                    <th>Referência</th>
                    <th>Usuário</th>
                    <th>IP</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in Model ?? Enumerable.Empty<dynamic>())
                {
                    var type = Convert.ToString(r.label_type);

                    var reference = type == "BOX"
                    ? $"Caixa #{r.box_no} — {r.label_code}"
                    : $"{r.document_code} — {r.document_title}";

                    <tr>
                        <td class="text-nowrap">
                            @Convert.ToDateTime(r.printed_at).ToString("dd/MM/yyyy HH:mm")
                        </td>

                        <td>
                            <span class="badge @(type == "BOX" ? "text-bg-primary" : "text-bg-success")">
                                @(type == "BOX" ? "Caixa" : "Documento")
                            </span>
                        </td>

                        <td>@reference</td>

                        <td>@(r.printed_by_name ?? "—")</td>

                        <td class="text-muted small">
                            @(r.ip_address ?? "—")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>