@model InovaGed.Application.SystemHealth.SchemaHealthReportDto
@{
    ViewData["Title"] = "Diagnóstico do banco";
    var script = "database/apply_all_required_migrations.sql";
    var correctionSql = "psql \"$CONNECTION_STRING\" -v ON_ERROR_STOP=1 -f database/apply_all_required_migrations.sql";
    var ok = Model.IsHealthy;
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1">Diagnóstico de schema do banco</h1>
            <p class="text-muted mb-0">Validação preventiva para GED, OCR, uploads, logs e versionamento documental.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText('@script')">Copiar script recomendado</button>
            <button type="button" class="btn btn-primary" onclick="navigator.clipboard.writeText('@correctionSql')">Copiar SQL de correção</button>
            <a class="btn btn-outline-primary" href="/SystemHealth/Schema/Report">Baixar relatório</a>
        </div>
    </div>

    <div class="alert @(ok ? "alert-success" : "alert-danger")">
        <strong>Status geral:</strong> @(ok ? "Schema compatível" : "Schema desatualizado/incompatível")
        <span class="ms-3"><strong>Script:</strong> <code>@script</code></span>
    </div>

    @if (Model.MissingTables.Count > 0)
    {
        <section class="card mb-3 border-danger">
            <div class="card-header bg-danger text-white">Tabelas ausentes</div>
            <ul class="list-group list-group-flush">
                @foreach (var table in Model.MissingTables)
                {
                    <li class="list-group-item"><code>@table</code></li>
                }
            </ul>
        </section>
    }

    @if (Model.MissingColumns.Count > 0)
    {
        <section class="card mb-3 border-warning">
            <div class="card-header bg-warning">Colunas ausentes</div>
            <ul class="list-group list-group-flush">
                @foreach (var column in Model.MissingColumns)
                {
                    <li class="list-group-item"><code>@column</code></li>
                }
            </ul>
        </section>
    }

    <section class="card mb-3">
        <div class="card-header">Checks</div>
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Área</th>
                        <th>Tipo</th>
                        <th>Severidade</th>
                        <th>Objeto</th>
                        <th>Mensagem</th>
                        <th>Correção sugerida</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var check in Model.Checks.OrderBy(c => c.Success).ThenBy(c => c.Severity == "Crítico" ? 0 : c.Severity == "Recomendado" ? 1 : 2).ThenBy(c => c.Area).ThenBy(c => c.ObjectName))
                    {
                        <tr>
                            <td>@(check.Success ? "✅ OK" : "❌ Falha")</td>
                            <td>@check.Area</td>
                            <td>@check.CheckType</td>
                            <td><span class="badge @(check.Severity == "Crítico" ? "bg-danger" : check.Severity == "Recomendado" ? "bg-warning text-dark" : "bg-secondary")">@check.Severity</span></td>
                            <td><code>@check.ObjectName</code></td>
                            <td>@check.Message</td>
                            <td>@check.FixSuggestion</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="card">
        <div class="card-header">Recomendações</div>
        <ul class="list-group list-group-flush">
            @foreach (var recommendation in Model.Recommendations)
            {
                <li class="list-group-item">@recommendation</li>
            }
        </ul>
    </section>
</div>
