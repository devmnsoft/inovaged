@model InovaGed.Application.SystemHealth.HomologationReportDto
@{
    Layout = null;
    var okChecks = Model.Checks.Where(c => c.Status == "OK").ToList();
    var critical = Model.Checks.Where(c => c.Status == "Failed" && c.Severity == "Critical").ToList();
    var warnings = Model.Checks.Where(c => c.Status == "Warning" || (c.Status == "Failed" && c.Severity != "Critical")).ToList();
}
<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Relatório de Homologação do InovaGED</title>
    <style>
        body {
            font-family: Arial,Helvetica,sans-serif;
            margin: 32px;
            color: #1f2937
        }

        h1 {
            margin-bottom: 4px
        }

        .muted {
            color: #6b7280
        }

        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 12px
        }

        .ok {
            background: #dcfce7;
            color: #166534
        }

        .warn {
            background: #fef3c7;
            color: #92400e
        }

        .fail {
            background: #fee2e2;
            color: #991b1b
        }

        .manual {
            background: #dbeafe;
            color: #1e40af
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 16px 0
        }

        th, td {
            border: 1px solid #d1d5db;
            padding: 8px;
            vertical-align: top
        }

        th {
            background: #f3f4f6;
            text-align: left
        }

        .section {
            page-break-inside: avoid;
            margin-top: 28px
        }

        .summary {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px;
            margin: 20px 0
        }

        .card {
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 12px
        }

        .big {
            font-size: 28px;
            font-weight: bold
        }
        media

        print {
            a

        {
            color: #111;
            text-decoration: none
        }

        .no-print {
            display: none
        }

        }
    </style>
</head>
<body>
    <div class="no-print" style="text-align:right"><button onclick="window.print()">Imprimir / salvar PDF</button></div>
    <h1>Relatório de Homologação do InovaGED</h1>
    <div class="muted">Gerado em @Model.GeneratedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") por @Model.GeneratedBy</div>
    <div class="muted">Ambiente: @Model.Environment • Versão/build: @Model.Version</div>

    <div class="summary">
        <div class="card"><div class="muted">Resultado final</div><div class="big">@Model.OverallStatus</div></div>
        <div class="card"><div class="muted">Checks OK</div><div class="big">@Model.PassedChecks</div></div>
        <div class="card"><div class="muted">Pendências críticas</div><div class="big">@Model.CriticalIssues</div></div>
        <div class="card"><div class="muted">Warnings</div><div class="big">@Model.WarningIssues</div></div>
    </div>

    <div class="section">
        <h2>Status geral</h2>
        <p>@(Model.CriticalIssues > 0 ? "Não pronto: existem pendências críticas bloqueantes." : Model.WarningIssues > 0 ? "Pronto com ressalvas: não há pendências críticas, mas há recomendações/avisos." : "Pronto para apresentação: checks automáticos sem pendências críticas ou avisos.")</p>
    </div>

    <div class="section">
        <h2>Pendências críticas</h2>
        @if (!critical.Any())
        {
            <p class="muted">Nenhuma pendência crítica.</p>
        }
        else
        {
            <table>
                <thead><tr><th>Área</th><th>Check</th><th>Evidência</th><th>Ação recomendada</th><th>Link</th></tr></thead>
                <tbody>
                    @foreach (var item in critical)
                    {
                        <tr><td>@item.Area</td><td>@item.Name</td><td>@item.Evidence</td><td>@item.RecommendedAction</td><td>@item.Link</td></tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <h2>Warnings e recomendações</h2>
        @if (!warnings.Any())
        {
            <p class="muted">Nenhum warning.</p>
        }
        else
        {
            <table>
                <thead><tr><th>Área</th><th>Check</th><th>Evidência</th><th>Recomendação</th><th>Link</th></tr></thead>
                <tbody>
                    @foreach (var item in warnings)
                    {
                        <tr><td>@item.Area</td><td>@item.Name</td><td>@item.Evidence</td><td>@item.RecommendedAction</td><td>@item.Link</td></tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="section">
        <h2>Checks OK</h2>
        <table>
            <thead><tr><th>Área</th><th>Check</th><th>Evidência</th><th>Link</th></tr></thead>
            <tbody>
                @foreach (var item in okChecks)
                {
                    <tr><td>@item.Area</td><td>@item.Name</td><td>@item.Evidence</td><td>@item.Link</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Todas as evidências</h2>
        <table>
            <thead><tr><th>Área</th><th>Nome</th><th>Status</th><th>Severidade</th><th>Evidência</th><th>Ação</th><th>Link</th></tr></thead>
            <tbody>
                @foreach (var item in Model.Checks)
                {
                    var css = item.Status == "OK" ? "ok" : item.Status == "Warning" ? "warn" : item.Status == "Failed" ? "fail" : "manual";
                    <tr><td>@item.Area</td><td>@item.Name</td><td><span class="badge @css">@item.Status</span></td><td>@item.Severity</td><td>@item.Evidence</td><td>@item.RecommendedAction</td><td>@item.Link</td></tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>
