@model InovaGed.Application.Ocr.OcrEnvironmentReport
@{
    ViewData["Title"] = "Diagnóstico do Ambiente OCR";
}
<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1">Diagnóstico do Ambiente OCR</h1>
            <div class="text-muted">Gerado em @Model.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</div>
        </div>
        <a class="btn btn-outline-secondary" href="/SystemHealth/OcrEnvironment">Revalidar</a>
    </div>

    <div class="alert @(Model.IsValid ? "alert-success" : "alert-danger")">
        <strong>@(Model.IsValid ? "Ambiente OCR válido" : "Ambiente OCR inválido")</strong><br />
        Usuário do processo: <code>@Model.ProcessUser</code> — WindowsIdentity: <code>@Model.WindowsIdentity</code><br />
        Storage: <code>@Model.StoragePath</code>
    </div>

    @if (Model.Warnings.Any())
    {
        <div class="alert alert-warning">
            <ul class="mb-0">
            @foreach (var warning in Model.Warnings) { <li>@warning</li> }
            </ul>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead class="table-light"><tr><th>Item</th><th>Caminho configurado</th><th>Existe</th><th>Permissão</th><th>Versão</th><th>Comando de teste</th><th>Resultado</th><th>Erro</th></tr></thead>
            <tbody>
            @foreach (var c in Model.Checks)
            {
                <tr class="@(c.Exists && c.PermissionOk ? "" : "table-danger")">
                    <td>@c.Name</td>
                    <td><code>@c.ConfiguredPath</code></td>
                    <td>@(c.Exists ? "OK" : "Falha")</td>
                    <td>@(c.PermissionOk ? "OK" : "Falha")</td>
                    <td><code>@c.Version</code></td>
                    <td><code>@c.TestCommand</code></td>
                    <td>
                        @if (c.CommandResult is not null)
                        {
                            <div>ExitCode: @c.CommandResult.ExitCode — @c.CommandResult.ElapsedMs ms — Timeout: @c.CommandResult.TimedOut</div>
                            <details><summary>stdout/stderr</summary><pre class="small">@c.CommandResult.StdOut
@c.CommandResult.StdErr</pre></details>
                        }
                    </td>
                    <td>@c.ErrorMessage</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
