@using Microsoft.AspNetCore.Mvc.TagHelpers
@using System.Security.Claims
@using InovaGed.Web.Security
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    string? subtitle = ViewData["Subtitle"] as string;

    string UserInitials()
    {
        var name = User?.Identity?.Name;

        if (string.IsNullOrWhiteSpace(name))
            return "IG";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .ToArray();

        if (parts.Length == 0)
            return "IG";

        var chars = parts.Select(p => char.ToUpperInvariant(p[0])).ToArray();

        return new string(chars);
    }

    var userName = User?.Identity?.Name ?? "Usuário";

    bool CanDocumentos() =>
        AppMenuPolicy.CanCreateHospitalDocuments(User);

    var roles = User?.FindAll(ClaimTypes.Role).Select(x => x.Value).ToArray() ?? Array.Empty<string>();
    var primaryRole = roles.FirstOrDefault(r => string.Equals(r, AppRoles.Admin, StringComparison.OrdinalIgnoreCase))
        ?? roles.FirstOrDefault(r => string.Equals(r, AppRoles.Administrador, StringComparison.OrdinalIgnoreCase))
        ?? roles.FirstOrDefault(r => string.Equals(r, AppRoles.AdministradorOphir, StringComparison.OrdinalIgnoreCase))
        ?? roles.FirstOrDefault(r => string.Equals(r, AppRoles.ArquivistaOphir, StringComparison.OrdinalIgnoreCase))
        ?? roles.FirstOrDefault(r => string.Equals(r, AppRoles.Hospital, StringComparison.OrdinalIgnoreCase))
        ?? roles.FirstOrDefault()
        ?? "SEM PERFIL";
    var primaryRoleLabel = primaryRole.ToUpperInvariant() switch
    {
        AppRoles.Admin => "Administrador do Sistema",
        AppRoles.Administrador => "Administrador do Sistema",
        AppRoles.AdministradorOphir => "Administrador Ophir",
        AppRoles.ArquivistaOphir => "Arquivista Ophir",
        AppRoles.Hospital => "Usuário Hospitalar",
        _ => "Perfil operacional"
    };
    var sector = User?.FindFirst("sector")?.Value ?? User?.FindFirst("setor")?.Value ?? User?.FindFirst("lotacao")?.Value ?? User?.FindFirst("sector_name")?.Value;
    var showSectorWarning = (string.Equals(primaryRole, AppRoles.AdministradorOphir, StringComparison.OrdinalIgnoreCase)
        || string.Equals(primaryRole, AppRoles.ArquivistaOphir, StringComparison.OrdinalIgnoreCase))
        && string.IsNullOrWhiteSpace(sector);
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - InovaGED</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inovaged.css" asp-append-version="true" />

    <style>
        .topbar-user-avatar {
            width: 28px;
            height: 28px;
            border-radius: .85rem;
            background: linear-gradient(135deg,#2563eb,#22c55e);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: .85rem;
        }

        .sidebar-brand .logo {
            width: 40px;
            height: 40px;
            border-radius: 1rem;
            background: linear-gradient(135deg,#2563eb,#22c55e);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 900;
        }

        .dropdown-menu .dropdown-item i {
            width: 18px;
        }

        .sidebar-menu a.active {
            font-weight: 700;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="@(isAuthenticated ? "layout-app" : "layout-auth")">

    @if (isAuthenticated)
    {
        <div class="wrapper app-shell">

            <!-- SIDEBAR DESKTOP -->
            <aside class="sidebar app-sidebar d-none d-lg-flex" aria-label="Menu lateral">
                <div class="sidebar-brand">
                    <span class="logo">IG</span>

                    <div class="sidebar-brand-title">
                        <span class="name">InovaGED</span>
                        <span class="subtitle">Gestão Eletrônica de Documentos</span>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <partial name="_SidebarMenu" />
                </nav>

                <div class="sidebar-footer">
                    <div>© @DateTime.Now.Year InovaGED</div>
                </div>
            </aside>

            <!-- SIDEBAR MOBILE -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="ocSidebar" aria-labelledby="ocSidebarLabel">
                <div class="offcanvas-header border-bottom">
                    <div class="d-flex align-items-center gap-2">
                        <span class="logo"
                              style="width:32px;height:32px;border-radius:.9rem;background:linear-gradient(135deg,#2563eb,#22c55e);display:inline-flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.95rem;">
                            IG
                        </span>

                        <div>
                            <div id="ocSidebarLabel" class="fw-semibold">InovaGED</div>
                            <div class="text-muted small">Gestão Eletrônica de Documentos</div>
                        </div>
                    </div>

                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
                </div>

                <div class="offcanvas-body p-2">
                    <nav class="sidebar-menu" style="padding:.25rem;">
                        <partial name="_SidebarMenu" />
                    </nav>
                </div>
            </div>

            <!-- CONTEÚDO PRINCIPAL -->
            <div class="main app-main">
                <header class="topbar app-topbar">
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary d-inline-flex d-lg-none"
                                type="button"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#ocSidebar"
                                aria-controls="ocSidebar"
                                title="Menu">
                            <i class="bi bi-list"></i>
                        </button>

                        <div class="topbar-left">
                            <div class="page-title">@ViewData["Title"]</div>

                            @if (!string.IsNullOrWhiteSpace(subtitle))
                            {
                                <div class="page-subtitle">@subtitle</div>
                            }
                        </div>
                    </div>

                    <div class="topbar-actions">
                        @if (AppMenuPolicy.IsFullAdmin(User))
                        {
                            <a class="btn btn-sm btn-primary d-none d-sm-inline-flex"
                               asp-controller="Ged"
                               asp-action="Create">
                                <i class="bi bi-file-earmark-plus me-1"></i>
                                Novo Documento
                            </a>
                        }

                        <div class="dropdown">
                            <button class="btn btn-sm btn-light border d-inline-flex align-items-center gap-2"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                <span class="topbar-user-avatar">@UserInitials()</span>
                                <span class="d-none d-md-inline text-start lh-sm">
                                    <span class="d-block">@userName</span>
                                    <span class="d-block small text-muted">Perfil: @primaryRole</span>
                                </span>
                                <i class="bi bi-chevron-down small"></i>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li class="px-3 py-2">
                                    <div class="small text-muted">Logado como</div>
                                    <div class="fw-semibold">@userName</div>
                                    <div class="small text-muted mt-1">@primaryRoleLabel</div>
                                    <div class="small">Perfil: <span class="fw-semibold">@primaryRole</span></div>
                                    @if (!string.IsNullOrWhiteSpace(sector))
                                    {
                                        <div class="small">Setor: <span class="fw-semibold">@sector</span></div>
                                    }
                                    else if (showSectorWarning)
                                    {
                                        <div class="small text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Setor não configurado</div>
                                    }
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>
                                            Sair
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>

                <main class="content app-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="container py-4">
            @RenderBody()
        </main>
    }

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)


    <div id="appToastContainer"
         class="toast-container position-fixed top-0 end-0 p-3"
         style="z-index: 2000;">
    </div>

    <div class="modal fade" id="appConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="appConfirmTitle">Confirmar ação</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    <p id="appConfirmMessage" class="mb-0">Deseja continuar?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" id="appConfirmCancel" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" id="appConfirmOk" class="btn btn-primary">Confirmar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            async function loadClassificationBadge() {
                try {
                    const res = await fetch('/ClassificationDashboard/Count', {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!res.ok)
                        return;

                    const data = await res.json();
                    const total = (data && typeof data.total === 'number') ? data.total : 0;

                    document.querySelectorAll('.js-cls-badge').forEach(function (el) {
                        el.textContent = total;
                        el.classList.toggle('d-none', total <= 0);
                    });
                } catch {
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadClassificationBadge);
            } else {
                loadClassificationBadge();
            }
        })();
    </script>

</body>
</html>