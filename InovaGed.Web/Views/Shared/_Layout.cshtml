@using Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;

    var ctrl = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    var act = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();

    string? subtitle = ViewData["Subtitle"] as string;

    string Active(string controller, params string[] actions)
    {
        var c = controller.ToLowerInvariant();
        if (ctrl != c) return "";
        if (actions == null || actions.Length == 0) return "active";
        return actions.Any(a => string.Equals(act, a.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    }

    string ActiveAny(params string[] controllers)
        => controllers.Any(c => string.Equals(ctrl, c.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) ? "active" : "";

    string UserInitials()
    {
        var name = User?.Identity?.Name;
        if (string.IsNullOrWhiteSpace(name)) return "IG";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToArray();
        if (parts.Length == 0) return "IG";
        var chars = parts.Select(p => char.ToUpperInvariant(p[0])).ToArray();
        return new string(chars);
    }

    var userName = User?.Identity?.Name ?? "Usuário";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InovaGED</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/inovaged.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body class="@(isAuthenticated ? "layout-app" : "layout-auth")">

    @if (isAuthenticated)
    {
        <div class="wrapper">

            <!-- ===== SIDEBAR (DESKTOP) ===== -->
            <aside class="sidebar d-none d-lg-flex" aria-label="Menu lateral">
                <div class="sidebar-brand">
                    <span class="logo">IG</span>
                    <div class="sidebar-brand-title">
                        <span class="name">InovaGED</span>
                        <span class="subtitle">Gestão Eletrônica de Documentos</span>
                    </div>
                </div>

                <nav class="sidebar-menu">
                    <div class="sidebar-section-title">Principal</div>
                    <a asp-controller="Home" asp-action="Index" class="@Active("Home","Index")">
                        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                    </a>

                    <div class="sidebar-section-title">GED</div>
                    <a asp-controller="Ged" asp-action="Index" class="@ActiveAny("Ged")">
                        <i class="bi bi-folder2-open"></i><span>Explorer</span>
                    </a>
                    <a asp-controller="Ged" asp-action="Folders" class="@Active("Ged","Folders")">
                        <i class="bi bi-folder"></i><span>Pastas / Dossiês</span>
                    </a>

                    <div class="sidebar-section-title">Governança</div>
                    <a asp-controller="Classification" asp-action="Index" class="@ActiveAny("Classification")">
                        <i class="bi bi-diagram-3"></i><span>Classificação</span>
                    </a>

                    <!-- Dashboard de Classificação + badge -->
                    <a asp-controller="ClassificationDashboard" asp-action="Index" class="@ActiveAny("ClassificationDashboard")">
                        <i class="bi bi-inboxes"></i>
                        <span class="d-flex align-items-center gap-2">
                            Pendências
                            <span id="clsBadge" class="badge text-bg-danger d-none">0</span>
                        </span>
                    </a>

                    <a asp-controller="Workflow" asp-action="Index" class="@ActiveAny("Workflow")">
                        <i class="bi bi-shuffle"></i><span>Workflows</span>
                    </a>

                    <div class="sidebar-section-title">Conta</div>
                    <a asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i><span>Sair</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div>© @DateTime.Now.Year InovaGED</div>
                    <div class="text-muted">ASP.NET Core + PostgreSQL</div>
                </div>
            </aside>

            <!-- ===== OFFCANVAS (MOBILE/TABLET) ===== -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="ocSidebar" aria-labelledby="ocSidebarLabel">
                <div class="offcanvas-header border-bottom">
                    <div class="d-flex align-items-center gap-2">
                        <span class="logo" style="width:32px;height:32px;border-radius:.9rem;background:linear-gradient(135deg,#2563eb,#22c55e);display:inline-flex;align-items:center;justify-content:center;font-weight:700;color:#fff;font-size:.95rem;">IG</span>
                        <div>
                            <div id="ocSidebarLabel" class="fw-semibold">InovaGED</div>
                            <div class="text-muted small">Gestão Eletrônica de Documentos</div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
                </div>

                <div class="offcanvas-body p-2">
                    <nav class="sidebar-menu" style="padding: .25rem;">
                        <div class="sidebar-section-title">Principal</div>
                        <a asp-controller="Home" asp-action="Index" class="@Active("Home","Index")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                        </a>

                        <div class="sidebar-section-title">GED</div>
                        <a asp-controller="Ged" asp-action="Index" class="@ActiveAny("Ged")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-folder2-open"></i><span>Explorer</span>
                        </a>
                        <a asp-controller="Ged" asp-action="Folders" class="@Active("Ged","Folders")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-folder"></i><span>Pastas / Dossiês</span>
                        </a>

                        <div class="sidebar-section-title">Governança</div>
                        <a asp-controller="Classification" asp-action="Index" class="@ActiveAny("Classification")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-diagram-3"></i><span>Classificação</span>
                        </a>
                        <a asp-controller="ClassificationDashboard" asp-action="Index" class="@ActiveAny("ClassificationDashboard")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-inboxes"></i>
                            <span class="d-flex align-items-center gap-2">
                                Pendências
                                <span id="clsBadgeMobile" class="badge text-bg-danger d-none">0</span>
                            </span>
                        </a>

                        <a asp-controller="Workflow" asp-action="Index" class="@ActiveAny("Workflow")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-shuffle"></i><span>Workflows</span>
                        </a>

                        <div class="sidebar-section-title">Conta</div>
                        <a asp-controller="Account" asp-action="Logout" data-bs-dismiss="offcanvas">
                            <i class="bi bi-box-arrow-right"></i><span>Sair</span>
                        </a>
                    </nav>
                </div>
            </div>

            <!-- ===== MAIN ===== -->
            <div class="main">

                <header class="topbar">
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary d-inline-flex d-lg-none"
                                type="button"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#ocSidebar"
                                aria-controls="ocSidebar"
                                title="Menu">
                            <i class="bi bi-list"></i>
                        </button>

                        <div class="topbar-left">
                            <div class="page-title">@ViewData["Title"]</div>
                            @if (!string.IsNullOrWhiteSpace(subtitle))
                            {
                                <div class="page-subtitle">@subtitle</div>
                            }
                        </div>
                    </div>

                    <div class="topbar-actions">
                        <a class="btn btn-sm btn-primary d-none d-sm-inline-flex"
                           asp-controller="Ged" asp-action="Create">
                            <i class="bi bi-file-earmark-plus me-1"></i> Novo
                        </a>

                        <div class="dropdown">
                            <button class="btn btn-sm btn-light border d-inline-flex align-items-center gap-2"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="topbar-user-avatar">@UserInitials()</span>
                                <span class="d-none d-md-inline">@userName</span>
                                <i class="bi bi-chevron-down small"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sair
                                    </a>
                                </li>
                            </ul>
                        </div>

                    </div>
                </header>

                <main class="content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="container py-4">
            @RenderBody()
        </main>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <script>
        // Badge de pendências (desktop + mobile)
        (function () {
            async function loadBadge() {
                try {
                    const res = await fetch('/ClassificationDashboard/Count', { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
                    if (!res.ok) return;
                    const data = await res.json();
                    const total = (data && typeof data.total === 'number') ? data.total : 0;

                    const el = document.getElementById('clsBadge');
                    const elm = document.getElementById('clsBadgeMobile');

                    if (el) {
                        el.textContent = total;
                        el.classList.toggle('d-none', total <= 0);
                    }
                    if (elm) {
                        elm.textContent = total;
                        elm.classList.toggle('d-none', total <= 0);
                    }
                } catch { /* silencia */ }
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadBadge);
            } else {
                loadBadge();
            }
        })();
    </script>

</body>
</html>
