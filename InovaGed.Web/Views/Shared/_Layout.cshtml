@using Dapper
@using Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using InovaGed.Application.Common.Database
@inject IDbConnectionFactory DbFactory

@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;

    var ctrl = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    var act = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();

    string? subtitle = ViewData["Subtitle"] as string;

    string Active(string controller, params string[] actions)
    {
        var c = controller.ToLowerInvariant();
        if (ctrl != c) return "";
        if (actions == null || actions.Length == 0) return "active";
        return actions.Any(a => string.Equals(act, a.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) ? "active" : "";
    }

    string ActiveAny(params string[] controllers)
        => controllers.Any(c => string.Equals(ctrl, c.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) ? "active" : "";

    string ActivePath(string startsWith)
    {
        var path = Context.Request.Path.Value?.ToLowerInvariant() ?? "";
        var sw = (startsWith ?? "").ToLowerInvariant();
        return path.StartsWith(sw) ? "active" : "";
    }

    string UserInitials()
    {
        var name = User?.Identity?.Name;
        if (string.IsNullOrWhiteSpace(name)) return "IG";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToArray();
        if (parts.Length == 0) return "IG";
        var chars = parts.Select(p => char.ToUpperInvariant(p[0])).ToArray();
        return new string(chars);
    }

    var userName = User?.Identity?.Name ?? "Usuário";

    int pacsBadge = 0;
    int dispElimBadge = 0;
    int dispTransBadge = 0;
    int dispReviewBadge = 0;

    try
    {
        using var conn = await DbFactory.OpenAsync(Context.RequestAborted);

        pacsBadge = await conn.ExecuteScalarAsync<int>(
            "select count(*) from pacs.ocr_job where status='PENDING'");

        dispElimBadge = await conn.ExecuteScalarAsync<int>(
            "select count(*) from ged.document where disposition_status='ELIMINATION_READY'");

        dispTransBadge = await conn.ExecuteScalarAsync<int>(
            "select count(*) from ged.document where disposition_status='TRANSFER_READY'");

        dispReviewBadge = await conn.ExecuteScalarAsync<int>(
            "select count(*) from ged.document where disposition_status='REVIEW_REQUIRED'");
    }
    catch
    {
        pacsBadge = 0;
        dispElimBadge = dispTransBadge = dispReviewBadge = 0;
    }

    int dispTotalBadge = dispElimBadge + dispTransBadge + dispReviewBadge;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InovaGED</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/inovaged.css" asp-append-version="true" />

    <style>
        .topbar-user-avatar {
            width: 28px;
            height: 28px;
            border-radius: .85rem;
            background: linear-gradient(135deg,#2563eb,#22c55e);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: .85rem;
        }

        .sidebar-brand .logo {
            width: 40px;
            height: 40px;
            border-radius: 1rem;
            background: linear-gradient(135deg,#2563eb,#22c55e);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 900;
        }

        .dropdown-menu .dropdown-item i {
            width: 18px;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body class="@(isAuthenticated ? "layout-app" : "layout-auth")">

    @if (isAuthenticated)
    {
        <div class="wrapper">

            <!-- ===== SIDEBAR (DESKTOP) ===== -->
            <aside class="sidebar d-none d-lg-flex" aria-label="Menu lateral">
                <div class="sidebar-brand">
                    <span class="logo">IG</span>
                    <div class="sidebar-brand-title">
                        <span class="name">InovaGED</span>
                        <span class="subtitle">Gestão Eletrônica de Documentos</span>
                    </div>
                </div>

                <nav class="sidebar-menu">

                    <!-- 0) PRINCIPAL -->
                    <div class="sidebar-section-title">Principal</div>
                    <a asp-controller="Home" asp-action="Index" class="@Active("Home","Index")">
                        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                    </a>

                    <!-- 1) USUÁRIOS E AUTORIDADES -->
                    <div class="sidebar-section-title">Usuários e Autoridades</div>
                    <a asp-controller="Users" asp-action="Index" class="@Active("Users","Index")">
                        <i class="bi bi-people"></i><span>Usuários</span>
                    </a>
                    <a asp-controller="Users" asp-action="Create" class="@Active("Users","Create")">
                        <i class="bi bi-person-plus"></i><span>Criar Usuário</span>
                    </a>

                    <!-- 2) INSTRUMENTOS ARQUIVÍSTICOS -->
                    <div class="sidebar-section-title">Instrumentos Arquivísticos</div>

                    <!-- Base: PCD/TTD/POP -->
                    <a asp-controller="Classification" asp-action="Index" class="@ActiveAny("Classification")">
                        <i class="bi bi-diagram-3"></i><span>PCD / TTD / POP</span>
                    </a>

                    <a asp-controller="ClassificationDashboard" asp-action="Index" class="@ActiveAny("ClassificationDashboard")">
                        <i class="bi bi-inboxes"></i>
                        <span class="d-flex align-items-center gap-2">
                            Pendências
                            <span id="clsBadge" class="badge text-bg-danger d-none">0</span>
                        </span>
                    </a>

                    <!-- ✅ CORRIGIDO: Movimentação de códigos (rota real do InstrumentosArquivisticosController) -->
                    <a asp-controller="InstrumentosArquivisticos" asp-action="MoveCode" class="@Active("InstrumentosArquivisticos","MoveCode")">
                        <i class="bi bi-arrow-left-right"></i><span>Movimentar Código (PCD/TTD)</span>
                    </a>

                    <!-- ✅ CORRIGIDO: Versions (rota real do InstrumentosArquivisticosController) -->
                    <a asp-controller="InstrumentosArquivisticos" asp-action="Versions" class="@Active("InstrumentosArquivisticos","Versions")">
                        <i class="bi bi-clock-history"></i><span>Versões (PCD/TTD/POP)</span>
                    </a>

                    <!-- ✅ CORRIGIDO: POPs (lista) no InstrumentsController -->
                    <a asp-controller="Instruments" asp-action="Pop" class="@Active("Instruments","Pop")">
                        <i class="bi bi-journal-richtext"></i><span>POPs</span>
                    </a>

                    <!-- 3) CADASTRO E CONTROLE DE DOCUMENTOS -->
                    <div class="sidebar-section-title">Documentos</div>
                    <a asp-controller="Ged" asp-action="Index" class="@ActiveAny("Ged")">
                        <i class="bi bi-folder2-open"></i><span>Explorer</span>
                    </a>
                    <a asp-controller="Ged" asp-action="Folders" class="@Active("Ged","Folders")">
                        <i class="bi bi-folder"></i><span>Pastas / Dossiês</span>
                    </a>

                    <!-- PACS (externo) -->
                    <a href="https://yndustech.com.br/GedDocs" target="_blank" rel="noopener noreferrer" class="@ActiveAny("Pacs")">
                        <i class="bi bi-heart-pulse"></i>
                        <span class="d-flex align-items-center gap-2">
                            Sistema de Imagem
                            <span id="pacsBadge" class="badge text-bg-danger @(pacsBadge > 0 ? "" : "d-none")">@pacsBadge</span>
                        </span>
                    </a>

                    <!-- 3.1) Lotes físicos (fase do tratamento) -->
                    <a asp-controller="Batches" asp-action="Index" class="@ActiveAny("Batches")">
                        <i class="bi bi-box-seam"></i><span>Lotes (Tratamento)</span>
                    </a>

                    <!-- 3.2) Guarda Física -->
                    <div class="sidebar-section-title">Guarda Física</div>
                    <a asp-controller="Physical" asp-action="Locations" class="@Active("Physical","Locations")">
                        <i class="bi bi-geo-alt"></i><span>Localizações</span>
                    </a>
                    <a asp-controller="Physical" asp-action="Boxes" class="@Active("Physical","Boxes")">
                        <i class="bi bi-inbox"></i><span>Caixas</span>
                    </a>
                    <a asp-controller="Physical" asp-action="BoxHistory" class="@Active("Physical","BoxHistory")">
                        <i class="bi bi-list-columns-reverse"></i><span>Histórico da Caixa</span>
                    </a>

                    <!-- 4) ASSINATURA DIGITAL ICP -->
                    <div class="sidebar-section-title">Assinatura ICP</div>
                    <a asp-controller="Reports" asp-action="SignatureValidation" class="@Active("Reports","SignatureValidation")">
                        <i class="bi bi-patch-check"></i><span>Validação de Assinaturas</span>
                    </a>

                    <!-- 5) TEMPORALIDADE / DESTINAÇÃO -->
                    <div class="sidebar-section-title">Temporalidade e Destinação</div>

                    <a asp-controller="Temporalidade" asp-action="Index" class="@ActiveAny("Temporalidade")">
                        <i class="bi bi-hourglass-split"></i><span>Central de Temporalidade</span>
                    </a>

                    <a asp-controller="Retention" asp-action="Queue" class="@Active("Retention","Queue")">
                        <i class="bi bi-list-check"></i><span>Fila (Operacional)</span>
                    </a>

                    <a asp-controller="Disposition" asp-action="Index" class="@ActiveAny("Disposition")">
                        <i class="bi bi-archive"></i><span>Painel de Destinação</span>
                    </a>

                    <a asp-controller="Disposition" asp-action="Queue" class="@Active("Disposition","Queue")">
                        <i class="bi bi-inbox"></i>
                        <span class="d-flex align-items-center gap-2">
                            Fila de Destinação
                            <span class="badge text-bg-danger @(dispTotalBadge > 0 ? "" : "d-none")">@dispTotalBadge</span>
                        </span>
                    </a>

                    <a href="/RetentionCases" class="@ActivePath("/retentioncases")">
                        <i class="bi bi-journal-text"></i><span>Casos de Temporalidade</span>
                    </a>

                    <a href="/RetentionTerms" class="@ActivePath("/retentionterms")">
                        <i class="bi bi-file-earmark-text"></i><span>Termos de Destinação</span>
                    </a>

                    <a asp-controller="Disposition" asp-action="Terms" class="@Active("Disposition","Terms")">
                        <i class="bi bi-card-list"></i><span>Relatório de Termos</span>
                    </a>

                    <!-- 6) EMPRÉSTIMOS -->
                    <div class="sidebar-section-title">Empréstimos</div>
                    <a asp-controller="Loans" asp-action="Index" class="@ActiveAny("Loans")">
                        <i class="bi bi-journal-arrow-up"></i><span>Solicitações</span>
                    </a>
                    <a asp-controller="Loans" asp-action="Overdue" class="@Active("Loans","Overdue")">
                        <i class="bi bi-alarm"></i><span>Vencidos</span>
                    </a>
                    <form asp-controller="Loans" asp-action="RunOverdue" method="post" class="m-0 p-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link sidebar-link text-start p-0 w-100" style="text-decoration:none;">
                            <span class="d-flex align-items-center gap-2 px-3 py-2">
                                <i class="bi bi-play-circle"></i><span>Rodar rotina de vencidos</span>
                            </span>
                        </button>
                    </form>

                    <!-- 7) RELATÓRIOS -->
                    <div class="sidebar-section-title">Relatórios</div>
                    <a asp-controller="Reports" asp-action="Loans" class="@Active("Reports","Loans")">
                        <i class="bi bi-file-earmark-text"></i><span>Relatório de Empréstimos</span>
                    </a>
                    <a asp-controller="Reports" asp-action="PcdFull" class="@Active("Reports","PcdFull")">
                        <i class="bi bi-printer"></i><span>Imprimir PLC/PCD (Completo)</span>
                    </a>

                    <a asp-controller="Reports" asp-action="PcdByClass" class="@Active("Reports","PcdByClass")">
                        <i class="bi bi-funnel"></i><span>Imprimir PLC/PCD (por Classe)</span>
                    </a>

                    <a asp-controller="Reports" asp-action="TtdFull" class="@Active("Reports","TtdFull")">
                        <i class="bi bi-hourglass"></i><span>Imprimir TTD (Completo)</span>
                    </a>

                    <a asp-controller="Reports" asp-action="TtdByClass" class="@Active("Reports","TtdByClass")">
                        <i class="bi bi-funnel"></i><span>Imprimir TTD (por Classe)</span>
                    </a>
                    <!-- 8) AUDITORIA -->
                    <div class="sidebar-section-title">Auditoria</div>
                    <a asp-controller="Audit" asp-action="Index" class="@ActiveAny("Audit")">
                        <i class="bi bi-shield-lock"></i><span>Log de Auditoria</span>
                    </a>
                    <a asp-controller="Audit" asp-action="AccessDenied" class="@Active("Audit","AccessDenied")">
                        <i class="bi bi-shield-x"></i><span>Falhas de Acesso</span>
                    </a>

                    <!-- CONTA -->
                    <div class="sidebar-section-title">Conta</div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link sidebar-link text-start p-0 w-100" style="text-decoration:none;">
                            <span class="d-flex align-items-center gap-2 px-3 py-2">
                                <i class="bi bi-box-arrow-right"></i><span>Sair</span>
                            </span>
                        </button>
                    </form>
                </nav>

                <div class="sidebar-footer">
                    <div>© @DateTime.Now.Year InovaGED</div>
                </div>
            </aside>

            <!-- ===== OFFCANVAS (MOBILE/TABLET) ===== -->
            <div class="offcanvas offcanvas-start" tabindex="-1" id="ocSidebar" aria-labelledby="ocSidebarLabel">
                <div class="offcanvas-header border-bottom">
                    <div class="d-flex align-items-center gap-2">
                        <span class="logo"
                              style="width:32px;height:32px;border-radius:.9rem;background:linear-gradient(135deg,#2563eb,#22c55e);display:inline-flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.95rem;">IG</span>
                        <div>
                            <div id="ocSidebarLabel" class="fw-semibold">InovaGED</div>
                            <div class="text-muted small">Gestão Eletrônica de Documentos</div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
                </div>

                <div class="offcanvas-body p-2">
                    <nav class="sidebar-menu" style="padding:.25rem;">
                        <a asp-controller="Home" asp-action="Index" class="@Active("Home","Index")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                        </a>

                        <div class="sidebar-section-title">Instrumentos Arquivísticos</div>
                        <a asp-controller="Classification" asp-action="Index" class="@ActiveAny("Classification")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-diagram-3"></i><span>PCD / TTD / POP</span>
                        </a>

                        <!-- ✅ CORRIGIDO: MoveCode -->
                        <a asp-controller="InstrumentosArquivisticos" asp-action="MoveCode"
                           class="@Active("InstrumentosArquivisticos","MoveCode")"
                           data-bs-dismiss="offcanvas">
                            <i class="bi bi-arrow-left-right"></i><span>Movimentar Código</span>
                        </a>

                        <!-- ✅ CORRIGIDO: Versions -->
                        <a asp-controller="InstrumentosArquivisticos" asp-action="Versions"
                           class="@Active("InstrumentosArquivisticos","Versions")"
                           data-bs-dismiss="offcanvas">
                            <i class="bi bi-clock-history"></i><span>Versões (PCD/TTD/POP)</span>
                        </a>

                        <!-- ✅ CORRIGIDO: POPs -->
                        <a asp-controller="Instruments" asp-action="Pop"
                           class="@Active("Instruments","Pop")"
                           data-bs-dismiss="offcanvas">
                            <i class="bi bi-journal-richtext"></i><span>POPs</span>
                        </a>

                        <div class="sidebar-section-title">Temporalidade e Destinação</div>
                        <a asp-controller="Temporalidade" asp-action="Index" class="@ActiveAny("Temporalidade")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-hourglass-split"></i><span>Central de Temporalidade</span>
                        </a>
                        <a href="/RetentionTerms" class="@ActivePath("/retentionterms")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-file-earmark-text"></i><span>Termos de Destinação</span>
                        </a>

                        <div class="sidebar-section-title">Empréstimos</div>
                        <a asp-controller="Loans" asp-action="Index" class="@ActiveAny("Loans")" data-bs-dismiss="offcanvas">
                            <i class="bi bi-journal-arrow-up"></i><span>Solicitações</span>
                        </a>
                    </nav>
                </div>
            </div>

            <!-- ===== MAIN ===== -->
            <div class="main">
                <header class="topbar">
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary d-inline-flex d-lg-none"
                                type="button"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#ocSidebar"
                                aria-controls="ocSidebar"
                                title="Menu">
                            <i class="bi bi-list"></i>
                        </button>

                        <div class="topbar-left">
                            <div class="page-title">@ViewData["Title"]</div>
                            @if (!string.IsNullOrWhiteSpace(subtitle))
                            {
                                <div class="page-subtitle">@subtitle</div>
                            }
                        </div>
                    </div>

                    <div class="topbar-actions">
                        <a class="btn btn-sm btn-primary d-none d-sm-inline-flex" asp-controller="Ged" asp-action="Create">
                            <i class="bi bi-file-earmark-plus me-1"></i> Novo
                        </a>

                        <div class="dropdown">
                            <button class="btn btn-sm btn-light border d-inline-flex align-items-center gap-2"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="topbar-user-avatar">@UserInitials()</span>
                                <span class="d-none d-md-inline">@userName</span>
                                <i class="bi bi-chevron-down small"></i>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li class="px-3 py-2">
                                    <div class="small text-muted">Logado como</div>
                                    <div class="fw-semibold">@userName</div>
                                </li>
                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sair
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>

                    </div>
                </header>

                <main class="content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <main class="container py-4">
            @RenderBody()
        </main>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <script>
        (function () {
            async function loadBadge() {
                try {
                    const res = await fetch('/ClassificationDashboard/Count', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (!res.ok) return;
                    const data = await res.json();
                    const total = (data && typeof data.total === 'number') ? data.total : 0;

                    const el = document.getElementById('clsBadge');
                    const elm = document.getElementById('clsBadgeMobile');

                    if (el) {
                        el.textContent = total;
                        el.classList.toggle('d-none', total <= 0);
                    }
                    if (elm) {
                        elm.textContent = total;
                        elm.classList.toggle('d-none', total <= 0);
                    }
                } catch { }
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadBadge);
            } else {
                loadBadge();
            }
        })();
    </script>

</body>
</html>