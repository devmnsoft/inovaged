@{
    ViewData["Title"] = "Banco de dados desatualizado";
    var correlationId = ViewData["CorrelationId"]?.ToString();
    var sqlState = ViewData["SqlState"]?.ToString();
    var migration = ViewData["Migration"]?.ToString() ?? "database/apply_all_required_migrations.sql";
}

<div class="container py-4">
    <div class="alert alert-danger shadow-sm">
        <h1 class="h4 mb-3"><i class="bi bi-database-exclamation"></i> Estrutura do banco de dados desatualizada</h1>
        <p class="mb-2">Execute as migrations do sistema antes de acessar esta tela crítica.</p>
        <p class="mb-1"><strong>Script recomendado:</strong> <code>@migration</code></p>
        @if (!string.IsNullOrWhiteSpace(sqlState))
        {
            <p class="mb-1"><strong>Código PostgreSQL:</strong> <code>@sqlState</code></p>
        }
        @if (!string.IsNullOrWhiteSpace(correlationId))
        {
            <p class="mb-0"><strong>CorrelationId:</strong> <code>@correlationId</code></p>
        }
    </div>
    <a class="btn btn-primary" href="/SystemHealth/Schema">Abrir diagnóstico do banco</a>
</div>
