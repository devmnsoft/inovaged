<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - InovaGED</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap + Icons -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Seu CSS global -->
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        /* Fundo mais moderno (sem depender de imagem) */
        .auth-bg {
            min-height: 100vh;
            background: radial-gradient(1200px 600px at 10% 10%, rgba(37,99,235,.20), transparent 60%), radial-gradient(1200px 600px at 90% 20%, rgba(34,197,94,.18), transparent 55%), linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
        }

        .auth-shell {
            max-width: 420px;
            width: 100%;
        }

        .auth-card {
            border-radius: 1rem;
            overflow: hidden;
        }

        .auth-topbar {
            height: 8px;
            background: linear-gradient(90deg, #2563eb, #22c55e);
        }

        .auth-footer {
            color: rgba(0,0,0,.55);
        }

        .auth-muted {
            color: rgba(0,0,0,.60);
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="auth-bg d-flex flex-column">
        <!-- HEADER MINIMAL -->
        <div class="container py-3">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <div class="d-inline-flex align-items-center justify-content-center"
                         style="width:36px;height:36px;border-radius:.9rem;
                                background:linear-gradient(135deg,#2563eb,#22c55e);
                                color:#fff;font-weight:800;">
                        IG
                    </div>
                    <div class="lh-sm">
                        <div class="fw-bold">InovaGED</div>
                        <div class="small auth-muted">Autenticação</div>
                    </div>
                </div>

                <div class="small auth-muted">
                    <i class="bi bi-shield-lock me-1"></i> Ambiente seguro
                </div>
            </div>
        </div>

        <!-- BODY -->
        <main class="container flex-grow-1 d-flex align-items-center justify-content-center py-4">
            <div class="auth-shell">
                @RenderBody()
            </div>
        </main>

        <!-- FOOTER -->
        <footer class="container pb-4 text-center small auth-footer">
            © @DateTime.Now.Year InovaGED · Gestão Eletrônica de Documentos
        </footer>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
