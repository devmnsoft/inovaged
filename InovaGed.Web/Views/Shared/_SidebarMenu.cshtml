@using Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using InovaGed.Web.Security

@{
    var ctrl = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var act = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;

    string Active(string controller, params string[] actions)
    {
        if (!string.Equals(ctrl, controller.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) return string.Empty;
        return actions.Length == 0 || actions.Any(a => string.Equals(act, a.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) ? "active" : string.Empty;
    }

    string ActiveAny(params string[] controllers) => controllers.Any(c => string.Equals(ctrl, c.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)) ? "active" : string.Empty;
    string ActivePathStarts(string startsWith) => path.StartsWith((startsWith ?? string.Empty).ToLowerInvariant()) ? "active" : string.Empty;

    var isFullAdmin = AppMenuPolicy.IsFullAdmin(User);
    var isAdministradorOphir = AppMenuPolicy.IsAdministradorOphir(User) && !isFullAdmin;
    var isArquivistaOphir = AppMenuPolicy.IsArquivistaOphir(User) && !isFullAdmin;
    var isHospital = AppMenuPolicy.IsHospitalUser(User) && !isFullAdmin && !isAdministradorOphir && !isArquivistaOphir;
}

@if (isFullAdmin)
{
    <div class="sidebar-section-title">Visão Geral</div>
    <a asp-controller="Home" asp-action="Index" class="@Active("Home", "Index")"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
    <a asp-controller="Operations" asp-action="Index" class="@ActivePathStarts("/operations")"><i class="bi bi-command"></i><span>Central Operacional</span></a>
    <a asp-controller="DocumentQuality" asp-action="Index" class="@ActivePathStarts("/documentquality")"><i class="bi bi-shield-check"></i><span>Qualidade Documental</span></a>

    <div class="sidebar-section-title">Documentos</div>
    <a asp-controller="Ged" asp-action="Index" class="@ActiveAny("Ged", "GedSearch")"><i class="bi bi-folder2-open"></i><span>GED / Explorer</span></a>
    <a asp-controller="HospitalDocuments" asp-action="Index" class="@ActiveAny("HospitalDocuments")"><i class="bi bi-search-heart"></i><span>Busca Hospitalar</span></a>
    <a asp-controller="SmartSearch" asp-action="Index" class="@ActiveAny("SmartSearch")"><i class="bi bi-stars"></i><span>Busca Inteligente</span></a>
    <a asp-controller="HospitalIntelligence" asp-action="Index" class="@ActiveAny("HospitalIntelligence")"><i class="bi bi-activity"></i><span>Inteligência Hospitalar</span></a>
    <a asp-controller="HospitalTrends" asp-action="Index" class="@ActiveAny("HospitalTrends")"><i class="bi bi-graph-up-arrow"></i><span>Alertas e Tendências</span></a>
    <a asp-controller="Ged" asp-action="Create" class="@Active("Ged", "Create")"><i class="bi bi-cloud-upload"></i><span>Uploads</span></a>
    <a asp-controller="Ocr" asp-action="Index" class="@ActiveAny("Ocr")"><i class="bi bi-filetype-pdf"></i><span>Central OCR</span></a>
    <a href="/Ocr/Queue" class="@ActivePathStarts("/ocr/queue")"><i class="bi bi-list-check"></i><span>Fila OCR</span></a>
    <a href="/Ocr/AutoSchedule" class="@ActivePathStarts("/ocr/autoschedule")"><i class="bi bi-calendar2-check"></i><span>Agendamento OCR</span></a>
    <a asp-controller="GedClassification" asp-action="Queue" class="@ActiveAny("GedClassification", "GedClassifications", "ClassificationDashboard")"><i class="bi bi-tags"></i><span>Classificação</span></a>
    <a asp-controller="Ged" asp-action="Folders" class="@Active("Ged", "Folders")"><i class="bi bi-folder"></i><span>Pastas</span></a>
    <a asp-controller="Batches" asp-action="Index" class="@ActiveAny("Batches")"><i class="bi bi-collection"></i><span>Dossiês</span></a>

    <div class="sidebar-section-title">Guarda Física</div>
    <a asp-controller="Physical" asp-action="Locations" class="@Active("Physical", "Locations")"><i class="bi bi-geo-alt"></i><span>Localizações</span></a>
    <a asp-controller="Physical" asp-action="Boxes" class="@Active("Physical", "Boxes")"><i class="bi bi-inbox"></i><span>Caixas</span></a>
    <a asp-controller="Labels" asp-action="Boxes" class="@ActiveAny("Labels")"><i class="bi bi-upc-scan"></i><span>Etiquetas</span></a>

    <div class="sidebar-section-title">Operação</div>
    <a asp-controller="Loans" asp-action="Index" class="@ActiveAny("Loans", "Solicitacoes")"><i class="bi bi-arrow-left-right"></i><span>Empréstimos</span></a>
    <a asp-controller="Protocolo" asp-action="Index" class="@ActiveAny("Protocolo")"><i class="bi bi-journal-check"></i><span>Protocolo</span></a>
    <a asp-controller="ProtocolRequests" asp-action="New" class="@Active("ProtocolRequests", "New")"><i class="bi bi-send-plus"></i><span>Solicitar Protocolo</span></a>
    <a asp-controller="ProtocolRequests" asp-action="My" class="@Active("ProtocolRequests", "My")"><i class="bi bi-list-check"></i><span>Minhas Solicitações</span></a>
    <a href="/Protocols/WorkQueue" class="@ActivePathStarts("/protocols/workqueue")"><i class="bi bi-inboxes"></i><span>Fila de Protocolos</span></a>

    <div class="sidebar-section-title">Administração</div>
    <a asp-controller="Administration" asp-action="Index" class="@ActiveAny("Administration")"><i class="bi bi-shield-lock"></i><span>Administração</span></a>
    <a asp-controller="Parameters" asp-action="Index" class="@ActiveAny("Parameters", "ProtocoloParametros")"><i class="bi bi-sliders"></i><span>Parâmetros</span></a>
    <a asp-controller="Users" asp-action="Index" class="@ActiveAny("Users")"><i class="bi bi-people"></i><span>Usuários</span></a>
    <a asp-controller="SystemLogs" asp-action="Index" class="@ActiveAny("SystemLogs", "Audit", "AuditDashboard", "SecurityAudit")"><i class="bi bi-activity"></i><span>Logs</span></a>
    <a asp-controller="SystemHealth" asp-action="Index" class="@ActiveAny("SystemHealth")"><i class="bi bi-heart-pulse"></i><span>SystemHealth</span></a>
    <a href="/SystemHealth/Schema" class="@ActivePathStarts("/systemhealth/schema")"><i class="bi bi-database-check"></i><span>Schema do Banco</span></a>
    <a href="/SystemHealth/Homologation" class="@ActivePathStarts("/systemhealth/homologation")"><i class="bi bi-clipboard2-check"></i><span>Homologação</span></a>
    <a asp-controller="Security" asp-action="Roles" class="@ActiveAny("Security")"><i class="bi bi-gear"></i><span>Configurações</span></a>
}
else if (isAdministradorOphir)
{
    <div class="sidebar-section-title">Setor</div>
    <a asp-controller="HospitalDocuments" asp-action="Index" class="@ActiveAny("HospitalDocuments")"><i class="bi bi-search-heart"></i><span>Documentos Hospitalares</span></a>
    <a asp-controller="Loans" asp-action="Index" class="@ActiveAny("Loans")"><i class="bi bi-arrow-left-right"></i><span>Pedidos do Setor</span></a>
    <a href="/Protocols/WorkQueue" class="@ActivePathStarts("/protocols/workqueue")"><i class="bi bi-inboxes"></i><span>Fila de Protocolos</span></a>
    <a href="/Users/Sector" class="@ActivePathStarts("/users/sector")"><i class="bi bi-people"></i><span>Usuários do meu setor</span></a>
}
else if (isArquivistaOphir)
{
    <div class="sidebar-section-title">Solicitações</div>
    <a asp-controller="HospitalDocuments" asp-action="Index" class="@ActiveAny("HospitalDocuments")"><i class="bi bi-search-heart"></i><span>Documentos Hospitalares</span></a>
    <a asp-controller="Loans" asp-action="New" class="@Active("Loans", "New")"><i class="bi bi-file-earmark-plus"></i><span>Novo Pedido de Documento</span></a>
    <a asp-controller="Loans" asp-action="Index" class="@Active("Loans", "Index")"><i class="bi bi-collection"></i><span>Meus Pedidos</span></a>
    <a asp-controller="ProtocolRequests" asp-action="My" class="@Active("ProtocolRequests", "My")"><i class="bi bi-list-check"></i><span>Meus Protocolos</span></a>
}
else if (isHospital)
{
    <div class="sidebar-section-title">Consulta</div>
    <a asp-controller="HospitalDocuments" asp-action="Index" class="@ActiveAny("HospitalDocuments")"><i class="bi bi-search-heart"></i><span>Documentos Hospitalares</span></a>
}
else
{
    <div class="sidebar-section-title">Consulta</div>
    <a asp-controller="HospitalDocuments" asp-action="Index" class="@ActiveAny("HospitalDocuments")"><i class="bi bi-search-heart"></i><span>Buscar Prontuários e Documentos</span></a>
    <a asp-controller="SmartSearch" asp-action="Index" class="@ActiveAny("SmartSearch")"><i class="bi bi-stars"></i><span>Busca Inteligente</span></a>
}

<div class="sidebar-section-title">Conta</div>
<form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-link sidebar-link text-start p-0 w-100" style="text-decoration:none;">
        <span class="d-flex align-items-center gap-2 px-3 py-2"><i class="bi bi-box-arrow-right"></i><span>Sair</span></span>
    </button>
</form>
