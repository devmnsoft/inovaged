@using Dapper
@using Microsoft.AspNetCore.Mvc.TagHelpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using InovaGed.Application.Common.Database
@using InovaGed.Web.Security
@inject IDbConnectionFactory DbFactory

@{
	var ctrl = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
	var act = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
	var path = Context.Request.Path.Value?.ToLowerInvariant() ?? "";

	string Active(string controller, params string[] actions)
	{
		var c = controller.ToLowerInvariant();

		if (ctrl != c)
			return "";

		if (actions == null || actions.Length == 0)
			return "active";

		return actions.Any(a => string.Equals(act, a.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase))
			? "active"
			: "";
	}

	string ActiveAny(params string[] controllers)
		=> controllers.Any(c => string.Equals(ctrl, c.ToLowerInvariant(), StringComparison.OrdinalIgnoreCase))
			? "active"
			: "";

	string ActivePathStarts(string startsWith)
	{
		var sw = (startsWith ?? "").ToLowerInvariant();
		return path.StartsWith(sw) ? "active" : "";
	}

	string ActivePathExact(string exactPath)
	{
		var current = path.TrimEnd('/');
		var exact = (exactPath ?? "").ToLowerInvariant().TrimEnd('/');

		if (string.IsNullOrWhiteSpace(current))
			current = "/";

		return current == exact ? "active" : "";
	}

	bool HasRole(string role) =>
		User.Claims
			.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role || c.Type == "role")
			.Any(c => string.Equals(NormalizeRole(c.Value), NormalizeRole(role), StringComparison.OrdinalIgnoreCase));

	string NormalizeRole(string? value) =>
		(value ?? "").Trim().Replace(" ", "").Replace("_", "").Replace("-", "").ToUpperInvariant();

	bool IsAdmin() =>
		HasRole(AppRoles.Admin);

	bool IsArquivistaOphir() =>
		HasRole(AppRoles.ArquivistaOphir);

	bool IsAdministradorOphir() =>
		HasRole(AppRoles.AdministradorOphir);

	bool IsOnlyArquivistaOphir() =>
		IsArquivistaOphir() && !IsAdministradorOphir() && !IsAdmin();

	bool IsOnlyAdministradorOphir() =>
		IsAdministradorOphir() && !IsAdmin();

	bool CanDashboard() =>
		!IsOnlyArquivistaOphir() && !IsOnlyAdministradorOphir() && (
		User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Arquivista) ||
		User.IsInRole(AppRoles.Operador) ||
		User.IsInRole(AppRoles.Gestor) ||
		User.IsInRole(AppRoles.Auditor) ||
		IsAdministradorOphir());

	bool CanDocumentos() =>
		IsArquivistaOphir() ||
		IsAdministradorOphir() ||
		User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Arquivista) ||
		User.IsInRole(AppRoles.Operador);

	bool CanEmprestimos() =>
		(IsAdministradorOphir() ||
		User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Arquivista) ||
		User.IsInRole(AppRoles.Gestor) ||
		User.IsInRole(AppRoles.Operador));

	bool CanCreateHospitalDocuments() =>
		IsAdministradorOphir() || User.IsInRole(AppRoles.Admin);

	bool CanRelatorios() =>
		!IsOnlyAdministradorOphir() && !IsOnlyArquivistaOphir() && (User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Arquivista) ||
		User.IsInRole(AppRoles.Gestor) ||
		User.IsInRole(AppRoles.Auditor) ||
		User.IsInRole(AppRoles.Operador));

	bool CanAuditoria() =>
		!IsOnlyAdministradorOphir() && !IsOnlyArquivistaOphir() && (User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Gestor) ||
		User.IsInRole(AppRoles.Auditor));

	bool CanArquivistico() =>
		!IsOnlyAdministradorOphir() && !IsOnlyArquivistaOphir() && (User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Arquivista));

	bool CanAssinaturaDigital() =>
		!IsOnlyAdministradorOphir() && !IsOnlyArquivistaOphir() && (User.IsInRole(AppRoles.Admin) ||
		User.IsInRole(AppRoles.Arquivista));

	int pacsBadge = 0;
	int dispElimBadge = 0;
	int dispTransBadge = 0;
	int dispReviewBadge = 0;
	int loanPendingBadge = 0;

	try
	{
		using var conn = await DbFactory.OpenAsync(Context.RequestAborted);

		pacsBadge = await conn.ExecuteScalarAsync<int>(
			new CommandDefinition(
										@"select count(*)
                  from pacs.ocr_job
                  where status='PENDING'",
				cancellationToken: Context.RequestAborted));

		dispElimBadge = await conn.ExecuteScalarAsync<int>(
			new CommandDefinition(
										@"select count(*)
                  from ged.document
                  where disposition_status='ELIMINATION_READY'",
				cancellationToken: Context.RequestAborted));

		dispTransBadge = await conn.ExecuteScalarAsync<int>(
			new CommandDefinition(
										@"select count(*)
                  from ged.document
                  where disposition_status='TRANSFER_READY'",
				cancellationToken: Context.RequestAborted));

		dispReviewBadge = await conn.ExecuteScalarAsync<int>(
			new CommandDefinition(
										@"select count(*)
                  from ged.document
                  where disposition_status='REVIEW_REQUIRED'",
				cancellationToken: Context.RequestAborted));
	}
	catch
	{
		pacsBadge = 0;
		dispElimBadge = 0;
		dispTransBadge = 0;
		dispReviewBadge = 0;
		loanPendingBadge = 0;
	}

	var dispTotalBadge = dispElimBadge + dispTransBadge + dispReviewBadge;
}

