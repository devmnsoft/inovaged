@using InovaGed.Application.Ged.Batches
@model IReadOnlyList<BatchRowDto>

@{
    ViewData["Title"] = "Lotes de Tratamento Documental";

    var q = (ViewBag.Q as string) ?? "";
    var status = (ViewBag.Status as string) ?? "";

    var total = Model?.Count ?? 0;
    var totalItens = Model?.Sum(x => x.ItemsCount) ?? 0;

    var recebidos = Model?.Count(x => x.Status == "RECEIVED") ?? 0;
    var triagem = Model?.Count(x => x.Status == "TRIAGE") ?? 0;
    var digitalizacao = Model?.Count(x => x.Status == "DIGITIZATION") ?? 0;
    var indexacao = Model?.Count(x => x.Status == "INDEXING") ?? 0;
    var arquivados = Model?.Count(x => x.Status == "ARCHIVED") ?? 0;

    string StatusLabel(string value) => value switch
    {
        "RECEIVED" => "Recebido",
        "TRIAGE" => "Triagem",
        "DIGITIZATION" => "Digitalização",
        "INDEXING" => "Indexação",
        "ARCHIVED" => "Arquivado",
        _ => string.IsNullOrWhiteSpace(value) ? "Não informado" : value
    };

    string StatusDescription(string value) => value switch
    {
        "RECEIVED" => "Documentos recebidos e aguardando conferência inicial.",
        "TRIAGE" => "Documentos em análise, separação e conferência.",
        "DIGITIZATION" => "Documentos em processo de digitalização ou preparação para captura.",
        "INDEXING" => "Documentos em classificação, indexação e complementação de metadados.",
        "ARCHIVED" => "Documentos concluídos e arquivados no fluxo documental.",
        _ => "Etapa não identificada."
    };

    string StatusBadge(string value) => value switch
    {
        "RECEIVED" => "text-bg-secondary",
        "TRIAGE" => "text-bg-info",
        "DIGITIZATION" => "text-bg-primary",
        "INDEXING" => "text-bg-warning text-dark",
        "ARCHIVED" => "text-bg-success",
        _ => "text-bg-light text-dark"
    };

    string StatusIcon(string value) => value switch
    {
        "RECEIVED" => "bi-inbox",
        "TRIAGE" => "bi-diagram-3",
        "DIGITIZATION" => "bi-scanner",
        "INDEXING" => "bi-tags",
        "ARCHIVED" => "bi-archive",
        _ => "bi-question-circle"
    };
}

@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>@err</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2">
        <i class="bi bi-check-circle-fill"></i>
        <div>@ok</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-box-seam me-2"></i>
            @ViewData["Title"]
        </h3>
        <div class="text-muted">
            Acompanhe os lotes de documentos recebidos, visualize a fase atual do tratamento documental
            e acesse os itens vinculados a cada lote.
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="ImportExport" asp-action="Index">
            <i class="bi bi-cloud-upload me-1"></i>
            Importar documentos
        </a>

        <a class="btn btn-outline-secondary" asp-controller="ImportExport" asp-action="ExportCenter">
            <i class="bi bi-cloud-download me-1"></i>
            Exportar documentos
        </a>

        <a class="btn btn-primary" asp-controller="Batches" asp-action="New">
            <i class="bi bi-plus-circle me-1"></i>
            Novo lote
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="alert alert-primary border-0 shadow-sm h-100 mb-0">
            <div class="d-flex gap-3">
                <div class="fs-3">
                    <i class="bi bi-info-circle"></i>
                </div>

                <div>
                    <strong>Para que serve esta tela?</strong>

                    <div class="small mt-1">
                        Esta tela serve para controlar os <strong>lotes de tratamento documental</strong>.
                        Um lote representa um conjunto de documentos físicos ou digitais que foram recebidos
                        para conferência, triagem, digitalização, indexação e arquivamento.
                    </div>

                    <div class="small mt-2">
                        Aqui o usuário consegue verificar quantos lotes existem, em qual etapa cada lote está,
                        quantos documentos foram vinculados, quando o lote foi criado e acessar os detalhes
                        para consultar histórico, itens, movimentações e auditoria.
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <span class="badge text-bg-secondary">
                            <i class="bi bi-inbox me-1"></i> Recebido
                        </span>
                        <span class="badge text-bg-info">
                            <i class="bi bi-diagram-3 me-1"></i> Triagem
                        </span>
                        <span class="badge text-bg-primary">
                            <i class="bi bi-scanner me-1"></i> Digitalização
                        </span>
                        <span class="badge text-bg-warning text-dark">
                            <i class="bi bi-tags me-1"></i> Indexação
                        </span>
                        <span class="badge text-bg-success">
                            <i class="bi bi-archive me-1"></i> Arquivado
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <strong>
                    <i class="bi bi-lightbulb me-1"></i>
                    Como usar
                </strong>
            </div>

            <div class="card-body small text-muted">
                <div class="mb-2">
                    <strong class="text-dark">1.</strong> Clique em <strong>Novo lote</strong> para registrar um recebimento.
                </div>

                <div class="mb-2">
                    <strong class="text-dark">2.</strong> Use os filtros para localizar lotes por número, observação ou etapa.
                </div>

                <div class="mb-2">
                    <strong class="text-dark">3.</strong> Clique em <strong>Ver</strong> para acessar documentos, histórico e auditoria.
                </div>

                <div>
                    <strong class="text-dark">4.</strong> Use Importação/Exportação quando precisar inserir ou baixar documentos do GED.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Total de lotes</div>
                <div class="fs-4 fw-bold">@total</div>
                <div class="small text-muted">
                    <i class="bi bi-box-seam me-1"></i>
                    lotes cadastrados
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Documentos vinculados</div>
                <div class="fs-4 fw-bold">@totalItens</div>
                <div class="small text-muted">
                    <i class="bi bi-files me-1"></i>
                    itens em lotes
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Recebidos</div>
                <div class="fs-4 fw-bold">@recebidos</div>
                <span class="badge text-bg-secondary">
                    <i class="bi bi-inbox me-1"></i>
                    aguardando triagem
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Em triagem</div>
                <div class="fs-4 fw-bold">@triagem</div>
                <span class="badge text-bg-info">
                    <i class="bi bi-diagram-3 me-1"></i>
                    conferência
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Em tratamento</div>
                <div class="fs-4 fw-bold">@(digitalizacao + indexacao)</div>
                <span class="badge text-bg-primary">
                    <i class="bi bi-scanner me-1"></i>
                    digitalização/indexação
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-2">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Arquivados</div>
                <div class="fs-4 fw-bold">@arquivados</div>
                <span class="badge text-bg-success">
                    <i class="bi bi-archive me-1"></i>
                    concluídos
                </span>
            </div>
        </div>
    </div>
</div>

<form method="get" class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <strong>
                <i class="bi bi-funnel me-1"></i>
                Filtros de pesquisa
            </strong>
            <div class="small text-muted">
                Use os filtros abaixo para localizar rapidamente um lote específico.
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(q) || !string.IsNullOrWhiteSpace(status))
        {
            <span class="badge text-bg-primary">
                Filtro aplicado
            </span>
        }
    </div>

    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Busca</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>
                    <input class="form-control"
                           name="q"
                           value="@q"
                           placeholder="Digite o número do lote ou parte da observação..." />
                </div>
                <div class="form-text">
                    Exemplo: número do lote, setor de origem, período, observação ou palavra-chave.
                </div>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Etapa do lote</label>
                <select class="form-select" name="status">
                    <option value="">Todas as etapas</option>

                    @if (status == "RECEIVED")
                    {
                        <option value="RECEIVED" selected>Recebido</option>
                    }
                    else
                    {
                        <option value="RECEIVED">Recebido</option>
                    }

                    @if (status == "TRIAGE")
                    {
                        <option value="TRIAGE" selected>Triagem</option>
                    }
                    else
                    {
                        <option value="TRIAGE">Triagem</option>
                    }

                    @if (status == "DIGITIZATION")
                    {
                        <option value="DIGITIZATION" selected>Digitalização</option>
                    }
                    else
                    {
                        <option value="DIGITIZATION">Digitalização</option>
                    }

                    @if (status == "INDEXING")
                    {
                        <option value="INDEXING" selected>Indexação</option>
                    }
                    else
                    {
                        <option value="INDEXING">Indexação</option>
                    }

                    @if (status == "ARCHIVED")
                    {
                        <option value="ARCHIVED" selected>Arquivado</option>
                    }
                    else
                    {
                        <option value="ARCHIVED">Arquivado</option>
                    }
                </select>

                <div class="form-text">
                    Filtre pela fase atual do tratamento documental.
                </div>
            </div>

            <div class="col-md-3">
                <div class="d-grid d-md-flex gap-2">
                    <button class="btn btn-primary flex-fill" type="submit">
                        <i class="bi bi-search me-1"></i>
                        Filtrar
                    </button>

                    <a class="btn btn-outline-secondary flex-fill" asp-controller="Batches" asp-action="Index">
                        <i class="bi bi-x-circle me-1"></i>
                        Limpar
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <strong>
                <i class="bi bi-list-check me-1"></i>
                Lotes encontrados
            </strong>
            <div class="small text-muted">
                @total registro(s) localizado(s). Clique em <strong>Ver</strong> para consultar os detalhes do lote.
            </div>
        </div>

        <a class="btn btn-sm btn-outline-primary" asp-controller="Batches" asp-action="New">
            <i class="bi bi-plus-circle me-1"></i>
            Novo lote
        </a>
    </div>

    <div class="card-body p-0">
        @if (Model is null || Model.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                <h5 class="mb-1">Nenhum lote encontrado</h5>
                <div class="mb-3">
                    Não há lotes cadastrados ou nenhum registro corresponde aos filtros informados.
                </div>

                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <a class="btn btn-primary" asp-controller="Batches" asp-action="New">
                        <i class="bi bi-plus-circle me-1"></i>
                        Criar novo lote
                    </a>

                    <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">
                        <i class="bi bi-x-circle me-1"></i>
                        Limpar filtros
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 130px;">Nº lote</th>
                            <th style="width: 200px;">Etapa atual</th>
                            <th>Observações / identificação</th>
                            <th style="width: 190px;">Criado em</th>
                            <th style="width: 120px;" class="text-end">Itens</th>
                            <th style="width: 160px;" class="text-end">Ações</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">#@b.BatchNo</div>
                                    <div class="small text-muted">Número do lote</div>
                                </td>

                                <td>
                                    <span class="badge @StatusBadge(b.Status)">
                                        <i class="bi @StatusIcon(b.Status) me-1"></i>
                                        @StatusLabel(b.Status)
                                    </span>

                                    <div class="small text-muted mt-1">
                                        @StatusDescription(b.Status)
                                    </div>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(b.Notes))
                                    {
                                        <div class="text-truncate" style="max-width: 620px;" title="@b.Notes">
                                            @b.Notes
                                        </div>
                                        <div class="small text-muted">
                                            Observação registrada no recebimento ou movimentação do lote.
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sem observações registradas.</span>
                                        <div class="small text-muted">
                                            Recomenda-se informar origem, período ou setor ao criar novos lotes.
                                        </div>
                                    }
                                </td>

                                <td>
                                    <div>@b.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="small text-muted">@b.CreatedAt.ToString("HH:mm")</div>
                                </td>

                                <td class="text-end">
                                    <span class="badge text-bg-light text-dark border">
                                        <i class="bi bi-files me-1"></i>
                                        @b.ItemsCount
                                    </span>
                                    <div class="small text-muted">documento(s)</div>
                                </td>

                                <td class="text-end">
                                    <div class="btn-group">
                                        <a class="btn btn-sm btn-outline-primary"
                                           asp-controller="Batches"
                                           asp-action="Details"
                                           asp-route-id="@b.Id"
                                           title="Abrir o lote para ver documentos, etapa, histórico e auditoria">
                                            <i class="bi bi-eye me-1"></i>
                                            Ver
                                        </a>

                                        <a class="btn btn-sm btn-outline-secondary"
                                           asp-controller="Batches"
                                           asp-action="Details"
                                           asp-route-id="@b.Id"
                                           title="Consultar histórico e auditoria do lote">
                                            <i class="bi bi-clock-history"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card-footer bg-white">
        <div class="small text-muted">
            <i class="bi bi-shield-check me-1"></i>
            Todas as alterações relevantes do lote devem gerar histórico e registro de auditoria:
            criação, inclusão de documentos, mudança de etapa, movimentação física e arquivamento.
        </div>
    </div>
</div>