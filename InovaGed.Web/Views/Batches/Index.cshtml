@using InovaGed.Application.Ged.Batches
@model IReadOnlyList<BatchRowDto>

@{
    ViewData["Title"] = "Lotes Físicos";
    ViewData["Subtitle"] = "Controle de lotes e itens";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h4 class="mb-0">Lotes Físicos</h4>
        <div class="text-muted small">Entrada, processamento e arquivamento</div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-primary" type="button" disabled>
            <i class="bi bi-plus-lg me-1"></i>Novo (PoC)
        </button>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Lote</th>
                    <th>Status</th>
                    <th>Criado em</th>
                    <th>Notas</th>
                    <th class="text-center">Itens</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-muted p-3">Nenhum lote.</td></tr>
                }
                else
                {
                    foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@r.BatchNo</td>
                            <td><span class="badge bg-secondary">@r.Status</span></td>
                            <td>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-muted">@r.Notes</td>
                            <td class="text-center"><span class="badge bg-dark">@r.ItemsCount</span></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>