@using InovaGed.Application.Ged.Batches
@model BatchCreateVM

@{
    ViewData["Title"] = "Novo lote";
    var allowed = ViewBag.AllowedStatus as string[] ?? Array.Empty<string>();
}

@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle"></i>
        <div>@err</div>
    </div>
}
@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success d-flex align-items-center gap-2">
        <i class="bi bi-check2-circle"></i>
        <div>@ok</div>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="text-muted small">
            Crie um lote e adicione documentos por busca. (Item 16 – Criação de lotes)
        </div>
    </div>

    <a class="btn btn-outline-secondary" href="/Batches">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>
</div>

<div class="row g-3">
    <!-- COLUNA ESQUERDA: METADADOS DO LOTE -->
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <strong>Dados do lote</strong>
            </div>
            <div class="card-body">

                <div class="mb-3">
                    <label class="form-label">Observações</label>
                    <textarea class="form-control" rows="4" name="Notes" form="frmCreate">@Model?.Notes</textarea>
                    <div class="form-text">Ex.: “Prontuários recebidos do SAME – Março/2026”.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Caixa (opcional)</label>
                    <input class="form-control" name="BoxId" id="boxId" placeholder="GUID da caixa (opcional)" form="frmCreate" />
                    <div class="form-text">
                        Se você informar a caixa, o sistema registra o vínculo físico no histórico (Item 17/24).
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button id="btnSubmit" type="submit" class="btn btn-primary" form="frmCreate">
                        <i class="bi bi-check2-circle me-1"></i> Criar lote
                    </button>
                    <div class="text-muted small">
                        Ao criar, o lote inicia em <span class="badge text-bg-secondary">RECEIVED</span> e registra histórico automaticamente.
                    </div>
                </div>

            </div>
        </div>

        <div class="card shadow-sm mt-3">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <strong>Resumo</strong>
                <span class="text-muted small" id="resumeCount">0 documentos</span>
            </div>
            <div class="card-body">
                <div class="small text-muted mb-2">Você está prestes a criar um lote com:</div>
                <ul class="mb-0">
                    <li><span id="resumeDocs">0</span> documento(s) selecionado(s)</li>
                    <li>Caixa: <span class="text-muted" id="resumeBox">—</span></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- COLUNA DIREITA: SELEÇÃO DE DOCUMENTOS -->
    <div class="col-lg-7">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white">
                <strong>Adicionar documentos</strong>
            </div>
            <div class="card-body">
                <label class="form-label">Buscar (código ou título)</label>
                <input id="docSearch" class="form-control" placeholder="Digite 3+ caracteres..." autocomplete="off" />
                <div id="docResults" class="list-group mt-2" style="max-height:280px; overflow:auto; display:none;"></div>
                <div class="form-text">Clique em um resultado para adicionar à lista.</div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <strong>Documentos selecionados</strong>
                <span class="text-muted small" id="pickedCount">0</span>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:180px;">Código</th>
                                <th>Título</th>
                                <th style="width:90px;" class="text-end">Ação</th>
                            </tr>
                        </thead>
                        <tbody id="pickedBody">
                            <tr id="pickedEmpty">
                                <td colspan="3" class="text-center text-muted py-4">
                                    Nenhum documento selecionado.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white d-flex align-items-center justify-content-between">
                <div class="text-muted small">
                    Dica: você pode criar o lote só com observações, mas o ideal é já selecionar documentos.
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnClear" disabled>
                    <i class="bi bi-eraser me-1"></i> Limpar seleção
                </button>
            </div>
        </div>
    </div>
</div>

<!-- FORM REAL DE POST (com DocumentIds dinâmico) -->
<form id="frmCreate" method="post" asp-action="New">
    @Html.AntiForgeryToken()
    <div id="docHidden"></div>
</form>

@section Scripts {
    <script>
        (() => {
          const input = document.getElementById('docSearch');
          const results = document.getElementById('docResults');

          const pickedBody = document.getElementById('pickedBody');
          const pickedEmpty = document.getElementById('pickedEmpty');
          const hidden = document.getElementById('docHidden');

          const pickedCount = document.getElementById('pickedCount');
          const resumeCount = document.getElementById('resumeCount');
          const resumeDocs = document.getElementById('resumeDocs');
          const resumeBox = document.getElementById('resumeBox');
          const boxId = document.getElementById('boxId');

          const btnClear = document.getElementById('btnClear');

          // map: docId -> { id, code, title }
          const picked = new Map();
          let timer = null;

          function esc(s){
            return (s ?? '').toString().replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
          }

          function syncHidden() {
            hidden.innerHTML = '';
            for (const id of picked.keys()) {
              const i = document.createElement('input');
              i.type = 'hidden';
              i.name = 'DocumentIds';
              i.value = id;
              hidden.appendChild(i);
            }
          }

          function updateUI() {
            const n = picked.size;
            pickedCount.textContent = n;
            resumeDocs.textContent = n;
            resumeCount.textContent = `${n} documento(s)`;
            btnClear.disabled = n === 0;
            pickedEmpty.style.display = n === 0 ? '' : 'none';

            resumeBox.textContent = (boxId.value || '').trim() ? boxId.value.trim() : '—';
          }

          function addPicked(d) {
            if (!d || !d.id) return;
            if (picked.has(d.id)) return;

            picked.set(d.id, { id: d.id, code: d.code || '(sem código)', title: d.title || '' });

            const tr = document.createElement('tr');
            tr.dataset.docId = d.id;
            tr.innerHTML = `
              <td class="fw-semibold">${esc(d.code || '(sem código)')}</td>
              <td>${esc(d.title || '')}</td>
              <td class="text-end">
                <button type="button" class="btn btn-sm btn-outline-danger">
                  <i class="bi bi-x-lg"></i>
                </button>
              </td>
            `;
            tr.querySelector('button').addEventListener('click', () => {
              picked.delete(d.id);
              tr.remove();
              syncHidden();
              updateUI();
            });

            pickedBody.appendChild(tr);
            syncHidden();
            updateUI();
          }

          function clearPickList() {
            picked.clear();
            // remove todas as linhas, mantendo a placeholder
            [...pickedBody.querySelectorAll('tr')].forEach(r => {
              if (r.id !== 'pickedEmpty') r.remove();
            });
            syncHidden();
            updateUI();
          }

          btnClear.addEventListener('click', clearPickList);

          boxId.addEventListener('input', updateUI);

          async function search(q) {
            const url = `/Batches/DocumentsSearch?q=${encodeURIComponent(q)}&take=20`;
            const r = await fetch(url, { headers: { 'Accept': 'application/json' }});
            if (!r.ok) return [];
            return await r.json();
          }

          function render(list) {
            results.innerHTML = '';
            if (!list || list.length === 0) { results.style.display='none'; return; }
            results.style.display = '';

            for (const d of list) {
              const btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'list-group-item list-group-item-action';
              btn.innerHTML = `
                <div class="fw-semibold">${esc(d.code || '(sem código)')}</div>
                <div class="small text-muted">${esc(d.title || '')}</div>
                <div class="small">${esc(d.status || '')}</div>
              `;
              btn.addEventListener('click', () => {
                addPicked(d);
                results.style.display='none';
                input.value = '';
                input.focus();
              });
              results.appendChild(btn);
            }
          }

          input.addEventListener('input', () => {
            const q = input.value.trim();
            if (timer) clearTimeout(timer);
            if (q.length < 3) { results.style.display='none'; return; }

            timer = setTimeout(async () => {
              const list = await search(q);
              render(list);
            }, 250);
          });

          document.addEventListener('click', (e) => {
            if (!results.contains(e.target) && e.target !== input) results.style.display='none';
          });

          // inicial
          updateUI();
        })();
    </script>
}