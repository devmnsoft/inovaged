@using InovaGed.Application.Ged.Batches
@model BatchCreateVM

@{
    ViewData["Title"] = "Novo lote";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="text-muted small">Crie um lote para agrupar documentos.</div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">
        Voltar
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" asp-action="New">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <!-- Ajuste os campos conforme seu BatchCreateVM real -->
                <div class="col-md-6">
                    <label class="form-label">Observações</label>
                    <textarea class="form-control" rows="4" name="Notes">@Model?.Notes</textarea>
                    <div class="form-text">Opcional.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Status inicial</label>
                    <input class="form-control" name="Status" value="@Model?.Status" placeholder="Ex.: OPEN" />
                    <div class="form-text">Se o seu backend ignora esse campo, pode remover da view.</div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-check2-circle me-1"></i> Criar
                </button>
                <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>