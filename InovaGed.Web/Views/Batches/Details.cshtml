@using InovaGed.Application.Ged.Batches

@{
    var header = ViewBag.Header as BatchRowDto;
    var items = ViewBag.Items as List<BatchItemDto> ?? new List<BatchItemDto>();
    var history = ViewBag.History as List<BatchHistoryDto> ?? new List<BatchHistoryDto>();

    ViewData["Title"] = header is null ? "Detalhes do lote" : $"Lote #{header.BatchNo}";

    string StatusLabel(string value) => value switch
    {
        "RECEIVED" => "Recebido",
        "TRIAGE" => "Triagem",
        "DIGITIZATION" => "Digitalização",
        "INDEXING" => "Indexação",
        "ARCHIVED" => "Arquivado",
        _ => string.IsNullOrWhiteSpace(value) ? "Não informado" : value
    };

    string StatusDescription(string value) => value switch
    {
        "RECEIVED" => "O lote foi recebido e aguarda conferência inicial.",
        "TRIAGE" => "O lote está em triagem, conferência e separação documental.",
        "DIGITIZATION" => "O lote está em digitalização ou preparação para captura.",
        "INDEXING" => "O lote está em classificação, indexação e complementação de metadados.",
        "ARCHIVED" => "O lote foi tratado e arquivado.",
        _ => "Etapa não identificada."
    };

    string StatusBadge(string value) => value switch
    {
        "RECEIVED" => "text-bg-secondary",
        "TRIAGE" => "text-bg-info",
        "DIGITIZATION" => "text-bg-primary",
        "INDEXING" => "text-bg-warning text-dark",
        "ARCHIVED" => "text-bg-success",
        _ => "text-bg-light text-dark border"
    };

    string StatusIcon(string value) => value switch
    {
        "RECEIVED" => "bi-inbox",
        "TRIAGE" => "bi-diagram-3",
        "DIGITIZATION" => "bi-scanner",
        "INDEXING" => "bi-tags",
        "ARCHIVED" => "bi-archive",
        _ => "bi-question-circle"
    };

    var canDelete = header is not null && header.Status != "ARCHIVED";
}

@if (header is null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>
        Não foi possível carregar o lote.
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i>
        Voltar para lotes
    </a>

    return;
}

@if (TempData["Err"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>@err</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Ok"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2">
        <i class="bi bi-check-circle-fill"></i>
        <div>@ok</div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h3 class="mb-1">
            <i class="bi bi-box-seam me-2"></i>
            @ViewData["Title"]
        </h3>
        <div class="text-muted">
            Consulte, atualize e acompanhe os documentos vinculados a este lote de tratamento documental.
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Batches" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>
            Voltar
        </a>

        <a class="btn btn-primary" asp-controller="Batches" asp-action="New">
            <i class="bi bi-plus-circle me-1"></i>
            Novo lote
        </a>

        @if (canDelete)
        {
            <button type="button"
                    class="btn btn-outline-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteBatchModal">
                <i class="bi bi-trash me-1"></i>
                Excluir lote
            </button>
        }
        else
        {
            <button type="button"
                    class="btn btn-outline-danger"
                    disabled
                    title="Lotes arquivados não podem ser excluídos.">
                <i class="bi bi-trash me-1"></i>
                Excluir lote
            </button>
        }
    </div>
</div>

@if (!canDelete)
{
    <div class="alert alert-warning border-0 shadow-sm">
        <i class="bi bi-lock me-1"></i>
        Este lote está arquivado. Por segurança e rastreabilidade documental, lotes arquivados não podem ser excluídos diretamente.
    </div>
}

<div class="alert alert-primary border-0 shadow-sm mb-4">
    <div class="d-flex gap-3">
        <div class="fs-3">
            <i class="bi bi-info-circle"></i>
        </div>

        <div>
            <strong>Para que serve esta tela?</strong>

            <div class="small mt-1">
                Esta tela permite acompanhar o ciclo completo de um lote documental.
                Aqui você pode editar observações, alterar a etapa do tratamento, adicionar documentos,
                remover documentos do lote, mover documentos entre caixas e consultar o histórico de auditoria.
            </div>

            <div class="small mt-2">
                A exclusão do lote, quando permitida, é sempre lógica. Isso significa que o lote deixa de aparecer nas consultas,
                mas o registro histórico e a auditoria permanecem preservados para rastreabilidade.
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <span class="badge @StatusBadge(header.Status)">
                    <i class="bi @StatusIcon(header.Status) me-1"></i>
                    Etapa atual: @StatusLabel(header.Status)
                </span>

                <span class="badge text-bg-light text-dark border">
                    <i class="bi bi-files me-1"></i>
                    @items.Count documento(s)
                </span>

                <span class="badge text-bg-light text-dark border">
                    <i class="bi bi-clock-history me-1"></i>
                    @history.Count evento(s) no histórico
                </span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <strong>
                    <i class="bi bi-clipboard-data me-1"></i>
                    Resumo do lote
                </strong>
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <div class="text-muted small">Número do lote</div>
                    <div class="fs-5 fw-bold">#@header.BatchNo</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Etapa atual</div>
                    <span class="badge @StatusBadge(header.Status)">
                        <i class="bi @StatusIcon(header.Status) me-1"></i>
                        @StatusLabel(header.Status)
                    </span>
                    <div class="small text-muted mt-1">
                        @StatusDescription(header.Status)
                    </div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Criado em</div>
                    <div class="fw-semibold">@header.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Documentos vinculados</div>
                    <div class="fw-semibold">@items.Count documento(s)</div>
                </div>

                <div>
                    <div class="text-muted small">Observações atuais</div>
                    <div class="border rounded p-3 bg-light">
                        @(!string.IsNullOrWhiteSpace(header.Notes) ? header.Notes : "Sem observações registradas.")
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <strong>
                    <i class="bi bi-pencil-square me-1"></i>
                    Editar informações do lote
                </strong>
            </div>

            <div class="card-body">
                <form method="post"
                      asp-controller="Batches"
                      asp-action="Update"
                      asp-route-id="@header.Id">

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Observações do lote</label>
                        <textarea class="form-control"
                                  name="notes"
                                  rows="5"
                                  maxlength="1000"
                                  placeholder="Informe origem, setor, período, responsável, observações de tratamento ou conferência...">@header.Notes</textarea>

                        <div class="form-text">
                            Use este campo para registrar informações úteis para rastreabilidade do lote.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-save me-1"></i>
                        Salvar alterações
                    </button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <strong>
                    <i class="bi bi-arrow-repeat me-1"></i>
                    Alterar etapa do tratamento
                </strong>
            </div>

            <div class="card-body">
                <form method="post"
                      asp-controller="Batches"
                      asp-action="ChangeStatus"
                      asp-route-id="@header.Id">

                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nova etapa</label>

                        @if (ViewBag.AllowedStatus is string[] allowed && allowed.Length > 0)
                        {
                            <select class="form-select" name="status" required>
                                <option value="">Selecione a nova etapa...</option>

                                @foreach (var s in allowed)
                                {
                                    if (s == header.Status)
                                    {
                                        <option value="@s" selected>@StatusLabel(s) — atual</option>
                                    }
                                    else
                                    {
                                        <option value="@s">@StatusLabel(s)</option>
                                    }
                                }
                            </select>
                        }
                        else
                        {
                            <input class="form-control"
                                   name="status"
                                   placeholder="Ex.: RECEIVED, TRIAGE, DIGITIZATION, INDEXING, ARCHIVED" />
                        }

                        <div class="form-text">
                            A alteração de etapa registra histórico e auditoria automaticamente.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Justificativa ou observação</label>
                        <input class="form-control"
                               name="notes"
                               placeholder="Ex.: Triagem concluída, enviado para digitalização..." />
                    </div>

                    <button class="btn btn-outline-primary w-100" type="submit">
                        <i class="bi bi-check2-circle me-1"></i>
                        Atualizar etapa
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <strong>
                        <i class="bi bi-files me-1"></i>
                        Documentos do lote
                    </strong>
                    <div class="small text-muted">
                        Documentos vinculados a este lote de tratamento documental.
                    </div>
                </div>

                <span class="badge text-bg-secondary">@items.Count item(ns)</span>
            </div>

            <div class="card-body p-0">
                @if (items.Count == 0)
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                        <h5 class="mb-1">Nenhum documento vinculado</h5>
                        <div>Use o painel abaixo para buscar e adicionar documentos ao lote.</div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 180px;">Código</th>
                                    <th>Documento</th>
                                    <th style="width: 240px;">Caixa física</th>
                                    <th style="width: 230px;" class="text-end">Ações</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var it in items)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold font-monospace">
                                                @(string.IsNullOrWhiteSpace(it.DocumentCode) ? "—" : it.DocumentCode)
                                            </div>
                                        </td>

                                        <td>
                                            <div class="fw-semibold">
                                                @(string.IsNullOrWhiteSpace(it.DocumentTitle) ? "Documento sem título" : it.DocumentTitle)
                                            </div>
                                            <div class="small text-muted">
                                                ID: @it.DocumentId
                                            </div>
                                        </td>

                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(it.BoxLabel))
                                            {
                                                <span class="badge text-bg-light text-dark border">
                                                    <i class="bi bi-box me-1"></i>
                                                    @it.BoxLabel
                                                </span>
                                            }
                                            else if (it.BoxId.HasValue && it.BoxId.Value != Guid.Empty)
                                            {
                                                <span class="badge text-bg-light text-dark border">
                                                    <i class="bi bi-box me-1"></i>
                                                    @it.BoxId
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Sem caixa vinculada</span>
                                            }
                                        </td>

                                        <td class="text-end">
                                            <div class="btn-group">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-secondary"
                                                        onclick="openMoveModal('@it.DocumentId','@it.DocumentCode')"
                                                        title="Mover documento para outra caixa">
                                                    <i class="bi bi-box-arrow-in-right"></i>
                                                </button>

                                                <form class="d-inline"
                                                      method="post"
                                                      asp-controller="Batches"
                                                      asp-action="RemoveItem"
                                                      asp-route-id="@header.Id"
                                                      onsubmit="return confirm('Deseja remover este documento do lote? A ação será registrada em auditoria.');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@it.DocumentId" />

                                                    <button class="btn btn-sm btn-outline-danger" type="submit" title="Remover documento do lote">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <strong>
                    <i class="bi bi-plus-circle me-1"></i>
                    Adicionar documento ao lote
                </strong>
                <div class="small text-muted">
                    Busque um documento já cadastrado no GED e vincule ao lote atual.
                </div>
            </div>

            <div class="card-body">
                <div class="alert alert-light border small">
                    <i class="bi bi-info-circle me-1"></i>
                    Digite pelo menos 3 caracteres para localizar documentos por código ou título.
                    Após selecionar o documento, clique em <strong>Adicionar ao lote</strong>.
                </div>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Buscar documento</label>
                        <input id="docSearch"
                               class="form-control"
                               placeholder="Digite código, título ou palavra-chave..."
                               autocomplete="off" />

                        <div id="docLoading" class="small text-muted mt-2 d-none">
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            Buscando documentos...
                        </div>

                        <div id="docResults"
                             class="list-group mt-2"
                             style="max-height: 260px; overflow: auto; display: none;">
                        </div>

                        <div id="docEmpty" class="alert alert-warning small mt-2 d-none mb-0">
                            Nenhum documento encontrado.
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Caixa física</label>
                        <input id="boxId"
                               class="form-control"
                               placeholder="GUID da caixa, se houver" />
                        <div class="form-text">
                            Opcional. Use quando o documento estiver vinculado a uma caixa física.
                        </div>
                    </div>
                </div>

                <form id="addDocForm"
                      method="post"
                      asp-controller="Batches"
                      asp-action="AddItem"
                      asp-route-id="@header.Id"
                      class="mt-3">

                    @Html.AntiForgeryToken()

                    <input type="hidden" name="documentId" id="documentId" />
                    <input type="hidden" name="boxId" id="boxIdHidden" />

                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="text-muted small">Documento selecionado</div>
                        <div class="fw-semibold" id="pickedDoc">Nenhum documento selecionado.</div>
                    </div>

                    <button class="btn btn-primary" type="submit" disabled id="btnAddDoc">
                        <i class="bi bi-plus-circle me-1"></i>
                        Adicionar ao lote
                    </button>
                </form>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                <div>
                    <strong>
                        <i class="bi bi-clock-history me-1"></i>
                        Histórico e auditoria do lote
                    </strong>
                    <div class="small text-muted">
                        Registro das principais ações executadas neste lote.
                    </div>
                </div>

                <span class="badge text-bg-secondary">@history.Count evento(s)</span>
            </div>

            <div class="card-body p-0">
                @if (history.Count == 0)
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-clock-history fs-1 d-block mb-3"></i>
                        <h5 class="mb-1">Sem histórico registrado</h5>
                        <div>As alterações do lote serão exibidas aqui.</div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 170px;">Data/hora</th>
                                    <th style="width: 150px;">De</th>
                                    <th style="width: 150px;">Para</th>
                                    <th>Descrição</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var h in history)
                                {
                                    <tr>
                                        <td>
                                            <div>@h.ChangedAt.ToString("dd/MM/yyyy")</div>
                                            <div class="small text-muted">@h.ChangedAt.ToString("HH:mm")</div>
                                        </td>

                                        <td>
                                            <span class="badge text-bg-light text-dark border">
                                                @(string.IsNullOrWhiteSpace(h.FromStatus) ? "—" : StatusLabel(h.FromStatus))
                                            </span>
                                        </td>

                                        <td>
                                            <span class="badge text-bg-light text-dark border">
                                                @(string.IsNullOrWhiteSpace(h.ToStatus) ? "—" : StatusLabel(h.ToStatus))
                                            </span>
                                        </td>

                                        <td>
                                            <div class="text-truncate" style="max-width: 520px;" title="@h.Notes">
                                                @(!string.IsNullOrWhiteSpace(h.Notes) ? h.Notes : "Evento registrado sem observação.")
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="moveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post"
                  asp-controller="Batches"
                  asp-action="MoveItem"
                  asp-route-id="@header.Id">

                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Mover documento para caixa
                    </h5>

                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="documentId" id="moveDocId" />

                    <div class="mb-3">
                        <div class="text-muted small">Documento selecionado</div>
                        <div class="fw-semibold" id="moveDocLabel">—</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nova caixa física</label>
                        <input class="form-control"
                               name="newBoxId"
                               placeholder="Informe o GUID da nova caixa. Deixe vazio para remover vínculo." />
                        <div class="form-text">
                            A movimentação registra histórico físico e auditoria do lote.
                        </div>
                    </div>

                    <div class="alert alert-warning small mb-0">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Confirme a caixa antes de salvar. Esta ação será registrada no histórico.
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i>
                        Confirmar movimentação
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteBatchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post"
                  asp-controller="Batches"
                  asp-action="Delete"
                  asp-route-id="@header.Id">

                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title text-danger">
                        <i class="bi bi-trash me-1"></i>
                        Excluir lote
                    </h5>

                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>

                <div class="modal-body">
                    <div class="alert alert-warning">
                        <strong>Atenção:</strong> esta ação não apaga fisicamente o lote do banco.
                        O lote será marcado como inativo e deixará de aparecer nas consultas principais.
                        A auditoria e o histórico serão preservados.
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Lote selecionado</div>
                        <div class="fw-semibold">#@header.BatchNo — @StatusLabel(header.Status)</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Motivo da exclusão</label>
                        <textarea class="form-control"
                                  name="reason"
                                  rows="4"
                                  maxlength="500"
                                  required
                                  placeholder="Informe o motivo da exclusão lógica do lote..."></textarea>

                        <div class="form-text">
                            O motivo será registrado no histórico e na auditoria do sistema.
                        </div>
                    </div>

                    <div class="small text-muted">
                        Documentos vinculados ao lote não serão apagados do GED. Apenas o vínculo ativo com este lote será inativado.
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>
                        Confirmar exclusão lógica
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('docSearch');
            const results = document.getElementById('docResults');
            const loading = document.getElementById('docLoading');
            const empty = document.getElementById('docEmpty');

            const hiddenDocId = document.getElementById('documentId');
            const hiddenBoxId = document.getElementById('boxIdHidden');
            const boxId = document.getElementById('boxId');
            const btn = document.getElementById('btnAddDoc');
            const picked = document.getElementById('pickedDoc');

            let timer = null;

            function clearPick() {
                hiddenDocId.value = '';
                btn.disabled = true;
                picked.textContent = 'Nenhum documento selecionado.';
            }

            function escapeHtml(s) {
                return (s ?? '').toString().replace(/[&<>"']/g, m => ({
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                }[m]));
            }

            function setLoading(value) {
                loading?.classList.toggle('d-none', !value);
            }

            function hideResults() {
                results.style.display = 'none';
                empty?.classList.add('d-none');
            }

            function render(list) {
                results.innerHTML = '';

                if (!list || list.length === 0) {
                    results.style.display = 'none';
                    empty?.classList.remove('d-none');
                    return;
                }

                empty?.classList.add('d-none');
                results.style.display = '';

                for (const d of list) {
                    const item = document.createElement('button');
                    item.type = 'button';
                    item.className = 'list-group-item list-group-item-action';

                    item.innerHTML = `
                        <div class="d-flex justify-content-between gap-2">
                            <div>
                                <div class="fw-semibold">${escapeHtml(d.code || '(sem código)')}</div>
                                <div class="small text-muted">${escapeHtml(d.title || '')}</div>
                            </div>
                            <span class="badge text-bg-light align-self-start">Selecionar</span>
                        </div>
                    `;

                    item.addEventListener('click', () => {
                        hiddenDocId.value = d.id;
                        btn.disabled = false;
                        picked.textContent = `${d.code || '(sem código)'} - ${d.title || ''}`;
                        hideResults();
                    });

                    results.appendChild(item);
                }
            }

            async function search(q) {
                const url = `/Batches/DocumentsSearch?q=${encodeURIComponent(q)}&take=20`;

                const response = await fetch(url, {
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok)
                    throw new Error('Erro ao buscar documentos.');

                return await response.json();
            }

            input?.addEventListener('input', () => {
                const q = input.value.trim();

                clearPick();

                if (timer)
                    clearTimeout(timer);

                if (q.length < 3) {
                    hideResults();
                    return;
                }

                timer = setTimeout(async () => {
                    try {
                        setLoading(true);
                        const list = await search(q);
                        render(list);
                    } catch {
                        results.style.display = 'none';
                        empty.textContent = 'Erro ao buscar documentos. Tente novamente.';
                        empty.classList.remove('d-none');
                    } finally {
                        setLoading(false);
                    }
                }, 300);
            });

            boxId?.addEventListener('input', () => {
                hiddenBoxId.value = boxId.value.trim();
            });

            document.addEventListener('click', e => {
                if (!results.contains(e.target) && e.target !== input) {
                    results.style.display = 'none';
                }
            });
        })();

        function openMoveModal(docId, docCode) {
            const modalElement = document.getElementById('moveModal');

            if (!modalElement)
                return;

            document.getElementById('moveDocId').value = docId;
            document.getElementById('moveDocLabel').textContent = docCode || docId;

            const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
            modal.show();
        }
    </script>
}