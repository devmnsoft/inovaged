@model InovaGed.Web.Models.Protocolo.ProtocoloComprovanteVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Comprovante @Model.Numero</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { padding: 32px; font-size: 14px; }
        .print-actions { position: fixed; top: 10px; right: 10px; }
        media print { .print-actions { display:none; } body { padding: 0; } }
        .box { border: 1px solid #333; padding: 12px; margin-bottom: 12px; }
    </style>
</head>
<body>
    <div class="print-actions">
        <button onclick="window.print()" class="btn btn-primary btn-sm">Imprimir</button>
        <a href="/Protocolo/Details/@Model.Id" class="btn btn-secondary btn-sm">Voltar</a>
    </div>

    <div class="text-center mb-4">
        <h3>COMPROVANTE DE PROTOCOLO</h3>
        <h4>@Model.Numero</h4>
    </div>

    <div class="box">
        <div class="row">
            <div class="col-4"><strong>Data/Hora:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
            <div class="col-4"><strong>Status:</strong> @Model.Status</div>
            <div class="col-4"><strong>Prazo:</strong> @Model.DataPrazo?.ToString("dd/MM/yyyy")</div>
            <div class="col-6"><strong>Setor Origem:</strong> @Model.SetorOrigem</div>
            <div class="col-6"><strong>Setor Atual/Destino:</strong> @Model.SetorAtual</div>
        </div>
    </div>

    <div class="box">
        <div><strong>Espécie:</strong> @Model.Especie</div>
        <div><strong>Tipo:</strong> @Model.TipoSolicitacao</div>
        <div><strong>Procedência:</strong> @Model.Procedencia</div>
        <div><strong>Origem:</strong> @Model.OrigemPedido</div>
        <div><strong>Assunto:</strong> @Model.Assunto</div>
    </div>

    <div class="box">
        <div><strong>Solicitante:</strong> @Model.SolicitanteNome</div>
        <div><strong>Interessado:</strong> @Model.Interessado</div>
        <div><strong>CPF/CNPJ:</strong> @Model.CpfCnpj</div>
        <div><strong>Criado por:</strong> @Model.CriadoPorNome</div>
    </div>

    <div class="box">
        <strong>Anexos (@Model.TotalAnexos):</strong>
        <table class="table table-sm mt-2">
            <thead><tr><th>Arquivo</th><th>Setor</th><th>Usuário</th><th>Data</th></tr></thead>
            <tbody>
            @foreach (var a in Model.Anexos)
            {
                <tr>
                    <td>@a.NomeArquivo</td>
                    <td>@a.SetorNome</td>
                    <td>@a.AnexadoPorNome</td>
                    <td>@a.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="text-center mt-5">
        <small>Documento gerado eletronicamente pelo InovaGED.</small>
    </div>
</body>
</html>
