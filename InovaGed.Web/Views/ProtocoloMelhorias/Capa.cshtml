@model InovaGed.Web.Models.Protocolo.ProtocoloComprovanteVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>Capa @Model.Numero</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { padding: 32px; font-size: 14px; }
        .print-actions { position: fixed; top: 10px; right: 10px; }
        media print { .print-actions { display:none; } body { padding: 0; } }
        .capa { border: 2px solid #111; padding: 24px; min-height: 95vh; }
        .linha { border-bottom: 1px solid #ccc; padding: 8px 0; }
    </style>
</head>
<body>
    <div class="print-actions">
        <button onclick="window.print()" class="btn btn-primary btn-sm">Imprimir</button>
        <a href="/Protocolo/Details/@Model.Id" class="btn btn-secondary btn-sm">Voltar</a>
    </div>

    <div class="capa">
        <div class="text-center mb-5">
            <h3>INOVAGED</h3>
            <h4>CAPA DE PROCESSO / PROTOCOLO</h4>
            <h2 class="mt-4">@Model.Numero</h2>
        </div>

        <div class="linha"><strong>Espécie:</strong> @Model.Especie</div>
        <div class="linha"><strong>Procedência:</strong> @Model.Procedencia</div>
        <div class="linha"><strong>Interessado:</strong> @Model.Interessado</div>
        <div class="linha"><strong>CPF/CNPJ:</strong> @Model.CpfCnpj</div>
        <div class="linha"><strong>Assunto:</strong> @Model.Assunto</div>
        <div class="linha"><strong>Setor Atual:</strong> @Model.SetorAtual</div>
        <div class="linha"><strong>Status:</strong> @Model.Status</div>
        <div class="linha"><strong>Data de Abertura:</strong> @Model.DataAbertura?.ToString("dd/MM/yyyy HH:mm")</div>
        <div class="linha"><strong>Prazo:</strong> @Model.DataPrazo?.ToString("dd/MM/yyyy")</div>

        <h5 class="mt-4">Histórico Resumido</h5>
        <table class="table table-sm">
            <thead><tr><th>Data</th><th>Ação</th><th>Origem</th><th>Destino</th><th>Usuário</th></tr></thead>
            <tbody>
            @foreach (var m in Model.Movimentos)
            {
                <tr>
                    <td>@m.DataTramitacao.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@m.Acao</td>
                    <td>@m.SetorOrigemNome</td>
                    <td>@m.SetorDestinoNome</td>
                    <td>@m.UsuarioNome</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</body>
</html>
