@using InovaGed.Web.Models.Workflow
@model WorkflowDefinitionFormVM

@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Editar workflow" : "Novo workflow";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h3 class="m-0">@ViewData["Title"]</h3>
        <div class="text-muted">Definição de workflow (código, nome e descrição).</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>
</div>

<form method="post">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" asp-for="Id" />
    }

    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label">Código</label>
            <input asp-for="Code" class="form-control" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="col-md-9">
            <label class="form-label">Nome</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label class="form-label">Descrição</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        @if (isEdit)
        {
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select asp-for="IsActive" class="form-select">
                    <option value="true">Ativo</option>
                    <option value="false">Inativo</option>
                </select>
            </div>
        }
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i> Salvar</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancelar</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
