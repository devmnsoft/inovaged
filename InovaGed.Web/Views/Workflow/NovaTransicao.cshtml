@using InovaGed.Domain.Workflow
@using InovaGed.Web.Models.Workflow 
@model WorkflowTransitionFormVM

@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Editar transição" : "Nova transição";
    var stages = ViewBag.Stages as IReadOnlyList<WorkflowStageRowDto> ?? Array.Empty<WorkflowStageRowDto>();
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h3 class="m-0">@ViewData["Title"]</h3>
        <div class="text-muted">Transições entre etapas.</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-id="@Model.WorkflowId">
        <i class="bi bi-arrow-left me-1"></i> Voltar
    </a>
</div>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="WorkflowId" />
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">De (etapa)</label>
            <select asp-for="FromStageId" class="form-select">
                @foreach (var s in stages)
                {
                    <option value="@s.Id">@s.SortOrder - @s.Code - @s.Name</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label">Para (etapa)</label>
            <select asp-for="ToStageId" class="form-select">
                @foreach (var s in stages)
                {
                    <option value="@s.Id">@s.SortOrder - @s.Code - @s.Name</option>
                }
            </select>
        </div>

        <div class="col-md-8">
            <label class="form-label">Nome da transição</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="RequiresReason" class="form-check-input" />
                <label class="form-check-label">Exige justificativa</label>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i> Salvar</button>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-id="@Model.WorkflowId">Cancelar</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
