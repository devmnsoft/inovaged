@{
    ViewData["Title"] = "Busca de Documentos Hospitalares";
}

@section Styles {
    <link rel="stylesheet" href="~/css/hospital-documents.css" asp-append-version="true" />
}

<div class="hospital-documents-page hospital-search-page" data-hospital-documents-page>
    <section class="hospital-search-hero" aria-labelledby="hospitalSearchTitle">
        <div class="hospital-hero-grid">
            <div class="hospital-hero-main">
                <span class="hospital-secure-badge"><i class="bi bi-shield-lock" aria-hidden="true"></i> Consulta segura somente leitura</span>
                <h1 id="hospitalSearchTitle">Busca de Documentos Hospitalares</h1>
                <p class="hospital-hero-subtitle">Localize documentos por nome, prontuário, termo do OCR, paciente, exame ou conteúdo textual.</p>

                <form id="hospitalSearchForm" class="hospital-search-form" autocomplete="off">
                    <div class="hospital-search-input-wrap hospital-search-box-wrapper">
                        <label class="visually-hidden" for="searchInput">Termo de busca hospitalar</label>
                        <i class="bi bi-search hospital-search-icon" aria-hidden="true"></i>
                        <input id="searchInput" class="hospital-search-input" type="search" autocomplete="off" placeholder="Busque por nome, prontuário, APAC, carcinoma, exame, laudo ou trecho do OCR..." aria-describedby="searchHelp" aria-controls="suggestions" />
                        <button id="btnClearSearch" class="hospital-input-clear" type="button" aria-label="Limpar busca"><i class="bi bi-x-lg" aria-hidden="true"></i></button>
                        <div id="suggestions" class="hospital-suggestions hospital-suggestions-dropdown" role="listbox" aria-label="Sugestões de busca"></div>
                    </div>

                    <label class="visually-hidden" for="typeFilter">Tipo documental</label>
                    <select id="typeFilter" class="hospital-type-select" aria-label="Tipo documental">
                        <option value="">Todos os tipos</option>
                        <option value="pdf">PDF</option>
                        <option value="word">Documento Word</option>
                        <option value="image">Imagem digitalizada</option>
                    </select>

                    <button id="btnSearch" type="submit" class="hospital-btn-primary"><span class="btn-label">Pesquisar</span></button>
                    <button id="btnAdvancedFilters" class="hospital-btn-secondary" type="button" data-bs-toggle="offcanvas" data-bs-target="#advancedFiltersCanvas" aria-controls="advancedFiltersCanvas"><i class="bi bi-sliders" aria-hidden="true"></i> Filtros</button>
                </form>

                <div id="searchHelp" class="hospital-search-help">Digite uma informação e pressione Enter ou clique em Pesquisar.</div>

                <div class="hospital-quick-chips" aria-label="Filtros rápidos">
                    <button type="button" class="hospital-filter-chip" data-chip="type" data-type="pdf">PDF</button>
                    <button type="button" class="hospital-filter-chip" data-chip="type" data-type="image">Imagens</button>
                    <button type="button" class="hospital-filter-chip" data-chip="ocr" data-ocr="with">Com OCR</button>
                    <button type="button" class="hospital-filter-chip" data-chip="ocr" data-ocr="without">Sem OCR</button>
                    <button type="button" class="hospital-filter-chip" data-chip="recent" data-recent="true">Últimos 7 dias</button>
                    <button type="button" class="hospital-filter-chip" data-chip="term" data-term="prontuário">Prontuários</button>
                    <button type="button" class="hospital-filter-chip" data-chip="term" data-term="exame">Exames</button>
                    <button type="button" class="hospital-filter-chip" data-chip="term" data-term="laudo">Laudos</button>
                    <button type="button" class="hospital-filter-chip" data-chip="term" data-term="APAC">APAC</button>
                    <button type="button" class="hospital-filter-chip" data-chip="term" data-term="oncologia">Oncologia</button>
                    <button type="button" class="hospital-filter-chip" data-chip="term" data-term="contrato">Contratos/Administrativo</button>
                </div>

                <div id="activeFilters" class="hospital-active-filters" aria-live="polite"></div>
            </div>
        </div>
    </section>

    <section class="hospital-results-shell" aria-label="Central de resultados hospitalares">
        <div class="hospital-results-layout">
            <section class="hospital-results-column" aria-label="Resultados encontrados">
                <main class="hospital-results-panel">
                    <div class="hospital-panel-header">
                        <div>
                            <h2>Resultados da busca</h2>
                            <p id="resultsMeta">Nenhuma busca executada ainda.</p>
                        </div>
                        <div class="hospital-panel-actions">
                            <button id="btnToggleView" type="button" class="btn btn-sm btn-outline-secondary"><i class="bi bi-grid-3x3-gap" aria-hidden="true"></i> Lista/Card</button>
                            <button id="btnExportCsv" type="button" class="btn btn-sm btn-outline-secondary"><i class="bi bi-filetype-csv" aria-hidden="true"></i> CSV</button>
                            <button id="btnClearAll" type="button" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle" aria-hidden="true"></i> Limpar</button>
                        </div>
                    </div>

                    <div id="searchSummary" class="hospital-search-summary-inline" aria-live="polite"></div>
                    <div id="resultsList" class="hospital-results-list hospital-results-list-mode" aria-live="polite"></div>
                    <div class="hospital-load-more-wrap"><button id="btnLoadMore" type="button" class="hospital-btn-secondary d-none">Carregar mais resultados</button></div>
                </main>
            </section>

            <aside id="hospitalPreviewPanel" class="hospital-preview-panel" aria-label="Preview lateral do documento">
                <div class="hospital-preview-header">
                    <div class="hospital-preview-heading">
                        <span id="previewTypeBadge" class="hospital-badge">Documento</span>
                        <h3 id="previewTitle">Selecione um documento</h3>
                        <p id="previewSubtitle">Clique em um resultado da busca para abrir o preview ao lado.</p>
                    </div>
                    <button id="btnClosePreviewPanel" class="btn btn-sm btn-outline-secondary" type="button" aria-label="Limpar preview"><i class="bi bi-x-lg" aria-hidden="true"></i></button>
                </div>

                <div class="hospital-preview-toolbar">
                    <button id="btnExpandPreview" type="button" class="btn btn-sm btn-outline-primary js-expand-preview"><i class="bi bi-arrows-fullscreen" aria-hidden="true"></i> Expandir</button>
                    <a id="btnOpenNewTab" class="btn btn-sm btn-primary disabled" target="_blank" rel="noopener" aria-disabled="true"><i class="bi bi-box-arrow-up-right" aria-hidden="true"></i> Abrir em nova aba</a>
                    <button id="btnCopyReference" type="button" class="btn btn-sm btn-outline-secondary"><i class="bi bi-clipboard" aria-hidden="true"></i> Copiar referência</button>
                </div>

                <ul class="nav nav-pills hospital-preview-tabs" role="tablist" aria-label="Áreas do painel do documento">
                    <li class="nav-item" role="presentation"><button class="nav-link active" type="button" data-panel-tab="preview" role="tab">Preview</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" type="button" data-panel-tab="ocr" role="tab">OCR</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" type="button" data-panel-tab="meta" role="tab">Dados</button></li>
                </ul>

                <div class="hospital-preview-body">
                    <div id="previewContent" class="hospital-preview-tab-content active" data-panel-content="preview">
                        <div id="previewEmptyState" class="hospital-preview-empty">
                            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                            <strong>Selecione um documento para visualizar.</strong>
                            <span>Clique em um resultado da busca para abrir o preview ao lado.</span>
                        </div>
                        <div id="previewLoading" class="hospital-preview-loading d-none"><span class="spinner-border spinner-border-sm"></span> Carregando preview...</div>
                        <iframe id="hospitalPreviewFrame" class="hospital-preview-frame d-none" title="Preview do documento"></iframe>
                    </div>
                    <div id="ocrContent" class="hospital-preview-tab-content" data-panel-content="ocr">
                        <div id="ocrPanelStatus" class="hospital-ocr-status">Selecione um documento para consultar o OCR.</div>
                        <pre id="ocrPanelText" class="hospital-ocr-text"></pre>
                    </div>
                    <div id="metaContent" class="hospital-preview-tab-content" data-panel-content="meta">
                        <div id="metaPanelContent" class="hospital-meta-list hospital-preview-empty">Nenhum documento selecionado.</div>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="advancedFiltersCanvas" aria-labelledby="advancedFiltersTitle">
        <div class="offcanvas-header">
            <h5 id="advancedFiltersTitle" class="offcanvas-title"><i class="bi bi-funnel" aria-hidden="true"></i> Filtros avançados</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fechar"></button>
        </div>
        <div class="offcanvas-body">
            <div class="row g-3">
                <div class="col-12"><label class="form-label" for="advancedType">Tipo documental</label><select id="advancedType" class="form-select"><option value="">Todos</option><option value="pdf">PDF</option><option value="word">Documento Word</option><option value="image">Imagem</option></select></div>
                <div class="col-12"><label class="form-label" for="advancedOcrStatus">Status OCR</label><select id="advancedOcrStatus" class="form-select"><option value="">Todos</option><option value="with">Com OCR</option><option value="without">Sem OCR</option><option value="PROCESSING">Em processamento</option><option value="PENDING">Na fila</option><option value="ERROR">Com erro</option></select></div>
                <div class="col-6"><label class="form-label" for="dateFrom">Período inicial</label><input id="dateFrom" type="date" class="form-control" /></div>
                <div class="col-6"><label class="form-label" for="dateTo">Período final</label><input id="dateTo" type="date" class="form-control" /></div>
                <div class="col-12"><label class="form-label" for="folderFilter">Pasta</label><input id="folderFilter" class="form-control" placeholder="Nome da pasta" /></div>
                <div class="col-12 form-check form-switch ms-2"><input id="ocrRequired" class="form-check-input" type="checkbox" /><label class="form-check-label" for="ocrRequired">Termo OCR obrigatório</label></div>
                <div class="col-12 form-check form-switch ms-2"><input id="recentOnly" class="form-check-input" type="checkbox" /><label class="form-check-label" for="recentOnly">Apenas documentos recentes</label></div>
                <div class="col-12 form-check form-switch ms-2"><input id="previewOnly" class="form-check-input" type="checkbox" /><label class="form-check-label" for="previewOnly">Apenas com preview</label></div>
                <div class="col-12"><label class="form-label" for="sortFilter">Ordenação</label><select id="sortFilter" class="form-select"><option value="relevance">Mais relevantes</option><option value="recent">Mais recentes</option><option value="az">Nome A-Z</option><option value="type">Tipo documental</option></select></div>
            </div>
            <div id="advancedFilterSummary" class="hospital-filter-summary mt-3">Nenhum filtro avançado aplicado.</div>
            <div class="d-grid gap-2 mt-4"><button id="btnApplyAdvanced" type="button" class="hospital-btn-primary" data-bs-dismiss="offcanvas">Aplicar filtros</button><button id="btnResetAdvanced" type="button" class="hospital-btn-secondary">Limpar filtros</button></div>
        </div>
    </div>


    <div id="hospitalAutocompletePortal" aria-live="polite"></div>

    <div class="modal fade hospital-preview-expanded-modal"
         id="hospitalPreviewExpandedModal"
         tabindex="-1"
         aria-hidden="true">
        <div class="modal-dialog modal-fullscreen-xl-down modal-xl modal-dialog-centered">
            <div class="modal-content hospital-preview-expanded-content">
                <div class="modal-header">
                    <div class="hospital-expanded-preview-heading">
                        <span id="expandedPreviewType" class="badge bg-primary-subtle text-primary">Documento</span>
                        <h5 id="expandedPreviewTitle" class="modal-title">Preview ampliado</h5>
                        <small id="expandedPreviewSubtitle" class="text-muted"></small>
                    </div>

                    <div class="d-flex gap-2 align-items-center hospital-expanded-preview-actions">
                        <button type="button" id="btnExpandedOpenNewTab" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                            Nova aba
                        </button>
                        <button type="button" id="btnExpandedCopyReference" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-clipboard" aria-hidden="true"></i>
                            Copiar referência
                        </button>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>
                </div>

                <div class="modal-body">
                    <iframe id="expandedPreviewFrame"
                            class="hospital-expanded-preview-frame"
                            title="Preview ampliado do documento"></iframe>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/hospital-documents.js" asp-append-version="true"></script>
}
