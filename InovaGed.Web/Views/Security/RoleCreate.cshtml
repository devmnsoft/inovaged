@model InovaGed.Web.Controllers.RoleEditVm
@{
    ViewData["Title"] = "Novo Perfil";
    ViewData["Subtitle"] = "Criar nível de autoridade ()";
}

<div class="container py-3">
    <h3 class="mb-0">@ViewData["Title"]</h3>
    <div class="text-muted mb-3">@ViewData["Subtitle"]</div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input asp-for="Name" class="form-control" placeholder="Ex.: Arquivista" />
                    <span class="text-danger small" asp-validation-for="Name"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Normalizado (opcional)</label>
                    <input asp-for="NormalizedName" class="form-control" placeholder="Ex.: ARQUIVISTA" />
                    <div class="form-text">Se vazio, será gerado automaticamente.</div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-success" type="submit">Salvar</button>
                    <a class="btn btn-outline-secondary" asp-action="Roles">Voltar</a>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mt-3">
                        Verifique os campos e tente novamente.
                    </div>
                }
            </form>
        </div>
    </div>
</div>