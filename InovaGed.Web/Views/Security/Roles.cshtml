@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Perfis e Permissões";
    ViewData["Subtitle"] = "Níveis de autoridade, privilégios e sigilo (PoC 11)";
}

<div class="container py-3">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h3 class="mb-0">@ViewData["Title"]</h3>
            <div class="text-muted">@ViewData["Subtitle"]</div>
        </div>
        <a class="btn btn-success"
           asp-controller="Security"
           asp-action="RoleCreate">
            + Novo Perfil
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Normalizado</th>
                    <th>Criado</th>
                    <th style="width:320px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model ?? Enumerable.Empty<dynamic>())
                {
                    <tr>
                        <td><strong>@r.name</strong></td>
                        <td class="text-muted">@r.normalized_name</td>
                        <td class="small text-muted">@r.created_at</td>
                        <td class="text-end">

                            <a class="btn btn-sm btn-outline-secondary me-1"
                               asp-controller="Security"
                               asp-action="RoleEdit"
                               asp-route-id="@r.id">
                                Editar
                            </a>

                            <a class="btn btn-sm btn-primary me-1"
                               asp-controller="Security"
                               asp-action="RolePermissions"
                               asp-route-roleId="@r.id">
                                Permissões
                            </a>

                            <form class="d-inline" method="post"
                                  asp-controller="Security"
                                  asp-action="RoleDelete"
                                  asp-route-id="@r.id"
                                  onsubmit="return confirm('Excluir este perfil?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Excluir
                                </button>
                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>