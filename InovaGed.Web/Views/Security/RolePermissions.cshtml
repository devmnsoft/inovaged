@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Permissões do Perfil";
    var roleId = (Guid)ViewBag.RoleId;
    var roleName = (string)ViewBag.RoleName;
}

<div class="container py-3">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <div>
            <h3 class="mb-0">@ViewData["Title"]</h3>
            <div class="text-muted">Perfil: <strong>@roleName</strong></div>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Roles">Voltar</a>
    </div>

    <div class="alert alert-info">
        Clique em <strong>Habilitar/Desabilitar</strong> para alternar permissões (PoC 11).
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th style="width:220px;">Código</th>
                    <th>Permissão</th>
                    <th style="width:180px;" class="text-end">Ação</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model ?? Enumerable.Empty<dynamic>())
                {
                    bool enabled = (bool)p.enabled;
                    <tr>
                        <td class="text-muted">@p.code</td>
                        <td>
                            <div class="fw-semibold">@p.name</div>
                            <div class="small text-muted">Status: @(enabled ? "Habilitada" : "Desabilitada")</div>
                        </td>
                        <td class="text-end">
                            <form method="post"
                                  asp-controller="Security"
                                  asp-action="TogglePermission">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="roleId" value="@roleId" />
                                <input type="hidden" name="permissionCode" value="@p.code" />
                                <input type="hidden" name="enable" value="@(!enabled)" />

                                @if (enabled)
                                {
                                    <button class="btn btn-sm btn-outline-danger" type="submit">
                                        Desabilitar
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-success" type="submit">
                                        Habilitar
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>