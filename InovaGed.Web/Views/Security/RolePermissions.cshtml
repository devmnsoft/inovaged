@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Permissões do Perfil";
    var roleId = (Guid)(ViewBag.RoleId ?? Guid.Empty);
    ViewData["Subtitle"] = $"RoleId: {roleId}";
}

<div class="container py-3">
    <div class="alert alert-warning">
        Marque/desmarque permissões para demonstrar sigilo/privilégios (PoC 11).
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nome</th>
                    <th>Status</th>
                    <th style="width:240px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model ?? Enumerable.Empty<dynamic>())
                {
                    bool enabled = (bool)p.enabled;
                    <tr>
                        <td class="font-monospace">@p.code</td>
                        <td>@p.name</td>
                        <td>
                            @if (enabled)
                            {
                                <span class="badge text-bg-success">Habilitada</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Desabilitada</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-controller="Security" asp-action="TogglePermission" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="roleId" value="@roleId" />
                                <input type="hidden" name="permissionCode" value="@p.code" />
                                <input type="hidden" name="enable" value="@(enabled ? "false" : "true")" />
                                <button class="btn btn-sm @(enabled ? "btn-outline-danger" : "btn-outline-success")" type="submit">
                                    @(enabled ? "Revogar" : "Conceder")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Security" asp-action="Roles">Voltar</a>
</div>