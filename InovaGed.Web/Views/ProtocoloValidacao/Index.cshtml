@model InovaGed.Web.Models.Protocolo.ProtocoloValidacaoVM
@{ Layout = null; }
<!DOCTYPE html><html lang="pt-br"><head><meta charset="utf-8" /><title>Validação de Protocolo</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /></head>
<body class="bg-light"><main class="container py-5"><div class="card border-0 shadow-sm mx-auto" style="max-width:720px;"><div class="card-body p-4"><h3>Validação de Protocolo</h3>
@if (!Model.Encontrado) { <div class="alert alert-danger">Protocolo não encontrado ou código inválido.</div> } else { <div class="alert alert-success">Protocolo localizado.</div><table class="table"><tr><th>Número</th><td>@Model.Numero</td></tr><tr><th>Assunto</th><td>@Model.Assunto</td></tr><tr><th>Interessado</th><td>@Model.Interessado</td></tr><tr><th>Status</th><td>@Model.Status</td></tr><tr><th>Data</th><td>@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td></tr><tr><th>Hash</th><td><code>@Model.HashComprovante</code></td></tr></table> }
</div></div></main></body></html>
