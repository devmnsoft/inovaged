@{
    ViewData["Title"] = "Troca obrigatória de senha";
}

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-7 col-md-9">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                        <i class="bi bi-shield-lock fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-1">Troca obrigatória de senha</h4>
                        <div class="text-muted small">
                            Para continuar usando o InovaGED, defina uma nova senha de acesso.
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body p-4">
                @if (TempData["Error"] is string erro && !string.IsNullOrWhiteSpace(erro))
                {
                    <div class="alert alert-danger">@erro</div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <form method="post" asp-action="ChangePassword" asp-controller="Account" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" for="currentPassword">Senha atual</label>
                        <input id="currentPassword"
                               name="currentPassword"
                               type="password"
                               class="form-control"
                               autocomplete="current-password"
                               required />
                        <span class="text-danger small">@Html.ValidationMessage("currentPassword")</span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="newPassword">Nova senha</label>
                        <input id="newPassword"
                               name="newPassword"
                               type="password"
                               class="form-control"
                               minlength="8"
                               autocomplete="new-password"
                               required />
                        <span class="text-danger small">@Html.ValidationMessage("newPassword")</span>
                        <div class="form-text">Use no mínimo 8 caracteres.</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" for="confirmPassword">Confirmar nova senha</label>
                        <input id="confirmPassword"
                               name="confirmPassword"
                               type="password"
                               class="form-control"
                               minlength="8"
                               autocomplete="new-password"
                               required />
                        <span class="text-danger small">@Html.ValidationMessage("confirmPassword")</span>
                    </div>

                    <div class="alert alert-info small mb-4">
                        <i class="bi bi-info-circle me-1"></i>
                        Após salvar, a pendência de troca de senha será removida e o acesso ao sistema será liberado normalmente.
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i>
                            Salvar nova senha
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>