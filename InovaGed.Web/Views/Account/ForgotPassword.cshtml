@model InovaGed.Web.Models.Auth.ForgotPasswordVM

@{
    ViewData["Title"] = "Recuperar Senha";
    Layout = "_LayoutAuth";
}

@section Styles {
    <style>
        .recover-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px;
            background: radial-gradient(900px 520px at 14% 10%, rgba(37,99,235,.38), transparent 62%), radial-gradient(820px 520px at 94% 18%, rgba(14,165,233,.26), transparent 60%), linear-gradient(135deg, #07111f, #0b172a);
        }

        .recover-card {
            width: min(520px, 100%);
            background: #fff;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 30px 90px rgba(2, 6, 23, .42);
            border: 1px solid rgba(255,255,255,.16);
        }

        .recover-topbar {
            height: 7px;
            background: linear-gradient(90deg, #2563eb, #0ea5e9, #22c55e, #2563eb);
            background-size: 220% 100%;
            animation: topbarMove 7s linear infinite;
        }

        @@keyframes topbarMove {
            to {
                background-position: 220% 0;
            }
        }

        .recover-body {
            padding: 38px;
        }

        .recover-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 26px;
        }

        .recover-logo {
            width: 54px;
            height: 54px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            font-weight: 950;
            color: #fff;
            background: linear-gradient(135deg, #2563eb, #22c55e);
        }

        .recover-title h3 {
            margin: 0;
            color: #0f172a;
            font-weight: 950;
            letter-spacing: -.4px;
        }

        .recover-title p {
            margin: 5px 0 0;
            color: #64748b;
            font-size: .92rem;
        }

        .form-label {
            color: #334155;
            font-size: .82rem;
            font-weight: 800;
            margin-bottom: 7px;
        }

        .input-group-text {
            width: 50px;
            justify-content: center;
            background: #f8fafc !important;
            border: 1px solid #e2e8f0 !important;
            border-right: 0 !important;
            color: #64748b;
            border-radius: 16px 0 0 16px !important;
        }

        .form-control {
            min-height: 50px;
            border: 1px solid #e2e8f0;
            color: #0f172a;
            font-weight: 500;
        }

        .input-group .form-control {
            border-left: 0;
        }

        .form-control:focus {
            border-color: rgba(37,99,235,.55);
            box-shadow: 0 0 0 5px rgba(37,99,235,.12);
        }

        .btn-main {
            min-height: 50px;
            border: 0;
            border-radius: 16px;
            background: linear-gradient(135deg, #2563eb, #0ea5e9);
            color: #fff;
            font-weight: 850;
            box-shadow: 0 18px 38px rgba(37,99,235,.23);
        }

            .btn-main:hover {
                color: #fff;
                filter: brightness(1.03);
            }

        .user-found-box {
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            border-radius: 18px;
            padding: 16px;
            margin: 18px 0;
        }

        .user-found-icon {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            background: rgba(37,99,235,.10);
            color: #2563eb;
            font-size: 1.25rem;
        }

        .password-note {
            color: #64748b;
            font-size: .82rem;
            margin-top: 6px;
        }

        .footer-mini {
            margin-top: 20px;
            text-align: center;
            color: #94a3b8;
            font-size: .78rem;
            line-height: 1.45;
        }

        @@media (max-width: 640px) {
            .recover-page {
                padding: 16px;
                align-items: flex-start;
            }

            .recover-body {
                padding: 28px 22px;
            }
        }
    </style>
}

<div class="recover-page">
    <div class="recover-card">
        <div class="recover-topbar"></div>

        <div class="recover-body">
            <div class="recover-brand">
                <div class="recover-logo">IG</div>

                <div class="recover-title">
                    <h3>Recuperar senha</h3>
                    <p>Informe o CPF para localizar seu usuário.</p>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary()
                </div>
            }

            <form method="post" asp-action="ForgotPasswordBuscar" asp-controller="Account">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="TenantSlug" value="@Model.TenantSlug" />

                <div class="mb-3">
                    <label asp-for="Cpf" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-credit-card-2-front"></i>
                        </span>

                        <input asp-for="Cpf"
                               class="form-control"
                               placeholder="000.000.000-00"
                               inputmode="numeric" />
                    </div>
                    <span asp-validation-for="Cpf" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-main w-100">
                    <i class="bi bi-search me-1"></i>
                    Buscar usuário
                </button>
            </form>

            @if (Model.UsuarioEncontrado)
            {
                <div class="user-found-box">
                    <div class="d-flex align-items-center gap-3">
                        <div class="user-found-icon">
                            <i class="bi bi-person-check"></i>
                        </div>

                        <div>
                            <div class="fw-bold text-dark">@Model.NomeUsuario</div>
                            <div class="small text-muted">@Model.EmailUsuario</div>
                        </div>
                    </div>

                    <div class="password-note">
                        A senha atual não é exibida por segurança. Informe abaixo a nova senha.
                    </div>
                </div>

                <form method="post" asp-action="ForgotPasswordRedefinir" asp-controller="Account">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="TenantSlug" value="@Model.TenantSlug" />
                    <input type="hidden" asp-for="Cpf" value="@Model.Cpf" />

                    <div class="mb-3">
                        <label asp-for="NovaSenha" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock"></i>
                            </span>

                            <input asp-for="NovaSenha"
                                   type="password"
                                   class="form-control"
                                   placeholder="Mínimo 4 caracteres" />
                        </div>
                        <span asp-validation-for="NovaSenha" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmarNovaSenha" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock-fill"></i>
                            </span>

                            <input asp-for="ConfirmarNovaSenha"
                                   type="password"
                                   class="form-control"
                                   placeholder="Confirme a nova senha" />
                        </div>
                        <span asp-validation-for="ConfirmarNovaSenha" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-main w-100">
                        <i class="bi bi-check2-circle me-1"></i>
                        Redefinir senha
                    </button>
                </form>
            }

            <div class="text-center mt-3">
                <a href="@Url.Action("Login", "Account")" class="text-decoration-none fw-semibold">
                    Voltar para o login
                </a>
            </div>

            <div class="footer-mini">
                InovaGED • Gestão Eletrônica de Documentos<br />
                LocDesk Locação de Equip. e Sol. em Info Ltda
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}