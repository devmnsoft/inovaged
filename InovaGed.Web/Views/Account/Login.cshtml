@model InovaGed.Web.Models.Auth.LoginVM
@{
    ViewData["Title"] = "Entrar";
    Layout = "_LayoutAuth";

    /*
    Certificado digital ficará oculto por enquanto.
                Mantive as variáveis para uso futuro, caso o bloco seja reativado.
            */
    var openCert = TempData["open_cert"] is bool b && b;
    var certErr = TempData["cert_err"] as string;
    var certOk = TempData["cert_ok"] as string;
}

@section Styles {
    <style>
        :root {
            --ig-navy-950: #020617;
            --ig-navy-900: #07111f;
            --ig-navy-850: #0b172a;
            --ig-navy-800: #10213b;
            --ig-blue: #2563eb;
            --ig-blue-2: #1d4ed8;
            --ig-cyan: #0ea5e9;
            --ig-green: #22c55e;
            --ig-emerald: #10b981;
            --ig-slate-950: #0f172a;
            --ig-slate-800: #1e293b;
            --ig-slate-700: #334155;
            --ig-slate-600: #475569;
            --ig-slate-500: #64748b;
            --ig-slate-400: #94a3b8;
            --ig-slate-300: #cbd5e1;
            --ig-slate-200: #e2e8f0;
            --ig-slate-100: #f1f5f9;
            --ig-slate-50: #f8fafc;
            --ig-white: #ffffff;
            --ig-shadow-strong: 0 34px 100px rgba(2, 6, 23, .48);
            --ig-shadow-card: 0 24px 70px rgba(15, 23, 42, .16);
            --ig-radius-shell: 36px;
            --ig-radius-card: 30px;
        }

        html,
        body {
            min-height: 100%;
            overflow-x: hidden;
        }

        .login-page {
            width: 100%;
            min-height: 100vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 34px;
            overflow: hidden;
            background: radial-gradient(880px 540px at 10% 8%, rgba(37, 99, 235, .42), transparent 62%), radial-gradient(860px 520px at 95% 10%, rgba(14, 165, 233, .30), transparent 60%), radial-gradient(760px 520px at 52% 112%, rgba(34, 197, 94, .20), transparent 62%), linear-gradient(135deg, var(--ig-navy-950) 0%, var(--ig-navy-900) 42%, var(--ig-navy-850) 100%);
        }

            .login-page::before {
                content: "";
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
                background-size: 44px 44px;
                opacity: .82;
                pointer-events: none;
                mask-image: linear-gradient(to bottom, rgba(0,0,0,.94), rgba(0,0,0,.35));
            }

            .login-page::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(115deg, rgba(255,255,255,.08), transparent 26%), linear-gradient(295deg, rgba(255,255,255,.06), transparent 30%);
                pointer-events: none;
            }

        .login-orb {
            position: absolute;
            width: 380px;
            height: 380px;
            border-radius: 999px;
            filter: blur(20px);
            opacity: .30;
            animation: floatOrb 9s ease-in-out infinite;
            pointer-events: none;
        }

            .login-orb.one {
                background: var(--ig-blue);
                top: -145px;
                left: -110px;
            }

            .login-orb.two {
                background: var(--ig-green);
                right: -160px;
                bottom: -170px;
                animation-delay: -4s;
            }

            .login-orb.three {
                width: 280px;
                height: 280px;
                background: var(--ig-cyan);
                left: 44%;
                top: -120px;
                opacity: .14;
                animation-delay: -2s;
            }

        @@keyframes floatOrb {
            0%, 100% {
                transform: translateY(0) scale(1);
            }

            50% {
                transform: translateY(24px) scale(1.045);
            }
        }

        .login-shell {
            width: min(1240px, calc(100vw - 68px));
            min-height: 730px;
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: minmax(0, 1.05fr) minmax(470px, .95fr);
            overflow: hidden;
            border-radius: var(--ig-radius-shell);
            background: rgba(255, 255, 255, .08);
            border: 1px solid rgba(255, 255, 255, .18);
            box-shadow: var(--ig-shadow-strong);
            backdrop-filter: blur(20px);
        }

        /* =======================
                   PAINEL GED ESQUERDO
                   ======================= */

        .login-info {
            position: relative;
            min-width: 0;
            padding: 54px;
            color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            overflow: hidden;
            background: radial-gradient(580px 420px at 18% 20%, rgba(255,255,255,.13), transparent 62%), linear-gradient(135deg, rgba(37,99,235,.68), rgba(14,165,233,.16) 54%, rgba(34,197,94,.08)), rgba(255,255,255,.035);
        }

            .login-info::before {
                content: "";
                position: absolute;
                width: 620px;
                height: 620px;
                right: -315px;
                top: 35px;
                border-radius: 999px;
                border: 96px solid rgba(255,255,255,.075);
                pointer-events: none;
            }

            .login-info::after {
                content: "";
                position: absolute;
                left: 52px;
                right: 52px;
                bottom: 118px;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent);
                pointer-events: none;
            }

        .login-brand {
            position: relative;
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .login-logo {
            width: 62px;
            height: 62px;
            border-radius: 20px;
            display: grid;
            place-items: center;
            font-weight: 950;
            letter-spacing: .5px;
            color: #fff;
            background: linear-gradient(135deg, rgba(255,255,255,.18), transparent), linear-gradient(135deg, var(--ig-blue), var(--ig-green));
            box-shadow: 0 20px 50px rgba(37,99,235,.34), inset 0 1px 0 rgba(255,255,255,.24);
            flex: 0 0 auto;
        }

        .login-brand h1 {
            margin: 0;
            font-weight: 950;
            line-height: 1;
            letter-spacing: -.6px;
            font-size: 1.62rem;
        }

        .login-brand p {
            margin: 5px 0 0;
            color: rgba(255,255,255,.76);
            font-size: .92rem;
        }

        .login-hero {
            position: relative;
            z-index: 3;
            max-width: 620px;
        }

        .login-hero-pill {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 9px 13px;
            border-radius: 999px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.18);
            color: rgba(255,255,255,.90);
            font-size: .84rem;
            margin-bottom: 20px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
        }

            .login-hero-pill i {
                color: rgba(255,255,255,.98);
            }

        .login-hero h2 {
            font-size: clamp(2.35rem, 3.3vw, 3.75rem);
            line-height: 1.01;
            font-weight: 950;
            letter-spacing: -2px;
            margin: 0;
        }

        .login-hero-highlight {
            display: block;
            background: linear-gradient(90deg, #fff, rgba(255,255,255,.74));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .ged-workspace {
            position: relative;
            z-index: 3;
            width: min(560px, 100%);
            margin-top: 34px;
        }

        .ged-doc-board {
            position: relative;
            min-height: 350px;
            border-radius: 34px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,.20);
            background: radial-gradient(circle at 30% 12%, rgba(255,255,255,.20), transparent 28%), linear-gradient(135deg, rgba(255,255,255,.15), rgba(255,255,255,.055));
            box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 30px 85px rgba(2,6,23,.20);
        }

            .ged-doc-board::before {
                content: "";
                position: absolute;
                inset: 22px;
                border: 1px dashed rgba(255,255,255,.20);
                border-radius: 28px;
            }

            .ged-doc-board::after {
                content: "";
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
                background-size: 26px 26px;
                opacity: .5;
            }

        .ged-folder-hero {
            position: absolute;
            z-index: 4;
            left: 50%;
            top: 48%;
            width: 132px;
            height: 132px;
            transform: translate(-50%, -50%);
            border-radius: 38px;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, rgba(255,255,255,.20), transparent), linear-gradient(135deg, var(--ig-blue), var(--ig-green));
            color: #fff;
            box-shadow: 0 26px 68px rgba(37,99,235,.34), 0 0 0 14px rgba(255,255,255,.075), inset 0 1px 0 rgba(255,255,255,.24);
        }

            .ged-folder-hero i {
                font-size: 4.35rem;
            }

        .ged-ring {
            position: absolute;
            z-index: 3;
            left: 50%;
            top: 48%;
            width: 250px;
            height: 250px;
            transform: translate(-50%, -50%);
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.18);
            box-shadow: 0 0 0 36px rgba(255,255,255,.035);
        }

        .ged-line-x,
        .ged-line-y {
            position: absolute;
            z-index: 2;
            left: 50%;
            top: 48%;
            transform: translate(-50%, -50%);
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.30), transparent);
        }

        .ged-line-x {
            width: 78%;
            height: 1px;
        }

        .ged-line-y {
            width: 1px;
            height: 72%;
            background: linear-gradient(180deg, transparent, rgba(255,255,255,.25), transparent);
        }

        .ged-mini-card {
            position: absolute;
            z-index: 6;
            min-width: 132px;
            padding: 12px 14px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            gap: 9px;
            color: rgba(255,255,255,.95);
            background: rgba(255,255,255,.145);
            border: 1px solid rgba(255,255,255,.22);
            backdrop-filter: blur(12px);
            box-shadow: 0 18px 38px rgba(2,6,23,.18), inset 0 1px 0 rgba(255,255,255,.11);
        }

            .ged-mini-card i {
                font-size: 1.25rem;
            }

            .ged-mini-card span {
                font-size: .82rem;
                font-weight: 850;
                white-space: nowrap;
            }

        .ged-card-doc {
            left: 28px;
            top: 36px;
            animation: softFloatA 5.5s ease-in-out infinite;
        }

        .ged-card-index {
            right: 28px;
            top: 50px;
            animation: softFloatB 6.5s ease-in-out infinite;
        }

        .ged-card-archive {
            left: 36px;
            bottom: 54px;
            animation: softFloatB 6.2s ease-in-out infinite;
        }

        .ged-card-audit {
            right: 36px;
            bottom: 46px;
            animation: softFloatA 5.8s ease-in-out infinite;
        }

        .ged-card-flow {
            left: 50%;
            bottom: 18px;
            transform: translateX(-50%);
            animation: softFloatShield 6.5s ease-in-out infinite;
        }

        .ged-document-stack {
            position: absolute;
            z-index: 3;
            left: 42px;
            top: 118px;
            width: 86px;
            height: 112px;
            opacity: .82;
        }

        .ged-paper {
            position: absolute;
            width: 70px;
            height: 92px;
            border-radius: 12px;
            background: rgba(255,255,255,.18);
            border: 1px solid rgba(255,255,255,.20);
            box-shadow: 0 18px 32px rgba(2,6,23,.10);
        }

            .ged-paper.one {
                left: 0;
                top: 16px;
                transform: rotate(-10deg);
            }

            .ged-paper.two {
                left: 14px;
                top: 6px;
                transform: rotate(-2deg);
            }

            .ged-paper.three {
                left: 28px;
                top: 0;
                transform: rotate(8deg);
            }

            .ged-paper::before,
            .ged-paper::after {
                content: "";
                position: absolute;
                left: 13px;
                right: 13px;
                height: 5px;
                border-radius: 999px;
                background: rgba(255,255,255,.28);
            }

            .ged-paper::before {
                top: 24px;
            }

            .ged-paper::after {
                top: 40px;
                right: 24px;
            }

        @@keyframes softFloatA {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-8px);
            }
        }

        @@keyframes softFloatB {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(8px);
            }
        }

        @@keyframes softFloatShield {
            0%, 100% {
                transform: translateX(-50%) translateY(0);
            }

            50% {
                transform: translateX(-50%) translateY(8px);
            }
        }

        .login-info-footer {
            position: relative;
            z-index: 3;
            color: rgba(255,255,255,.64);
            font-size: .82rem;
            line-height: 1.48;
        }

        /* =======================
                   CARD DE LOGIN
                   ======================= */

        .login-panel {
            min-width: 0;
            background: radial-gradient(540px 320px at 80% 0%, rgba(37,99,235,.08), transparent 60%), rgba(248,250,252,.985);
            padding: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 520px;
            background: linear-gradient(180deg, rgba(255,255,255,1), rgba(255,255,255,.985));
            border: 1px solid rgba(15,23,42,.08);
            border-radius: var(--ig-radius-card);
            box-shadow: var(--ig-shadow-card);
            overflow: hidden;
        }

        .login-card-topbar {
            height: 7px;
            background: linear-gradient(90deg, var(--ig-blue), var(--ig-cyan), var(--ig-green), var(--ig-blue));
            background-size: 220% 100%;
            animation: topbarMove 7s linear infinite;
        }

        @@keyframes topbarMove {
            to {
                background-position: 220% 0;
            }
        }

        .login-card-body {
            padding: 44px;
        }

        .login-card-title {
            margin-bottom: 24px;
        }

        .login-title-icon {
            width: 52px;
            height: 52px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            margin-bottom: 16px;
            color: #fff;
            background: linear-gradient(135deg, var(--ig-blue), var(--ig-cyan));
            box-shadow: 0 16px 34px rgba(37,99,235,.22);
        }

            .login-title-icon i {
                font-size: 1.55rem;
            }

        .login-card-title h3 {
            margin: 0;
            color: var(--ig-slate-950);
            font-weight: 950;
            letter-spacing: -.6px;
            font-size: 1.72rem;
        }

        .login-card-title p {
            margin: 8px 0 0;
            color: var(--ig-slate-500);
            font-size: .96rem;
        }

        .form-label {
            color: var(--ig-slate-700);
            font-size: .82rem;
            font-weight: 850;
            margin-bottom: 8px;
        }

        .input-group {
            border-radius: 17px;
            box-shadow: 0 1px 0 rgba(15,23,42,.02);
        }

        .input-group-text {
            width: 52px;
            justify-content: center;
            background: var(--ig-slate-50) !important;
            border: 1px solid var(--ig-slate-200) !important;
            border-right: 0 !important;
            color: var(--ig-slate-500);
            border-radius: 17px 0 0 17px !important;
        }

        .form-control {
            min-height: 52px;
            border: 1px solid var(--ig-slate-200);
            color: var(--ig-slate-950);
            font-weight: 520;
        }

        .input-group .form-control {
            border-left: 0;
        }

        .form-control::placeholder {
            color: var(--ig-slate-400);
            font-weight: 400;
        }

        .form-control:focus {
            border-color: rgba(37,99,235,.56);
            box-shadow: 0 0 0 5px rgba(37,99,235,.12);
        }

        .password-toggle {
            min-width: 52px;
            border: 1px solid var(--ig-slate-200);
            border-left: 0;
            background: #fff;
            color: var(--ig-slate-500);
            border-radius: 0 17px 17px 0 !important;
        }

            .password-toggle:hover {
                background: var(--ig-slate-50);
                color: var(--ig-slate-950);
            }

        .field-helper {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 6px;
            font-size: .76rem;
            color: var(--ig-slate-500);
        }

            .field-helper i {
                font-size: .85rem;
                color: var(--ig-blue);
            }

        .btn-login {
            min-height: 54px;
            border: 0;
            border-radius: 17px;
            background: linear-gradient(135deg, rgba(255,255,255,.14), transparent), linear-gradient(135deg, var(--ig-blue), var(--ig-cyan));
            color: #fff;
            font-weight: 900;
            letter-spacing: -.1px;
            box-shadow: 0 18px 42px rgba(37,99,235,.25);
            transition: transform .16s ease, filter .16s ease, box-shadow .16s ease;
        }

            .btn-login:hover {
                color: #fff;
                filter: brightness(1.035);
                transform: translateY(-1px);
                box-shadow: 0 22px 46px rgba(37,99,235,.30);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .login-actions {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            margin-top: 16px;
            font-size: .9rem;
        }

            .login-actions a {
                color: var(--ig-blue);
                text-decoration: none;
                font-weight: 800;
            }

                .login-actions a:hover {
                    text-decoration: underline;
                }

        .secure-note {
            color: var(--ig-slate-500);
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-weight: 700;
            white-space: nowrap;
        }

        .auth-alert {
            border-radius: 16px;
            border: 0;
        }

        .btn-wait {
            display: none;
        }

        .is-loading .btn-text {
            display: none;
        }

        .is-loading .btn-wait {
            display: inline-flex;
            align-items: center;
        }

        .footer-mini {
            margin-top: 22px;
            padding-top: 18px;
            border-top: 1px solid var(--ig-slate-200);
            text-align: center;
            color: var(--ig-slate-400);
            font-size: .78rem;
            line-height: 1.48;
        }

        @@media (max-width: 1180px) {
            .login-page {
                padding: 26px;
            }

            .login-shell {
                width: min(1080px, calc(100vw - 52px));
                min-height: 700px;
                grid-template-columns: minmax(0, 1fr) minmax(430px, .95fr);
            }

            .login-info {
                padding: 42px;
            }

            .login-hero h2 {
                font-size: clamp(2.05rem, 3vw, 2.95rem);
            }

            .ged-doc-board {
                min-height: 320px;
            }

            .login-panel {
                padding: 36px;
            }

            .login-card-body {
                padding: 36px;
            }
        }

        @@media (max-width: 920px) {
            .login-page {
                align-items: flex-start;
                padding: 24px;
                overflow-y: auto;
            }

            .login-shell {
                width: min(780px, 100%);
                min-height: auto;
                grid-template-columns: 1fr;
            }

            .login-info {
                padding: 34px;
            }

            .login-hero {
                margin-top: 34px;
            }

                .login-hero h2 {
                    font-size: clamp(2rem, 7vw, 3rem);
                }

            .login-panel {
                padding: 34px;
            }

            .login-card {
                max-width: 100%;
            }
        }

        @@media (max-width: 640px) {
            .login-page {
                padding: 16px;
                display: block;
            }

                .login-orb,
                .login-page::before,
                .login-page::after {
                    display: none;
                }

            .login-shell {
                width: 100%;
                display: block;
                border-radius: 0;
                background: transparent;
                border: 0;
                box-shadow: none;
            }

            .login-info {
                display: none;
            }

            .login-panel {
                padding: 0;
                background: transparent;
            }

            .login-card {
                max-width: none;
                border-radius: 24px;
            }

            .login-card-body {
                padding: 30px 22px;
            }

            .login-card-title h3 {
                font-size: 1.48rem;
            }

            .login-actions {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

<div class="login-page">
    <div class="login-orb one"></div>
    <div class="login-orb two"></div>
    <div class="login-orb three"></div>

    <div class="login-shell">
        <aside class="login-info">
            <div class="login-brand">
                <div class="login-logo">IG</div>
                <div>
                    <h1>InovaGED</h1>
                    <p>Gestăo Eletrônica de Documentos</p>
                </div>
            </div>

            <div class="login-hero">
                <div class="login-hero-pill">
                    <i class="bi bi-folder-check"></i>
                    Plataforma GED para gestăo segura de documentos
                </div>

                <h2>
                    Gestăo documental
                    <span class="login-hero-highlight">segura, inteligente e centralizada.</span>
                </h2>

                <div class="ged-workspace">
                    <div class="ged-doc-board">
                        <div class="ged-ring"></div>
                        <div class="ged-line-x"></div>
                        <div class="ged-line-y"></div>

                        <div class="ged-document-stack">
                            <div class="ged-paper one"></div>
                            <div class="ged-paper two"></div>
                            <div class="ged-paper three"></div>
                        </div>

                        <div class="ged-folder-hero">
                            <i class="bi bi-folder-check"></i>
                        </div>

                        <div class="ged-mini-card ged-card-doc">
                            <i class="bi bi-file-earmark-text"></i>
                            <span>Documentos</span>
                        </div>

                        <div class="ged-mini-card ged-card-index">
                            <i class="bi bi-tags"></i>
                            <span>Indexaçăo</span>
                        </div>

                        <div class="ged-mini-card ged-card-archive">
                            <i class="bi bi-archive"></i>
                            <span>Arquivo</span>
                        </div>

                        <div class="ged-mini-card ged-card-audit">
                            <i class="bi bi-clock-history"></i>
                            <span>Histórico</span>
                        </div>

                        <div class="ged-mini-card ged-card-flow">
                            <i class="bi bi-diagram-3"></i>
                            <span>Fluxo GED</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="login-info-footer">
                © @DateTime.Now.Year InovaGED • Soluçăo de Gestăo Eletrônica de Documentos<br />
                LocDesk Locaçăo de Equip. e Sol. em Info Ltda
            </div>
        </aside>

        <main class="login-panel">
            <div class="login-card">
                <div class="login-card-topbar"></div>

                <div class="login-card-body">
                    <div class="login-card-title">
                        <div class="login-title-icon">
                            <i class="bi bi-person-lock"></i>
                        </div>

                        <h3>Bem-vindo de volta</h3>
                        <p>Informe seus dados para acessar o ambiente GED.</p>
                    </div>

                    <form id="loginForm" asp-action="Login" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />

                        @*
                            Tenant oculto por enquanto.
                            IMPORTANTE:
                            Troque "default" pelo valor real da coluna ged.tenant.code.
                            Exemplos possíveis: "inovaged", "ophir", "locdesk", "demo".
                        *@
                        <input type="hidden" asp-for="TenantSlug" value="default" />

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-person-circle"></i>
                                </span>

                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="E-mail de acesso"
                                       autocomplete="username" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>

                            <div class="field-helper">
                                <i class="bi bi-info-circle"></i>
                                Utilize o e-mail cadastrado para acesso ao GED.
                            </div>
                        </div>

                        <div class="mb-2">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-lock"></i>
                                </span>

                                <input asp-for="Password"
                                       type="password"
                                       class="form-control"
                                       id="passwordInput"
                                       placeholder="Senha"
                                       autocomplete="current-password" />

                                <button type="button"
                                        class="btn password-toggle"
                                        title="Mostrar/ocultar senha"
                                        tabindex="-1"
                                        onclick="togglePassword()">
                                    <i class="bi bi-eye" id="passwordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>

                            <div class="field-helper">
                                <i class="bi bi-key"></i>
                                Sua senha é protegida e validada de forma segura.
                            </div>
                        </div>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger auth-alert py-2 small mt-3 mb-0">
                                <div class="d-flex align-items-start gap-2">
                                    <i class="bi bi-exclamation-triangle mt-1"></i>
                                    <div>@Html.ValidationSummary(excludePropertyErrors: true)</div>
                                </div>
                            </div>
                        }

                        <button id="loginBtn" type="submit" class="btn btn-login w-100 mt-3">
                            <span class="btn-text">
                                <i class="bi bi-box-arrow-in-right me-1"></i>
                                Entrar no sistema
                            </span>

                            <span class="btn-wait">
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                Entrando...
                            </span>
                        </button>

                        <div class="login-actions">
                            <a href="@Url.Action("ForgotPassword", "Account")">
                                Esqueci minha senha
                            </a>

                            <span class="secure-note">
                                <i class="bi bi-shield-lock"></i>
                                Ambiente seguro
                            </span>
                        </div>
                    </form>

                    @*
                        Acesso alternativo por certificado digital oculto por enquanto.
                        Para reativar futuramente, remova o comentário deste bloco.

                    <div class="section-divider">Acesso alternativo</div>

                    <div class="cert-box">
                        ...
                    </div>
                    *@

                    <div class="footer-mini">
                        InovaGED • Gestăo Eletrônica de Documentos<br />
                        LocDesk Locaçăo de Equip. e Sol. em Info Ltda
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('passwordIcon');

            if (!input || !icon) return;

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        function setBtnLoading(btn, loading) {
            if (!btn) return;

            if (loading) {
                btn.classList.add("is-loading");
                btn.setAttribute("disabled", "disabled");
            } else {
                btn.classList.remove("is-loading");
                btn.removeAttribute("disabled");
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            const loginForm = document.getElementById("loginForm");
            const loginBtn = document.getElementById("loginBtn");

            loginForm?.addEventListener("submit", () => {
                setBtnLoading(loginBtn, true);
            });
        });
    </script>
}