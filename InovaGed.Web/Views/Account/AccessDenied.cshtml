@using InovaGed.Web.Security
@{
    ViewData["Title"] = "Acesso negado";
    var returnUrl = AppMenuPolicy.IsFullAdmin(User)
        ? "/Ged"
        : AppMenuPolicy.IsAdministradorOphir(User)
            ? "/Operations"
            : AppMenuPolicy.IsArquivistaOphir(User)
                ? "/ProtocolRequests"
                : "/HospitalDocuments";
}
<div class="container" style="max-width:760px; margin-top:60px;">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5 text-center">
            <div class="display-6 text-warning mb-3"><i class="bi bi-shield-lock"></i></div>
            <h3 class="mb-2">Acesso negado</h3>
            <p class="text-muted mb-4">Você não possui permissão para acessar esta funcionalidade.</p>
            <a class="btn btn-primary" href="@returnUrl">
                <i class="bi bi-arrow-left me-1"></i>
                Voltar para minha área
            </a>
        </div>
    </div>
</div>
