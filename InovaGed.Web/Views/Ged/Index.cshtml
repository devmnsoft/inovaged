@model InovaGed.Web.Models.Ged.GedExplorerVM
@{
    ViewData["Title"] = "GED - Documentos";
}

<div class="row">
    <!-- COLUNA PASTAS -->
    <div class="col-12 col-xl-3">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Pastas</span>
                <a class="btn btn-sm btn-outline-primary"
                   asp-action="Folders" asp-controller="Ged">
                    <i class="bi bi-folder-plus"></i> Nova
                </a>
            </div>

            <div class="card-body p-2" style="max-height:70vh; overflow:auto;">
                @{
                    // ===========================
                    // ÁRVORE DE PASTAS (Explorer)
                    // ✅ FIX: NÃO usar null como chave do Dictionary
                    // ===========================
                    var byParent = Model.Folders
                    .Where(x => x.ParentId != null)
                    .GroupBy(x => x.ParentId!.Value)
                    .ToDictionary(
                    g => g.Key,
                    g => g.OrderBy(x => x.Name).ToList()
                    );

                    var rootFolders = Model.Folders
                    .Where(x => x.ParentId == null)
                    .OrderBy(x => x.Name)
                    .ToList();

                    void RenderTree(Guid parentId)
                    {
                        if (!byParent.TryGetValue(parentId, out var children) || children.Count == 0)
                            return;

                        <ul class="ged-tree">
                            @foreach (var n in children)
                            {
                                var hasChildren = byParent.ContainsKey(n.Id);
                                var isActive = Model.CurrentFolderId == n.Id;

                                // Link SEM taghelper
                                var href = Url.Action("Index", "Ged", new { folderId = n.Id }) ?? "#";

                                <li class="ged-tree-node"
                                    data-id="@n.Id"
                                    data-parent="@(n.ParentId?.ToString() ?? "")"
                                    data-has-children="@(hasChildren ? "1" : "0")">

                                    <div class="ged-tree-row @(isActive ? "active" : "")">
                                        @if (hasChildren)
                                        {
                                            <button type="button" class="ged-tree-toggle" aria-label="Expandir/Recolher">
                                                <i class="bi bi-caret-right-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="ged-tree-spacer"></span>
                                        }

                                        <i class="bi bi-folder2 ged-tree-folder"></i>

                                        <a class="ged-tree-link" href="@href">@n.Name</a>
                                    </div>

                                    <div class="ged-tree-children" style="display:none;">
                                        @{
                                            RenderTree(n.Id);
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                }

                @if (!Model.Folders.Any())
                {
                    <div class="text-muted small">Nenhuma pasta cadastrada.</div>
                }
                else
                {
                    var raizHref = Url.Action("Index", "Ged") ?? "#";

                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">
                            <a class="d-flex align-items-center gap-2 text-decoration-none @(Model.CurrentFolderId == null ? "fw-bold" : "")"
                               href="@raizHref">
                                <i class="bi bi-house"></i> Raiz
                            </a>
                        </li>
                    </ul>

                    <div class="mt-2">
                        <!-- ✅ Render ROOT folders primeiro (ParentId = null) -->
                        <ul class="ged-tree">
                            @foreach (var n in rootFolders)
                            {
                                var hasChildren = byParent.ContainsKey(n.Id);
                                var isActive = Model.CurrentFolderId == n.Id;

                                var href = Url.Action("Index", "Ged", new { folderId = n.Id }) ?? "#";

                                <li class="ged-tree-node"
                                    data-id="@n.Id"
                                    data-parent=""
                                    data-has-children="@(hasChildren ? "1" : "0")">

                                    <div class="ged-tree-row @(isActive ? "active" : "")">
                                        @if (hasChildren)
                                        {
                                            <button type="button" class="ged-tree-toggle" aria-label="Expandir/Recolher">
                                                <i class="bi bi-caret-right-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="ged-tree-spacer"></span>
                                        }

                                        <i class="bi bi-folder2 ged-tree-folder"></i>
                                        <a class="ged-tree-link" href="@href">@n.Name</a>
                                    </div>

                                    <div class="ged-tree-children" style="display:none;">
                                        @{
                                            RenderTree(n.Id);
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- COLUNA DOCUMENTOS -->
    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-files"></i>
                    <strong>Documentos</strong>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <!-- 🔍 BUSCA OCR -->
                    <form class="d-flex gap-2"
                          method="get"
                          asp-action="Search"
                          asp-controller="Ged">
                        <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
                        <input class="form-control"
                               style="min-width:280px"
                               name="q"
                               placeholder="Pesquisar por nome ou conteúdo (OCR)..." />
                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <!-- UPLOAD -->
                    <button class="btn btn-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#modalUpload"
                    @(Model.CurrentFolderId == null ? "disabled" : "")>
                        <i class="bi bi-upload"></i> Upload
                    </button>
                </div>
            </div>

            <div class="card-body p-0">
                @if (!Model.Documents.Any())
                {
                    <div class="p-3 text-muted">
                        Nenhum documento nesta pasta.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Título</th>
                                    <th style="width:200px;">Tipo</th>
                                    <th style="width:240px;">Arquivo</th>
                                    <th style="width:180px;">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.Documents)
                                {
                                    <tr>
                                        <td class="fw-semibold">@d.Title</td>
                                        <td>@(d.TypeName ?? "-")</td>
                                        <td class="text-muted small">@d.FileName</td>
                                        <td class="d-flex gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-action="Details"
                                               asp-controller="Ged"
                                               asp-route-id="@d.Id">
                                                <i class="bi bi-eye"></i> Abrir
                                            </a>

                                            <form method="post"
                                                  asp-action="Delete"
                                                  asp-controller="Ged"
                                                  class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@d.Id" />
                                                <button class="btn btn-sm btn-outline-danger"
                                                        type="submit"
                                                        onclick="return confirm('Deseja excluir este documento?');">
                                                    <i class="bi bi-trash"></i> Excluir
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- MODAL UPLOAD -->
<div class="modal fade" id="modalUpload" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload de Documento</h5>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>

            <form method="post"
                  enctype="multipart/form-data"
                  asp-action="Upload"
                  asp-controller="Ged">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />

                    <div class="mb-3">
                        <label class="form-label">Arquivo</label>
                        <input class="form-control" type="file" name="file" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Título</label>
                        <input class="form-control" type="text" name="title" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-light" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary"
                            type="submit"
                    @(Model.CurrentFolderId == null ? "disabled" : "")>
                        Enviar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .ged-tree {
        list-style: none;
        padding-left: .75rem;
        margin: 0;
    }

    .ged-tree-node {
        margin: 0;
    }

    .ged-tree-row {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .25rem .35rem;
        border-radius: .35rem;
        user-select: none;
    }

        .ged-tree-row:hover {
            background: rgba(0,0,0,.04);
        }

        .ged-tree-row.active {
            background: rgba(13,110,253,.12);
        }

    .ged-tree-link {
        text-decoration: none;
        color: inherit;
    }

        .ged-tree-link:hover {
            text-decoration: underline;
        }

    .ged-tree-toggle {
        border: 0;
        background: transparent;
        padding: 0;
        width: 18px;
        height: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .ged-tree-toggle i {
            transition: transform .12s ease;
        }

    .ged-tree-node.open > .ged-tree-row .ged-tree-toggle i {
        transform: rotate(90deg);
    }

    .ged-tree-spacer {
        width: 18px;
        height: 18px;
        display: inline-block;
    }

    .ged-tree-folder {
        opacity: .9;
    }
</style>

<script>
    (function () {
        const KEY = "ged_tree_open_ids";

        function loadOpenSet() {
            try { return new Set(JSON.parse(localStorage.getItem(KEY) || "[]")); }
            catch { return new Set(); }
        }
        function saveOpenSet(set) {
            localStorage.setItem(KEY, JSON.stringify(Array.from(set)));
        }

        const openSet = loadOpenSet();
        const nodes = Array.from(document.querySelectorAll(".ged-tree-node"));

        function setNodeOpen(li, open) {
            const hasChildren = li.getAttribute("data-has-children") === "1";
            if (!hasChildren) return;

            const children = li.querySelector(":scope > .ged-tree-children");
            if (!children) return;

            if (open) {
                li.classList.add("open");
                children.style.display = "block";
                openSet.add(li.getAttribute("data-id"));
            } else {
                li.classList.remove("open");
                children.style.display = "none";
                openSet.delete(li.getAttribute("data-id"));
            }
            saveOpenSet(openSet);
        }

        // Aplica estado salvo
        nodes.forEach(li => {
            const id = li.getAttribute("data-id");
            if (openSet.has(id)) setNodeOpen(li, true);
        });

        // Click no toggle
        document.addEventListener("click", (e) => {
            const btn = e.target.closest(".ged-tree-toggle");
            if (!btn) return;

            const li = btn.closest(".ged-tree-node");
            if (!li) return;

            const isOpen = li.classList.contains("open");
            setNodeOpen(li, !isOpen);
            e.preventDefault();
            e.stopPropagation();
        });

        // Auto-expande a cadeia de pais da pasta atual (linha ativa)
        const active = document.querySelector(".ged-tree-row.active");
        if (active) {
            let li = active.closest(".ged-tree-node");
            while (li) {
                setNodeOpen(li, true);

                const parentId = li.getAttribute("data-parent");
                if (!parentId) break;

                li = document.querySelector(`.ged-tree-node[data-id="${parentId}"]`);
            }
        }
    })();
</script>
