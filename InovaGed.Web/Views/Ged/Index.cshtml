@model InovaGed.Web.Models.Ged.GedExplorerVM
@{
    ViewData["Title"] = "GED - Documentos";
}

<div class="row">
    <div class="col-12 col-xl-3">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Pastas</span>
                <a class="btn btn-sm btn-outline-primary" asp-action="Folders" asp-controller="Ged"><i class="bi bi-folder-plus"></i> Nova</a>
            </div>
            <div class="card-body p-2" style="max-height: 70vh; overflow:auto;">
                @if (!Model.Folders.Any())
                {
                    <div class="text-muted small">Nenhuma pasta cadastrada.</div>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @{
                            var rootActive = Model.CurrentFolderId == null ? "fw-bold" : "";
                        }
                        <li class="py-1">
                            <a class="text-decoration-none @rootActive" asp-controller="Ged" asp-action="Index">
                                <i class="bi bi-house-door"></i> Raiz (todas as pastas)
                            </a>
                        </li>

                        @foreach (var f in Model.Folders)
                        {
                            var active = Model.CurrentFolderId == f.Id ? "fw-bold" : "";
                            <li class="py-1">
                                <a class="text-decoration-none @active"
                                   asp-controller="Ged" asp-action="Index"
                                   asp-route-folderId="@f.Id">
                                    <span style="padding-left:@(f.Level * 14)px">
                                        <i class="bi bi-folder2-open"></i> @f.Name
                                    </span>
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-9">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <form class="d-flex gap-2" method="get" asp-action="Index" asp-controller="Ged">
                    <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
                    <input class="form-control" style="min-width:280px"
                           name="q" value="@Model.Query" placeholder="Pesquisar por título, tipo, arquivo ou texto (OCR)..." />
                    <button class="btn btn-outline-secondary" type="submit" title="Pesquisar">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <button class="btn btn-primary"
                        data-bs-toggle="modal" data-bs-target="#modalUpload"
                @(Model.CurrentFolderId == null ? "disabled" : "")>
                    <i class="bi bi-upload"></i> Upload
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Tipo</th>
                            <th>Tamanho</th>
                            <th>Criado em</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.CurrentFolderId == null)
                        {
                            <tr>
                                <td colspan="5" class="text-muted p-4">Selecione uma pasta para visualizar os documentos.</td>
                            </tr>
                        }
                        else if (!Model.Documents.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-muted p-4">Nenhum documento nesta pasta.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var d in Model.Documents)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-file-earmark-text"></i>
                                            <div>
                                                <div class="fw-semibold">@d.Title</div>
                                                <div class="text-muted small">@d.FileName</div>
                                            </div>
                                            @if (d.IsConfidential)
                                            {
                                                <span class="badge bg-warning text-dark">Privado</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@(d.TypeName ?? "-")</td>
                                    <td>@(Math.Round(d.SizeBytes / 1024.0, 1)) KB</td>
                                    <td class="text-muted small">@d.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary"
                                           asp-action="Details" asp-route-id="@d.Id" title="Detalhes">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Upload -->
<div class="modal fade" id="modalUpload" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />

                <div class="modal-header">
                    <h5 class="modal-title">Upload de Documento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Arquivo</label>
                            <input class="form-control" type="file" name="file" required />
                            <div class="form-text">Selecione um arquivo (PDF, DOCX, imagem, etc.).</div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Título</label>
                            <input class="form-control" name="title" placeholder="Opcional (usa o nome do arquivo)" />
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="isConfidential" id="isConfidential">
                                <label class="form-check-label" for="isConfidential">
                                    Documento privado (visibilidade PRIVATE)
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-light" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary" type="submit" @(Model.CurrentFolderId == null ? "disabled" : "")>
                        Enviar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
