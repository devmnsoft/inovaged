@section Scripts {
    <script src="~/js/ged-folder-navigation.js" asp-append-version="true"></script>
    <script src="~/js/ged-bulk-upload.js" asp-append-version="true"></script>
    <script src="~/js/ged-document-move.js" asp-append-version="true"></script>
    <script src="~/js/ged-queue-visualizer.js" asp-append-version="true"></script>
    <script src="~/js/ged-smart-search.js" asp-append-version="true"></script>

<script>
    (function () {
        const KEY = "ged.folderTree.expanded";
        const SCROLL_KEY = "ged.folderTree.scrollTop";
        const treeScroll = document.querySelector(".ged-folder-tree");
        if (treeScroll) {
            const savedScroll = Number(sessionStorage.getItem(SCROLL_KEY) || "0");
            if (savedScroll > 0) treeScroll.scrollTop = savedScroll;
            treeScroll.addEventListener("scroll", () => sessionStorage.setItem(SCROLL_KEY, String(treeScroll.scrollTop)));
        }
        document.addEventListener("click", (e) => {
            if (e.target.closest(".js-folder-node") && treeScroll) sessionStorage.setItem(SCROLL_KEY, String(treeScroll.scrollTop));
        }, true);
        document.getElementById("btnReloadFolderTree")?.addEventListener("click", () => window.location.reload());
        document.getElementById("gedFolderSearch")?.addEventListener("input", (e) => {
            const q = (e.target.value || "").trim().toLowerCase();
            document.querySelectorAll(".ged-tree-node").forEach(li => {
                const name = (li.dataset.folderName || li.textContent || "").toLowerCase();
                li.classList.toggle("d-none", q.length > 0 && !name.includes(q));
            });
        });
        document.addEventListener("click", async (e) => {
            const btn = e.target.closest(".js-copy-folder-path");
            if (!btn) return;
            await navigator.clipboard?.writeText(btn.dataset.folderPath || "").catch(() => null);
            showToast("Caminho da pasta copiado.", "info");
        });

        function loadOpenSet() {
            try { return new Set(JSON.parse(localStorage.getItem(KEY) || "[]")); }
            catch { return new Set(); }
        }
        function saveOpenSet(set) {
            localStorage.setItem(KEY, JSON.stringify(Array.from(set)));
        }

        const openSet = loadOpenSet();
        const nodes = Array.from(document.querySelectorAll(".ged-tree-node"));

        function setNodeOpen(li, open) {
            const hasChildren = li.getAttribute("data-has-children") === "1";
            if (!hasChildren) return;

            const children = li.querySelector(":scope > .ged-tree-children");
            if (!children) return;

            if (open) {
                li.classList.add("open");
                children.style.display = "block";
                openSet.add(li.getAttribute("data-id"));
            } else {
                li.classList.remove("open");
                children.style.display = "none";
                openSet.delete(li.getAttribute("data-id"));
            }
            saveOpenSet(openSet);
        }

        nodes.forEach(li => {
            const id = li.getAttribute("data-id");
            if (openSet.has(id)) setNodeOpen(li, true);
        });

        document.addEventListener("click", (e) => {
            const btn = e.target.closest(".ged-tree-toggle");
            if (!btn) return;

            const li = btn.closest(".ged-tree-node");
            if (!li) return;

            const isOpen = li.classList.contains("open");
            setNodeOpen(li, !isOpen);
            e.preventDefault();
            e.stopPropagation();
        });

        const active = document.querySelector(".ged-tree-row.active");
        if (active) {
            let li = active.closest(".ged-tree-node");
            while (li) {
                setNodeOpen(li, true);

                const parentId = li.getAttribute("data-parent");
                if (!parentId) break;

                li = document.querySelector(`.ged-tree-node[data-id="${parentId}"]`);
            }
        }

        // Modais Pasta Explorer
        const newFolderModal = document.getElementById('modalNovaPasta');
        newFolderModal?.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const parent = btn?.getAttribute('data-parent-id') || '';
            const input = document.getElementById('new-folder-parent-id');
            if (input) input.value = parent;
        });

        const renameModal = document.getElementById('modalRenomearPastaExplorer');
        renameModal?.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const id = btn.getAttribute('data-id');
            const nome = btn.getAttribute('data-nome');

            document.getElementById('exp-rename-id').value = id;
            document.getElementById('exp-rename-old').textContent = nome;
            document.getElementById('exp-rename-nome').value = nome;
        });

        const delModal = document.getElementById('modalExcluirPastaExplorer');
        delModal?.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const id = btn.getAttribute('data-id');
            const nome = btn.getAttribute('data-nome');

            document.getElementById('exp-del-id').value = id;
            document.getElementById('exp-del-nome').textContent = nome;
        });

        function setBtnLoading(btn, loading) {
            if (!btn) return;
            const text = btn.querySelector('.btn-text');
            const loadingEl = btn.querySelector('.btn-loading');
            if (loading) {
                btn.setAttribute('disabled', 'disabled');
                if (text) text.classList.add('d-none');
                if (loadingEl) loadingEl.classList.remove('d-none');
            } else {
                btn.removeAttribute('disabled');
                if (text) text.classList.remove('d-none');
                if (loadingEl) loadingEl.classList.add('d-none');
            }
        }

        function showToast(message, type) {
            if (!message) return;
            const hostId = 'gedToastHost';
            let host = document.getElementById(hostId);
            if (!host) {
                host = document.createElement('div');
                host.id = hostId;
                host.style.position = 'fixed';
                host.style.top = '1rem';
                host.style.right = '1rem';
                host.style.zIndex = '1080';
                host.style.maxWidth = '420px';
                document.body.appendChild(host);
            }
            const cls = type === 'danger' ? 'alert-danger' : 'alert-info';
            const el = document.createElement('div');
            el.className = `alert ${cls} shadow-sm mb-2`;
            el.innerText = message;
            host.appendChild(el);
            setTimeout(() => el.remove(), 5000);
        }

        document.querySelectorAll('.js-feedback-form').forEach(form => {
            form.addEventListener('submit', function () {
                const btn = form.querySelector('button[type=\"submit\"]');
                setBtnLoading(btn, true);
                showToast('Processando sua solicitação...', 'info');
            });
        });

        function updateSelectedKpi() {
            const count = new Set(Array.from(document.querySelectorAll('.js-doc-select:checked')).map(x => x.value).filter(Boolean)).size;
            const el = document.getElementById('selectedDocumentsKpi');
            if (el) el.textContent = String(count);
        }

        window.GedDocumentsView = window.GedDocumentsView || {
            key: 'ged.documents.viewMode',
            init: function () {
                const container = document.getElementById('gedDocumentsContainer');
                if (!container) return;
                const apply = (mode) => {
                    const normalized = mode === 'table' ? 'table' : 'list';
                    container.querySelector('[data-documents-view="list"]')?.classList.toggle('d-none', normalized !== 'list');
                    container.querySelector('[data-documents-view="table"]')?.classList.toggle('d-none', normalized !== 'table');
                    container.querySelectorAll('.js-doc-view-mode').forEach(btn => {
                        btn.classList.toggle('active', btn.dataset.viewMode === normalized);
                        btn.classList.toggle('btn-primary', btn.dataset.viewMode === normalized);
                        btn.classList.toggle('btn-outline-primary', btn.dataset.viewMode !== normalized);
                    });
                    localStorage.setItem(this.key, normalized);
                    this.syncTableScroll();
                };
                container.querySelectorAll('.js-doc-view-mode').forEach(btn => {
                    btn.addEventListener('click', () => apply(btn.dataset.viewMode));
                });
                apply(localStorage.getItem(this.key) || 'list');
            },
            syncTableScroll: function () {
                document.querySelectorAll('.ged-table-scroll-wrap').forEach(wrap => {
                    const top = wrap.querySelector('.ged-table-top-scroll');
                    const body = wrap.querySelector('.ged-table-scroll');
                    const table = body?.querySelector('table');
                    const spacer = top?.firstElementChild;
                    if (!top || !body || !table || !spacer || wrap.dataset.scrollSynced === 'true') return;
                    const resize = () => { spacer.style.width = `${table.scrollWidth}px`; };
                    resize();
                    top.addEventListener('scroll', () => { body.scrollLeft = top.scrollLeft; });
                    body.addEventListener('scroll', () => { top.scrollLeft = body.scrollLeft; });
                    window.addEventListener('resize', resize);
                    wrap.dataset.scrollSynced = 'true';
                });
            }
        };
        document.addEventListener('change', (e) => {
            if (e.target.matches('.js-doc-select, #selectAllDocuments')) setTimeout(updateSelectedKpi, 0);
        });
        updateSelectedKpi();
        window.GedDocumentsView.init();

    })();
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
(function(){
  if (!window.bootstrap) {
    console.error('[GED] Bootstrap JS não carregado. Verifique _Layout.cshtml.');
    return;
  }
  const state={documentId:null,folderId:null,title:''};
  const modalEl=document.getElementById('deleteDocumentModal');
  if(!modalEl) return;
  const modal=window.bootstrap.Modal.getOrCreateInstance(modalEl);
  const inline=document.getElementById('deleteDocumentInline');
  document.addEventListener('click',(e)=>{
    const btn=e.target.closest('.js-delete-document');
    if(!btn) return;
    state.documentId=btn.dataset.documentId; state.folderId=btn.dataset.folderId; state.title=btn.dataset.documentTitle||'';
    document.getElementById('deleteDocumentMessage').textContent=`Deseja realmente excluir este documento${state.title?` (${state.title})`:''}? Se houver OCR em andamento, ele será cancelado.`;
    inline.className='d-none alert'; inline.textContent='';
    modal.show();
  });

  document.getElementById('btnConfirmDeleteDocument')?.addEventListener('click', async ()=>{
    const btn=document.getElementById('btnConfirmDeleteDocument');
    btn.disabled=true; const old=btn.innerHTML; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Excluindo...';
    try{
      const fd=new FormData(); fd.append('id',state.documentId||''); if(state.folderId) fd.append('folderId',state.folderId);
      const token=document.querySelector('input[name="__RequestVerificationToken"]')?.value;
      const res=await fetch('/Ged/DeleteDocument',{method:'POST',body:fd,headers: token?{'RequestVerificationToken':token}:{}});
      const payload=await res.json().catch(()=>({success:false,message:'Não foi possível excluir o documento.'}));
      if(res.ok&&payload.success){ window.showAppToast?.(payload.message||'Documento excluído com sucesso.','success','Exclusão'); modal.hide(); window.GedFolderNavigation?.refreshCurrentFolder?.(); return; }
      inline.className='alert alert-danger'; inline.textContent=payload.message||'Não foi possível excluir o documento.'; window.showAppToast?.(inline.textContent,'error','Erro');
    }catch{ inline.className='alert alert-danger'; inline.textContent='Não foi possível excluir o documento.'; window.showAppToast?.(inline.textContent,'error','Erro'); }
    finally{ btn.disabled=false; btn.innerHTML=old; }
  });
})();
});
</script>

<script>
window.GedSmartSearch?.init({
    module: 'GED',
    inputSelector: '#smartSearchInput',
    suggestionsSelector: '#smartSearchSuggestions',
    searchButtonSelector: '#btnSmartSearch',
    endpoint: '/Ged/Search/Suggestions',
    searchUrl: '/Ged/Search',
    folderIdProvider: () => document.querySelector('#currentFolderId')?.value,
    scopeProvider: () => document.querySelector('[name="searchScope"]:checked')?.value || 'folder'
});
</script>

