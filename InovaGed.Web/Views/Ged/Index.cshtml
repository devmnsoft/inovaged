@model InovaGed.Web.Models.Ged.GedExplorerVM
@using InovaGed.Application.Identity
@using InovaGed.Application.Classification
@using System.Threading

@inject ICurrentUser CurrentUser
@inject IDocumentClassificationQueries ClassificationQueries

@{
    ViewData["Title"] = "GED - Documentos";

    // KPI: documentos não classificados (na pasta atual)
    var unclassifiedCount = 0;
    if (CurrentUser.IsAuthenticated)
    {
        unclassifiedCount = await ClassificationQueries.CountUnclassifiedAsync(
            CurrentUser.TenantId,
            Model.CurrentFolderId,
            CancellationToken.None
        );
    }

    var runningOcrCount = (ViewBag.RunningOcrCount as int?) ?? 0;
}

<div class="row">
    <div id="pageAlertHost" class="mb-2">
        @if (TempData["Success"] is string okMsg && !string.IsNullOrWhiteSpace(okMsg))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i>@okMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }
        @if (TempData["Error"] is string errMsg && !string.IsNullOrWhiteSpace(errMsg))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i>@errMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }
    </div>

    <!-- COLUNA PASTAS -->
    <div class="col-12 col-xl-3">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Pastas</span>
                <a class="btn btn-sm btn-outline-primary"
                   asp-action="Folders" asp-controller="Ged">
                    <i class="bi bi-gear"></i> Gerenciar
                </a>
            </div>

            <div class="card-body p-2" style="max-height:70vh; overflow:auto;">
                @{
                    var byParent = Model.Folders
                    .Where(x => x.ParentId != null)
                    .GroupBy(x => x.ParentId!.Value)
                    .ToDictionary(
                    g => g.Key,
                    g => g.OrderBy(x => x.Name).ToList()
                    );

                    var rootFolders = Model.Folders
                    .Where(x => x.ParentId == null)
                    .OrderBy(x => x.Name)
                    .ToList();

                    string BuildFolderPath(Guid folderId)
                    {
                        var chain = new List<string>();
                        var current = Model.Folders.FirstOrDefault(x => x.Id == folderId);
                        while (current is not null)
                        {
                            chain.Add(current.Name);
                            current = current.ParentId.HasValue
                                ? Model.Folders.FirstOrDefault(x => x.Id == current.ParentId.Value)
                                : null;
                        }

                        chain.Reverse();
                        return chain.Count == 0 ? string.Empty : string.Join(" > ", chain);
                    }

                    void RenderTree(Guid parentId)
                    {
                        if (!byParent.TryGetValue(parentId, out var children) || children.Count == 0)
                            return;

                        <ul class="ged-tree">
                            @foreach (var n in children)
                            {
                                var hasChildren = byParent.ContainsKey(n.Id);
                                var isActive = Model.CurrentFolderId == n.Id;
                                var href = Url.Action("Index", "Ged", new { folderId = n.Id }) ?? "#";

                                <li class="ged-tree-node"
                                    data-id="@n.Id"
                                    data-parent="@(n.ParentId?.ToString() ?? "")"
                                    data-has-children="@(hasChildren ? "1" : "0")"
                                    data-folder-id="@n.Id"
                                    data-folder-parent-id="@(n.ParentId?.ToString() ?? "")"
                                    data-folder-name="@n.Name"
                                    data-folder-path="@BuildFolderPath(n.Id)">

                                    <div class="ged-tree-row @(isActive ? "active" : "")">
                                        @if (hasChildren)
                                        {
                                            <button type="button" class="ged-tree-toggle" aria-label="Expandir/Recolher">
                                                <i class="bi bi-caret-right-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="ged-tree-spacer"></span>
                                        }

                                        <i class="bi bi-folder2 ged-tree-folder"></i>

                                        <a class="ged-tree-link flex-grow-1" href="@href">@n.Name</a>

                                        <!-- ✅ AÇÕES DA PASTA -->
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-link text-muted p-0"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false"
                                                    title="Ações">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <button class="dropdown-item"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalRenomearPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-pencil me-1"></i> Renomear
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button class="dropdown-item text-danger"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalExcluirPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-trash me-1"></i> Excluir
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="ged-tree-children" style="display:none;">
                                        @{
                                            RenderTree(n.Id);
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                }

                @if (!Model.Folders.Any())
                {
                    <div class="text-muted small">Nenhuma pasta cadastrada.</div>
                }
                else
                {
                    var raizHref = Url.Action("Index", "Ged") ?? "#";

                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">
                            <a class="d-flex align-items-center gap-2 text-decoration-none @(Model.CurrentFolderId == null ? "fw-bold" : "")"
                               href="@raizHref"
                               data-folder-id="f0000000-0000-0000-0000-000000000001"
                               data-folder-name="Raiz"
                               data-folder-path="Raiz">
                                <i class="bi bi-house"></i> Raiz
                            </a>
                        </li>
                    </ul>

                    <div class="mt-2">
                        <ul class="ged-tree">
                            @foreach (var n in rootFolders)
                            {
                                var hasChildren = byParent.ContainsKey(n.Id);
                                var isActive = Model.CurrentFolderId == n.Id;
                                var href = Url.Action("Index", "Ged", new { folderId = n.Id }) ?? "#";

                                <li class="ged-tree-node"
                                    data-id="@n.Id"
                                    data-parent=""
                                    data-has-children="@(hasChildren ? "1" : "0")"
                                    data-folder-id="@n.Id"
                                    data-folder-parent-id=""
                                    data-folder-name="@n.Name"
                                    data-folder-path="@BuildFolderPath(n.Id)">

                                    <div class="ged-tree-row @(isActive ? "active" : "")">
                                        @if (hasChildren)
                                        {
                                            <button type="button" class="ged-tree-toggle" aria-label="Expandir/Recolher">
                                                <i class="bi bi-caret-right-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="ged-tree-spacer"></span>
                                        }

                                        <i class="bi bi-folder2 ged-tree-folder"></i>
                                        <a class="ged-tree-link flex-grow-1" href="@href">@n.Name</a>

                                        <!-- ✅ AÇÕES DA PASTA -->
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-link text-muted p-0"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false"
                                                    title="Ações">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <button class="dropdown-item"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalRenomearPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-pencil me-1"></i> Renomear
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button class="dropdown-item text-danger"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalExcluirPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-trash me-1"></i> Excluir
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="ged-tree-children" style="display:none;">
                                        @{
                                            RenderTree(n.Id);
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- COLUNA DOCUMENTOS -->
    <div class="col-12 col-xl-9">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-files"></i>
                    <strong>Documentos</strong>

                    <span class="badge bg-light text-dark ms-2" title="Documentos sem classificação na pasta atual">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Não classificados: @unclassifiedCount
                    </span>

                    @if (runningOcrCount > 0)
                    {
                        <a class="badge bg-warning text-dark text-decoration-none"
                           asp-action="Processing"
                           asp-controller="Ged"
                           title="Existem OCRs em execução. Clique para acompanhar">
                            <i class="bi bi-cpu me-1"></i>
                            OCR em execução: @runningOcrCount
                        </a>
                    }

                    <button type="button"
                            class="btn btn-sm btn-outline-dark"
                            data-bs-toggle="modal"
                            data-bs-target="#modalFilaOcr">
                        <i class="bi bi-list-task me-1"></i> Ver fila OCR
                    </button>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <form class="d-flex gap-2"
                          method="get"
                          asp-action="Search"
                          asp-controller="Ged">
                        <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />

                        <input class="form-control"
                               style="min-width:280px"
                               name="q"
                               value="@Model.Query"
                               placeholder="Pesquisar por nome, código, arquivo ou conteúdo (OCR)..." />

                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>



                    @if (Model.CanBulkUpload)
                    {
                        <button type="button" id="btnOpenBulkUpload" class="btn btn-primary" data-bs-toggle="tooltip" title="Envie um ou mais arquivos para a pasta atual." @(Model.CurrentFolderId == null ? "disabled" : "")>
                            <i class="bi bi-cloud-arrow-up me-1"></i> Adicionar documentos
                        </button>
                    }
                    <a class="btn btn-outline-dark"
                       asp-controller="Ged"
                       asp-action="Kpi">
                        <i class="bi bi-bar-chart-line me-1"></i>KPI GED
                    </a>
                    <button id="btnMoveSelected" type="button" class="btn btn-outline-primary" disabled>
                        Mover selecionados <span id="moveSelectedCount">(0)</span>
                    </button>
                </div>
            </div>

            <div class="card-body p-0">
                @if (!Model.Documents.Any())
                {
                    <div class="p-3 text-muted">
                        Nenhum documento nesta pasta.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle" data-ged-document-list>
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px;"><input type="checkbox" id="selectAllDocuments" /></th>
                                    <th>Título</th>
                                    <th style="width:220px;">Tipo</th>
                                    <th style="width:260px;">Arquivo</th>
                                    <th style="width:240px;">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.Documents)
                                {
                                    var isUnclassified = string.IsNullOrWhiteSpace(d.TypeName) || d.TypeName == "-";

                                    <tr draggable="true" data-document-id="@d.Id">
                                        <td><input type="checkbox" class="js-doc-select" value="@d.Id" data-document-title="@d.Title" /></td>
                                        <td class="fw-semibold">@d.Title</td>
                                        <td>
                                            @if (isUnclassified)
                                            {
                                                <span class="badge bg-secondary">Sem classificação</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark">
                                                    <i class="bi bi-tags me-1"></i>@d.TypeName
                                                </span>
                                            }
                                        </td>
                                        <td class="text-muted small">@d.FileName</td>
                                        <td class="d-flex gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-action="Details"
                                               asp-controller="Ged"
                                               asp-route-id="@d.Id">
                                                <i class="bi bi-eye"></i> Abrir
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-secondary js-move-one" data-document-id="@d.Id" data-document-title="@d.Title">
                                                <i class="bi bi-folder-symlink"></i> Mover
                                            </button>

                                            @if (isUnclassified)
                                            {
                                                <a class="btn btn-sm btn-outline-success"
                                                   asp-action="Details"
                                                   asp-controller="Ged"
                                                   asp-route-id="@d.Id"
                                                   asp-route-openClassify="true">
                                                    <i class="bi bi-pencil-square"></i> Classificar
                                                </a>
                                            }

                                            <form method="post" asp-controller="Ged" asp-action="DeleteDocument" class="d-inline js-feedback-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@d.Id" />
                                                <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
                                                <button type="button" class="btn btn-sm btn-outline-danger js-delete-document" data-document-id="@d.Id" data-folder-id="@Model.CurrentFolderId" data-document-title="@d.Title">
                                                    <i class="bi bi-trash"></i> Excluir
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
@Html.AntiForgeryToken()
<div class="modal fade" id="moveDocumentsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Mover documento(s) para outra pasta</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div id="selectedDocumentsSummary" class="small text-muted mb-2"></div>
                <input id="destinationFolderId" type="hidden" />
                <label class="form-label">Pasta destino</label>
                <input type="text" id="folderSearchInput" class="form-control" placeholder="Digite para buscar pasta..." />
                <input type="text" id="destinationFolderName" class="form-control mt-2" placeholder="Pasta selecionada" readonly />
                <div id="folderSearchResults" class="list-group mt-2" style="max-height: 240px; overflow-y: auto;"></div>
                <div id="folderSearchEmpty" class="text-muted small mt-2 d-none">Nenhuma pasta encontrada.</div>
                <div id="folderSearchLoading" class="text-muted small mt-2 d-none">Buscando pastas...</div>
                <label class="form-label mt-2">Justificativa (opcional)</label>
                <textarea id="moveReason" class="form-control" rows="2"></textarea>
                <div id="moveDocumentsMessage" class="d-none mt-2"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button><button id="btnConfirmMove" type="button" class="btn btn-primary" disabled>Confirmar movimentação</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalFilaOcr" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-diagram-3 me-1"></i>Fila de Processamento OCR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2 mb-3">
                    <div class="col-4">
                        <div class="card"><div class="card-body py-2">
                            <div class="small text-muted">Processando</div>
                            <div class="h5 mb-0" id="queueProcessingCount">0</div>
                        </div></div>
                    </div>
                    <div class="col-4">
                        <div class="card"><div class="card-body py-2">
                            <div class="small text-muted">Pendentes</div>
                            <div class="h5 mb-0" id="queuePendingCount">0</div>
                        </div></div>
                    </div>
                    <div class="col-4">
                        <div class="card"><div class="card-body py-2">
                            <div class="small text-muted">Total na fila</div>
                            <div class="h5 mb-0" id="queueTotalCount">0</div>
                        </div></div>
                    </div>
                </div>
                <div class="progress mb-3" style="height:8px;">
                    <div id="queueLoadBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width:0%"></div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Posição</th>
                                <th>Job</th>
                                <th>Documento</th>
                                <th>Status</th>
                                <th>Solicitado</th>
                                <th>Iniciado</th>
                            </tr>
                        </thead>
                        <tbody id="queueTableBody">
                            <tr><td colspan="6" class="text-muted">Carregando fila...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL RENOMEAR PASTA (EXPLORER) -->
<div class="modal fade" id="modalRenomearPastaExplorer" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Ged" asp-action="RenomearPastaExplorer" method="post" class="js-feedback-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="exp-rename-id" />
                <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil me-1"></i> Renomear pasta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2 text-muted">
                        Pasta: <strong id="exp-rename-old"></strong>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Novo nome</label>
                        <input name="nome" id="exp-rename-nome" class="form-control" maxlength="200" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i> Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL EXCLUIR PASTA (EXPLORER) -->
<div class="modal fade" id="modalExcluirPastaExplorer" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Ged" asp-action="ExcluirPastaExplorer" method="post" class="js-feedback-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="exp-del-id" />
                <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><i class="bi bi-trash me-1"></i> Excluir pasta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">
                        Confirma a exclusão da pasta <strong id="exp-del-nome"></strong>?
                        <br />
                        <span class="text-muted small">A exclusão é lógica (pasta fica inativa).</span>
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-danger" type="submit"><i class="bi bi-trash me-1"></i> Excluir</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL UPLOAD -->
<div class="modal fade" id="modalUpload" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload de Documento</h5>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>

            <form method="post"
                  enctype="multipart/form-data"
                  asp-action="Upload"
                  asp-controller="Ged"
                  class="js-feedback-form">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />

                    <div class="mb-3">
                        <label class="form-label">Arquivo</label>
                        <input class="form-control" type="file" name="file" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Título</label>
                        <input class="form-control" type="text" name="title" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-light" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary"
                            type="submit"
                    @(Model.CurrentFolderId == null ? "disabled" : "")>
                        <span class="btn-text">Enviar</span>
                        <span class="btn-loading d-none"><span class="spinner-border spinner-border-sm me-1"></span>Enviando...</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="bulkUploadModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header"><div><h5 class="modal-title">Adicionar documentos em lote</h5><small class="text-muted">Envie vários arquivos diretamente para a pasta selecionada.</small></div><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <input type="hidden" id="bulkFolderId" value="@Model.CurrentFolderId" />
        <div id="bulkUploadMessage" class="d-none alert"></div>
        <div id="bulkDropzone" class="border border-2 border-secondary-subtle rounded p-4 text-center mb-3" style="border-style:dashed !important; cursor:pointer;">
            <i class="bi bi-cloud-arrow-up fs-1 d-block mb-2"></i><strong>Arraste arquivos aqui ou clique para selecionar</strong>
            <input id="bulkFileInput" type="file" multiple class="d-none" />
        </div>
        <div id="bulkDuplicateDecision" class="alert alert-warning d-none"><strong>Arquivos com o mesmo nome já existem.</strong><div class="small mb-2">Escolha como deseja continuar.</div><ul id="bulkDuplicateList" class="mb-2"></ul><div class="btn-group btn-group-sm"><button type="button" class="btn btn-outline-danger" id="btnDupOverwrite">Sobrescrever todos</button><button type="button" class="btn btn-outline-primary" id="btnDupRename">Renomear todos</button><button type="button" class="btn btn-outline-secondary" id="btnDupSkip">Ignorar duplicados</button><button type="button" class="btn btn-outline-dark" id="btnDupCancel">Cancelar envio</button></div></div><div class="d-flex justify-content-between align-items-center mb-2"><strong>Arquivos selecionados</strong><button class="btn btn-sm btn-outline-secondary" id="btnBulkClear">Limpar lista</button></div><div id="bulkSummary" class="small text-muted mb-2"></div>
        <div class="table-responsive"><table class="table table-sm"><thead><tr><th>Arquivo</th><th>Tamanho</th><th>Status</th><th>Progresso</th><th></th></tr></thead><tbody id="bulkFileList"></tbody></table></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button><button type="button" class="btn btn-outline-warning d-none" id="btnBulkRetryFailed">Tentar novamente falhos</button><button type="button" class="btn btn-primary" id="btnBulkSend">Enviar documentos</button></div>
    </div>
  </div>
</div>


<div class="modal fade" id="deleteDocumentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger">Confirmar exclusão</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <p id="deleteDocumentMessage" class="mb-2">Deseja realmente excluir este documento? Se houver OCR em andamento, ele será cancelado.</p>
        <div id="deleteDocumentInline" class="d-none alert"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-danger" id="btnConfirmDeleteDocument">Excluir documento</button>
