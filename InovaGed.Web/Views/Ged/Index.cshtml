        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload de Documento</h5>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>

            <form method="post"
                  enctype="multipart/form-data"
                  asp-action="Upload"
                  asp-controller="Ged"
                  class="js-feedback-form">
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />

                    <div class="mb-3">
                        <label class="form-label">Arquivo</label>
                        <input class="form-control" type="file" name="file" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Título</label>
                        <input class="form-control" type="text" name="title" />
                    </div>

                    <div class="card border-warning-subtle mb-3">
                        <div class="card-body py-3">
                            <div class="fw-semibold mb-2"><i class="bi bi-diagram-2 me-1"></i>Tipo de documento enviado</div>
                            <div class="form-check mb-2">
                                <input class="form-check-input js-upload-partial-mode" type="radio" name="uploadPartialMode" id="uploadDocumentComplete" value="complete" checked>
                                <label class="form-check-label fw-semibold" for="uploadDocumentComplete">Documento completo</label>
                                <div class="form-text">Use quando o arquivo enviado já representa o documento inteiro.</div>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input js-upload-partial-mode" type="radio" name="uploadPartialMode" id="uploadDocumentIncomplete" value="partial" @(canManagePartialDocuments ? null : "disabled")>
                                <label class="form-check-label fw-semibold" for="uploadDocumentIncomplete">Documento incompleto</label>
                                <button type="button" class="btn btn-link btn-sm p-0 ms-1 align-baseline" data-bs-toggle="popover" data-bs-trigger="hover focus" data-bs-placement="right" title="Documento fracionado" data-bs-content="Documento incompleto é um documento enviado parcialmente e que poderá receber novas partes futuramente. Exemplo: um documento de agendamento foi digitalizado pela metade hoje e a outra parte será enviada depois." aria-label="Ajuda sobre documento incompleto"><i class="bi bi-question-circle"></i></button>
                                <div class="form-text">Use quando o documento está sendo enviado em partes e será complementado futuramente.@(!canManagePartialDocuments ? " Permissão necessária: DOCUMENT_PART_MARK_INCOMPLETE ou DOCUMENT_PART_ADD." : "")</div>
                            </div>
                            <div id="uploadPartialFields" class="alert alert-warning mt-3 mb-0 d-none">
                                <input type="hidden" name="isDocumentPart" id="uploadIsDocumentPart" value="false" />
                                <div class="mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Documento incompleto é um documento enviado parcialmente e que poderá receber novas partes futuramente. Exemplo: um documento de agendamento foi digitalizado pela metade hoje e a outra parte será enviada depois.</div>
                                <div class="row g-2">
                                    <div class="col-sm-4">
                                        <label class="form-label" for="uploadPartNumber">Parte número</label>
                                        <input type="number" class="form-control" name="partNumber" id="uploadPartNumber" min="1" step="1" value="1" />
                                    </div>
                                    <div class="col-sm-4">
                                        <label class="form-label" for="uploadTotalParts">Total previsto (opcional)</label>
                                        <input type="number" class="form-control" name="totalParts" id="uploadTotalParts" min="1" step="1" placeholder="Ex.: 2" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label" for="uploadPartialNotes">Observação (opcional)</label>
                                        <textarea class="form-control" name="partialNotes" id="uploadPartialNotes" rows="2" placeholder="Primeira parte do agendamento, complemento será enviado posteriormente."></textarea>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label" for="uploadExistingPartialDocumentId">Vincular a documento incompleto existente (opcional)</label>
                                        <input type="text" class="form-control" name="existingDocumentId" id="uploadExistingPartialDocumentId" placeholder="UUID do documento incompleto, quando esta for uma nova parte" />
                                        <div class="form-text">Use apenas quando o arquivo enviado deve complementar um documento incompleto já cadastrado.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-light" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary"
                            type="submit"
                    @(Model.CurrentFolderId == null ? "disabled" : "")>
                        <span class="btn-text">Enviar</span>
                        <span class="btn-loading d-none"><span class="spinner-border spinner-border-sm me-1"></span>Enviando...</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

