@model InovaGed.Web.Models.Ged.GedExplorerVM
@using InovaGed.Application.Identity
@using InovaGed.Application.Classification
@using InovaGed.Application.Ged.Folders
@using System.Threading
@using Microsoft.Extensions.Options
@using InovaGed.Web.Security

@inject ICurrentUser CurrentUser
@inject IDocumentClassificationQueries ClassificationQueries
@inject IOptions<InovaGed.Application.Ged.Documents.DocumentUploadOptions> DocumentUploadOptions

@{
    ViewData["Title"] = "GED - Documentos";

    // KPI: documentos não classificados (na pasta atual)
    var unclassifiedCount = 0;
    if (CurrentUser.IsAuthenticated)
    {
        unclassifiedCount = await ClassificationQueries.CountUnclassifiedAsync(
            CurrentUser.TenantId,
            Model.CurrentListingFolderId ?? Model.CurrentFolderId,
            CancellationToken.None
        );
    }

    var runningOcrCount = (ViewBag.RunningOcrCount as int?) ?? 0;
    var canManagePartialDocuments = RolePolicyHelper.IsFullAdmin(User) || User.IsInRole(AppRoles.Arquivista) || User.IsInRole(AppRoles.ArquivistaOphir);
    var uploadFolderIsVirtual = Model.CurrentFolderIsVirtual || FolderIdHelper.IsVirtualFolder(Model.CurrentFolderId);
    var uploadFolderLabel = !string.IsNullOrWhiteSpace(Model.CurrentFolderName) ? Model.CurrentFolderName : "pasta selecionada";
    var currentFolderNode = Model.CurrentFolderId.HasValue ? Model.Folders.FirstOrDefault(x => x.Id == Model.CurrentFolderId.Value || x.ListingFolderId == Model.CurrentFolderId.Value || x.UploadFolderId == Model.CurrentFolderId.Value) : null;
    var currentListingFolderId = Model.CurrentListingFolderId ?? currentFolderNode?.ListingFolderId ?? Model.CurrentFolderId;
    var currentUploadFolderId = Model.CurrentUploadFolderId ?? (currentFolderNode?.UploadFolderId == Guid.Empty ? Model.CurrentFolderId : (currentFolderNode?.UploadFolderId ?? currentListingFolderId));
    var currentCanReceiveDocuments = currentFolderNode?.CanReceiveDocuments ?? Model.CurrentFolderId.HasValue;
    var allowLegacyUploadFallback = DocumentUploadOptions.Value.AllowLegacyUploadFallback;
    var uploadOptions = DocumentUploadOptions.Value;
    var ocrAvailableCount = Model.Documents.Count(d => d.IsOcrAvailable);
    var incompleteCount = Model.Documents.Count(d => d.IsDocumentIncomplete || string.Equals(d.PartialStatus, "INCOMPLETE", StringComparison.OrdinalIgnoreCase));
    var readyToConsolidateCount = Model.Documents.Count(d => d.IsPartialDocument && !d.IsDocumentIncomplete && string.Equals(d.PartialStatus, "COMPLETE", StringComparison.OrdinalIgnoreCase));
    var consolidatedCount = Model.Documents.Count(d => string.Equals(d.PartialStatus, "CONSOLIDATED", StringComparison.OrdinalIgnoreCase) || d.ConsolidatedVersionId.HasValue);
    var partialOcrCount = Model.Documents.Count(d => d.PartialPartsWithOcrCount > 0 && d.PartialPartsWithOcrCount < (d.TotalParts ?? d.PartialTotalParts ?? d.PartialPartsCount));
    var pendingOcrCount = runningOcrCount;
    var breadcrumbText = currentFolderNode?.Path ?? (!string.IsNullOrWhiteSpace(Model.CurrentFolderName) ? Model.CurrentFolderName : "Raiz");
}

<div class="ged-page">
    <div id="pageAlertHost" class="mb-2">
        @if (Model.CurrentFolderIsVirtual)
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle me-1"></i>Destino selecionado: @uploadFolderLabel. O sistema validará o destino ao iniciar o upload.
            </div>
        }
        @if (TempData["Success"] is string okMsg && !string.IsNullOrWhiteSpace(okMsg))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i>@okMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }
        @if (TempData["Error"] is string errMsg && !string.IsNullOrWhiteSpace(errMsg))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i>@errMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning" role="alert">
                <i class="bi bi-database-exclamation me-1"></i>@Model.ErrorMessage
            </div>
        }
    </div>

    <!-- COLUNA PASTAS -->
    <aside class="ged-folder-panel">
        <div class="ged-folder-panel-header">
            <div>
                <div class="fw-semibold">Pastas</div>
                <div class="small text-muted">Explorer documental</div>
            </div>
            <div class="d-flex gap-1">
                <button type="button" class="btn btn-sm btn-light" id="btnReloadFolderTree" title="Recarregar"><i class="bi bi-arrow-clockwise"></i></button>
                <a class="btn btn-sm btn-outline-primary" asp-action="Folders" asp-controller="Ged" title="Gerenciar pastas"><i class="bi bi-gear"></i></a>
            </div>
        </div>
        <div class="ged-folder-search p-2 border-bottom">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input id="gedFolderSearch" class="form-control" placeholder="Buscar pasta" autocomplete="off" />
            </div>
        </div>
        <div class="ged-folder-tree ged-folder-scroll">
                @{
                    var byParent = Model.Folders
                    .Where(x => x.ParentId != null)
                    .GroupBy(x => x.ParentId!.Value)
                    .ToDictionary(
                    g => g.Key,
                    g => g.OrderBy(x => x.Name).ToList()
                    );

                    var rootFolders = Model.Folders
                    .Where(x => x.ParentId == null)
                    .OrderBy(x => x.Name)
                    .ToList();

                    string BuildFolderPath(Guid folderId)
                    {
                        var chain = new List<string>();
                        var current = Model.Folders.FirstOrDefault(x => x.Id == folderId);
                        while (current is not null)
                        {
                            chain.Add(current.Name);
                            current = current.ParentId.HasValue
                                ? Model.Folders.FirstOrDefault(x => x.Id == current.ParentId.Value)
                                : null;
                        }

                        chain.Reverse();
                        return chain.Count == 0 ? string.Empty : string.Join(" > ", chain);
                    }

                    void RenderTree(Guid parentId)
                    {
                        if (!byParent.TryGetValue(parentId, out var children) || children.Count == 0)
                            return;

                        <ul class="ged-tree">
                            @foreach (var n in children)
                            {
                                var hasChildren = byParent.ContainsKey(n.Id);
                                var isActive = Model.CurrentFolderId == n.Id;
                                var href = Url.Action("Index", "Ged", new { folderId = n.Id }) ?? "#";
                                var isVirtual = FolderIdHelper.IsVirtualFolder(n.Id);

                                <li class="ged-tree-node"
                                    data-id="@n.Id"
                                    data-parent="@(n.ParentId?.ToString() ?? "")"
                                    data-has-children="@(hasChildren ? "1" : "0")"
                                    data-folder-id="@n.Id"
                                    data-upload-folder-id="@(n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId)"
                                    data-listing-folder-id="@(n.ListingFolderId == Guid.Empty ? (n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId) : n.ListingFolderId)"
                                    data-can-receive-documents="@(n.CanReceiveDocuments ? "true" : "false")"
                                    data-folder-parent-id="@(n.ParentId?.ToString() ?? "")"
                                    data-folder-name="@n.Name"
                                    data-folder-path="@(n.Path ?? BuildFolderPath(n.Id))"
                                    data-is-virtual="@(n.IsVirtual.ToString().ToLowerInvariant())"
                                    data-folder-virtual="@(n.IsVirtual ? "true" : "false")">

                                    <div class="ged-tree-row @(isActive ? "active" : "")">
                                        @if (hasChildren)
                                        {
                                            <button type="button" class="ged-tree-toggle" aria-label="Expandir/Recolher">
                                                <i class="bi bi-caret-right-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="ged-tree-spacer"></span>
                                        }

                                        <i class="bi bi-folder2 ged-tree-folder"></i>

                                        <a class="js-folder-node ged-tree-link flex-grow-1" href="@href"
                                           data-folder-id="@n.Id"
                                           data-upload-folder-id="@(n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId)"
                                    data-listing-folder-id="@(n.ListingFolderId == Guid.Empty ? (n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId) : n.ListingFolderId)"
                                           data-folder-name="@n.Name"
                                           data-folder-path="@(n.Path ?? BuildFolderPath(n.Id))"
                                           data-is-virtual="@(n.IsVirtual.ToString().ToLowerInvariant())"
                                           data-can-receive-documents="@(n.CanReceiveDocuments.ToString().ToLowerInvariant())">@n.Name</a>

                                        <!-- ✅ AÇÕES DA PASTA -->
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-link text-muted p-0"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false"
                                                    title="Ações">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <button class="dropdown-item"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalRenomearPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-pencil me-1"></i> Renomear
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#modalNovaPasta" data-parent-id="@n.Id">
                                                        <i class="bi bi-folder-plus me-1"></i> Nova subpasta
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item" type="button" data-upload-folder-id="@(n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId)"
                                    data-listing-folder-id="@(n.ListingFolderId == Guid.Empty ? (n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId) : n.ListingFolderId)" data-folder-id="@n.Id" onclick="window.GedBulkUpload?.startUploadToFolder?.(this.dataset.uploadFolderId, [], '@n.Name', this.dataset.folderId, true)">
                                                        <i class="bi bi-cloud-arrow-up me-1"></i> Enviar documentos
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item js-copy-folder-path" type="button" data-folder-path="@(n.Path ?? BuildFolderPath(n.Id))">
                                                        <i class="bi bi-clipboard me-1"></i> Copiar caminho
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button class="dropdown-item text-danger"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalExcluirPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-trash me-1"></i> Excluir
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="ged-tree-children" style="display:none;">
                                        @{
                                            RenderTree(n.Id);
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                }

                @if (!Model.Folders.Any())
                {
                    <div class="text-muted small">Nenhuma pasta cadastrada.</div>
                }
                else
                {
                    var virtualRootId = Guid.Parse("f0000000-0000-0000-0000-000000000001");
                    var virtualRootNode = Model.Folders.FirstOrDefault(x => x.Id == virtualRootId);
                    var virtualRootUploadId = virtualRootNode?.UploadFolderId == Guid.Empty ? virtualRootId : (virtualRootNode?.UploadFolderId ?? virtualRootId);
                    var virtualRootCanReceive = virtualRootNode?.CanReceiveDocuments ?? true;
                    var raizHref = Url.Action("Index", "Ged", new { folderId = virtualRootId }) ?? "#";

                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">
                            <a class="js-folder-node ged-tree-root d-flex align-items-center gap-2 text-decoration-none @(Model.CurrentFolderId == virtualRootId ? "active" : "")"
                               href="@raizHref"
                               data-folder-id="f0000000-0000-0000-0000-000000000001"
                               data-upload-folder-id="@virtualRootUploadId"
                               data-listing-folder-id="@virtualRootUploadId"
                               data-folder-name="Raiz"
                               data-folder-path="Raiz"
                               data-is-virtual="true"
                               data-can-receive-documents="@(virtualRootCanReceive.ToString().ToLowerInvariant())"
                               data-folder-virtual="true">
                                <i class="bi bi-house"></i> Raiz
                            </a>
                        </li>
                    </ul>

                    <div class="mt-2">
                        <ul class="ged-tree">
                            @foreach (var n in rootFolders)
                            {
                                var hasChildren = byParent.ContainsKey(n.Id);
                                var isActive = Model.CurrentFolderId == n.Id;
                                var href = Url.Action("Index", "Ged", new { folderId = n.Id }) ?? "#";
                                var isVirtual = FolderIdHelper.IsVirtualFolder(n.Id);

                                <li class="ged-tree-node"
                                    data-id="@n.Id"
                                    data-parent=""
                                    data-has-children="@(hasChildren ? "1" : "0")"
                                    data-folder-id="@n.Id"
                                    data-upload-folder-id="@(n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId)"
                                    data-listing-folder-id="@(n.ListingFolderId == Guid.Empty ? (n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId) : n.ListingFolderId)"
                                    data-can-receive-documents="@(n.CanReceiveDocuments ? "true" : "false")"
                                    data-folder-parent-id=""
                                    data-folder-name="@n.Name"
                                    data-folder-path="@(n.Path ?? BuildFolderPath(n.Id))"
                                    data-is-virtual="@(n.IsVirtual.ToString().ToLowerInvariant())"
                                    data-folder-virtual="@(n.IsVirtual ? "true" : "false")">

                                    <div class="ged-tree-row @(isActive ? "active" : "")">
                                        @if (hasChildren)
                                        {
                                            <button type="button" class="ged-tree-toggle" aria-label="Expandir/Recolher">
                                                <i class="bi bi-caret-right-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="ged-tree-spacer"></span>
                                        }

                                        <i class="bi bi-folder2 ged-tree-folder"></i>
                                        <a class="js-folder-node ged-tree-link flex-grow-1" href="@href"
                                           data-folder-id="@n.Id"
                                           data-upload-folder-id="@(n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId)"
                                    data-listing-folder-id="@(n.ListingFolderId == Guid.Empty ? (n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId) : n.ListingFolderId)"
                                           data-folder-name="@n.Name"
                                           data-folder-path="@(n.Path ?? BuildFolderPath(n.Id))"
                                           data-is-virtual="@(n.IsVirtual.ToString().ToLowerInvariant())"
                                           data-can-receive-documents="@(n.CanReceiveDocuments.ToString().ToLowerInvariant())">@n.Name</a>

                                        <!-- ✅ AÇÕES DA PASTA -->
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-link text-muted p-0"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-expanded="false"
                                                    title="Ações">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <button class="dropdown-item"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalRenomearPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-pencil me-1"></i> Renomear
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#modalNovaPasta" data-parent-id="@n.Id">
                                                        <i class="bi bi-folder-plus me-1"></i> Nova subpasta
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item" type="button" data-upload-folder-id="@(n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId)"
                                    data-listing-folder-id="@(n.ListingFolderId == Guid.Empty ? (n.UploadFolderId == Guid.Empty ? n.Id : n.UploadFolderId) : n.ListingFolderId)" data-folder-id="@n.Id" onclick="window.GedBulkUpload?.startUploadToFolder?.(this.dataset.uploadFolderId, [], '@n.Name', this.dataset.folderId, true)">
                                                        <i class="bi bi-cloud-arrow-up me-1"></i> Enviar documentos
                                                    </button>
                                                </li>
                                                <li>
                                                    <button class="dropdown-item js-copy-folder-path" type="button" data-folder-path="@(n.Path ?? BuildFolderPath(n.Id))">
                                                        <i class="bi bi-clipboard me-1"></i> Copiar caminho
                                                    </button>
                                                </li>
                                                <li><hr class="dropdown-divider" /></li>
                                                <li>
                                                    <button class="dropdown-item text-danger"
                                                            type="button"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#modalExcluirPastaExplorer"
                                                            data-id="@n.Id"
                                                            data-nome="@n.Name">
                                                        <i class="bi bi-trash me-1"></i> Excluir
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="ged-tree-children" style="display:none;">
                                        @{
                                            RenderTree(n.Id);
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }
        </div>
    </aside>

    <!-- COLUNA DOCUMENTOS -->
    <section class="ged-main-panel">
        <div class="ged-folder-header">
            <div class="ged-folder-heading">
                <div class="ged-folder-header-icon"><i class="bi bi-folder2-open"></i></div>
                <div class="min-w-0">
                    <h1 class="h5 mb-1 text-truncate" data-current-folder-title>@(!string.IsNullOrWhiteSpace(Model.CurrentFolderName) ? Model.CurrentFolderName : "Raiz")</h1>
                    <div class="ged-breadcrumb text-truncate" data-current-folder-breadcrumb><i class="bi bi-diagram-3 me-1"></i>@breadcrumbText</div>
                    <div class="ged-metrics-strip">
                        <span class="ged-metric-pill"><strong id="documentsTotalKpi">@Model.Documents.Count</strong> Documentos</span>
                        <span class="ged-metric-pill"><strong id="selectedDocumentsKpi">0</strong> Selecionados</span>
                        <span class="ged-metric-pill"><strong id="documentsUnclassifiedKpi">@unclassifiedCount</strong> Não classificados</span>
                        <span class="ged-metric-pill"><strong id="documentsOcrKpi">@ocrAvailableCount</strong> Com OCR</span>
                        <span class="ged-metric-pill"><strong id="documentsIncompleteKpi">@incompleteCount</strong> Incompletos <button type="button" class="btn btn-link btn-sm p-0 ged-help-popover" data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="bottom" title="Documento incompleto" data-bs-content="Documento incompleto é um documento enviado parcialmente e que poderá receber novas partes futuramente. Exemplo: um documento de agendamento foi digitalizado pela metade hoje e a outra parte será enviada depois. Quando todas as partes forem anexadas, o sistema pode consolidar em uma versão final." aria-label="Ajuda sobre documentos incompletos"><i class="bi bi-question-circle"></i></button></span>
                        <span class="ged-metric-pill"><strong id="documentsReadyConsolidateKpi">@readyToConsolidateCount</strong> Prontos para consolidar</span>
                        <span class="ged-metric-pill"><strong id="documentsConsolidatedKpi">@consolidatedCount</strong> Consolidados</span>
                        <span class="ged-metric-pill"><strong id="documentsPartialOcrKpi">@partialOcrCount</strong> OCR parcial</span>
                        <span class="ged-metric-pill"><strong>@pendingOcrCount</strong> Pendentes</span>
                    </div>
                </div>
            </div>
            <div class="ged-folder-actions">
                @if (Model.CanBulkUpload || Model.CurrentFolderId != null)
                {
                    <button type="button" id="btnOpenBulkUpload" class="btn btn-primary btn-sm"><i class="bi bi-cloud-arrow-up me-1"></i> Adicionar documentos</button>
                }
                <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index", "Ged", new { folderId = Model.CurrentFolderId, q = Model.Query })"><i class="bi bi-arrow-clockwise me-1"></i> Atualizar</a>
                <div class="dropdown">
                    <button class="btn btn-light btn-sm border" type="button" data-bs-toggle="dropdown" aria-label="Mais ações"><i class="bi bi-three-dots"></i></button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Ged" asp-action="Kpi"><i class="bi bi-bar-chart-line me-2"></i>KPI GED</a></li>
                        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#modalFilaOcr"><i class="bi bi-list-task me-2"></i>Ver fila OCR</button></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-2" aria-label="Filtros rápidos de documentos fracionados">
            <button type="button" class="btn btn-sm btn-outline-warning js-quick-partial-filter" data-filter="incomplete"><i class="bi bi-funnel me-1"></i>Ver incompletos</button>
            <button type="button" class="btn btn-sm btn-outline-primary js-quick-partial-filter" data-filter="ready"><i class="bi bi-check2-circle me-1"></i>Ver prontos para consolidar</button>
            <button type="button" class="btn btn-sm btn-outline-info js-quick-partial-filter" data-filter="consolidated"><i class="bi bi-layers me-1"></i>Ver consolidados</button>
            <button type="button" class="btn btn-sm btn-outline-secondary js-quick-partial-filter" data-filter="ocr-partial"><i class="bi bi-text-paragraph me-1"></i>Ver OCR parcial</button>
            <button type="button" class="btn btn-sm btn-light border d-none" id="btnClearPartialFilters"><i class="bi bi-x-circle me-1"></i>Limpar filtro</button>
            <span id="gedActiveQuickFilterChip" class="ged-filter-chip d-none">Filtro: <span data-filter-label></span> <button type="button" class="btn btn-link btn-sm p-0 ms-1" id="btnClearQuickFilterChip" aria-label="Limpar filtro rápido">×</button></span>
        </div>
        <div id="gedFilteredEmptyState" class="alert alert-info d-none" role="status">Nenhum documento encontrado para este filtro.</div>

        <div class="ged-toolbar">
            <div class="ged-toolbar-search">
                <input type="hidden" id="currentFolderId" value="@Model.CurrentFolderId" />
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input id="smartSearchInput" class="form-control" name="q" value="@Model.Query" placeholder="Busque por documento, prontuário, paciente, pasta, tipo, termo do OCR ou número..." />
                    <button id="btnSmartSearchClear" class="btn btn-outline-secondary" type="button" title="Limpar busca"><i class="bi bi-x-lg"></i></button>
                    <button id="btnSmartFilters" class="btn btn-outline-secondary" type="button" title="Filtros avançados"><i class="bi bi-sliders"></i> Filtros</button>
                    <button id="btnSmartSearch" class="btn btn-primary" type="button"><i class="bi bi-search"></i> Pesquisar</button>
                </div>
                <div id="smartSearchSuggestions" class="ged-smart-suggestions"></div>
                <div id="smartSearchFilters" class="border rounded-3 p-2 mt-2 bg-light d-none">
                    <div class="d-flex gap-3 flex-wrap small">
                        <label class="form-check-label"><input class="form-check-input" type="radio" name="searchScope" value="folder" checked /> Pasta atual</label>
                        <label class="form-check-label"><input class="form-check-input" type="radio" name="searchScope" value="global" /> Todo GED</label>
                        <label class="form-check-label"><input class="form-check-input" type="checkbox" disabled /> Apenas com OCR</label>
                        <label class="form-check-label"><input class="form-check-input" type="checkbox" disabled /> Sem classificação</label>
                    </div>
                    <div id="smartSearchChips" class="d-flex flex-wrap gap-1 mt-2"></div>
                </div>
            </div>
            <div class="ged-toolbar-actions">
                <a class="btn btn-sm btn-outline-dark" asp-controller="Ged" asp-action="Kpi"><i class="bi bi-bar-chart-line me-1"></i>KPI GED</a>
                <button type="button" class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#modalFilaOcr"><i class="bi bi-list-task me-1"></i> Fila OCR</button>
