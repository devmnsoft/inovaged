        .ged-operational-icon, .ged-smart-type, .ged-smart-upload { display:none; }
        .ged-operational-content, .ged-smart-main { grid-column:2 / 3; }
        .ged-operational-quick-actions, .ged-smart-actions { grid-column:3; justify-content:flex-end; }
        .ged-documents-view-toolbar { align-items:flex-start; flex-direction:column; }
        .ged-view-actions { width:100%; }
        .ged-view-actions .btn { flex:1 1 0; }
    }
    @@media (max-width: 1199.98px) { .ged-page { grid-template-columns:360px minmax(0,1fr); } .ged-page.with-document-panel { grid-template-columns:360px minmax(0,1fr); } .ged-document-side-panel { grid-column:1 / -1; } .ged-folder-panel { position:static; } .ged-metrics-strip { gap:6px; } }
    @@media (max-width: 768px) { .ged-page, .ged-page.with-document-panel { grid-template-columns:1fr; } }
    .bulk-large-file-hint { color:#0369a1; }
    .ged-how-partial-list li { margin-bottom:.9rem; }
    .ged-how-partial-list span { color:#475569; }
</style>

@section Scripts {
    <script src="~/js/ged-folder-navigation.js" asp-append-version="true"></script>
    <script src="~/js/ged-documents-list.js" asp-append-version="true"></script>
    <script src="~/js/ged-document-side-panel.js" asp-append-version="true"></script>
    <script src="~/js/ged-bulk-upload.js" asp-append-version="true"></script>
    <script src="~/js/ged-document-move.js" asp-append-version="true"></script>
    <script src="~/js/ged-queue-visualizer.js" asp-append-version="true"></script>
    <script src="~/js/ged-smart-search.js" asp-append-version="true"></script>

<script>
    (function () {
        const KEY = "ged.folderTree.expanded";
        const SCROLL_KEY = "ged.folderTree.scrollTop";
        const treeScroll = document.querySelector(".ged-folder-tree");
        if (treeScroll) {
            const savedScroll = Number(sessionStorage.getItem(SCROLL_KEY) || "0");
            if (savedScroll > 0) treeScroll.scrollTop = savedScroll;
            treeScroll.addEventListener("scroll", () => sessionStorage.setItem(SCROLL_KEY, String(treeScroll.scrollTop)));
        }
        document.addEventListener("click", (e) => {
            if (e.target.closest(".js-folder-node") && treeScroll) sessionStorage.setItem(SCROLL_KEY, String(treeScroll.scrollTop));
        }, true);
        document.getElementById("btnReloadFolderTree")?.addEventListener("click", () => window.location.reload());
        document.getElementById("gedFolderSearch")?.addEventListener("input", (e) => {
            const q = (e.target.value || "").trim().toLowerCase();
            document.querySelectorAll(".ged-tree-node").forEach(li => {
                const name = (li.dataset.folderName || li.textContent || "").toLowerCase();
                li.classList.toggle("d-none", q.length > 0 && !name.includes(q));
            });
        });
        document.addEventListener("click", async (e) => {
            const btn = e.target.closest(".js-copy-folder-path");
            if (!btn) return;
            await navigator.clipboard?.writeText(btn.dataset.folderPath || "").catch(() => null);
            showToast("Caminho da pasta copiado.", "info");
        });

        function loadOpenSet() {
            try { return new Set(JSON.parse(localStorage.getItem(KEY) || "[]")); }
            catch { return new Set(); }
        }
        function saveOpenSet(set) {
            localStorage.setItem(KEY, JSON.stringify(Array.from(set)));
        }

        const openSet = loadOpenSet();
        const nodes = Array.from(document.querySelectorAll(".ged-tree-node"));

        function setNodeOpen(li, open) {
            const hasChildren = li.getAttribute("data-has-children") === "1";
            if (!hasChildren) return;

            const children = li.querySelector(":scope > .ged-tree-children");
            if (!children) return;

            if (open) {
                li.classList.add("open");
                children.style.display = "block";
                openSet.add(li.getAttribute("data-id"));
            } else {
                li.classList.remove("open");
                children.style.display = "none";
                openSet.delete(li.getAttribute("data-id"));
            }
            saveOpenSet(openSet);
        }

        nodes.forEach(li => {
            const id = li.getAttribute("data-id");
            if (openSet.has(id)) setNodeOpen(li, true);
        });

        document.addEventListener("click", (e) => {
            const btn = e.target.closest(".ged-tree-toggle");
            if (!btn) return;

            const li = btn.closest(".ged-tree-node");
            if (!li) return;

            const isOpen = li.classList.contains("open");
            setNodeOpen(li, !isOpen);
            e.preventDefault();
            e.stopPropagation();
        });

        const active = document.querySelector(".ged-tree-row.active");
        if (active) {
            let li = active.closest(".ged-tree-node");
            while (li) {
                setNodeOpen(li, true);

                const parentId = li.getAttribute("data-parent");
                if (!parentId) break;

                li = document.querySelector(`.ged-tree-node[data-id="${parentId}"]`);
            }
        }

        // Modais Pasta Explorer
        const newFolderModal = document.getElementById('modalNovaPasta');
        newFolderModal?.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const parent = btn?.getAttribute('data-parent-id') || '';
            const input = document.getElementById('new-folder-parent-id');
            if (input) input.value = parent;
        });

        const renameModal = document.getElementById('modalRenomearPastaExplorer');
        renameModal?.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const id = btn.getAttribute('data-id');
            const nome = btn.getAttribute('data-nome');

            document.getElementById('exp-rename-id').value = id;
            document.getElementById('exp-rename-old').textContent = nome;
            document.getElementById('exp-rename-nome').value = nome;
        });

        const delModal = document.getElementById('modalExcluirPastaExplorer');
        delModal?.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            const id = btn.getAttribute('data-id');
            const nome = btn.getAttribute('data-nome');

            document.getElementById('exp-del-id').value = id;
            document.getElementById('exp-del-nome').textContent = nome;
        });

        function setBtnLoading(btn, loading) {
            if (!btn) return;
            const text = btn.querySelector('.btn-text');
            const loadingEl = btn.querySelector('.btn-loading');
            if (loading) {
                btn.setAttribute('disabled', 'disabled');
                if (text) text.classList.add('d-none');
                if (loadingEl) loadingEl.classList.remove('d-none');
            } else {
                btn.removeAttribute('disabled');
                if (text) text.classList.remove('d-none');
                if (loadingEl) loadingEl.classList.add('d-none');
            }
        }

        function showToast(message, type) {
            if (!message) return;
            const hostId = 'gedToastHost';
            let host = document.getElementById(hostId);
            if (!host) {
                host = document.createElement('div');
                host.id = hostId;
                host.style.position = 'fixed';
                host.style.top = '1rem';
                host.style.right = '1rem';
                host.style.zIndex = '1080';
                host.style.maxWidth = '420px';
                document.body.appendChild(host);
            }
            const cls = type === 'danger' ? 'alert-danger' : 'alert-info';
            const el = document.createElement('div');
            el.className = `alert ${cls} shadow-sm mb-2`;
            el.innerText = message;
            host.appendChild(el);
            setTimeout(() => el.remove(), 5000);
        }

        document.querySelectorAll('.js-feedback-form').forEach(form => {
            form.addEventListener('submit', function () {
                const btn = form.querySelector('button[type=\"submit\"]');
                setBtnLoading(btn, true);
                showToast('Processando sua solicitação...', 'info');
            });
        });

        function updateSelectedKpi() {
            const count = new Set(Array.from(document.querySelectorAll('.js-doc-select:checked')).map(x => x.value).filter(Boolean)).size;
            const el = document.getElementById('selectedDocumentsKpi');
            if (el) el.textContent = String(count);
            const inline = document.getElementById('selectedDocumentsInlineInfo');
            if (inline) inline.textContent = `${count} documento${count === 1 ? '' : 's'} selecionado${count === 1 ? '' : 's'}`;
            document.querySelectorAll('.ged-selection-bar').forEach(x => x.classList.toggle('has-selection', count > 0));
            document.querySelectorAll('.js-clear-document-selection').forEach(btn => { btn.disabled = count === 0; });
        }

        function escapeCssValue(value) {
            return window.CSS?.escape ? CSS.escape(value) : String(value).replace(/[^a-zA-Z0-9_-]/g, "\\$&");
        }

        function updateDocumentSelectionState(checkbox) {
            const row = checkbox.closest('.ged-doc-row, .ged-smart-doc-row, .ged-operational-row, .ged-document-row, tr[data-document-id]');
            if (row) row.classList.toggle('is-selected', checkbox.checked);
        }

        function syncDocumentSelection(documentId, checked) {
            if (!documentId) return;
            document.querySelectorAll(`#gedDocumentsContainer .js-doc-select[value="${escapeCssValue(documentId)}"]`).forEach(cb => {
                cb.checked = checked;
                updateDocumentSelectionState(cb);
            });
        }

        function updateSelectAllStates() {
            const container = document.getElementById('gedDocumentsContainer');
            if (!container) return;
            const ids = Array.from(new Set(Array.from(container.querySelectorAll('.js-doc-select')).map(x => x.value).filter(Boolean)));
            const selected = new Set(Array.from(container.querySelectorAll('.js-doc-select:checked')).map(x => x.value).filter(Boolean));
            const allChecked = ids.length > 0 && ids.every(id => selected.has(id));
            const partial = selected.size > 0 && !allChecked;
            container.querySelectorAll('#selectAllDocuments, #selectAllDocumentsTable').forEach(cb => {
                cb.checked = allChecked;
                cb.indeterminate = partial;
            });
        }

        function normalizeDocumentsViewMode(mode) {
            return mode === 'table' || mode === 'technical-table' ? 'table' : 'smart-list';
        }

        function applyDocumentsViewMode(mode) {
            const normalized = normalizeDocumentsViewMode(mode);

            document.querySelectorAll('[data-documents-view]').forEach(el => {
                const isActive = el.dataset.documentsView === normalized;
                el.classList.toggle('d-none', !isActive);
            });

            document.querySelectorAll('.js-doc-view-mode').forEach(btn => {
                const active = btn.dataset.viewMode === normalized;
                btn.classList.toggle('active', active);
                btn.classList.toggle('btn-primary', active);
                btn.classList.toggle('btn-outline-primary', !active);
                btn.setAttribute('aria-pressed', active ? 'true' : 'false');
            });

            localStorage.setItem('ged.documents.viewMode', normalized);
            initializeDocumentDropdowns();
            updateSelectAllStates();
            updateSelectedKpi();
        }

        function initializeDocumentDropdowns() {
            if (!window.bootstrap?.Dropdown) return;
            document.querySelectorAll('#gedDocumentsContainer [data-bs-toggle="dropdown"]').forEach(el => window.bootstrap.Dropdown.getOrCreateInstance(el));
        }

        function initDocumentsViewMode() {
            const container = document.getElementById('gedDocumentsContainer');
            if (!container) return;
            const selected = new Set(Array.from(container.querySelectorAll('.js-doc-select:checked')).map(x => x.value).filter(Boolean));
            selected.forEach(id => syncDocumentSelection(id, true));
            container.querySelectorAll('.js-doc-select:not(:checked)').forEach(updateDocumentSelectionState);
            const saved = localStorage.getItem('ged.documents.viewMode') || 'smart-list';
            applyDocumentsViewMode(saved);
        }

        window.GedDocumentsView = {
            key: 'ged.documents.viewMode',
            defaultMode: 'smart-list',
            apply: applyDocumentsViewMode,
            init: initDocumentsViewMode,
            initDropdowns: initializeDocumentDropdowns
        };

        window.applyDocumentsViewMode = applyDocumentsViewMode;
        window.initDocumentsViewMode = initDocumentsViewMode;
        window.initializeDocumentsViewMode = initDocumentsViewMode;
        window.updateDocumentSelectionState = updateDocumentSelectionState;
        window.updateSelectedDocumentsState = function () { updateSelectAllStates(); updateSelectedKpi(); window.updateMoveSelectedButton?.(); };

        if (!window.__gedDocumentsViewClickBound) {
            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.js-doc-view-mode');
                if (!btn) return;

                e.preventDefault();
                applyDocumentsViewMode(btn.dataset.viewMode || 'smart-list');
            });
            window.__gedDocumentsViewClickBound = true;
        }

        document.addEventListener('change', (e) => {
            if (e.target.matches('.js-doc-select')) {
                syncDocumentSelection(e.target.value, e.target.checked);
                updateSelectAllStates();
                setTimeout(updateSelectedKpi, 0);
                window.updateMoveSelectedButton?.();
            }
            if (e.target.matches('#selectAllDocuments, #selectAllDocumentsTable')) {
                document.querySelectorAll('#gedDocumentsContainer .js-doc-select').forEach(cb => {
                    cb.checked = e.target.checked;
                    updateDocumentSelectionState(cb);
                });
                updateSelectAllStates();
                setTimeout(updateSelectedKpi, 0);
                window.updateMoveSelectedButton?.();
            }
        });

        document.addEventListener('click', function (e) {
            const filterLabels = { incomplete: 'Incompletos', ready: 'Prontos para consolidar', consolidated: 'Consolidados', 'ocr-partial': 'OCR parcial' };
            function matchesGedQuickFilter(row, filterName) {
                if (filterName === 'ready') return row.dataset.documentReadyToConsolidate === 'true' || row.dataset.documentReadyConsolidate === 'true';
                if (filterName === 'consolidated') return row.dataset.documentConsolidated === 'true';
                if (filterName === 'ocr-partial') return row.dataset.documentOcrPartial === 'true';
                return row.dataset.documentIncomplete === 'true';
            }
            function updateGedFilterChip(filterName) {
                const chip = document.getElementById('gedActiveQuickFilterChip');
                if (!chip) return;
                chip.querySelector('[data-filter-label]').textContent = filterLabels[filterName] || filterName;
                chip.classList.remove('d-none');
            }
            function toggleGedFilteredEmptyState(isEmpty, filterName) {
                const empty = document.getElementById('gedFilteredEmptyState');
                if (!empty) return;
                empty.textContent = isEmpty ? `Nenhum documento encontrado para este filtro (${filterLabels[filterName] || filterName}).` : '';
                empty.classList.toggle('d-none', !isEmpty);
            }
            function applyGedQuickFilter(filterName, sourceButton) {
                const activeRows = document.querySelectorAll('#gedDocumentsContainer [data-documents-view="smart-list"] [data-document-id]');
                let visibleCount = 0;
                document.querySelectorAll('#gedDocumentsContainer [data-document-id]').forEach(row => {
                    const visible = matchesGedQuickFilter(row, filterName);
                    row.classList.toggle('d-none', !visible);
                });
                activeRows.forEach(row => { if (!row.classList.contains('d-none')) visibleCount++; });
                document.querySelectorAll('.js-quick-partial-filter').forEach(btn => btn.classList.toggle('active', btn === sourceButton));
                document.getElementById('btnClearPartialFilters')?.classList.remove('d-none');
                updateGedFilterChip(filterName);
                toggleGedFilteredEmptyState(visibleCount === 0, filterName);
                fetch('/Ged/DocumentParts/FilterAudit', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }, body: JSON.stringify({ filterName }) }).catch(() => {});
            }
            function clearGedQuickFilter() {
                document.querySelectorAll('#gedDocumentsContainer [data-document-id]').forEach(row => row.classList.remove('d-none'));
                document.querySelectorAll('.js-quick-partial-filter').forEach(btn => btn.classList.remove('active'));
                document.getElementById('btnClearPartialFilters')?.classList.add('d-none');
                document.getElementById('gedActiveQuickFilterChip')?.classList.add('d-none');
                document.getElementById('gedFilteredEmptyState')?.classList.add('d-none');
            }

            const partialFilterBtn = e.target.closest('.js-quick-partial-filter');
            if (partialFilterBtn) {
                e.preventDefault();
                applyGedQuickFilter(partialFilterBtn.dataset.filter, partialFilterBtn);
                return;
            }

            const clearPartialFilters = e.target.closest('#btnClearPartialFilters, #btnClearQuickFilterChip');
            if (clearPartialFilters) {
                e.preventDefault();
                clearGedQuickFilter();
                return;
            }

            const filterBtn = e.target.closest('#btnFilterIncompleteDocs');
            if (filterBtn) {
                e.preventDefault();
                document.querySelectorAll('#gedDocumentsContainer [data-document-incomplete]').forEach(row => {
                    const isIncomplete = row.dataset.documentIncomplete === 'true';
                    row.classList.toggle('d-none', !isIncomplete);
                });
                document.getElementById('gedIncompleteFilterChip')?.classList.remove('d-none');
                filterBtn.textContent = 'Mostrando incompletos';
            }

            const clearFilterBtn = e.target.closest('#btnClearIncompleteFilter');
            if (clearFilterBtn) {
                e.preventDefault();
                document.querySelectorAll('#gedDocumentsContainer [data-document-incomplete]').forEach(row => row.classList.remove('d-none'));
                document.getElementById('gedIncompleteFilterChip')?.classList.add('d-none');
                const btn = document.getElementById('btnFilterIncompleteDocs');
                if (btn) btn.innerHTML = '<i class="bi bi-funnel me-1"></i>Ver incompletos';
            }

            const clearSelectionBtn = e.target.closest('.js-clear-document-selection');
            if (clearSelectionBtn) {
                e.preventDefault();
                document.querySelectorAll('#gedDocumentsContainer .js-doc-select, #selectAllDocuments, #selectAllDocumentsTable').forEach(cb => {
                    cb.checked = false;
                    cb.indeterminate = false;
                    if (cb.classList.contains('js-doc-select')) updateDocumentSelectionState(cb);
                });
                updateSelectAllStates();
                updateSelectedKpi();
                window.updateMoveSelectedButton?.();
            }
        });

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => window.bootstrap?.Popover?.getOrCreateInstance(el));
            const syncLegacyPartialFields = () => {
                const isPartial = document.getElementById('uploadDocumentIncomplete')?.checked === true;
                document.getElementById('uploadPartialFields')?.classList.toggle('d-none', !isPartial);
                const flag = document.getElementById('uploadIsDocumentPart');
                if (flag) flag.value = isPartial ? 'true' : 'false';
            };
            document.querySelectorAll('.js-upload-partial-mode').forEach(el => el.addEventListener('change', syncLegacyPartialFields));
            syncLegacyPartialFields();
        });

        document.addEventListener('DOMContentLoaded', initDocumentsViewMode);
        updateSelectedKpi();
        initDocumentsViewMode();

    })();
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const addPartEl = document.getElementById('modalAddDocumentPart');
    const partsEl = document.getElementById('modalDocumentParts');
    const addPartModal = addPartEl && window.bootstrap?.Modal ? window.bootstrap.Modal.getOrCreateInstance(addPartEl) : null;
    const partsModal = partsEl && window.bootstrap?.Modal ? window.bootstrap.Modal.getOrCreateInstance(partsEl) : null;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    const escapeHtml = (value) => window.escapeHtml ? window.escapeHtml(value) : String(value ?? '').replace(/[&<>"]/g, ch => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[ch]));

    function showAddPartMessage(message, type) {
        const el = document.getElementById('addPartMessage');
        if (!el) return;
        el.className = `alert alert-${type || 'info'} mt-3`;
        el.textContent = message;
    }

    async function loadDocumentParts(documentId, title) {
        const body = document.getElementById('documentPartsTableBody');
        const titleEl = document.getElementById('documentPartsTitle');
        const consolidateBtn = document.getElementById('btnConsolidateDocument');
        if (titleEl) titleEl.innerHTML = title ? `<strong>Documento:</strong> ${escapeHtml(title)}<br><span class="text-muted">Status e partes serão carregados abaixo.</span>` : '';
        if (body) body.innerHTML = '<tr><td colspan="8" class="text-muted"><span class="spinner-border spinner-border-sm me-1"></span>Carregando partes...</td></tr>';
        if (consolidateBtn) { consolidateBtn.disabled = true; consolidateBtn.dataset.documentId = documentId || ''; }
        try {
            const res = await fetch(`/Ged/DocumentPartsJson?id=${encodeURIComponent(documentId)}`, { headers: { 'X-Requested-With': 'XMLHttpRequest', Accept: 'application/json' } });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();
            const parts = data.parts || [];
            if (!parts.length) {
                body.innerHTML = '<tr><td colspan="8" class="text-muted">Nenhuma parte detalhada encontrada para este documento.</td></tr>';
                return;
            }
            const maxTotal = data.totalParts || parts.map(p => p.totalParts).filter(Boolean).sort((a,b)=>b-a)[0] || null;
            const receivedLabel = maxTotal ? `${parts.length} de ${maxTotal}` : `${parts.length}`;
            const statusLabel = maxTotal && parts.length >= maxTotal ? 'Partes completas — pronto para consolidar' : 'Documento incompleto';
            const ocrLabel = data.ocrSummary || `${data.partsWithOcr || 0} de ${parts.length} partes com OCR`;
            if (titleEl) titleEl.innerHTML = `<strong>Documento:</strong> ${escapeHtml(title || data.title || '')}<br><strong>Status:</strong> ${statusLabel}<br><strong>Partes recebidas:</strong> ${receivedLabel}<br><strong>OCR:</strong> ${escapeHtml(ocrLabel)}${(data.partsWithoutOcr || 0) > 0 ? '<div class="alert alert-warning py-2 mt-2 mb-0">Atenção: nem todas as partes possuem OCR. Você pode consolidar mesmo assim e reprocessar o OCR na versão final.</div>' : ''}`;
            body.innerHTML = parts.map(p => `<tr><td>${escapeHtml(p.partNumber || '-')} / ${escapeHtml(p.totalParts || maxTotal || '-')}</td><td>${escapeHtml(p.fileName || '-')}</td><td>${escapeHtml(p.uploadedAtLabel || '')}</td><td>${escapeHtml(p.uploadedByName || '-')}</td><td><span class="badge ged-badge ged-badge-info">${escapeHtml(p.status || '-')}</span></td><td>${p.sizeBytes ? (Number(p.sizeBytes)/1024).toFixed(1)+' KB' : '-'}</td><td><span class="badge ${escapeHtml(p.ocrCss || 'bg-secondary')}">${escapeHtml(p.ocrLabel || 'Sem OCR')}</span></td><td class="text-end"><div class="btn-group btn-group-sm">${p.previewUrl ? `<a class="btn btn-light border" href="${escapeHtml(p.previewUrl)}" target="_blank" rel="noopener" title="Visualizar parte"><i class="bi bi-eye"></i></a>` : ''}${p.ocrUrl ? `<a class="btn btn-light border" href="${escapeHtml(p.ocrUrl)}" target="_blank" rel="noopener" title="Ver OCR"><i class="bi bi-body-text"></i></a>` : ''}${p.downloadUrl ? `<a class="btn btn-light border" href="${escapeHtml(p.downloadUrl)}" title="Baixar parte"><i class="bi bi-download"></i></a>` : ''}</div></td></tr>`).join('');
            const complete = parts.length > 1 && (!maxTotal || parts.length >= maxTotal);
            if (consolidateBtn) consolidateBtn.disabled = !complete;
        } catch {
            if (body) body.innerHTML = '<tr><td colspan="8" class="text-danger">Não foi possível carregar as partes agora.</td></tr>';
        }
    }

    document.addEventListener('click', function (e) {
        const addBtn = e.target.closest('.js-add-document-part');
        if (addBtn && addPartModal) {
            e.preventDefault();
            document.getElementById('partDocumentId').value = addBtn.dataset.documentId || '';
            document.getElementById('partDocumentTitle').value = addBtn.dataset.documentTitle || '';
            document.getElementById('partDocumentFile').value = '';
            document.getElementById('partNumber').value = '';
            document.getElementById('partTotal').value = '';
            document.getElementById('partNotes').value = '';
            const msg = document.getElementById('addPartMessage');
            if (msg) msg.className = 'd-none mt-3';
            addPartModal.show();
        }

        const viewBtn = e.target.closest('.js-view-document-parts');
        if (viewBtn && partsModal) {
            e.preventDefault();
            partsModal.show();
            loadDocumentParts(viewBtn.dataset.documentId, viewBtn.dataset.documentTitle || '');
        }

        const cancelBtn = e.target.closest('.js-cancel-document-partial');
        if (cancelBtn) {
            e.preventDefault();
            const documentId = cancelBtn.dataset.documentId || '';
            if (!documentId) return;
            const reason = prompt('Informe o motivo para cancelar o fracionamento (opcional):') || '';
            const fd = new FormData(); fd.append('documentId', documentId); fd.append('reason', reason);
            fetch('/Ged/DocumentParts/Cancel', { method: 'POST', body: fd, headers: token ? { RequestVerificationToken: token } : {} })
                .then(r => r.json().then(j => ({ ok: r.ok, j })))
                .then(({ ok, j }) => { if (!ok || j.success === false) throw new Error(j.message || 'Falha ao cancelar fracionamento.'); window.showAppToast?.(j.message || 'Fracionamento cancelado.', 'success', 'Documento incompleto'); setTimeout(() => window.GedFolderNavigation?.refreshCurrentFolder?.() || window.location.reload(), 700); })
                .catch(err => window.showAppToast?.(err.message || 'Falha ao cancelar fracionamento.', 'danger', 'Documento incompleto'));
            return;
        }

        const markBtn = e.target.closest('.js-mark-document-incomplete');
        if (markBtn) {
            e.preventDefault();
            const documentId = markBtn.dataset.documentId || '';
            const title = markBtn.dataset.documentTitle || 'documento selecionado';
            if (!documentId) return;
            if (!confirm(`Marcar "${title}" como Documento incompleto? Ele ficará apto a receber novas partes futuramente.`)) return;
            const fd = new FormData(); fd.append('documentId', documentId);
            fetch('/Ged/DocumentParts/MarkIncomplete', { method: 'POST', body: fd, headers: token ? { RequestVerificationToken: token } : {} })
                .then(r => r.json().then(j => ({ ok: r.ok, j })))
                .then(({ ok, j }) => { if (!ok || j.success === false) throw new Error(j.message || 'Falha ao marcar como incompleto.'); window.showAppToast?.(j.message || 'Documento marcado como incompleto.', 'success', 'Documento incompleto'); setTimeout(() => window.GedFolderNavigation?.refreshCurrentFolder?.() || window.location.reload(), 700); })
                .catch(err => window.showAppToast?.(err.message || 'Falha ao marcar como incompleto.', 'danger', 'Documento incompleto'));
            return;
        }

        if (e.target.closest('.js-consolidate-document, #btnConsolidateDocument')) {
            e.preventDefault();
            const consolidateBtn = e.target.closest('.js-consolidate-document');
            const documentId = consolidateBtn?.dataset.documentId || document.getElementById('btnConsolidateDocument')?.dataset.documentId;
            if (!documentId) return;
            const sourceRow = document.querySelector(`[data-document-id="${window.CSS?.escape ? CSS.escape(documentId) : documentId}"]`);
            const partsWithOcr = Number(consolidateBtn?.dataset.partsWithOcr || sourceRow?.dataset.partialPartsWithOcr || 0);
            const partsCount = Number(consolidateBtn?.dataset.partsCount || sourceRow?.dataset.partialPartsCount || 0);
            if (partsCount > 0 && partsWithOcr > 0 && partsWithOcr < partsCount) {
                const choice = prompt(`Este documento possui OCR parcial: ${partsWithOcr} de ${partsCount} partes possui OCR. Após consolidar, o sistema poderá reprocessar o OCR da versão final.\n\nDigite 1 para Consolidar e reprocessar OCR, 2 para Consolidar sem reprocessar agora, ou deixe vazio para Cancelar.`);
                if (choice !== '1' && choice !== '2') return;
            } else if (!confirm('Revise o OCR de cada parte antes de consolidar. Deseja consolidar agora?')) return;
            const fd = new FormData(); fd.append('documentId', documentId);
            fetch('/Ged/DocumentParts/Consolidate', { method: 'POST', body: fd, headers: token ? { RequestVerificationToken: token } : {} })
                .then(r => r.json().then(j => ({ ok: r.ok, j })))
                .then(({ ok, j }) => { if (!ok || j.success === false) throw new Error(j.message || 'Falha ao consolidar.'); window.showAppToast?.(j.message || 'Documento consolidado.', 'success', 'Documento fracionado'); setTimeout(() => window.GedFolderNavigation?.refreshCurrentFolder?.() || window.location.reload(), 700); })
                .catch(err => window.showAppToast?.(err.message || 'Falha ao consolidar.', 'danger', 'Documento fracionado'));
        }
    });

    document.getElementById('btnSubmitDocumentPart')?.addEventListener('click', async function () {
        const btn = this;
        const fileInput = document.getElementById('partDocumentFile');
        const file = fileInput?.files?.[0];
        const documentId = document.getElementById('partDocumentId')?.value;
        if (!documentId || !file) { showAddPartMessage('Selecione o arquivo da nova parte.', 'warning'); return; }
        const partNumberValue = document.getElementById('partNumber')?.value;
        const totalPartsValue = document.getElementById('partTotal')?.value;
        if (!partNumberValue || Number(partNumberValue) <= 0) { showAddPartMessage('Informe o número da parte.', 'warning'); return; }
        if (totalPartsValue && Number(partNumberValue) > Number(totalPartsValue)) { showAddPartMessage('O número da parte não pode ser maior que o total previsto.', 'warning'); return; }
        const fd = new FormData();
        fd.append('file', file);
        fd.append('folderId', document.getElementById('currentFolderId')?.value || document.getElementById('gedDocumentsContainer')?.dataset.uploadFolderId || '');
        fd.append('uploadFolderId', document.getElementById('gedDocumentsContainer')?.dataset.uploadFolderId || document.getElementById('currentFolderId')?.value || '');
        fd.append('requestedFolderId', document.getElementById('gedDocumentsContainer')?.dataset.listingFolderId || document.getElementById('currentFolderId')?.value || '');
        fd.append('notes', document.getElementById('partNotes')?.value || '');
        fd.append('visibility', 'INTERNAL');
        fd.append('runOcr', 'true');
        fd.append('generatePreview', 'true');
        fd.append('isDocumentPart', 'true');
        fd.append('existingDocumentId', documentId);
        fd.append('consolidateIntoDocumentId', documentId);
        const partNumber = partNumberValue;
        const totalParts = totalPartsValue;
        if (partNumber) fd.append('partNumber', partNumber);
        if (totalParts) fd.append('totalParts', totalParts);
        btn.disabled = true;
        const old = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Enviando...';
        try {
            const res = await fetch('/Ged/Documents/BulkUploadSingle', { method: 'POST', body: fd, headers: token ? { RequestVerificationToken: token } : {} });
            const payload = await res.json().catch(() => null);
            if (!res.ok || payload?.success === false) throw new Error(payload?.message || 'Não foi possível enviar a parte.');
            showAddPartMessage('Parte enviada com sucesso. A lista será atualizada.', 'success');
            window.showAppToast?.('Parte do documento anexada com sucesso.', 'success', 'Documento fracionado');
            setTimeout(() => window.GedFolderNavigation?.refreshCurrentFolder?.() || window.location.reload(), 700);
        } catch (err) {
            showAddPartMessage(err.message || 'Não foi possível enviar a parte.', 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = old;
        }
    });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
(function(){
  if (!window.bootstrap) {
    console.error('[GED] Bootstrap JS não carregado. Verifique _Layout.cshtml.');
    return;
  }
  const state={documentId:null,folderId:null,title:'',isPartial:false};
  const modalEl=document.getElementById('deleteDocumentModal');
  if(!modalEl) return;
  const modal=window.bootstrap.Modal.getOrCreateInstance(modalEl);
  const inline=document.getElementById('deleteDocumentInline');
  document.addEventListener('click',(e)=>{
    const btn=e.target.closest('.js-delete-document');
    if(!btn) return;
    state.documentId=btn.dataset.documentId; state.folderId=btn.dataset.folderId; state.title=btn.dataset.documentTitle||'';
    const row=btn.closest('[data-document-id]');
    state.isPartial=(btn.dataset.isPartialDocument==='true') || (row?.dataset.documentPartial==='true') || (row?.dataset.documentIncomplete==='true');
    document.getElementById('deleteDocumentMessage').textContent=state.isPartial
      ? 'Este documento possui partes vinculadas. Deseja excluir o conjunto completo? As partes e arquivos físicos serão preservados para auditoria.'
      : `Deseja realmente excluir este documento${state.title?` (${state.title})`:''}? Se houver OCR em andamento, ele será cancelado.`;
    document.getElementById('btnConfirmDeleteDocument').textContent=state.isPartial ? 'Excluir conjunto' : 'Excluir documento';
    inline.className='d-none alert'; inline.textContent='';
    modal.show();
  });

  document.getElementById('btnConfirmDeleteDocument')?.addEventListener('click', async ()=>{
    const btn=document.getElementById('btnConfirmDeleteDocument');
    btn.disabled=true; const old=btn.innerHTML; btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Excluindo...';
    try{
      const fd=new FormData(); fd.append('id',state.documentId||''); if(state.folderId) fd.append('folderId',state.folderId);
      const token=document.querySelector('input[name="__RequestVerificationToken"]')?.value;
      const res=await fetch('/Ged/DeleteDocument',{method:'POST',body:fd,headers: token?{'RequestVerificationToken':token}:{}});
      const payload=await res.json().catch(()=>({success:false,message:'Não foi possível excluir o documento.'}));
      if(res.ok&&payload.success){
        const successMessage=payload.message||'Documento excluído com sucesso.';
        window.showAppToast?.(successMessage,'success','Exclusão');
        modal.hide();
        document.querySelectorAll(`[data-document-id="${CSS.escape(state.documentId || '')}"]`).forEach(el=>{
          if(el.closest('#documentSidePanelHost')) return;
          el.remove();
        });
        document.getElementById('documentSidePanelHost')?.replaceChildren();
        document.querySelector('.ged-page')?.classList.remove('with-document-panel');
        const totalEl=document.querySelector('[data-ged-total-documents]') || document.getElementById('totalDocumentsKpi');
        if(totalEl){ const n=Number((totalEl.textContent||'').replace(/\D/g,'')); if(Number.isFinite(n)&&n>0) totalEl.textContent=String(n-1); }
        window.updateSelectedDocumentsState?.();
        window.GedFolderNavigation?.refreshCurrentCounters?.();
        return;
      }
      inline.className='alert alert-danger'; inline.textContent=payload.message||'Não foi possível excluir o documento. Tente novamente ou verifique os logs.'; window.showAppToast?.(inline.textContent,'error','Erro');
    }catch{ inline.className='alert alert-danger'; inline.textContent='Não foi possível excluir o documento. Tente novamente ou verifique os logs.'; window.showAppToast?.(inline.textContent,'error','Erro'); }
    finally{ btn.disabled=false; btn.innerHTML=old; }
  });
})();
});
</script>

