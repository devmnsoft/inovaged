@model InovaGed.Web.Models.Ged.GedExplorerVM
@using InovaGed.Web.Ocr
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var localTimeZoneId = Configuration["Localization:DefaultTimeZone"] ?? Configuration["App:LocalTimeZoneId"] ?? Configuration["TimeZoneId"] ?? "America/Belem";
    var uploadDateFormat = Configuration["Localization:DateTimeFormat"] ?? "dd/MM/yyyy HH:mm";
    var folderName = !string.IsNullOrWhiteSpace(Model.CurrentFolderName) ? Model.CurrentFolderName : "Raiz";
}

<div class="ged-documents-table-mode d-none" data-documents-view="table">
    <div class="ged-table-scroll-wrap">
        <div class="ged-table-top-scroll" aria-hidden="true"><div></div></div>
        <div class="ged-table-scroll">
            <table class="table table-sm table-hover mb-0 align-middle ged-documents-table" data-ged-document-list>
                <thead class="table-light">
                    <tr>
                        <th style="width:42px;"></th>
                        <th>Documento</th>
                        <th style="width:300px;">Status</th>
                        <th style="width:240px;">Arquivo</th>
                        <th style="width:150px;">Upload em</th>
                        <th style="width:64px;" class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Documents)
                    {
                        var isUnclassified = string.IsNullOrWhiteSpace(d.TypeName) || d.TypeName == "-";
                        var versionId = d.CurrentVersionId?.ToString() ?? string.Empty;
                        var uploadDateUtc = d.UploadedAtUtc == default ? d.CreatedAt : d.UploadedAtUtc;
                        var uploadLocal = OcrUiHelper.ToConfiguredLocalTime(uploadDateUtc, localTimeZoneId);
                        var uploadLabel = string.IsNullOrWhiteSpace(d.UploadedAtLocalFormatted) ? uploadLocal.ToString(uploadDateFormat) : d.UploadedAtLocalFormatted;
                        var partialClass = d.IsDocumentIncomplete ? "table-warning ged-document-incomplete" : (d.IsPartialDocument ? "ged-document-partial" : string.Empty);
                        <tr class="@partialClass" draggable="true" data-document-id="@d.Id" data-version-id="@versionId" data-ocr-available="@(d.IsOcrAvailable ? "true" : "false")" data-document-incomplete="@(d.IsDocumentIncomplete ? "true" : "false")" data-document-unclassified="@(isUnclassified ? "true" : "false")" data-uploaded-at-utc="@uploadDateUtc.ToString("O")">
                            <td class="text-center"><input type="checkbox" class="form-check-input js-doc-select js-document-check" value="@d.Id" data-document-title="@d.Title" aria-label="Selecionar @d.Title" /></td>
                            <td>
                                <a class="ged-doc-title text-decoration-none" asp-action="Details" asp-controller="Ged" asp-route-id="@d.Id">@d.Title</a>
                                <div class="ged-doc-subtitle">@(isUnclassified ? "Tipo não definido" : d.TypeName) • @folderName • Versão atual</div>
                            </td>
                            <td><div class="ged-document-badges">@await Html.PartialAsync("_DocumentBadges", d)</div></td>
                            <td class="text-muted small text-truncate" title="@d.FileName">@(!string.IsNullOrWhiteSpace(d.FileName) ? d.FileName : "Arquivo sem nome")</td>
                            <td class="text-muted small"><span class="d-inline-flex align-items-center text-nowrap"><i class="bi bi-cloud-arrow-up me-1"></i>@uploadLabel</span></td>
                            <td class="text-end">@await Html.PartialAsync("_DocumentActionsDropdown", (d.Id, d.Title, versionId, Model.CurrentFolderId))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
