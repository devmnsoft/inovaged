@model InovaGed.Web.Models.Ged.GedExplorerVM
@using InovaGed.Web.Ocr
@using InovaGed.Web.Security
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var canAddDocumentPart = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Arquivista) || User.IsInRole(AppRoles.ArquivistaOphir);
    var canViewDocumentParts = User.Identity?.IsAuthenticated == true;
    var canConsolidateDocumentParts = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.Arquivista) || User.IsInRole(AppRoles.ArquivistaOphir);
    var canCancelDocumentParts = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.AdministradorOphir);
    var localTimeZoneId = Configuration["Localization:DefaultTimeZone"] ?? Configuration["App:LocalTimeZoneId"] ?? Configuration["TimeZoneId"] ?? "America/Belem";
    var uploadDateFormat = Configuration["Localization:DateTimeFormat"] ?? "dd/MM/yyyy HH:mm";
    var folderName = !string.IsNullOrWhiteSpace(Model.CurrentFolderName) ? Model.CurrentFolderName : "Raiz";
}

<div class="ged-documents-table-mode">
    <div class="ged-table-shell">
        <div class="ged-table-scroll">
            <table class="table align-middle mb-0 ged-documents-table" data-ged-document-list>
                <thead>
                    <tr>
                        <th class="ged-col-check">
                            <input type="checkbox" class="form-check-input" id="selectAllDocumentsTable" aria-label="Selecionar todos os documentos na tabela" />
                        </th>
                        <th>Documento</th>
                        <th class="ged-col-status">Status</th>
                        <th class="ged-col-upload">Upload em</th>
                        <th class="ged-col-actions text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Documents)
                    {
                        var isUnclassified = string.IsNullOrWhiteSpace(d.TypeName) || d.TypeName == "-";
                        var versionId = d.CurrentVersionId?.ToString() ?? string.Empty;
                        var uploadDateUtc = d.UploadedAtUtc == default ? d.CreatedAt : d.UploadedAtUtc;
                        var uploadLocal = OcrUiHelper.ToConfiguredLocalTime(uploadDateUtc, localTimeZoneId);
                        var uploadLabel = string.IsNullOrWhiteSpace(d.UploadedAtLocalFormatted) ? uploadLocal.ToString(uploadDateFormat) : d.UploadedAtLocalFormatted;
                        var iconClass = (d.FileName ?? string.Empty).EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ? "bi-file-earmark-pdf" : "bi-file-earmark-text";
                        var rowClass = d.IsDocumentIncomplete ? "ged-row-incomplete" : (d.IsPartialDocument ? "ged-row-partial" : string.Empty);
                        var isConsolidated = string.Equals(d.PartialStatus, "CONSOLIDATED", StringComparison.OrdinalIgnoreCase) || d.ConsolidatedVersionId.HasValue;
                        var isReadyToConsolidate = !isConsolidated && d.IsPartialDocument && !d.IsDocumentIncomplete && string.Equals(d.PartialStatus, "COMPLETE", StringComparison.OrdinalIgnoreCase);
                        var hasPartialOcr = d.PartialPartsWithOcrCount > 0 && d.PartialPartsWithOcrCount < (d.TotalParts ?? d.PartialTotalParts ?? d.PartialPartsCount);

                        <tr class="ged-document-table-row @rowClass"
                            draggable="true"
                            data-document-id="@d.Id"
                            data-version-id="@versionId"
                            data-ocr-available="@(d.IsOcrAvailable ? "true" : "false")"
                            data-document-incomplete="@(d.IsDocumentIncomplete ? "true" : "false")"
                            data-document-ready-to-consolidate="@(isReadyToConsolidate ? "true" : "false")"
                            data-document-ready-consolidate="@(isReadyToConsolidate ? "true" : "false")"
                            data-document-consolidated="@(isConsolidated ? "true" : "false")"
                            data-document-ocr-partial="@(hasPartialOcr ? "true" : "false")"
                            data-partial-parts-count="@(d.TotalParts ?? d.PartialTotalParts ?? d.PartialPartsCount)"
                            data-partial-parts-with-ocr="@d.PartialPartsWithOcrCount"
                            data-document-unclassified="@(isUnclassified ? "true" : "false")"
                            data-uploaded-at-utc="@uploadDateUtc.ToString("O")">

                            <td class="ged-col-check">
                                <input type="checkbox"
                                       class="form-check-input js-doc-select js-document-check"
                                       value="@d.Id"
                                       data-document-title="@d.Title"
                                       aria-label="Selecionar @d.Title" />
                            </td>

                            <td>
                                <div class="ged-table-document-cell">
                                    <div class="ged-table-file-icon" aria-hidden="true">
                                        <i class="bi @iconClass"></i>
                                    </div>
                                    <div class="ged-table-document-text">
                                        <a class="ged-table-title"
                                           asp-action="Details"
                                           asp-controller="Ged"
                                           asp-route-id="@d.Id"
                                           title="@d.Title">
                                            @d.Title
                                        </a>
                                        <div class="ged-table-file-name" title="@d.FileName">
                                            @(!string.IsNullOrWhiteSpace(d.FileName) ? d.FileName : "Arquivo sem nome")
                                        </div>
                                        @{
                                            var classificationLabel = !string.IsNullOrWhiteSpace(d.ClassificationLabel) ? d.ClassificationLabel : (!isUnclassified ? d.TypeName : "Classificar");
                                            var classificationStyle = !string.IsNullOrWhiteSpace(d.ClassificationColor) ? $"border-color:{d.ClassificationColor};color:{d.ClassificationColor};" : string.Empty;
                                        }
                                        <button type="button"
                                                class="ged-classification-tag js-open-classification-menu @(d.ClassificationId.HasValue ? "is-classified" : "is-empty")"
                                                data-document-id="@d.Id"
                                                data-current-classification-id="@d.ClassificationId"
                                                style="@classificationStyle"
                                                title="Classificação rápida">
                                            <i class="bi @(string.IsNullOrWhiteSpace(d.ClassificationIcon) ? "bi-tag" : d.ClassificationIcon)"></i>
                                            <span>@classificationLabel</span>
                                        </button>
                                        <div class="ged-table-meta">
                                            <span>@(isUnclassified ? "Tipo não definido" : d.TypeName)</span>
                                            <span>•</span>
                                            <span>@folderName</span>
                                            <span>•</span>
                                            <span>Versão atual</span>
                                        </div>
                                    </div>
                                </div>
                            </td>

                            <td class="ged-col-status">
                                <div class="ged-document-badges">
                                    @await Html.PartialAsync("_DocumentBadges", d)
                                </div>
                            </td>

                            <td class="ged-col-upload">
                                <span class="ged-upload-date" title="Upload em UTC: @uploadDateUtc.ToString("O")">
                                    <i class="bi bi-cloud-arrow-up me-1"></i>
                                    @uploadLabel
                                </span>
                            </td>

                            <td class="ged-col-actions text-end">
                                <div class="ged-doc-actions">
                                    <button type="button"
                                            class="btn btn-sm btn-light border js-preview-document"
                                            data-document-id="@d.Id"
                                            data-version-id="@versionId"
                                            title="Visualizar preview"
                                            aria-label="Visualizar preview de @d.Title">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    @await Html.PartialAsync("_DocumentActionsDropdown", new InovaGed.Web.Models.Ged.DocumentActionsVm { DocumentId = d.Id, Title = d.Title, VersionId = versionId, CurrentFolderId = Model.CurrentFolderId, IsOcrAvailable = d.IsOcrAvailable, IsPartialDocument = d.IsPartialDocument, IsDocumentIncomplete = d.IsDocumentIncomplete, PartialStatus = d.PartialStatus, PartialPartsCount = d.PartialPartsCount, PartialTotalParts = d.TotalParts ?? d.PartialTotalParts, CanAddPart = canAddDocumentPart, CanViewParts = canViewDocumentParts, CanConsolidate = canConsolidateDocumentParts, CanCancelPartial = canCancelDocumentParts, CanMarkAsIncomplete = canAddDocumentPart })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
