@model InovaGed.Web.Models.Ged.GedExplorerVM
@{
    var totalDocuments = Model.TotalDocuments > 0 ? Model.TotalDocuments : Model.Documents.Count;
    var hasMoreDocuments = Model.HasMoreDocuments;
    var ocrCount = Model.Documents.Count(d => d.IsOcrAvailable);
    var incompleteCount = Model.Documents.Count(d => d.IsDocumentIncomplete || string.Equals(d.PartialStatus, "INCOMPLETE", StringComparison.OrdinalIgnoreCase));
    var unclassifiedCount = Model.Documents.Count(d => string.IsNullOrWhiteSpace(d.TypeName) || d.TypeName == "-");
}

<div class="ged-documents-list"
     id="gedDocumentsContainer"
     data-folder-id="@Model.CurrentFolderId"
     data-listing-folder-id="@Model.CurrentListingFolderId"
     data-upload-folder-id="@Model.CurrentUploadFolderId"
     data-folder-name="@Model.CurrentFolderName"
     data-document-count="@totalDocuments"
     data-ocr-count="@ocrCount"
     data-incomplete-count="@incompleteCount"
     data-unclassified-count="@unclassifiedCount"
     data-page="@Model.Page"
     data-page-size="@Model.PageSize"
     data-has-more="@(hasMoreDocuments ? "true" : "false")">
    @if (!Model.Documents.Any())
    {
        <div class="ged-empty-state text-center p-5 text-muted">
            <div class="ged-empty-icon mb-3"><i class="bi bi-folder2-open"></i></div>
            <h5 class="text-dark mb-2">Nenhum documento nesta pasta.</h5>
            <p class="mb-3">Arraste arquivos para cá ou clique em Adicionar documentos.</p>
            <button type="button" id="btnOpenBulkUploadEmpty" class="btn btn-primary">
                <i class="bi bi-cloud-arrow-up me-1"></i> Adicionar documentos
            </button>
            <div class="small text-muted mt-3"><i class="bi bi-lightbulb me-1"></i>Você também pode mover documentos de outra pasta para este destino.</div>
        </div>
    }
    else
    {
        @if (incompleteCount > 0)
        {
            <div class="ged-incomplete-info" id="gedIncompleteInfo">
                <div>
                    <strong>@incompleteCount documento(s) incompleto(s)</strong>
                    <span>Documentos incompletos são arquivos enviados parcialmente e que podem receber novas partes futuramente.</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span id="gedIncompleteFilterChip" class="ged-filter-chip d-none">Filtro ativo: Incompletos <button type="button" class="btn btn-link btn-sm p-0 ms-1" id="btnClearIncompleteFilter" aria-label="Limpar filtro de incompletos">×</button></span>
                    <button type="button" class="btn btn-sm btn-outline-warning" id="btnFilterIncompleteDocs"><i class="bi bi-funnel me-1"></i>Ver incompletos</button>
                </div>
            </div>
        }

        <div class="ged-documents-view-toolbar ged-selection-bar">
            <div class="ged-bulk-select ged-selection-info">
                <input type="checkbox"
                       class="form-check-input"
                       id="selectAllDocuments" />

                <label for="selectAllDocuments" class="ged-select-all-label">
                    Selecionar todos
                </label>

                <span id="selectedDocumentsInlineInfo" class="ged-selected-inline-info ged-selected-count">
                    0 selecionados
                </span>
            </div>

            <div class="ged-toolbar-spacer"></div>

            <div class="ged-selection-actions">
            <button type="button"
                    class="btn btn-sm btn-outline-primary ged-move-selected-inline js-btn-move-selected"
                    id="btnMoveSelected"
                    disabled>
                <i class="bi bi-folder-symlink me-1"></i>Mover selecionados
                <span class="ms-1 js-move-selected-count">(0)</span>
            </button>
            </div>

            <div class="ged-view-actions" role="group" aria-label="Modo de visualização dos documentos">
                <button type="button"
                        class="btn btn-sm btn-primary js-doc-view-mode active"
                        data-view-mode="smart-list"
                        aria-pressed="true">
                    <i class="bi bi-list-check me-1"></i>Smart
                </button>

                <button type="button"
                        class="btn btn-sm btn-outline-primary js-doc-view-mode"
                        data-view-mode="table"
                        aria-pressed="false">
                    <i class="bi bi-table me-1"></i>Tabela
                </button>
            </div>
        </div>

        <div class="ged-documents-mode"
             data-documents-view="smart-list">
            @await Html.PartialAsync("_DocumentSmartList", Model)
        </div>

        <div class="ged-documents-mode d-none"
             data-documents-view="table">
            @await Html.PartialAsync("_DocumentTable", Model)
        </div>

        <div class="ged-load-more-row @(hasMoreDocuments ? "" : "d-none")">
            <button type="button" class="btn btn-sm btn-outline-primary js-ged-load-more" aria-label="Carregar mais documentos">
                <i class="bi bi-plus-circle me-1"></i>Carregar mais
            </button>
            <span class="small text-muted ms-2">Exibindo @Model.Documents.Count de @totalDocuments documentos</span>
        </div>
    }
</div>
