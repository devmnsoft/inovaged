@model InovaGed.Web.Models.Ged.GedExplorerVM.DocumentRowVM
@using InovaGed.Web.Ocr
@{
    var isUnclassified = string.IsNullOrWhiteSpace(Model.TypeName) || Model.TypeName == "-";
    var ocrBadgeClass = OcrUiHelper.BadgeClass(Model.IsOcrAvailable, Model.OcrStatus);
    var ocrLabel = OcrUiHelper.AvailabilityLabel(Model.IsOcrAvailable, Model.OcrStatus, Model.HasOcrText);
    var ocrTitle = $"Status OCR: {(string.IsNullOrWhiteSpace(Model.OcrStatus) ? "NONE" : Model.OcrStatus)}. Texto extraído: {(Model.HasOcrText ? "sim" : "não")}";
    var partialSuffix = Model.PartNumber.HasValue && Model.TotalParts.HasValue ? $" {Model.PartNumber}/{Model.TotalParts}" : string.Empty;
    var isConsolidated = Model.IsPartialDocument && Model.ConsolidatedVersionId.HasValue && !Model.IsDocumentIncomplete;
}

@if (isUnclassified)
{
    <span class="badge ged-badge ged-badge-muted"><i class="bi bi-tag me-1"></i>Sem classificação</span>
}
else
{
    <span class="badge ged-badge ged-badge-ok" title="Classificação: @Model.TypeName"><i class="bi bi-tags me-1"></i>Classificado</span>
}

<span class="badge ged-badge @ocrBadgeClass" title="@ocrTitle"><i class="bi bi-text-paragraph me-1"></i>@ocrLabel</span>

@if (Model.IsDocumentIncomplete)
{
    <span class="badge ged-badge ged-badge-warning"><i class="bi bi-exclamation-triangle me-1"></i>Documento incompleto@partialSuffix</span>
}
else if (isConsolidated)
{
    <span class="badge ged-badge ged-badge-info"><i class="bi bi-layers me-1"></i>Documento consolidado@partialSuffix</span>
}
else if (Model.IsPartialDocument)
{
    <span class="badge ged-badge ged-badge-info"><i class="bi bi-files me-1"></i>Documento parcial@partialSuffix</span>
}
