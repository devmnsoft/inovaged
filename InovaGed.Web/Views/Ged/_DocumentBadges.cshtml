@model InovaGed.Web.Models.Ged.GedExplorerVM.DocumentRowVM
@using InovaGed.Web.Ocr
@{
    var isUnclassified = !Model.ClassificationId.HasValue && (string.IsNullOrWhiteSpace(Model.TypeName) || Model.TypeName == "-");
    var ocrBadgeClass = !string.IsNullOrWhiteSpace(Model.OcrBadgeCss) ? Model.OcrBadgeCss : OcrUiHelper.BadgeClass(Model.IsOcrAvailable, Model.OcrStatus);
    var ocrLabel = !string.IsNullOrWhiteSpace(Model.OcrBadgeText) ? Model.OcrBadgeText : OcrUiHelper.AvailabilityLabel(Model.IsOcrAvailable, Model.OcrStatus, Model.HasOcrText);
    var ocrTitle = $"Status OCR: {(string.IsNullOrWhiteSpace(Model.OcrStatus) ? "NONE" : Model.OcrStatus)}. Texto extraído: {(Model.HasOcrText ? "sim" : "não")}.";
    if (Model.IsDocumentIncomplete || Model.IsPartialDocument)
    {
        ocrTitle += " Em documentos incompletos, o OCR refere-se à parte/versão atualmente cadastrada; após consolidar, ele poderá ser reprocessado na versão final.";
    }
    var partialSuffix = Model.PartNumber.HasValue && Model.TotalParts.HasValue ? $" {Model.PartNumber}/{Model.TotalParts}" : string.Empty;
    var isConsolidated = (Model.IsPartialDocument && Model.ConsolidatedVersionId.HasValue && !Model.IsDocumentIncomplete) || string.Equals(Model.PartialStatus, "CONSOLIDATED", StringComparison.OrdinalIgnoreCase);
    var isReadyToConsolidate = !isConsolidated && Model.IsPartialDocument && (string.Equals(Model.PartialStatus, "COMPLETE", StringComparison.OrdinalIgnoreCase) || (Model.PartialPartsCount > 1 && (!Model.TotalParts.HasValue || Model.PartialPartsCount >= Model.TotalParts.Value)));
}

@if (isUnclassified)
{
    <span class="badge ged-badge ged-badge-muted"><i class="bi bi-tag me-1"></i>Sem classificação</span>
}
else
{
    <span class="badge ged-badge ged-badge-ok" title="Classificação: @Model.TypeName"><i class="bi bi-tags me-1"></i>Classificado</span>
}

<span class="badge ged-badge @ocrBadgeClass" title="@ocrTitle"><i class="bi bi-text-paragraph me-1"></i>@ocrLabel</span>

@if (Model.IsDocumentIncomplete)
{
    <span class="badge ged-badge ged-badge-incomplete" title="Este documento possui partes pendentes e poderá ser complementado futuramente."><i class="bi bi-exclamation-triangle me-1"></i>Documento incompleto@partialSuffix</span>
}
else if (isReadyToConsolidate)
{
    <span class="badge ged-badge ged-badge-warning" title="Partes completas — pronto para consolidar."><i class="bi bi-check2-circle me-1"></i>Pronto para consolidar@partialSuffix</span>
}
else if (isConsolidated)
{
    <span class="badge ged-badge ged-badge-info" title="Este documento foi consolidado a partir de partes enviadas anteriormente."><i class="bi bi-layers me-1"></i>Documento consolidado@partialSuffix</span>
}
else if (Model.IsPartialDocument)
{
    <span class="badge ged-badge ged-badge-info" title="Documento fracionado com partes registradas."><i class="bi bi-files me-1"></i>Documento parcial@partialSuffix</span>
}
