@model InovaGed.Web.Models.Ged.GedExplorerVM.DocumentRowVM
@using InovaGed.Web.Ocr
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var isUnclassified = !Model.ClassificationId.HasValue && (string.IsNullOrWhiteSpace(Model.TypeName) || Model.TypeName == "-");
    var ocrBadgeClass = !string.IsNullOrWhiteSpace(Model.OcrSummaryCss) ? Model.OcrSummaryCss : (!string.IsNullOrWhiteSpace(Model.OcrBadgeCss) ? Model.OcrBadgeCss : OcrUiHelper.BadgeClass(Model.IsOcrAvailable, Model.OcrStatus));
    var ocrLabel = !string.IsNullOrWhiteSpace(Model.OcrSummaryText) ? Model.OcrSummaryText : (!string.IsNullOrWhiteSpace(Model.OcrBadgeText) ? Model.OcrBadgeText : OcrUiHelper.AvailabilityLabel(Model.IsOcrAvailable, Model.OcrStatus, Model.HasOcrText));
    var autoOcrEnabled = Configuration.GetValue("OcrAutoSchedule:Enabled", true);
    var ocrTitle = $"Status OCR: {(string.IsNullOrWhiteSpace(Model.OcrStatus) ? "NONE" : Model.OcrStatus)}. Texto extraído: {(Model.HasOcrText ? "sim" : "não")}.";
    if (!Model.IsOcrAvailable && !Model.HasOcrText && (string.IsNullOrWhiteSpace(Model.OcrStatus) || string.Equals(Model.OcrStatus, "NONE", StringComparison.OrdinalIgnoreCase)))
    {
        ocrTitle = autoOcrEnabled
            ? "Este documento será incluído na rotina automática diária de OCR, caso permaneça sem OCR."
            : "OCR automático está desabilitado. Execute manualmente ou habilite nas configurações.";
    }
    if (Model.IsDocumentIncomplete || Model.IsPartialDocument)
    {
        var totalForOcr = Model.TotalParts ?? Model.PartialTotalParts ?? Model.PartialPartsCount;
        ocrTitle = Model.PartialPartsCount > 0
            ? $"{Model.PartialPartsWithOcrCount} de {totalForOcr} partes possui OCR disponível. Abra ‘Ver partes’ para consultar cada OCR."
            : "Documento enviado em partes. Abra ‘Ver partes’ para consultar o OCR de cada parte.";
    }
    var partialSuffix = Model.PartialPartsCount > 0
        ? (Model.TotalParts.HasValue || Model.PartialTotalParts.HasValue ? $"{Model.PartialPartsCount}/{(Model.TotalParts ?? Model.PartialTotalParts)} partes" : $"{Model.PartialPartsCount} partes")
        : (Model.PartNumber.HasValue && Model.TotalParts.HasValue ? $"{Model.PartNumber}/{Model.TotalParts} partes" : string.Empty);
    var isConsolidated = (Model.IsPartialDocument && Model.ConsolidatedVersionId.HasValue && !Model.IsDocumentIncomplete) || string.Equals(Model.PartialStatus, "CONSOLIDATED", StringComparison.OrdinalIgnoreCase);
    var isReadyToConsolidate = !isConsolidated && Model.IsPartialDocument && (string.Equals(Model.PartialStatus, "COMPLETE", StringComparison.OrdinalIgnoreCase) || (Model.PartialPartsCount > 1 && (!Model.TotalParts.HasValue || Model.PartialPartsCount >= Model.TotalParts.Value)));
}

@if (isUnclassified)
{
    <span class="badge ged-badge ged-badge-muted"><i class="bi bi-tag me-1"></i>Sem classificação</span>
}
else
{
    <span class="badge ged-badge ged-badge-ok" title="Classificação: @Model.TypeName"><i class="bi bi-tags me-1"></i>Classificado</span>
}

<span class="badge ged-badge @ocrBadgeClass" title="@ocrTitle"><i class="bi bi-text-paragraph me-1"></i>@ocrLabel</span>

@if (Model.IsDocumentIncomplete)
{
    <span class="badge ged-badge ged-badge-incomplete" title="Este documento possui partes pendentes e poderá ser complementado futuramente."><i class="bi bi-exclamation-triangle me-1"></i>@(string.IsNullOrWhiteSpace(partialSuffix) ? "Documento incompleto" : $"Documento incompleto · {partialSuffix}")</span>
}
else if (isReadyToConsolidate)
{
    <span class="badge ged-badge ged-badge-warning" title="Todas as partes previstas foram recebidas. Você pode consolidar este documento."><i class="bi bi-check2-circle me-1"></i>@(string.IsNullOrWhiteSpace(partialSuffix) ? "Pronto para consolidar" : $"{partialSuffix} · pronto para consolidar")</span>
}
else if (isConsolidated)
{
    <span class="badge ged-badge ged-badge-info" title="Este documento foi consolidado a partir de partes enviadas anteriormente."><i class="bi bi-layers me-1"></i>@(string.IsNullOrWhiteSpace(partialSuffix) ? "Documento consolidado" : $"Documento consolidado · {partialSuffix}")</span>
}
else if (Model.IsPartialDocument)
{
    <span class="badge ged-badge ged-badge-info" title="Documento fracionado com partes registradas."><i class="bi bi-files me-1"></i>@(string.IsNullOrWhiteSpace(partialSuffix) ? "Documento enviado em partes" : $"Documento enviado em partes · {partialSuffix}")</span>
}
