@model InovaGed.Application.Ged.Documents.UploadMonitorDto
@{
    ViewData["Title"] = "Monitor de Uploads GED";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-cloud-upload me-2"></i>Monitor de Uploads GED</h4>
        <div class="text-muted small">Lotes recentes, falhas recuperáveis, uploads travados e fila de OCR gerada por uploads.</div>
    </div>
    <form method="post" action="@Url.Action("CleanStale", "UploadMonitor")">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-warning"><i class="bi bi-tools me-1"></i>Limpar RECEIVING travados</button>
    </form>
</div>
@if (TempData["Success"] is string ok) { <div class="alert alert-success">@ok</div> }

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">OCR pendente</div><div class="fs-3 fw-semibold">@Model.PendingOcrCount</div></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Lotes recentes</div><div class="fs-3 fw-semibold">@Model.Batches.Count</div></div></div></div>
    <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Itens travados</div><div class="fs-3 fw-semibold">@Model.StaleReceivingItems.Count</div></div></div></div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header bg-white fw-semibold">Lotes dos últimos 7 dias</div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead><tr><th>Lote</th><th>Status</th><th>Criado em</th><th>Total</th><th>Sucesso</th><th>Falha</th><th>Ignorados</th><th>Média ms</th><th>IP</th></tr></thead>
            <tbody>
            @foreach (var b in Model.Batches)
            {
                <tr>
                    <td><code>@b.Id</code></td>
                    <td><span class="badge bg-secondary">@b.Status</span></td>
                    <td>@b.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@b.TotalFiles</td><td>@b.SuccessFiles</td><td>@b.FailedFiles</td><td>@b.SkippedFiles</td>
                    <td>@(b.AvgElapsedMs?.ToString("N0") ?? "-")</td><td>@b.SourceIp</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold">Itens RECEIVING há mais de 10 minutos</div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead><tr><th>Item</th><th>Arquivo</th><th>Status</th><th>Erro</th><th>Correlação</th></tr></thead>
            <tbody>
            @foreach (var i in Model.StaleReceivingItems)
            {
                <tr><td><code>@i.Id</code></td><td>@i.OriginalFileName</td><td>@i.Status</td><td>@i.ErrorMessage</td><td><code>@i.CorrelationId</code></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
