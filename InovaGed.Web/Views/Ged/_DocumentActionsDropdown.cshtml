@model InovaGed.Web.Models.Ged.DocumentActionsVm
@using System

<div class="dropdown">
    <button class="btn btn-light border ged-actions-btn document-actions-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Ações de @Model.Title" aria-label="Ações de @Model.Title">
        <i class="bi bi-three-dots"></i>
    </button>
    <ul class="dropdown-menu dropdown-menu-end ged-actions-menu">
        <li><a class="dropdown-item" asp-action="Details" asp-controller="Ged" asp-route-id="@Model.DocumentId"><i class="bi bi-eye me-2"></i>Abrir</a></li>
        <li><a class="dropdown-item js-preview-document" asp-action="Preview" asp-controller="Ged" asp-route-id="@Model.VersionId" target="_blank" rel="noopener" data-document-id="@Model.DocumentId" data-version-id="@Model.VersionId"><i class="bi bi-file-earmark-richtext me-2"></i>Preview</a></li>
        @if (Model.IsOcrAvailable && !string.IsNullOrWhiteSpace(Model.VersionId))
        {
            <li><a class="dropdown-item" asp-action="OcrText" asp-controller="Ged" asp-route-versionId="@Model.VersionId" target="_blank" rel="noopener"><i class="bi bi-body-text me-2"></i>Ver OCR</a></li>
        }
        else
        {
            <li><button type="button" class="dropdown-item disabled text-muted" disabled title="OCR ainda não disponível"><i class="bi bi-body-text me-2"></i>Ver OCR</button></li>
        }
        @if (Model.CanMove)
        {
            <li><button type="button" class="dropdown-item js-move-one js-move-document" data-document-id="@Model.DocumentId" data-document-title="@Model.Title"><i class="bi bi-folder-symlink me-2"></i>Mover</button></li>
        }
        @if (Model.CanClassify)
        {
            <li><a class="dropdown-item js-classify-document" asp-action="Details" asp-controller="Ged" asp-route-id="@Model.DocumentId" asp-route-openClassify="true" data-document-id="@Model.DocumentId"><i class="bi bi-tags me-2"></i>Classificar</a></li>
        }
        <li><a class="dropdown-item" asp-action="Download" asp-controller="Ged" asp-route-id="@Model.VersionId"><i class="bi bi-download me-2"></i>Baixar</a></li>

        @if (Model.ShouldShowPartialActions)
        {
            <li><hr class="dropdown-divider" /></li>
            <li><h6 class="dropdown-header text-warning"><i class="bi bi-exclamation-triangle me-1"></i>Documento incompleto</h6></li>
            @if (Model.CanAddPart)
            {
                <li>
                    <button type="button" class="dropdown-item js-add-document-part" data-document-id="@Model.DocumentId" data-document-title="@Model.Title">
                        <i class="bi bi-file-earmark-plus me-2"></i>Adicionar parte
                    </button>
                </li>
            }
            @if (Model.CanViewParts)
            {
                <li>
                    <button type="button" class="dropdown-item js-view-document-parts" data-document-id="@Model.DocumentId" data-document-title="@Model.Title">
                        <i class="bi bi-files me-2"></i>Ver partes do documento
                    </button>
                </li>
            }
            @if (Model.CanConsolidate && Model.IsCompletePartial)
            {
                <li><button type="button" class="dropdown-item js-consolidate-document" data-document-id="@Model.DocumentId"><i class="bi bi-layers me-2"></i>Consolidar documento</button></li>
            }
            @if (Model.CanCancelPartial)
            {
                <li><button type="button" class="dropdown-item text-danger js-cancel-document-partial" data-document-id="@Model.DocumentId"><i class="bi bi-x-octagon me-2"></i>Cancelar fracionamento</button></li>
            }
        }
        else if (Model.CanMarkAsIncomplete)
        {
            <li><hr class="dropdown-divider" /></li>
            <li>
                <button type="button" class="dropdown-item js-mark-document-incomplete" data-document-id="@Model.DocumentId" data-document-title="@Model.Title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Marcar como incompleto
                </button>
            </li>
        }

        @if (Model.CanDelete)
        {
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form method="post" asp-controller="Ged" asp-action="DeleteDocument" class="d-inline js-feedback-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.DocumentId" />
                    <input type="hidden" name="folderId" value="@Model.CurrentFolderId" />
                    <button type="button" class="dropdown-item text-danger js-delete-document" data-document-id="@Model.DocumentId" data-folder-id="@Model.CurrentFolderId" data-document-title="@Model.Title"><i class="bi bi-trash me-2"></i>Excluir</button>
                </form>
            </li>
        }
    </ul>
</div>
