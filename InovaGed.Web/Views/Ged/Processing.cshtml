@model IReadOnlyList<InovaGed.Web.Controllers.GedController.ProcessingRowVm>
@{
    ViewData["Title"] = "Processamentos em execução";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-cpu me-2"></i>Processamentos em execução</h4>
    <div class="d-flex gap-2 align-items-center">
        <span id="processingCount" class="badge bg-warning text-dark">@Model.Count em execução</span>
        <a asp-action="Index" asp-controller="Ged" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
</div>

<div class="alert alert-info py-2">
    Esta tela atualiza automaticamente os OCRs em andamento (PENDING/PROCESSING).
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle" id="processingTable">
        <thead class="table-light">
            <tr>
                <th>Job</th>
                <th>Documento</th>
                <th>Status</th>
                <th>Solicitado em</th>
                <th>Iniciado em</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody id="processingTbody">
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-muted">Nenhum processamento em execução.</td></tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.JobId</td>
                        <td>@item.DocumentTitle</td>
                        <td>
                            <span class="badge @(item.Status == "PROCESSING" ? "bg-warning text-dark" : "bg-secondary")">@item.Status</span>
                        </td>
                        <td>@item.RequestedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@(item.StartedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary"
                               asp-action="Details"
                               asp-controller="Ged"
                               asp-route-id="@item.DocumentId"
                               asp-route-versionId="@item.VersionId">Abrir</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/ged-processing.js" asp-append-version="true"></script>
}
