@using System
@using System.Linq
@using System.Threading
@using InovaGed.Application.Identity
@using InovaGed.Application.Classification
@model InovaGed.Web.Models.Ged.GedDetailsVM

@inject ICurrentUser CurrentUser
@inject IDocumentClassificationQueries ClassificationQueries

@{
    var versions = Model.Versions ?? new System.Collections.Generic.List<InovaGed.Web.Models.Ged.GedDetailsVM.VersionVM>();
    var selectedVersionId = Model.SelectedVersionId ?? Model.CurrentVersionId;
    var selectedVersion = versions.FirstOrDefault(v => v.Id == selectedVersionId);

    var openClassify = (Context.Request.Query["openClassify"].ToString() ?? "")
        .Equals("true", StringComparison.OrdinalIgnoreCase);
}

<div class="row g-3">
    <!-- LEFT -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-eye"></i>
                    <strong>Visualização</strong>
                </div>

                <div class="d-flex gap-2 flex-wrap align-items-center">
                    @if (selectedVersionId != null)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnFull" title="Tela cheia">
                            <i class="bi bi-fullscreen"></i>
                        </button>

                        <a class="btn btn-sm btn-outline-primary"
                           target="_blank"
                           href="@Url.Action("PreviewVersion","Ged", new { versionId = selectedVersionId })">
                            Abrir
                        </a>

                        <form asp-action="RegeneratePreview" asp-controller="Ged" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="versionId" value="@selectedVersionId" />
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                Regerar preview
                            </button>
                        </form>

                        <form asp-action="RunOcr" asp-controller="Ged" method="post" class="d-inline" id="ocrForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="versionId" value="@selectedVersionId" />
                            <input type="hidden" name="force" value="false" />
                            <button type="submit" class="btn btn-sm btn-outline-success" id="btnOcr">
                                <span class="btn-text">OCR</span>
                                <span class="btn-loading d-none">
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    Processando...
                                </span>
                            </button>
                        </form>

                        <span id="ocrStatusBadge" class="ms-1">
                            <span class="badge bg-light text-dark">— OCR</span>
                        </span>
                    }
                </div>
            </div>

            <div class="card-body p-0 position-relative" id="previewContainer" style="height: 70vh;">
                @if (selectedVersionId == null)
                {
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                        Nenhuma versão disponível para visualização.
                    </div>
                }
                else
                {
                    <div id="previewLoading"
                         class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                         style="background: rgba(255,255,255,.75); z-index:10;">
                        <div class="text-center">
                            <div class="spinner-border" role="status"></div>
                            <div class="mt-2 text-muted">Carregando / gerando visualização…</div>
                        </div>
                    </div>

                    <iframe id="previewFrame"
                            src="@Url.Action("PreviewInline","Ged", new { versionId = selectedVersionId })"
                            style="width:100%; height:100%; border:0; background:#f5f5f7;"
                            loading="lazy">
                    </iframe>
                }
            </div>
        </div>

        <!-- Versions -->
        <div class="card mt-3">
            <div class="card-header">
                <strong>Versões</strong>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Arquivo</th>
                            <th>Criado em</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in versions.OrderByDescending(x => x.VersionNumber))
                        {
                            var isSelected = selectedVersionId.HasValue && v.Id == selectedVersionId.Value;
                            <tr class="@(isSelected ? "table-primary" : "")">
                                <td>@v.VersionNumber</td>
                                <td>
                                    <div class="fw-semibold">@v.FileName</div>
                                    <div class="text-muted small">@v.ContentType • @v.SizeBytes.ToString("N0") bytes</div>
                                </td>
                                <td class="text-muted">@v.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Url.Action("Details","Ged", new { id = Model.Id, versionId = v.Id })">
                                        Ver
                                    </a>
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="@Url.Action("DownloadVersion","Ged", new { versionId = v.Id })">
                                        Baixar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="col-lg-4">
        <!-- Painel de classificação -->
        <div id="classification-panel">
            @{
                var cls = await ClassificationQueries.GetAsync(CurrentUser.TenantId, Model.Id, CancellationToken.None);
                ViewData["DocumentId"] = Model.Id;
            }
            @await Html.PartialAsync("_DocumentClassificationPanel", cls)
        </div>

        <!-- ✅ host único do modal (NÃO coloque isso dentro do partial) -->
        <div id="classification-modal-host"></div>

        <!-- Documento info -->
        <div class="card mt-3">
            <div class="card-body">
                <div class="text-muted small">Documento</div>
                <div class="fw-semibold">@Model.Title</div>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="text-muted small mt-1">@Model.Description</div>
                }
            </div>
        </div>
    </div>
</div>

<form id="ajax-antiforgery-form" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        // =========================
        // Helpers UI
        // =========================
        function getAjaxAntiForgeryToken() {
            const tokenInput = document.querySelector('#ajax-antiforgery-form input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : '';
        }

        function setBtnLoading(btn, loading) {
            if (!btn) return;
            const t = btn.querySelector('.btn-text');
            const l = btn.querySelector('.btn-loading');
            if (loading) {
                btn.disabled = true;
                if (t) t.classList.add('d-none');
                if (l) l.classList.remove('d-none');
            } else {
                btn.disabled = false;
                if (t) t.classList.remove('d-none');
                if (l) l.classList.add('d-none');
            }
        }

        // =========================
        // Classificação (somente Editar)
        // =========================
        window.refreshClassificationPanel = async function (documentId) {
            const url = '@Url.Action("Panel", "Classification")' + '?documentId=' + encodeURIComponent(documentId);
            const resp = await fetch(url, { credentials: 'include', cache: 'no-store' });
            if (!resp.ok) return;
            const html = await resp.text();
            const panel = document.getElementById('classification-panel');
            if (panel) panel.innerHTML = html;
        };

        window.openClassificationModal = async function (documentId, btn) {
            if (!documentId) return;

            // Se vier botão, mostra loading nele
            if (btn) setBtnLoading(btn, true);

            const host = document.getElementById('classification-modal-host');
            if (!host) return;

            try {
                const url = '@Url.Action("EditModal", "Classification")' + '?documentId=' + encodeURIComponent(documentId);
                const resp = await fetch(url, { credentials: 'include', cache: 'no-store' });

                if (!resp.ok) {
                    const txt = await resp.text().catch(() => '');
                    alert('Falha ao abrir classificação. ' + txt);
                    return;
                }

                host.innerHTML = await resp.text();

                const modalEl = document.getElementById('modalEditClassification');
                if (!modalEl) {
                    alert('Modal não encontrado no HTML retornado.');
                    return;
                }

                const modal = new bootstrap.Modal(modalEl);
                modal.show();

                // wire submit (sem depender de <script> no partial)
                const form = modalEl.querySelector('#formEditClassification');
                if (form) {
                    form.addEventListener('submit', async (e) => {
                        e.preventDefault();

                        const submitBtn = form.querySelector('button[type="submit"]');
                        setBtnLoading(submitBtn, true);

                        try {
                            // MetadataLines -> metadataJson
                            const lines = (form.querySelector('[name="MetadataLines"]')?.value || '');
                            const obj = {};
                            lines.split(/\r?\n/).map(x => (x || '').trim()).filter(Boolean).forEach(line => {
                                if (line.startsWith('#')) return;
                                const idx = line.indexOf('=');
                                if (idx <= 0) return;
                                const k = line.substring(0, idx).trim();
                                const v = line.substring(idx + 1).trim();
                                if (!k) return;
                                obj[k] = v;
                            });

                            let hidden = form.querySelector('[name="metadataJson"]');
                            if (!hidden) {
                                hidden = document.createElement('input');
                                hidden.type = 'hidden';
                                hidden.name = 'metadataJson';
                                form.appendChild(hidden);
                            }
                            hidden.value = JSON.stringify(obj);

                            // POST SaveManual
                            const r = await fetch('@Url.Action("SaveManual", "Classification")', {
                                method: 'POST',
                                body: new FormData(form),
                                credentials: 'include'
                            });

                            if (!r.ok) {
                                const txt = await r.text().catch(() => '');
                                alert('Falha ao salvar classificação. ' + txt);
                                return;
                            }

                            modal.hide();
                            await window.refreshClassificationPanel(documentId);
                        } finally {
                            setBtnLoading(submitBtn, false);
                        }
                    }, { once: true });
                }

                modalEl.addEventListener('hidden.bs.modal', function () {
                    host.innerHTML = '';
                }, { once: true });

            } finally {
                if (btn) setBtnLoading(btn, false);
            }
        };

        window.applyClassificationSuggestion = async function (documentId, btn) {
            const token = getAjaxAntiForgeryToken();
            const typeId = btn?.dataset?.suggestedTypeId;
            const conf = btn?.dataset?.suggestedConfidence;
            const summary = btn?.dataset?.suggestedSummary || '';

            if (!typeId) {
                alert('Sugestão inválida (tipo não informado).');
                return;
            }

            setBtnLoading(btn, true);
            try {
                const body =
                    'documentId=' + encodeURIComponent(documentId) +
                    '&suggestedTypeId=' + encodeURIComponent(typeId) +
                    '&suggestedConfidence=' + encodeURIComponent(conf || '') +
                    '&suggestedSummary=' + encodeURIComponent(summary);

                const resp = await fetch('@Url.Action("ApplySuggestion", "Classification")', {
                    method: 'POST',
                    credentials: 'include',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body
                });

                if (!resp.ok) {
                    const txt = await resp.text().catch(() => '');
                    alert('Falha ao aplicar sugestão. ' + txt);
                    return;
                }

                await window.refreshClassificationPanel(documentId);
            } finally {
                setBtnLoading(btn, false);
            }
        };

        // auto-open (opcional; se você quiser manter deep link via openClassify)
        (function () {
            const mustOpen = @((openClassify ? "true" : "false"));
            if (mustOpen) window.openClassificationModal('@Model.Id');
        })();

        // =========================
        // Preview overlay (evita "carregando" infinito)
        // =========================
        (function () {
            function hideLoading() {
                const el = document.getElementById('previewLoading');
                if (el) el.style.display = 'none';
            }

            const frame = document.getElementById('previewFrame');
            if (!frame) return;

            frame.addEventListener('load', hideLoading);

            // Fallback: some sempre
            setTimeout(hideLoading, 2000);
            setTimeout(hideLoading, 8000);
        })();

        // =========================
        // OCR: spinner no botão + polling simples
        // =========================
        (function () {
            const form = document.getElementById('ocrForm');
            const btn = document.getElementById('btnOcr');
            const badgeWrap = document.getElementById('ocrStatusBadge');
            const versionId = "@(selectedVersionId ?? Guid.Empty)";

            function setBadge(status, err) {
                if (!badgeWrap) return;
                const st = (status || "").toUpperCase();

                if (st === "PROCESSING") badgeWrap.innerHTML = '<span class="badge bg-info text-dark">🔄 OCR processando</span>';
                else if (st === "PENDING") badgeWrap.innerHTML = '<span class="badge bg-secondary">⏳ OCR pendente</span>';
                else if (st === "COMPLETED") badgeWrap.innerHTML = '<span class="badge bg-success">✅ OCR concluído</span>';
                else if (st === "ERROR") badgeWrap.innerHTML = `<span class="badge bg-danger" title="${(err||'Falha no OCR').replaceAll('"','&quot;')}">❌ OCR falhou</span>`;
                else badgeWrap.innerHTML = '<span class="badge bg-light text-dark">— OCR</span>';
            }

            let timer = null;

            async function poll() {
                try {
                    const url = '@Url.Action("OcrStatus", "Ged")' + '?versionId=' + encodeURIComponent(versionId);
                    const resp = await fetch(url, { credentials:'include', cache:'no-store' });
                    if (!resp.ok) return;

                    const data = await resp.json();
                    setBadge(data.status, data.errorMessage);

                    const st = (data.status || "").toUpperCase();
                    if (st === "COMPLETED" && data.ocrVersionId) {
                        clearInterval(timer);
                        timer = null;
                        // abre versão OCR automaticamente
                        window.location.href =
                            '@Url.Action("Details", "Ged")' +
                            '?id=' + encodeURIComponent(data.documentId) +
                            '&versionId=' + encodeURIComponent(data.ocrVersionId);
                    }
                    if (st !== "PENDING" && st !== "PROCESSING") {
                        clearInterval(timer);
                        timer = null;
                    }
                } catch {}
            }

            if (form) {
                form.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    setBtnLoading(btn, true);
                    try {
                        const resp = await fetch(form.action, {
                            method: 'POST',
                            body: new FormData(form),
                            credentials: 'include',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        if (resp.ok) {
                            setBadge("PROCESSING");
                            if (!timer) timer = setInterval(poll, 2500);
                            poll();
                        } else {
                            setBadge("ERROR", "Falha ao iniciar OCR.");
                        }
                    } catch {
                        setBadge("ERROR", "Falha ao iniciar OCR.");
                    } finally {
                        setBtnLoading(btn, false);
                    }
                });
            }

            // start polling on load
            if (!timer) timer = setInterval(poll, 5000);
            poll();
        })();

        // Fullscreen
        (function () {
            const container = document.getElementById('previewContainer');
            const btnFull = document.getElementById('btnFull');
            if (btnFull && container) {
                btnFull.addEventListener('click', async () => {
                    if (!document.fullscreenElement) await container.requestFullscreen();
                    else await document.exitFullscreen();
                });
            }
        })();
    </script>
}
