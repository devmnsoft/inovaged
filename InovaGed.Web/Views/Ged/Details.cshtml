@using InovaGed.Domain.Documents
@model InovaGed.Web.Models.Ged.GedDetailsVM

@{
    ViewData["Title"] = "Detalhes do Documento";

    string ToSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        var kb = bytes / 1024d;
        if (kb < 1024) return $"{kb:N1} KB";
        var mb = kb / 1024d;
        if (mb < 1024) return $"{mb:N1} MB";
        var gb = mb / 1024d;
        return $"{gb:N1} GB";
    }

    string StatusBadge(DocumentStatus st) => st switch
    {
        DocumentStatus.Draft => "bg-secondary",
        DocumentStatus.InReview => "bg-info text-dark",
        DocumentStatus.InSignature => "bg-warning text-dark",
        DocumentStatus.Published => "bg-success",
        DocumentStatus.Archived => "bg-dark",
        _ => "bg-light text-dark"
    };

    string StatusLabel(DocumentStatus st) => st switch
    {
        DocumentStatus.Draft => "Rascunho",
        DocumentStatus.InReview => "Em análise",
        DocumentStatus.InSignature => "Em assinatura",
        DocumentStatus.Published => "Publicado",
        DocumentStatus.Archived => "Arquivado",
        _ => st.ToString()
    };

    string OcrBadgeClass(string? status) => (status ?? "").ToUpperInvariant() switch
    {
        "PENDING" => "bg-secondary",
        "PROCESSING" => "bg-warning text-dark",
        "COMPLETED" => "bg-success",
        "ERROR" => "bg-danger",
        _ => "bg-light text-dark"
    };

    string OcrLabel(string? status) => (status ?? "").ToUpperInvariant() switch
    {
        "PENDING" => "Pendente",
        "PROCESSING" => "Executando",
        "COMPLETED" => "Concluído",
        "ERROR" => "Erro",
        _ => "Não executado"
    };

    bool IsOcrRunning(string? status)
    {
        var s = (status ?? "").ToUpperInvariant();
        return s == "PENDING" || s == "PROCESSING";
    }

    bool IsOcrCompleted(string? status)
    {
        var s = (status ?? "").ToUpperInvariant();
        return s == "COMPLETED";
    }

    var selectedId = Model.SelectedVersionId
        ?? Model.CurrentVersionId
        ?? Model.Versions.OrderByDescending(v => v.VersionNumber).FirstOrDefault()?.Id;

    var selected = selectedId.HasValue
        ? Model.Versions.FirstOrDefault(v => v.Id == selectedId.Value)
        : null;

    var openClassify = (ViewBag.OpenClassify as bool?) == true;
    var ocrSwitched = (ViewBag.OcrSwitched as bool?) == true;
}

<div class="container-fluid">

    <div id="pageAlertHost"></div>

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h3 class="mb-1">
                <i class="bi bi-file-earmark-text me-1"></i> @Model.Title
            </h3>

            <div class="text-muted small d-flex flex-wrap gap-2 align-items-center">
                <span class="badge @StatusBadge(Model.Status)">
                    @StatusLabel(Model.Status)
                </span>

                @if (Model.IsConfidential)
                {
                    <span class="badge bg-danger">
                        <i class="bi bi-shield-lock me-1"></i> Confidencial
                    </span>
                }

                <span>Doc: <code>@Model.Id</code></span>

                @if (Model.FolderId.HasValue)
                {
                    <span>Pasta: <code>@Model.FolderId</code></span>
                }

                @if (ocrSwitched)
                {
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-magic me-1"></i> Preview alternado para OCR
                    </span>
                }
            </div>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-light" href="@Url.Action("Index", "Ged", new { folderId = Model.FolderId })">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>

            <button type="button" class="btn btn-outline-primary" id="btnOpenClassifyTop">
                <i class="bi bi-tags me-1"></i> Classificação
            </button>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-eye me-1"></i> Visualização</strong>

                    <div class="d-flex align-items-center gap-2">
                        @if (selected is not null)
                        {
                            <span class="text-muted small">
                                Versão @selected.VersionNumber · @ToSize(selected.SizeBytes)
                            </span>

                            <a class="btn btn-sm btn-outline-secondary"
                               href="@Url.Action("Download", "Ged", new { id = selected.Id })">
                                <i class="bi bi-download me-1"></i> Baixar
                            </a>
                        }
                    </div>
                </div>

                <div class="card-body p-0">
                    @if (selected is null)
                    {
                        <div class="p-3 text-muted">Nenhuma versão selecionada.</div>
                    }
                    else
                    {
                        <iframe src="@Url.Action("PreviewInline", "Ged", new { versionId = selected.Id })"
                                style="width:100%; height:75vh; border:0;">
                        </iframe>
                    }
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-layers me-1"></i> Versões</strong>

                    <div class="d-flex gap-2 align-items-center">
                        <span class="text-muted small">
                            Total: @Model.Versions.Count
                        </span>
                    </div>
                </div>

                <div class="card-body">
                    @if (Model.Versions.Count == 0)
                    {
                        <div class="text-muted">Nenhuma versão cadastrada.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th style="width:80px;">Ver.</th>
                                        <th>Arquivo</th>
                                        <th style="width:120px;">Tamanho</th>
                                        <th style="width:210px;">OCR</th>
                                        <th style="width:310px;" class="text-end">Ações</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var v in Model.Versions.OrderByDescending(x => x.VersionNumber))
                                    {
                                        var isSelected = selectedId.HasValue && v.Id == selectedId.Value;
                                        var hasOcrStatus = !string.IsNullOrWhiteSpace(v.OcrStatus);
                                        var ocrRunning = IsOcrRunning(v.OcrStatus);
                                        var ocrCompleted = IsOcrCompleted(v.OcrStatus);

                                        <tr class="@(isSelected ? "table-active" : "")">
                                            <td>
                                                <span class="badge @(v.IsCurrent ? "bg-primary" : "bg-light text-dark")">
                                                    @v.VersionNumber
                                                </span>
                                            </td>

                                            <td>
                                                <div class="fw-semibold">@v.FileName</div>
                                                <div class="text-muted small">@v.ContentType</div>
                                            </td>

                                            <td>@ToSize(v.SizeBytes)</td>

                                            <td>
                                                <div class="ocr-status-cell"
                                                     data-version-id="@v.Id"
                                                     data-current-status="@(v.OcrStatus ?? "NONE")">

                                                    @if (hasOcrStatus)
                                                    {
                                                        <span class="badge @OcrBadgeClass(v.OcrStatus) js-ocr-badge">
                                                            @OcrLabel(v.OcrStatus)
                                                        </span>

                                                        @if (ocrRunning)
                                                        {
                                                            <span class="spinner-border spinner-border-sm ms-1 js-ocr-spinner"
                                                                  role="status"
                                                                  aria-hidden="true"></span>
                                                        }

                                                        @if (ocrCompleted)
                                                        {
                                                            <span class="text-success small ms-1 js-ocr-done-icon">
                                                                <i class="bi bi-check-circle"></i>
                                                            </span>
                                                        }

                                                        @if (v.OcrJobId.HasValue)
                                                        {
                                                            <div class="text-muted small mt-1 js-ocr-job">
                                                                Job #@v.OcrJobId
                                                            </div>
                                                        }

                                                        @if (v.OcrRequestedAt.HasValue)
                                                        {
                                                            <div class="text-muted small js-ocr-requested">
                                                                Solicitado: @v.OcrRequestedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                            </div>
                                                        }

                                                        @if (v.OcrStartedAt.HasValue)
                                                        {
                                                            <div class="text-muted small js-ocr-started">
                                                                Início: @v.OcrStartedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                            </div>
                                                        }

                                                        @if (v.OcrFinishedAt.HasValue)
                                                        {
                                                            <div class="text-muted small js-ocr-finished">
                                                                Fim: @v.OcrFinishedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-light text-dark js-ocr-badge">
                                                            Não executado
                                                        </span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(v.OcrErrorMessage))
                                                    {
                                                        <div class="text-danger small mt-1 js-ocr-error">
                                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                                            @v.OcrErrorMessage
                                                        </div>
                                                    }

                                                    @if (ocrRunning)
                                                    {
                                                        <span data-ocr-autopoll="1" data-version-id="@v.Id"></span>
                                                    }
                                                </div>
                                            </td>

                                            <td class="text-end">
                                                <div class="btn-group">
                                                    <a class="btn btn-sm btn-outline-secondary"
                                                       title="Visualizar esta versão"
                                                       href="@Url.Action("Details", "Ged", new { id = Model.Id, versionId = v.Id })">
                                                        <i class="bi bi-eye"></i>
                                                    </a>

                                                    <a class="btn btn-sm btn-outline-secondary"
                                                       title="Baixar"
                                                       href="@Url.Action("Download", "Ged", new { id = v.Id })">
                                                        <i class="bi bi-download"></i>
                                                    </a>

                                                    <a class="btn btn-sm btn-outline-secondary"
                                                       title="Abrir OCR texto, se existir"
                                                       target="_blank"
                                                       href="@Url.Action("OcrText", "Ged", new { versionId = v.Id })">
                                                        <i class="bi bi-filetype-txt"></i>
                                                    </a>

                                                    <form method="post"
                                                          action="@Url.Action("RunOcr", "Ged")"
                                                          class="d-inline js-ocr-form">
                                                        @Html.AntiForgeryToken()

                                                        <input type="hidden" name="versionId" value="@v.Id" />
                                                        <input type="hidden" name="force" value="false" />

                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-primary"
                                                                title="Solicitar OCR"
                                                        @(ocrRunning ? "disabled" : "")>
                                                            <span class="btn-text">
                                                                <i class="bi bi-text-paragraph"></i>
                                                            </span>
                                                            <span class="btn-loading d-none">
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                            </span>
                                                        </button>
                                                    </form>

                                                    <form method="post"
                                                          action="@Url.Action("ReprocessOcr", "Ged")"
                                                          class="d-inline js-ocr-form js-ocr-force-form">
                                                        @Html.AntiForgeryToken()

                                                        <input type="hidden" name="versionId" value="@v.Id" />

                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-warning"
                                                                title="Reprocessar OCR forçando">
                                                            <span class="btn-text">
                                                                <i class="bi bi-arrow-clockwise"></i>
                                                            </span>
                                                            <span class="btn-loading d-none">
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                            </span>
                                                        </button>
                                                    </form>

                                                    <form method="post"
                                                          action="@Url.Action("RegeneratePreview", "Ged")"
                                                          class="d-inline js-simple-post-form">
                                                        @Html.AntiForgeryToken()

                                                        <input type="hidden" name="versionId" value="@v.Id" />

                                                        <button type="submit"
                                                                class="btn btn-sm btn-outline-dark"
                                                                title="Regerar preview">
                                                            <span class="btn-text">
                                                                <i class="bi bi-arrow-repeat"></i>
                                                            </span>
                                                            <span class="btn-loading d-none">
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                            </span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info small mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Quando o OCR for solicitado, a tela acompanhará o processamento automaticamente e avisará ao concluir.
                        </div>
                    }
                </div>
            </div>

            <div class="card mt-3" id="classifyCard">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-tags me-1"></i> Classificação</strong>

                    <div class="d-flex gap-2 align-items-center">
                        <button class="btn btn-sm btn-outline-secondary"
                                type="button"
                                onclick="toggleClassificationAudit('@Model.Id', this)"
                                title="Mostrar ou ocultar histórico da classificação">
                            <span class="btn-text">
                                <i class="bi bi-clock-history me-1"></i> Ver histórico
                            </span>
                            <span class="btn-loading d-none">
                                <span class="spinner-border spinner-border-sm me-1"></span>
                                Carregando...
                            </span>
                        </button>

                        <button class="btn btn-sm btn-outline-primary" type="button" id="btnOpenClassify">
                            <i class="bi bi-pencil-square me-1"></i> Editar classificação
                        </button>
                    </div>
                </div>

                <div class="card-body">
                    <div id="classifyPanelLoading" class="text-muted small d-none">
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        Carregando painel...
                    </div>

                    <div id="classifyPanel"></div>

                    <div id="classificationAudit"
                         class="d-none mt-3"
                         data-loaded="0">
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-diagram-3 me-1"></i> Ciclo de Vida</strong>
                    <span class="badge @StatusBadge(Model.Status)">
                        @StatusLabel(Model.Status)
                    </span>
                </div>

                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (Model.Status == DocumentStatus.Draft)
                        {
                            <button class="btn btn-outline-primary"
                                    onclick="openLifeModal('@Model.Id','@((int)DocumentStatus.InReview)','Enviar para análise', true)">
                                <i class="bi bi-send me-1"></i> Enviar para análise
                            </button>
                        }

                        @if (Model.Status == DocumentStatus.InReview)
                        {
                            <button class="btn btn-outline-success"
                                    onclick="openLifeModal('@Model.Id','@((int)DocumentStatus.InSignature)','Aprovar para assinatura', true)">
                                <i class="bi bi-check2-circle me-1"></i> Aprovar para assinatura
                            </button>

                            <button class="btn btn-outline-danger"
                                    onclick="openLifeModal('@Model.Id','@((int)DocumentStatus.Draft)','Reprovar e voltar para rascunho', true)">
                                <i class="bi bi-arrow-counterclockwise me-1"></i> Reprovar
                            </button>
                        }

                        @if (Model.Status == DocumentStatus.InSignature)
                        {
                            <button class="btn btn-outline-success"
                                    onclick="openLifeModal('@Model.Id','@((int)DocumentStatus.Published)','Publicar', false)">
                                <i class="bi bi-megaphone me-1"></i> Publicar
                            </button>

                            <button class="btn btn-outline-secondary"
                                    onclick="openLifeModal('@Model.Id','@((int)DocumentStatus.InReview)','Voltar para análise', true)">
                                <i class="bi bi-arrow-left-circle me-1"></i> Voltar para análise
                            </button>
                        }

                        @if (Model.Status == DocumentStatus.Published)
                        {
                            <button class="btn btn-outline-dark"
                                    onclick="openLifeModal('@Model.Id','@((int)DocumentStatus.Archived)','Arquivar', true)">
                                <i class="bi bi-archive me-1"></i> Arquivar
                            </button>
                        }

                        <button class="btn btn-outline-secondary"
                                id="btnLifeHistory"
                                onclick="toggleLifeHistory('@Model.Id', this)">
                            <span class="btn-text">
                                <i class="bi bi-clock-history me-1"></i> Ver histórico
                            </span>
                            <span class="btn-loading d-none">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                Carregando...
                            </span>
                        </button>

                        <div id="life-history-container" class="d-none mt-2"></div>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <strong><i class="bi bi-gear me-1"></i> Workflow de Processo</strong>
                </div>

                <div class="card-body">
                    @if (!Model.Workflow.HasActiveWorkflow)
                    {
                        <div class="text-muted small mb-2">
                            Nenhum workflow ativo para este documento.
                        </div>

                        @if (Model.Workflow.AvailableWorkflows.Count > 0)
                        {
                            <form method="post" action="@Url.Action("StartWorkflow", "Ged")" class="mt-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="documentId" value="@Model.Id" />

                                <label class="form-label">Selecionar workflow</label>
                                <select class="form-select mb-2" name="workflowId">
                                    @foreach (var wf in Model.Workflow.AvailableWorkflows)
                                    {
                                        <option value="@wf.Id">@wf.Name</option>
                                    }
                                </select>

                                <button type="submit" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-play-circle me-1"></i> Iniciar workflow
                                </button>

                                <div class="form-text mt-2">
                                    O sistema valida se o documento está classificado antes de iniciar.
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="text-muted small">
                                Nenhum workflow disponível.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mb-2">
                            <div class="text-muted small">Workflow</div>
                            <div class="fw-semibold">@Model.Workflow.WorkflowName</div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small">Etapa atual</div>
                            <div>@Model.Workflow.CurrentStageName</div>
                        </div>

                        @if (!Model.Workflow.IsCompleted && Model.Workflow.AvailableTransitions.Count > 0)
                        {
                            <form method="post" action="@Url.Action("ApplyTransition", "Ged")" id="formTransition">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="documentId" value="@Model.Id" />

                                <label class="form-label">Transição</label>
                                <select class="form-select mb-2" name="transitionId" id="transitionId">
                                    @foreach (var t in Model.Workflow.AvailableTransitions)
                                    {
                                        <option value="@t.Id" data-requires-reason="@(t.RequiresReason ? "1" : "0")">
                                            @t.Name → @t.ToStageName
                                        </option>
                                    }
                                </select>

                                <div class="mb-2">
                                    <label class="form-label">Motivo</label>
                                    <textarea class="form-control" rows="2" name="reason" id="transitionReason"></textarea>
                                    <div class="form-text" id="transitionReasonHelp"></div>
                                </div>

                                <div class="mb-2">
                                    <label class="form-label">Comentários</label>
                                    <textarea class="form-control" rows="2" name="comments"></textarea>
                                </div>

                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="bi bi-shuffle me-1"></i> Aplicar transição
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="text-muted small">
                                Sem transições disponíveis.
                            </div>
                        }

                        @if (Model.Workflow.History.Count > 0)
                        {
                            <hr />
                            <div class="fw-semibold mb-2">
                                <i class="bi bi-clock-history me-1"></i> Histórico do processo
                            </div>

                            <div class="list-group">
                                @foreach (var h in Model.Workflow.History.OrderByDescending(x => x.PerformedAt))
                                {
                                    <div class="list-group-item">
                                        <div class="fw-semibold">@h.FromStageName → @h.ToStageName</div>

                                        @if (!string.IsNullOrWhiteSpace(h.Reason))
                                        {
                                            <div class="text-muted small">@h.Reason</div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(h.Comments))
                                        {
                                            <div class="text-muted small">@h.Comments</div>
                                        }

                                        <div class="text-muted small">
                                            @h.PerformedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <strong><i class="bi bi-info-circle me-1"></i> Metadados</strong>
                </div>

                <div class="card-body">
                    <div class="mb-2">
                        <div class="text-muted small">Descrição</div>
                        <div id="documentDescription">
                            @(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)
                        </div>
                    </div>

                    <div class="mb-2">
                        <div class="text-muted small">Criado por</div>
                        <div>@(Model.CreatedBy?.ToString() ?? "-")</div>
                    </div>

                    <div class="mb-2">
                        <div class="text-muted small">Versão atual</div>
                        <div>@(Model.CurrentVersionId?.ToString() ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLife" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="formLife" method="post" action="@Url.Action("ChangeStatus", "DocumentWorkflow")">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title" id="lifeTitle">Alterar status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="documentId" id="lifeDocumentId" />
                    <input type="hidden" name="toStatus" id="lifeToStatus" />

                    <div class="mb-2 text-muted small" id="lifeSubtitle"></div>

                    <div class="mb-3">
                        <label class="form-label">Motivo</label>
                        <textarea class="form-control"
                                  rows="3"
                                  name="reason"
                                  id="lifeReason"
                                  placeholder="Descreva o motivo desta ação..."></textarea>
                        <div class="form-text" id="lifeReasonHelp"></div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit" class="btn btn-primary" id="lifeSubmit">
                        <span class="btn-text">Confirmar</span>
                        <span class="btn-loading d-none">
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            Salvando...
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalClassify" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" id="classifyModalContent">
            <div class="p-4 text-muted">
                <span class="spinner-border spinner-border-sm me-1"></span>
                Carregando…
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ged-ocr-status.js" asp-append-version="true"></script>
    <script>
        window.setBtnLoading = function (btn, loading) {
            if (!btn) return;

            const text = btn.querySelector('.btn-text');
            const loadingEl = btn.querySelector('.btn-loading');

            if (loading) {
                text && text.classList.add('d-none');
                loadingEl && loadingEl.classList.remove('d-none');
                btn.setAttribute('disabled', 'disabled');
            } else {
                text && text.classList.remove('d-none');
                loadingEl && loadingEl.classList.add('d-none');
                btn.removeAttribute('disabled');
            }
        };

        window.showGedToast = function (message, type) {
            type = type || 'success';

            let host = document.getElementById('gedToastHost');

            if (!host) {
                host = document.createElement('div');
                host.id = 'gedToastHost';
                host.style.position = 'fixed';
                host.style.top = '1rem';
                host.style.right = '1rem';
                host.style.zIndex = '1080';
                host.style.maxWidth = '420px';
                document.body.appendChild(host);
            }

            const cls = type === 'danger' ? 'alert-danger'
                : type === 'warning' ? 'alert-warning'
                : type === 'info' ? 'alert-info'
                : 'alert-success';

            const icon = type === 'danger' ? 'bi-exclamation-triangle'
                : type === 'warning' ? 'bi-exclamation-circle'
                : type === 'info' ? 'bi-info-circle'
                : 'bi-check-circle';

            const el = document.createElement('div');
            el.className = `alert ${cls} shadow-sm mb-2`;
            el.innerHTML = `
                <div class="d-flex align-items-center gap-2">
                    <i class="bi ${icon}"></i>
                    <div>${message}</div>
                </div>`;

            host.appendChild(el);

            setTimeout(() => {
                el.remove();
            }, 6000);
        };

        window.showPageAlert = function (message, type) {
            type = type || 'success';

            const host = document.getElementById('pageAlertHost');
            if (!host) return;

            const cls = type === 'danger' ? 'alert-danger'
                : type === 'warning' ? 'alert-warning'
                : type === 'info' ? 'alert-info'
                : 'alert-success';

            host.innerHTML = `
                <div class="alert ${cls} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                </div>`;
        };

        async function loadClassifyPanel() {
            const loading = document.getElementById('classifyPanelLoading');
            const panel = document.getElementById('classifyPanel');

            if (!panel) return;

            loading && loading.classList.remove('d-none');

            try {
                const url = '@Url.Action("Panel", "Classification")' + '?documentId=@Model.Id';

                const resp = await fetch(url, {
                    credentials: 'include',
                    cache: 'no-store'
                });

                if (!resp.ok) {
                    const txt = await resp.text().catch(() => '');
                    panel.innerHTML = `<div class="text-danger small">Erro ao carregar painel de classificação. ${txt}</div>`;
                    return;
                }

                panel.innerHTML = await resp.text();
            }
            finally {
                loading && loading.classList.add('d-none');
            }
        }

        async function openClassifyModal() {
            const content = document.getElementById('classifyModalContent');
            const modalEl = document.getElementById('modalClassify');

            if (!content || !modalEl) return;

            content.innerHTML =
                `<div class="p-4 text-muted">
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    Carregando…
                 </div>`;

            const modal = new bootstrap.Modal(modalEl);
            modal.show();

            const url = '@Url.Action("EditModal", "Classification")' + '?documentId=@Model.Id';

            const resp = await fetch(url, {
                credentials: 'include',
                cache: 'no-store'
            });

            if (!resp.ok) {
                const txt = await resp.text().catch(() => '');
                content.innerHTML = `<div class="p-4 text-danger">Erro ao abrir modal. ${txt}</div>`;
                return;
            }

            content.innerHTML = await resp.text();
        }

        function resetClassificationAudit() {
            const audit =
                document.getElementById('classificationAudit') ||
                document.getElementById('classification-audit-container') ||
                document.getElementById('classAuditContainer');

            if (audit) {
                audit.innerHTML = '';
                audit.setAttribute('data-loaded', '0');
                audit.classList.add('d-none');
            }
        }

        window.refreshClassificationPanel = async function () {
            await loadClassifyPanel();
        };

        window.toggleClassificationAudit = async function (documentId, btn) {
            const el =
                document.getElementById('classificationAudit') ||
                document.getElementById('classification-audit-container') ||
                document.getElementById('classAuditContainer') ||
                document.querySelector('[data-role="classification-audit"]');

            if (!el) {
                console.warn('Container de histórico da classificação não encontrado.');
                return;
            }

            if (!el.classList.contains('d-none')) {
                el.classList.add('d-none');
                return;
            }

            if (btn) setBtnLoading(btn, true);

            try {
                const loaded = el.getAttribute('data-loaded') === '1';

                if (!loaded) {
                    const url = '@Url.Action("Audit", "Classification")'
                        + '?documentId=' + encodeURIComponent(documentId || '@Model.Id')
                        + '&take=50';

                    const resp = await fetch(url, {
                        credentials: 'include',
                        cache: 'no-store'
                    });

                    if (!resp.ok) {
                        const txt = await resp.text().catch(() => '');

                        el.innerHTML =
                            `<div class="alert alert-warning mb-0">
                                <div class="fw-semibold">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    Não foi possível carregar o histórico.
                                </div>
                                <div class="small text-muted mt-1">HTTP ${resp.status} ${resp.statusText}</div>
                                ${txt ? `<div class="small text-muted mt-1">${txt}</div>` : ``}
                             </div>`;
                    } else {
                        el.innerHTML = await resp.text();
                    }

                    el.setAttribute('data-loaded', '1');
                }

                el.classList.remove('d-none');
            }
            finally {
                if (btn) setBtnLoading(btn, false);
            }
        };

        window.applyClassificationSuggestion = async function (documentId, btn) {
            if (!btn) return;

            const suggestedTypeId = btn.getAttribute('data-suggested-type-id');
            const suggestedConfidence = btn.getAttribute('data-suggested-confidence') || '';
            const suggestedSummary = btn.getAttribute('data-suggested-summary') || '';

            if (!suggestedTypeId) {
                showGedToast('Nenhuma sugestão disponível para aplicar.', 'warning');
                return;
            }

            setBtnLoading(btn, true);

            try {
                const fd = new FormData();
                fd.append('documentId', documentId);
                fd.append('suggestedTypeId', suggestedTypeId);
                fd.append('suggestedConfidence', suggestedConfidence);
                fd.append('suggestedSummary', suggestedSummary);

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) {
                    fd.append('__RequestVerificationToken', token);
                }

                const resp = await fetch('@Url.Action("ApplySuggestion", "Classification")', {
                    method: 'POST',
                    body: fd,
                    credentials: 'include',
                    cache: 'no-store',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                if (!resp.ok) {
                    const txt = await resp.text().catch(() => 'Erro ao aplicar sugestão.');
                    showGedToast(txt || 'Erro ao aplicar sugestão.', 'danger');
                    return;
                }

                showGedToast('Sugestão aplicada com sucesso.', 'success');
                showPageAlert('Sugestão aplicada com sucesso.', 'success');

                await refreshClassificationPanel();
                resetClassificationAudit();

                setTimeout(() => {
                    location.reload();
                }, 900);
            }
            finally {
                setBtnLoading(btn, false);
            }
        };

        document.addEventListener('submit', async function (e) {
            const form = e.target;

            if (!form || form.id !== 'formEditClassification') {
                return;
            }

            e.preventDefault();

            const btn = form.querySelector('button[type="submit"]');
            const err = document.getElementById('classificationSaveError');

            if (err) {
                err.classList.add('d-none');
                err.innerText = '';
            }

            setBtnLoading(btn, true);

            try {
                const resp = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    credentials: 'include',
                    cache: 'no-store',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json'
                    }
                });

                if (!resp.ok) {
                    const txt = await resp.text().catch(() => 'Erro ao salvar classificação.');

                    if (err) {
                        err.innerText = txt || 'Erro ao salvar classificação.';
                        err.classList.remove('d-none');
                    }

                    showGedToast(txt || 'Erro ao salvar classificação.', 'danger');
                    showPageAlert(txt || 'Erro ao salvar classificação.', 'danger');
                    return;
                }

                const modalEl = document.getElementById('modalClassify');

                if (modalEl && window.bootstrap) {
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal && modal.hide();
                }

                showGedToast('Classificação salva com sucesso.', 'success');
                showPageAlert('Classificação salva com sucesso.', 'success');

                await refreshClassificationPanel();
                resetClassificationAudit();

                setTimeout(() => {
                    location.reload();
                }, 900);
            }
            finally {
                setBtnLoading(btn, false);
            }
        });

        window.openLifeModal = function (documentId, toStatusInt, title, reasonRequired) {
            const modalEl = document.getElementById('modalLife');
            if (!modalEl) return;

            document.getElementById('lifeDocumentId').value = documentId;
            document.getElementById('lifeToStatus').value = toStatusInt;
            document.getElementById('lifeTitle').innerText = title || 'Alterar status';
            document.getElementById('lifeSubtitle').innerText = 'Esta ação registra histórico do ciclo de vida.';

            const reason = document.getElementById('lifeReason');
            const help = document.getElementById('lifeReasonHelp');

            reason.value = '';

            if (reasonRequired) {
                reason.setAttribute('required', 'required');
                help.innerText = 'Motivo obrigatório para esta transição.';
            } else {
                reason.removeAttribute('required');
                help.innerText = 'Motivo opcional.';
            }

            const modal = new bootstrap.Modal(modalEl);
            modal.show();

            const form = document.getElementById('formLife');
            const btn = document.getElementById('lifeSubmit');

            if (form && btn) {
                form.addEventListener('submit', function () {
                    setBtnLoading(btn, true);
                }, { once: true });
            }
        };

        window.toggleLifeHistory = async function (documentId, btn) {
            const container = document.getElementById('life-history-container');
            if (!container) return;

            if (!container.classList.contains('d-none')) {
                container.classList.add('d-none');
                container.innerHTML = '';

                const text = btn?.querySelector('.btn-text');
                if (text) {
                    text.innerHTML = '<i class="bi bi-clock-history me-1"></i> Ver histórico';
                }

                return;
            }

            if (btn) setBtnLoading(btn, true);

            try {
                const url = '@Url.Action("History", "GedWorkflow")'
                    + '?documentId=' + encodeURIComponent(documentId)
                    + '&take=20';

                const resp = await fetch(url, {
                    credentials: 'include',
                    cache: 'no-store'
                });

                if (!resp.ok) {
                    const txt = await resp.text().catch(() => '');
                    container.innerHTML = `<div class="text-danger small">Falha ao carregar histórico. ${txt}</div>`;
                    container.classList.remove('d-none');
                    return;
                }

                container.innerHTML = await resp.text();
                container.classList.remove('d-none');

                const text = btn?.querySelector('.btn-text');
                if (text) {
                    text.innerHTML = '<i class="bi bi-clock-history me-1"></i> Ocultar histórico';
                }
            }
            finally {
                if (btn) setBtnLoading(btn, false);
            }
        };

        function configureTransitionReason() {
            const sel = document.getElementById('transitionId');
            const txt = document.getElementById('transitionReason');
            const help = document.getElementById('transitionReasonHelp');

            if (!sel || !txt) return;

            function apply() {
                const opt = sel.options[sel.selectedIndex];
                const req = opt?.getAttribute('data-requires-reason') === '1';

                if (req) {
                    txt.setAttribute('required', 'required');
                    if (help) help.innerText = 'Motivo obrigatório para esta transição.';
                } else {
                    txt.removeAttribute('required');
                    if (help) help.innerText = 'Motivo opcional.';
                }
            }

            sel.addEventListener('change', apply);
            apply();
        }

        function configureOcrForms() {
            document.querySelectorAll('.js-ocr-form').forEach(form => {
                form.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const btn = form.querySelector('button[type="submit"]');
                    const versionId = form.querySelector('input[name="versionId"]')?.value;
                    const isForce = form.classList.contains('js-ocr-force-form');

                    if (isForce) {
                        const ok = confirm('Deseja realmente reprocessar o OCR? Isso pode gerar uma nova versão OCR.');
                        if (!ok) return;
                    }

                    setBtnLoading(btn, true);

                    try {
                        const resp = await fetch(form.action, {
                            method: 'POST',
                            body: new FormData(form),
                            credentials: 'include',
                            cache: 'no-store',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Accept': 'application/json'
                            }
                        });

                        if (!resp.ok) {
                            const txt = await resp.text().catch(() => '');
                            showGedToast(txt || 'Erro ao solicitar OCR.', 'danger');
                            showPageAlert(txt || 'Erro ao solicitar OCR.', 'danger');
                            return;
                        }

                        const data = await resp.json().catch(() => null);

                        showGedToast(data?.message || 'OCR solicitado com sucesso.', 'success');
                        showPageAlert(data?.message || 'OCR solicitado com sucesso.', 'success');

                        if (versionId) {
                            updateOcrCell(versionId, 'PENDING', data?.jobId || null, null);
                            startOcrPolling(versionId);
                        }
                    }
                    finally {
                        setBtnLoading(btn, false);
                    }
                });
            });

            document.querySelectorAll('.js-simple-post-form').forEach(form => {
                form.addEventListener('submit', function () {
                    const btn = form.querySelector('button[type="submit"]');
                    setBtnLoading(btn, true);
                });
            });
        }

        function updateOcrCell(versionId, status, jobId, errorMessage) {
            const cell = document.querySelector(`.ocr-status-cell[data-version-id="${versionId}"]`);
            if (!cell) return;

            const st = (status || 'NONE').toUpperCase();

            const badgeClass = st === 'PENDING' ? 'bg-secondary'
                : st === 'PROCESSING' ? 'bg-warning text-dark'
                : st === 'COMPLETED' ? 'bg-success'
                : st === 'ERROR' ? 'bg-danger'
                : 'bg-light text-dark';

            const label = st === 'PENDING' ? 'Pendente'
                : st === 'PROCESSING' ? 'Executando'
                : st === 'COMPLETED' ? 'Concluído'
                : st === 'ERROR' ? 'Erro'
                : 'Não executado';

            const spinner = (st === 'PENDING' || st === 'PROCESSING')
                ? `<span class="spinner-border spinner-border-sm ms-1 js-ocr-spinner" role="status" aria-hidden="true"></span>`
                : '';

            const done = st === 'COMPLETED'
                ? `<span class="text-success small ms-1 js-ocr-done-icon"><i class="bi bi-check-circle"></i></span>`
                : '';

            const error = errorMessage
                ? `<div class="text-danger small mt-1 js-ocr-error"><i class="bi bi-exclamation-triangle me-1"></i>${errorMessage}</div>`
                : '';

            const job = jobId
                ? `<div class="text-muted small mt-1 js-ocr-job">Job #${jobId}</div>`
                : '';

            cell.innerHTML = `
                <span class="badge ${badgeClass} js-ocr-badge">${label}</span>
                ${spinner}
                ${done}
                ${job}
                ${error}
            `;
        }

        function startOcrPolling(versionId) {
            let attempts = 0;
            const maxAttempts = 120;

            const timer = setInterval(async function () {
                attempts++;

                if (attempts > maxAttempts) {
                    clearInterval(timer);
                    showGedToast('OCR ainda está em processamento. Atualize a página depois.', 'info');
                    showPageAlert('OCR ainda está em processamento. Atualize a página depois.', 'info');
                    return;
                }

                try {
                    const url = '@Url.Action("OcrStatus", "Ged")'
                        + '?versionId=' + encodeURIComponent(versionId);

                    const resp = await fetch(url, {
                        credentials: 'include',
                        cache: 'no-store'
                    });

                    if (!resp.ok) return;

                    const data = await resp.json();

                    if (!data || !data.hasJob) return;

                    updateOcrCell(versionId, data.status, data.jobId, data.errorMessage);

                    if (data.completed) {
                        clearInterval(timer);

                        showGedToast('OCR concluído com sucesso.', 'success');
                        showPageAlert('OCR concluído com sucesso. A página será atualizada.', 'success');

                        setTimeout(() => {
                            location.reload();
                        }, 1200);
                    }

                    if (data.error) {
                        clearInterval(timer);

                        showGedToast(data.errorMessage || 'OCR finalizado com erro.', 'danger');
                        showPageAlert(data.errorMessage || 'OCR finalizado com erro.', 'danger');

                        setTimeout(() => {
                            location.reload();
                        }, 1600);
                    }
                } catch {
                    // polling silencioso
                }
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', function () {
            loadClassifyPanel();
            configureTransitionReason();
            configureOcrForms();

            const btn = document.getElementById('btnOpenClassify');
            if (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    openClassifyModal();
                });
            }

            const btnTop = document.getElementById('btnOpenClassifyTop');
            if (btnTop) {
                btnTop.addEventListener('click', function (e) {
                    e.preventDefault();
                    openClassifyModal();
                });
            }

            const shouldOpen = @((openClassify ? "true" : "false"));
            if (shouldOpen) {
                setTimeout(() => openClassifyModal(), 150);
            }

            document.querySelectorAll('[data-ocr-autopoll="1"]').forEach(el => {
                const versionId = el.getAttribute('data-version-id');
                if (versionId) {
                    startOcrPolling(versionId);
                }
            });
        });
    </script>
}