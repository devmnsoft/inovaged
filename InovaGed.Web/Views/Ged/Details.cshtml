@model InovaGed.Web.Models.Ged.GedDetailsVM

@{
    ViewData["Title"] = "Detalhes do Documento";
    var currentVersionId = Model.CurrentVersionId;
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">
                <i class="bi bi-file-earmark-text"></i>
                @Model.Title
            </h3>
            <small class="text-muted">Documento: <strong>@Model.Id</strong></small>
        </div>

        <div class="btn-group">
            <a class="btn btn-outline-secondary"
               asp-controller="Ged"
               asp-action="Index"
               asp-route-folderId="@Model.FolderId">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>

            @if (currentVersionId.HasValue)
            {
                <a class="btn btn-outline-primary"
                   asp-controller="Ged"
                   asp-action="Download"
                   asp-route-id="@currentVersionId.Value">
                    <i class="bi bi-download"></i> Baixar
                </a>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-7">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-eye me-1"></i> Visualização</span>
                    @if (currentVersionId.HasValue)
                    {
                        <span class="badge bg-light text-dark">Versão atual</span>
                    }
                </div>

                <div class="card-body p-0" style="min-height:650px;">
                    @if (currentVersionId.HasValue)
                    {
                        <iframe src="@Url.Action("Preview","Ged", new { id = currentVersionId.Value })"
                                style="width:100%; height:650px; border:0;">
                        </iframe>
                    }
                    else
                    {
                        <div class="p-3 text-muted">Documento ainda não possui versão para visualização.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-info-circle me-1"></i> Informações</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5">Confidencial</dt>
                        <dd class="col-7">@((Model.IsConfidential) ? "Sim" : "Não")</dd>

                        <dt class="col-5">Descrição</dt>
                        <dd class="col-7">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "-")</dd>
                    </dl>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><i class="bi bi-layers me-1"></i> Versões</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>V</th>
                                <th>Arquivo</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Versions != null && Model.Versions.Any())
                            {
                                foreach (var v in Model.Versions)
                                {
                                    <tr>
                                        <td>@v.VersionNumber</td>
                                        <td class="text-truncate" style="max-width:220px">@v.FileName</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-controller="Ged"
                                               asp-action="Preview"
                                               asp-route-id="@v.Id"
                                               title="Visualizar">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Ged"
                                               asp-action="Download"
                                               asp-route-id="@v.Id"
                                               title="Baixar">
                                                <i class="bi bi-download"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-primary"
                                               target="_blank"
                                               href="@Url.Action("PreviewVersion", "Ged", new { versionId = v.Id })">
                                                Visualizar
                                            </a>

                                            <a class="btn btn-sm btn-outline-secondary"
                                               href="@Url.Action("DownloadVersion", "Ged", new { versionId = v.Id })">
                                                Baixar
                                            </a>

                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-muted text-center p-3">Nenhuma versão registrada.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
 
        </div>
    </div>
</div>
