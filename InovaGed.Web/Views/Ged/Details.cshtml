@using System
@using System.Linq
@using System.Threading
@using InovaGed.Application.Identity
@using InovaGed.Application.Classification
@model InovaGed.Web.Models.Ged.GedDetailsVM

@inject ICurrentUser CurrentUser
@inject IDocumentClassificationQueries ClassificationQueries

@{
    var versions = Model.Versions ?? new System.Collections.Generic.List<InovaGed.Web.Models.Ged.GedDetailsVM.VersionVM>();

    var selectedVersionId = Model.SelectedVersionId ?? Model.CurrentVersionId;
    var selectedVersion = versions.FirstOrDefault(v => v.Id == selectedVersionId);

    var isViewingOcr = (selectedVersion?.FileName ?? "").EndsWith("_OCR.pdf", StringComparison.OrdinalIgnoreCase);
    var showToast = (ViewBag.OcrSwitched is bool b && b);

    // Para abrir modal automaticamente quando vier do Index
    var openClassify = (Context.Request.Query["openClassify"].ToString() ?? "")
        .Equals("true", StringComparison.OrdinalIgnoreCase);
}

@if (showToast)
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1200;">
        <div id="ocrToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    ✅ OCR concluído — abrindo versão OCR…
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Fechar"></button>
            </div>
        </div>
    </div>
}

<div class="row g-3">
    <!-- LEFT -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-eye"></i>
                    <strong>Visualização</strong>

                    @if (isViewingOcr)
                    {
                        <span class="badge bg-success ms-2" title="Você está visualizando a versão OCR">OCR</span>
                    }
                </div>

                <div class="d-flex gap-2 flex-wrap align-items-center">
                    @if (selectedVersionId != null)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnFull" title="Tela cheia">
                            <i class="bi bi-fullscreen"></i>
                        </button>

                        <a class="btn btn-sm btn-outline-primary"
                           target="_blank"
                           href="@Url.Action("PreviewVersion","Ged", new { versionId = selectedVersionId })">
                            Abrir
                        </a>

                        <form asp-action="RegeneratePreview" asp-controller="Ged" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="versionId" value="@selectedVersionId" />
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                Regerar preview
                            </button>
                        </form>

                        <form asp-action="RunOcr" asp-controller="Ged" method="post" class="d-inline" id="ocrForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="versionId" value="@selectedVersionId" />
                            <input type="hidden" name="force" value="false" />
                            <button type="submit" class="btn btn-sm btn-outline-success" id="btnOcr">
                                @(isViewingOcr ? "Refazer OCR" : "OCR")
                            </button>
                        </form>

                        <form asp-action="RunOcr" asp-controller="Ged" method="post" class="d-inline" id="ocrForceForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="versionId" value="@selectedVersionId" />
                            <input type="hidden" name="force" value="true" />
                            <button type="submit" class="btn btn-sm btn-warning" id="btnOcrForce" title="Forçar OCR (pode invalidar assinatura)">
                                Forçar OCR
                            </button>
                        </form>

                        <span id="ocrStatusBadge" class="ms-1">
                            <span class="badge bg-light text-dark">— OCR</span>
                        </span>
                    }
                </div>
            </div>

            <div class="card-body p-0 position-relative" id="previewContainer" style="height: 70vh;">
                @if (selectedVersionId == null)
                {
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                        Nenhuma versão disponível para visualização.
                    </div>
                }
                else
                {
                    <div id="previewLoading"
                         class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                         style="background: rgba(255,255,255,.75); z-index:10;">
                        <div class="text-center">
                            <div class="spinner-border" role="status"></div>
                            <div class="mt-2 text-muted">Carregando / gerando visualização…</div>
                        </div>
                    </div>

                    <iframe id="previewFrame"
                            src="@Url.Action("PreviewInline","Ged", new { versionId = selectedVersionId })"
                            style="width:100%; height:100%; border:0; background:#f5f5f7;"
                            loading="lazy">
                    </iframe>
                }
            </div>
        </div>

        <!-- Versions -->
        <div class="card mt-3">
            <div class="card-header">
                <strong>Versões</strong>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Arquivo</th>
                            <th>Criado em</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in versions.OrderByDescending(x => x.VersionNumber))
                        {
                            var isSelected = selectedVersionId.HasValue && v.Id == selectedVersionId.Value;
                            <tr class="@(isSelected ? "table-primary" : "")">
                                <td>@v.VersionNumber</td>
                                <td>
                                    <div class="fw-semibold">@v.FileName</div>
                                    <div class="text-muted small">@v.ContentType • @v.SizeBytes.ToString("N0") bytes</div>
                                </td>
                                <td class="text-muted">@v.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@Url.Action("Details","Ged", new { id = Model.Id, versionId = v.Id })">
                                        Ver
                                    </a>
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="@Url.Action("DownloadVersion","Ged", new { versionId = v.Id })">
                                        Baixar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="col-lg-4">
        <!-- ✅ painel de classificação -->
        <div id="classification-panel">
            @{
                var cls = await ClassificationQueries.GetAsync(CurrentUser.TenantId, Model.Id, CancellationToken.None);
                var vd = new ViewDataDictionary(ViewData);
                vd["DocumentId"] = Model.Id;
            }
            @await Html.PartialAsync("_DocumentClassificationPanel", cls, vd)
        </div>

        <!-- ✅ Host do modal (necessário para injetar _EditClassificationModal.cshtml) -->
        <div id="classification-modal-host"></div>

        <!-- Workflow -->
        <div class="card mt-3">
            <div class="card-header">
                <strong>Workflow</strong>
            </div>

            <div class="card-body">
                @if (!Model.Workflow.HasActiveWorkflow)
                {
                    <div class="alert alert-info">
                        Nenhum workflow ativo neste documento.
                    </div>

                    <form asp-action="StartWorkflow" asp-controller="Ged" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="documentId" value="@Model.Id" />

                        <div class="mb-2">
                            <label class="form-label">Iniciar workflow</label>
                            <select class="form-select" name="workflowId" required>
                                <option value="">Selecione...</option>
                                @foreach (var w in Model.Workflow.AvailableWorkflows.OrderBy(x => x.Name))
                                {
                                    <option value="@w.Id">@w.Name</option>
                                }
                            </select>
                        </div>

                        <button class="btn btn-primary w-100" type="submit">Iniciar</button>
                    </form>
                }
                else
                {
                    <div class="mb-2">
                        <div class="text-muted small">Workflow</div>
                        <div class="fw-semibold">@Model.Workflow.WorkflowName</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Etapa atual</div>
                        <div class="fw-semibold">
                            @Model.Workflow.CurrentStageName
                            @if (Model.Workflow.IsCompleted)
                            {
                                <span class="badge bg-success ms-2">Finalizado</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark ms-2">Em andamento</span>
                            }
                        </div>
                        <div class="text-muted small">
                            Iniciado em @Model.Workflow.StartedAt?.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>

                    @if (!Model.Workflow.IsCompleted)
                    {
                        <form asp-action="ApplyTransition" asp-controller="Ged" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="documentId" value="@Model.Id" />

                            <div class="mb-2">
                                <label class="form-label">Ação</label>
                                <select class="form-select" name="transitionId" id="transitionId" required>
                                    <option value="">Selecione...</option>
                                    @foreach (var t in Model.Workflow.AvailableTransitions)
                                    {
                                        <option value="@t.Id" data-requires-reason="@(t.RequiresReason ? "1" : "0")">
                                            @t.Name → @t.ToStageName
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="mb-2" id="grpReason" style="display:none;">
                                <label class="form-label">Motivo</label>
                                <input class="form-control" name="reason" id="reason" maxlength="400" />
                                <div class="form-text">Obrigatório quando a transição exigir justificativa.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Comentários</label>
                                <textarea class="form-control" name="comments" rows="3" maxlength="2000"></textarea>
                            </div>

                            <button class="btn btn-success w-100" type="submit">Aplicar transição</button>
                        </form>
                    }

                    <hr class="my-3" />

                    <div class="d-flex justify-content-between align-items-center">
                        <strong>Histórico</strong>
                        <span class="badge bg-light text-dark">@Model.Workflow.History.Count</span>
                    </div>

                    <div class="mt-2" style="max-height: 45vh; overflow:auto;">
                        @if (Model.Workflow.History.Count == 0)
                        {
                            <div class="text-muted small">Sem histórico.</div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var h in Model.Workflow.History)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between">
                                            <div class="fw-semibold">
                                                @(string.IsNullOrWhiteSpace(h.FromStageName) ? "Início" : h.FromStageName)
                                                → @h.ToStageName
                                            </div>
                                            <div class="text-muted small">@h.PerformedAt.ToString("dd/MM HH:mm")</div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(h.Reason))
                                        {
                                            <div class="small"><strong>Motivo:</strong> @h.Reason</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(h.Comments))
                                        {
                                            <div class="small text-muted">@h.Comments</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <div class="text-muted small">Documento</div>
                <div class="fw-semibold">@Model.Title</div>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="text-muted small mt-1">@Model.Description</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ✅ Token dedicado para as chamadas AJAX (evita pegar o token de outro form) -->
<form id="ajax-antiforgery-form" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        // ============================================================
        // Helpers
        // ============================================================
        function getAjaxAntiForgeryToken() {
            const tokenInput = document.querySelector('#ajax-antiforgery-form input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : '';
        }

        // ============================================================
        // CLASSIFICAÇÃO (MODAL + AJAX)  -> precisa ser GLOBAL (window.*)
        // ============================================================
        window.refreshClassificationPanel = async function (documentId) {
            const url = '@Url.Action("Panel", "Classification")' + '?documentId=' + encodeURIComponent(documentId);
            const html = await fetch(url, { credentials: 'include', cache: 'no-store' }).then(r => r.text());
            const el = document.getElementById('classification-panel');
            if (el) el.innerHTML = html;
        };

        window.openClassificationModal = async function (documentId) {
            const host = document.getElementById('classification-modal-host');
            if (!host) return;

            const url = '@Url.Action("EditModal", "Classification")' + '?documentId=' + encodeURIComponent(documentId);
            const html = await fetch(url, { credentials: 'include', cache: 'no-store' }).then(r => r.text());
            host.innerHTML = html;

            const modalEl = document.getElementById('modalEditClassification');
            if (!modalEl) return;

            const modal = new bootstrap.Modal(modalEl);
            modal.show();

            const form = modalEl.querySelector('#formEditClassification');
            if (form) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    const resp = await fetch('@Url.Action("SaveManual", "Classification")', {
                        method: 'POST',
                        body: new FormData(form),
                        credentials: 'include'
                    });

                    if (resp.ok) {
                        modal.hide();
                        await window.refreshClassificationPanel(documentId);
                    } else {
                        const txt = await resp.text().catch(() => '');
                        alert('Falha ao salvar classificação. ' + txt);
                    }
                }, { once: true });
            }

            modalEl.addEventListener('hidden.bs.modal', function () {
                host.innerHTML = '';
            }, { once: true });
        };

        window.applyClassificationSuggestion = async function (documentId) {
            const token = getAjaxAntiForgeryToken();

            const resp = await fetch('@Url.Action("ApplySuggestion", "Classification")', {
                method: 'POST',
                credentials: 'include',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'documentId=' + encodeURIComponent(documentId)
            });

            if (resp.ok) {
                await window.refreshClassificationPanel(documentId);
            } else {
                const txt = await resp.text().catch(() => '');
                alert('Não foi possível aplicar a sugestão. (' + resp.status + ') ' + txt);
            }
        };

        // Auto abrir modal (vindo do Index -> openClassify=true)
        ;(() => {
            const mustOpen = @((openClassify ? "true" : "false"));
            if (mustOpen) {
                window.openClassificationModal('@Model.Id');
            }
        })();

        // ============================================================
        // PREVIEW (overlay)
        // ============================================================
        ;(() => {
            function bindPreview() {
                const frame = document.getElementById('previewFrame');
                const loading = document.getElementById('previewLoading');

                if (!frame || !loading) return;

                loading.style.display = 'flex';
                frame.addEventListener('load', () => { loading.style.display = 'none'; });

                setTimeout(() => { if (loading) loading.style.display = 'none'; }, 15000);
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', bindPreview);
            } else {
                bindPreview();
            }
        })();

        // ============================================================
        // OCR Toast + Fullscreen + Workflow reason + OCR polling
        // ============================================================
        ;(() => {
            const container = document.getElementById('previewContainer');
            const btnFull = document.getElementById('btnFull');
            if (btnFull && container) {
                btnFull.addEventListener('click', async () => {
                    if (!document.fullscreenElement) await container.requestFullscreen();
                    else await document.exitFullscreen();
                });
            }

            const showToast = @((showToast ? "true" : "false"));
            if (showToast) {
                const el = document.getElementById('ocrToast');
                if (el && window.bootstrap && bootstrap.Toast) {
                    new bootstrap.Toast(el, { delay: 2500 }).show();
                }
            }

            // ===== Workflow: reason obrigatório =====
            const transitionSel = document.getElementById('transitionId');
            const grpReason = document.getElementById('grpReason');
            const reasonInput = document.getElementById('reason');

            function refreshReason() {
                if (!transitionSel || !grpReason) return;
                const opt = transitionSel.options[transitionSel.selectedIndex];
                const req = opt && opt.getAttribute('data-requires-reason') === '1';
                grpReason.style.display = req ? '' : 'none';
                if (reasonInput) {
                    reasonInput.required = req;
                    if (!req) reasonInput.value = '';
                }
            }
            if (transitionSel) {
                transitionSel.addEventListener('change', refreshReason);
                refreshReason();
            }

            // ===== OCR polling =====
            const selectedVersionId = "@(selectedVersionId ?? Guid.Empty)";
            const badgeWrap = document.getElementById('ocrStatusBadge');
            const btnOcr = document.getElementById('btnOcr');
            const btnOcrForce = document.getElementById('btnOcrForce');

            function setBadge(status, error) {
                if (!badgeWrap) return;
                const st = (status || "").toUpperCase();
                if (st === "NONE") {
                    badgeWrap.innerHTML = '<span class="badge bg-light text-dark">— OCR</span>';
                } else if (st === "PENDING") {
                    badgeWrap.innerHTML = '<span class="badge bg-secondary">⏳ OCR pendente</span>';
                } else if (st === "PROCESSING") {
                    badgeWrap.innerHTML = '<span class="badge bg-info text-dark">🔄 OCR processando</span>';
                } else if (st === "COMPLETED") {
                    badgeWrap.innerHTML = '<span class="badge bg-success">✅ OCR concluído</span>';
                } else if (st === "ERROR") {
                    const msg = (error || "Falha no OCR").replaceAll('"', '&quot;');
                    badgeWrap.innerHTML = `<span class="badge bg-danger" title="${msg}">❌ OCR falhou</span>`;
                } else {
                    badgeWrap.innerHTML = '<span class="badge bg-light text-dark">— OCR</span>';
                }
            }

            let pollTimer = null;
            function startPolling() { if (pollTimer) return; pollTimer = setInterval(pollOcr, 2500); pollOcr(); }
            function stopPolling() { if (!pollTimer) return; clearInterval(pollTimer); pollTimer = null; }

            async function pollOcr() {
                try {
                    const url = '@Url.Action("OcrStatus", "Ged")' + '?versionId=' + encodeURIComponent(selectedVersionId);
                    const resp = await fetch(url, { method: 'GET', cache: 'no-store', credentials: 'include' });
                    if (resp.status === 401) { stopPolling(); return; }
                    if (!resp.ok) return;

                    const data = await resp.json();
                    setBadge(data.status, data.errorMessage);

                    const st = (data.status || "").toUpperCase();
                    if (st === "COMPLETED" && data.ocrVersionId) {
                        stopPolling();
                        const target =
                            '@Url.Action("Details", "Ged")'
                            + '?id=' + encodeURIComponent(data.documentId)
                            + '&versionId=' + encodeURIComponent(data.ocrVersionId)
                            + '&ocrSwitched=true';
                        window.location.href = target;
                        return;
                    }

                    if (st !== "PENDING" && st !== "PROCESSING") {
                        stopPolling();
                    }
                } catch (e) { }
            }

            const ocrForm = document.getElementById('ocrForm');
            const ocrForceForm = document.getElementById('ocrForceForm');

            async function enqueue(form) {
                if (!form) return;
                if (btnOcr) btnOcr.disabled = true;
                if (btnOcrForce) btnOcrForce.disabled = true;

                try {
                    const resp = await fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form),
                        credentials: 'include'
                    });

                    if (resp.ok) {
                        startPolling();
                    }
                } catch (e) { }
                finally {
                    if (btnOcr) btnOcr.disabled = false;
                    if (btnOcrForce) btnOcrForce.disabled = false;
                }
            }

            if (ocrForm) {
                ocrForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    enqueue(ocrForm);
                });
            }
            if (ocrForceForm) {
                ocrForceForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    enqueue(ocrForceForm);
                });
            }

            startPolling();
        })();
    </script>
}
