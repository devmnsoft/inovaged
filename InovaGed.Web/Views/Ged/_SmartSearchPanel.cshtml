@model InovaGed.Web.Models.Ged.GedExplorerVM
<div class="ged-smart-search-panel card border-0 shadow-sm mb-3" data-smart-search-panel>
    <div class="card-body">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-2">
            <div>
                <h2 class="h6 mb-1"><i class="bi bi-stars text-primary me-1"></i>Busca inteligente do GED</h2>
                <p class="text-muted small mb-0">Descreva o documento que procura usando paciente, prontuário, tipo, pasta, ano, idade ou termos do OCR.</p>
            </div>
            <a class="btn btn-sm btn-outline-secondary" asp-controller="GedSearch" asp-action="Index"><i class="bi bi-sliders me-1"></i>Busca avançada</a>
        </div>
        <label class="form-label fw-semibold" for="smartSearchInput">Descreva o documento que procura</label>
        <div class="input-group input-group-lg ged-smart-box">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input id="smartSearchInput" class="form-control" name="q" value="@Model.Query" placeholder="Ex: exame do João, doença renal, 24 anos, em 2022" />
            <button id="btnSmartSearchClear" class="btn btn-outline-secondary" type="button"><i class="bi bi-x-lg me-1"></i>Limpar</button>
            <button id="btnSmartExamples" class="btn btn-outline-info" type="button"><i class="bi bi-lightbulb me-1"></i>Exemplos</button>
            <button id="btnSmartFilters" class="btn btn-outline-secondary" type="button"><i class="bi bi-sliders me-1"></i>Busca avançada</button>
            <button id="btnSmartSearch" class="btn btn-primary" type="button"><i class="bi bi-search me-1"></i>Buscar</button>
        </div>
        <div id="smartSearchSuggestions" class="ged-smart-suggestions"></div>
        <div id="smartSearchExamples" class="ged-smart-examples d-none mt-2">
            <button type="button" class="btn btn-sm btn-light border" data-smart-example="Quero o exame do João de 2022">exame do João de 2022</button>
            <button type="button" class="btn btn-sm btn-light border" data-smart-example="Prontuário 285775">Prontuário 285775</button>
            <button type="button" class="btn btn-sm btn-light border" data-smart-example="laudo de diabetes">laudo de diabetes</button>
            <button type="button" class="btn btn-sm btn-light border" data-smart-example="ultrassom 05/2026">ultrassom 05/2026</button>
        </div>
        <div id="smartSearchFilters" class="border rounded-3 p-2 mt-2 bg-light d-none">
            <div class="d-flex gap-3 flex-wrap small">
                <label class="form-check-label"><input class="form-check-input" type="radio" name="searchScope" value="folder" checked /> Pasta atual</label>
                <label class="form-check-label"><input class="form-check-input" type="radio" name="searchScope" value="global" /> Todo GED</label>
            </div>
            <div id="smartSearchChips" class="d-flex flex-wrap gap-1 mt-2"></div>
            <div id="smartSearchExplanation" class="small text-muted mt-2">Vou buscar pelos termos informados.</div>
        </div>
    </div>
</div>
