@model InovaGed.Web.Models.Protocolo.ProtocoloIndexVM
@{ ViewData["Title"] = "Protocolos"; ViewData["Subtitle"] = "Caixa de entrada, enviados e histórico."; }
<div class="d-flex justify-content-between align-items-center mb-3"><h4>Processos Solicitados</h4><a asp-action="Novo" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo Protocolo</a></div>
@if (TempData["ok"] != null){<div class="alert alert-success">@TempData["ok"]</div>} @if (TempData["erro"] != null){<div class="alert alert-danger">@TempData["erro"]</div>}
<div class="card border-0 shadow-sm mb-3"><div class="card-body"><form method="get" class="row g-2"><div class="col-md-3"><select name="visao" class="form-select"><option value="entrada" selected="@(Model.Visao=="entrada")">Caixa de Entrada</option><option value="enviados" selected="@(Model.Visao=="enviados")">Enviados</option><option value="historico" selected="@(Model.Visao=="historico")">Histórico</option></select></div><div class="col-md-3"><select name="status" class="form-select"><option value="">Todos</option><option>RASCUNHO</option><option>ABERTO</option><option>EM_TRAMITACAO</option><option>DEFERIDO</option><option>INDEFERIDO</option><option>FINALIZADO</option><option>ARQUIVADO</option></select></div><div class="col-md-4"><input name="q" value="@Model.Q" class="form-control" placeholder="Número, interessado, assunto..." /></div><div class="col-md-2"><button class="btn btn-outline-primary w-100">Filtrar</button></div></form></div></div>
<div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Número</th><th>Emissão</th><th>Setor Atual</th><th>Tipo</th><th>Interessado</th><th>Assunto</th><th>Status</th><th>Anexos</th><th></th></tr></thead><tbody>
@if (!Model.Itens.Any()){<tr><td colspan="9" class="text-center text-muted py-4">Nenhum protocolo encontrado.</td></tr>}else{foreach(var i in Model.Itens){<tr><td><strong>@i.Numero</strong><div class="small text-muted">@i.Especie</div></td><td>@i.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td><td>@i.SetorAtual</td><td>@i.TipoSolicitacao</td><td>@i.Interessado</td><td>@i.Assunto</td><td><span class="badge text-bg-secondary">@i.Status</span></td><td>@i.TotalAnexos</td><td class="text-end"><a asp-action="Details" asp-route-id="@i.Id" class="btn btn-sm btn-outline-primary">Ver</a></td></tr>}}
</tbody></table></div></div>
