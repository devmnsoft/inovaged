@model InovaGed.Web.Models.Protocolo.ProtocoloIndexVM
@{
    ViewData["Title"] = "Processos Solicitados";
    ViewData["Subtitle"] = "Caixa do setor atual do usuário";
}

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background:#dff2d8;">
        <h4 class="mb-0 text-success">Processos Solicitados</h4>
    </div>

    <div class="card-body">
        @if (TempData["ok"] is not null)
        {
            <div class="alert alert-success">@TempData["ok"]</div>
        }

        @if (TempData["erro"] is not null)
        {
            <div class="alert alert-danger">@TempData["erro"]</div>
        }

        <form method="get" class="row g-2 mb-4">
            <div class="col-md-5">
                <input type="text"
                       name="q"
                       value="@Model.Q"
                       class="form-control"
                       placeholder="Digite o número do processo, interessado ou assunto..." />
            </div>

            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Todos os status</option>
                    <option value="RASCUNHO" selected="@(Model.Status == "RASCUNHO")">Rascunho</option>
                    <option value="ABERTO" selected="@(Model.Status == "ABERTO")">Aberto</option>
                    <option value="EM_TRAMITACAO" selected="@(Model.Status == "EM_TRAMITACAO")">Em tramitação</option>
                    <option value="DEFERIDO" selected="@(Model.Status == "DEFERIDO")">Deferido</option>
                    <option value="INDEFERIDO" selected="@(Model.Status == "INDEFERIDO")">Indeferido</option>
                    <option value="FINALIZADO" selected="@(Model.Status == "FINALIZADO")">Finalizado</option>
                    <option value="ARQUIVADO" selected="@(Model.Status == "ARQUIVADO")">Arquivado</option>
                </select>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button class="btn btn-success" type="submit">
                    <i class="bi bi-search"></i> Buscar
                </button>

                <a asp-action="Index" class="btn btn-light border">
                    Mostrar Todos
                </a>

                <a asp-action="Novo" class="btn btn-primary ms-auto">
                    <i class="bi bi-plus-lg"></i> Novo Protocolo
                </a>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th><i class="bi bi-file-earmark-text"></i> Processo</th>
                        <th><i class="bi bi-calendar3"></i> Emissão</th>
                        <th><i class="bi bi-building"></i> Lotação</th>
                        <th><i class="bi bi-pin-angle-fill"></i> Tipo da Solicitação</th>
                        <th><i class="bi bi-person-fill"></i> Interessado</th>
                        <th><i class="bi bi-pencil-square"></i> Assunto</th>
                        <th>Status</th>
                        <th class="text-center"><i class="bi bi-search"></i> Verificar</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Protocolos.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Nenhum protocolo encontrado para o setor atual do usuário.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Protocolos)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Numero</td>
                            <td>@item.Emissao.ToString("dd/MM/yyyy")</td>
                            <td>@item.Lotacao</td>
                            <td>@item.TipoSolicitacao</td>
                            <td>@item.Interessado</td>
                            <td>@item.Assunto</td>
                            <td>
                                <span class="badge text-bg-secondary">@item.Status</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-search"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
