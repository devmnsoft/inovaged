@*
Adicionar em InovaGed.Web/Views/Protocolo/Details.cshtml:
<partial name="~/Views/Protocolo/_BotoesMelhoriasFinais.cshtml" model="Model" />
*@
<div class="d-flex flex-wrap gap-2 my-3">
    <a href="/Protocolo/Editar/@Model.Id" class="btn btn-outline-primary"><i class="bi bi-pencil-square me-1"></i>Editar</a>
    <a href="/Protocolo/Ged/Vinculos/@Model.Id" class="btn btn-outline-success"><i class="bi bi-link-45deg me-1"></i>Vincular GED</a>
    <a href="/Protocolo/Comprovante/@Model.Id" target="_blank" class="btn btn-outline-secondary"><i class="bi bi-printer me-1"></i>Comprovante</a>
    <a href="/Protocolo/Capa/@Model.Id" target="_blank" class="btn btn-outline-dark"><i class="bi bi-file-earmark-text me-1"></i>Capa</a>
</div>
