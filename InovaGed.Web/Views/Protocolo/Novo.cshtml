@model InovaGed.Web.Models.Protocolo.ProtocoloNovoVM
@{ ViewData["Title"] = "Novo Protocolo"; }
<div class="d-flex justify-content-between mb-3"><h4>Novo Protocolo</h4><a asp-action="Index" class="btn btn-outline-secondary">Voltar</a></div>
<form asp-action="Novo" method="post" enctype="multipart/form-data">@Html.AntiForgeryToken()<div asp-validation-summary="All" class="text-danger"></div>
<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold">Tramitação inicial</div><div class="card-body row g-3"><div class="col-md-6"><label class="form-label">Setor de origem</label><select asp-for="SetorOrigemId" asp-items="Model.Setores" class="form-select"><option value="">Selecione</option></select></div><div class="col-md-6"><label class="form-label">Setor de destino</label><select asp-for="SetorDestinoId" asp-items="Model.Setores" class="form-select"><option value="">Selecione</option></select></div><div class="col-md-3"><label>Tipo</label><select asp-for="TipoProtocoloId" asp-items="Model.Tipos" class="form-select"><option value="">Selecione</option></select></div><div class="col-md-3"><label>Assunto cadastrado</label><select asp-for="AssuntoId" asp-items="Model.Assuntos" class="form-select"><option value="">Selecione</option></select></div><div class="col-md-3"><label>Prioridade</label><select asp-for="PrioridadeId" asp-items="Model.Prioridades" class="form-select"><option value="">Normal</option></select></div><div class="col-md-3"><label>Canal</label><select asp-for="CanalEntradaId" asp-items="Model.CanaisEntrada" class="form-select"><option value="">Selecione</option></select></div></div></div>
<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold">Dados do processo</div><div class="card-body row g-3"><div class="col-md-3"><label>Espécie</label><input asp-for="Especie" class="form-control" /></div><div class="col-md-3"><label>Tipo da solicitação</label><input asp-for="TipoSolicitacao" class="form-control" /></div><div class="col-md-3"><label>Procedência</label><input asp-for="Procedencia" class="form-control" /></div><div class="col-md-3"><label>Origem</label><input asp-for="OrigemPedido" class="form-control" /></div><div class="col-md-12"><label>Assunto</label><input asp-for="Assunto" class="form-control" /></div><div class="col-md-12"><label>Descrição</label><textarea asp-for="Descricao" rows="3" class="form-control"></textarea></div><div class="col-md-12"><label>Informações complementares</label><textarea asp-for="InformacoesComplementares" rows="3" class="form-control"></textarea></div></div></div>
<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold">Solicitante / Interessado</div><div class="card-body row g-3"><div class="col-md-4"><label>Solicitante</label><input asp-for="SolicitanteNome" class="form-control" /></div><div class="col-md-4"><label>Matrícula</label><input asp-for="SolicitanteMatricula" class="form-control" /></div><div class="col-md-4"><label>Cargo</label><input asp-for="SolicitanteCargo" class="form-control" /></div><div class="col-md-4"><label>Interessado</label><input asp-for="Interessado" class="form-control" /></div><div class="col-md-2"><label>CPF/CNPJ</label><input asp-for="CpfCnpj" class="form-control" /></div><div class="col-md-3"><label>Email</label><input asp-for="Email" class="form-control" /></div><div class="col-md-3"><label>Telefone</label><input asp-for="Telefone" class="form-control" /></div></div></div>
<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-semibold">Anexos iniciais</div><div class="card-body"><input type="file" name="arquivos" multiple class="form-control" /><small class="text-muted">Permite vários arquivos.</small></div></div>
<div class="d-flex justify-content-between"><div class="form-check"><input asp-for="SalvarComoRascunho" class="form-check-input" /><label class="form-check-label">Salvar como rascunho</label></div><button class="btn btn-primary">Gerar Protocolo</button></div></form>
