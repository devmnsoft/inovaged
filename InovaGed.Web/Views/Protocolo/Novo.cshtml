@model InovaGed.Web.Models.Protocolo.ProtocoloFormVM
@{
    ViewData["Title"] = "Novo Protocolo";
    ViewData["Subtitle"] = "Abertura com número automático, tramitação inicial e múltiplos anexos";
}

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background:#dff2d8;">
        <h4 class="mb-0 text-success">
            <i class="bi bi-file-earmark-plus"></i> Novo Protocolo
        </h4>
    </div>

    <div class="card-body">
        @if (TempData["erro"] is not null)
        {
            <div class="alert alert-danger">@TempData["erro"]</div>
        }

        <form asp-action="Novo" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tipo da Solicitação / Espécie</label>
                    <select asp-for="TipoId" asp-items="Model.Tipos" class="form-select">
                        <option value="">- Selecione -</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Assunto cadastrado</label>
                    <select asp-for="AssuntoId" asp-items="Model.Assuntos" class="form-select">
                        <option value="">- Selecione -</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Prioridade</label>
                    <select asp-for="PrioridadeId" asp-items="Model.Prioridades" class="form-select">
                        <option value="">- Selecione -</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Canal de Entrada / Procedência</label>
                    <select asp-for="CanalEntradaId" asp-items="Model.CanaisEntrada" class="form-select">
                        <option value="">- Selecione -</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Setor de Origem</label>
                    <select asp-for="SetorOrigemId" asp-items="Model.Setores" class="form-select">
                        <option value="">- Selecione -</option>
                    </select>
                    <span asp-validation-for="SetorOrigemId" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Setor para tramitação inicial</label>
                    <select asp-for="SetorDestinoId" asp-items="Model.Setores" class="form-select">
                        <option value="">- Selecione -</option>
                    </select>
                    <span asp-validation-for="SetorDestinoId" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label class="form-label">Assunto do Processo</label>
                    <input asp-for="Assunto" class="form-control" maxlength="300" />
                    <span asp-validation-for="Assunto" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Interessado</label>
                    <input asp-for="Interessado" class="form-control" maxlength="250" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">CPF/CNPJ</label>
                    <input asp-for="CpfCnpj" class="form-control" maxlength="30" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Telefone</label>
                    <input asp-for="Telefone" class="form-control" maxlength="50" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" maxlength="200" />
                </div>

                <div class="col-12">
                    <label class="form-label">Descrição / Requerimento</label>
                    <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label">Informações Complementares</label>
                    <textarea asp-for="InformacoesComplementares" class="form-control" rows="3"></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label">Observação inicial</label>
                    <textarea asp-for="ObservacaoInicial" class="form-control" rows="3"></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label">
                        <i class="bi bi-paperclip"></i> Anexos iniciais
                    </label>
                    <input type="file" name="arquivos" class="form-control" multiple />
                    <div class="form-text">Você pode selecionar vários arquivos na criação do protocolo.</div>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="SalvarComoRascunho" class="form-check-input" />
                        <label asp-for="SalvarComoRascunho" class="form-check-label">
                            Salvar como rascunho
                        </label>
                    </div>
                    <div class="form-text">
                        Se não marcar rascunho, o sistema gera o número automático e já deixa o processo na caixa do setor destino.
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-success" type="submit">
                    <i class="bi bi-save"></i> Salvar Protocolo
                </button>

                <a asp-action="Index" class="btn btn-light border">
                    Voltar
                </a>
            </div>
        </form>
    </div>
</div>
