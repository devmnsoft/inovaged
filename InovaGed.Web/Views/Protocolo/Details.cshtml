@model InovaGed.Web.Models.Protocolo.ProtocoloDetailsVM
@{
    ViewData["Title"] = "Detalhes do Protocolo";
    ViewData["Subtitle"] = Model.Numero;
}

@if (TempData["ok"] is not null)
{
    <div class="alert alert-success">@TempData["ok"]</div>
}

@if (TempData["erro"] is not null)
{
    <div class="alert alert-danger">@TempData["erro"]</div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header text-center bg-white">
        <h5 class="mb-2">
            <i class="bi bi-file-earmark-text text-primary"></i>
            Pedido Solicitado: @Model.Numero
        </h5>

        <div>
            <i class="bi bi-tag-fill"></i> Espécie: @Model.TipoSolicitacao
            <span class="mx-2">|</span>
            <i class="bi bi-info-circle-fill"></i> Status:
            <span class="badge text-bg-secondary">@Model.Status</span>
        </div>
    </div>

    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <h5><i class="bi bi-person-fill"></i> - Solicitante</h5>
                <p>@(Model.Interessado ?? "Não informado")</p>

                <h5><i class="bi bi-geo-alt-fill"></i> - Procedência</h5>
                <p>@(Model.CanalEntrada ?? Model.Procedencia ?? "Não informada")</p>

                <h5><i class="bi bi-chat-left-text-fill"></i> - Assunto</h5>
                <p>@Model.Assunto</p>

                <h5><i class="bi bi-info-circle-fill"></i> - Informações Complementares</h5>
                <p>@(Model.InformacoesComplementares ?? "Sem informações complementares.")</p>

                <h5><i class="bi bi-building-fill"></i> - Setor Atual do Processo</h5>
                <p class="fw-semibold text-primary">@Model.SetorAtual</p>
            </div>

            <div class="col-md-6">
                <h5><i class="bi bi-tag-fill"></i> - Espécie</h5>
                <p>@Model.TipoSolicitacao</p>

                <h5><i class="bi bi-person-check-fill"></i> - Interessado</h5>
                <p>@(Model.Interessado ?? "Não informado")</p>

                <h5><i class="bi bi-paperclip"></i> - Anexos</h5>
                <p>@Model.Documentos.Count documento(s) anexado(s)</p>

                <h5><i class="bi bi-flag-fill"></i> - Origem do Pedido</h5>
                <p>@Model.SetorOrigem</p>

                @if (!string.IsNullOrWhiteSpace(Model.JustificativaEncerramento))
                {
                    <h5><i class="bi bi-check-circle-fill"></i> - Justificativa de Encerramento</h5>
                    <p>@Model.JustificativaEncerramento</p>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.PodeAtuar)
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header" style="background:#dff2d8;">
            <strong><i class="bi bi-pencil-square"></i> Ações do Setor Atual</strong>
        </div>

        <div class="card-body">
            <div class="row g-3">
                @if (Model.PodeAnexar)
                {
                    <div class="col-12">
                        <form asp-action="AnexarDocumentos" method="post" enctype="multipart/form-data" class="border rounded p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="protocoloId" value="@Model.Id" />

                            <h6><i class="bi bi-paperclip"></i> Adicionar novos anexos</h6>

                            <div class="row g-2">
                                <div class="col-md-4">
                                    <select name="tipoDocumentoId" asp-items="Model.TiposDocumento" class="form-select">
                                        <option value="">Tipo de documento</option>
                                    </select>
                                </div>

                                <div class="col-md-5">
                                    <input type="file" name="arquivos" class="form-control" multiple />
                                </div>

                                <div class="col-md-3">
                                    <button class="btn btn-success w-100" type="submit">
                                        <i class="bi bi-upload"></i> Anexar
                                    </button>
                                </div>

                                <div class="col-12">
                                    <input type="text" name="descricao" class="form-control" placeholder="Descrição dos anexos" />
                                </div>
                            </div>
                        </form>
                    </div>
                }

                <div class="col-12">
                    <form asp-action="AdicionarObservacao" method="post" class="border rounded p-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="protocoloId" value="@Model.Id" />

                        <h6><i class="bi bi-chat-left-text"></i> Adicionar Observação</h6>

                        <div class="row g-2">
                            <div class="col-md-3">
                                <select name="tipo" class="form-select">
                                    <option value="PUBLICA">Pública</option>
                                    <option value="DESPACHO">Despacho</option>
                                    <option value="INTERNA_SETOR">Interna do setor</option>
                                </select>
                            </div>

                            <div class="col-md-7">
                                <textarea name="observacao" class="form-control" rows="2" placeholder="Digite a observação"></textarea>
                            </div>

                            <div class="col-md-2">
                                <button class="btn btn-success w-100" type="submit">
                                    Salvar
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                @if (Model.PodeTramitar)
                {
                    <div class="col-12">
                        <form asp-action="Tramitar" method="post" enctype="multipart/form-data" class="border rounded p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="protocoloId" value="@Model.Id" />

                            <h6><i class="bi bi-arrow-left-right"></i> Tramitar Processo</h6>

                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label">Setor destino</label>
                                    <select name="setorDestinoId" asp-items="Model.SetoresDestino" class="form-select">
                                        <option value="">- Selecione -</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Anexos da tramitação</label>
                                    <input type="file" name="arquivos" class="form-control" multiple />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label">Tipo de documento</label>
                                    <select name="tipoDocumentoId" asp-items="Model.TiposDocumento" class="form-select">
                                        <option value="">Tipo de documento</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Despacho</label>
                                    <textarea name="despacho" class="form-control" rows="2"></textarea>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Observação</label>
                                    <textarea name="observacao" class="form-control" rows="2"></textarea>
                                </div>

                                <div class="col-12">
                                    <button class="btn btn-primary" type="submit">
                                        <i class="bi bi-send"></i> Encaminhar / Tramitar
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                }

                @if (Model.PodeFinalizar || Model.PodeArquivar)
                {
                    <div class="col-md-6">
                        <form asp-action="Finalizar" method="post" class="border rounded p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="protocoloId" value="@Model.Id" />

                            <h6><i class="bi bi-check2-circle"></i> Finalizar Processo</h6>
                            <textarea name="justificativa" class="form-control mb-2" rows="3" placeholder="Justificativa obrigatória"></textarea>

                            <button class="btn btn-success" type="submit">
                                Finalizar
                            </button>
                        </form>
                    </div>

                    <div class="col-md-6">
                        <form asp-action="Arquivar" method="post" class="border rounded p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="protocoloId" value="@Model.Id" />

                            <h6><i class="bi bi-archive"></i> Arquivar Processo</h6>
                            <textarea name="justificativa" class="form-control mb-2" rows="3" placeholder="Justificativa obrigatória"></textarea>

                            <button class="btn btn-warning" type="submit">
                                Arquivar processo
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header" style="background:#dff2d8;">
        <h5 class="mb-0 text-success">Documentos anexados</h5>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Documento</th>
                        <th>Tipo</th>
                        <th>Setor que anexou</th>
                        <th>Data</th>
                        <th class="text-center">Verificar</th>
                        <th class="text-center">Excluir</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Documentos.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted text-center">Nenhum documento anexado.</td>
                    </tr>
                }
                else
                {
                    foreach (var doc in Model.Documentos)
                    {
                        <tr>
                            <td>@doc.NomeArquivo</td>
                            <td>@doc.TipoDocumento</td>
                            <td>@doc.Setor</td>
                            <td>@doc.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <a asp-action="VisualizarDocumento"
                                   asp-route-id="@doc.Id"
                                   class="btn btn-sm btn-outline-primary"
                                   target="_blank">
                                    <i class="bi bi-search"></i>
                                </a>
                            </td>
                            <td class="text-center">
                                @if (doc.PodeExcluir)
                                {
                                    <form asp-action="ExcluirDocumento" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@doc.Id" />
                                        <input type="hidden" name="protocoloId" value="@Model.Id" />
                                        <input type="hidden" name="motivo" value="Exclusão solicitada pelo setor dono do anexo." />

                                        <button class="btn btn-sm btn-outline-danger"
                                                type="submit"
                                                onclick="return confirm('Confirma a exclusão deste anexo? Somente o setor que anexou pode executar esta ação.');">
                                            <i class="bi bi-x-circle-fill"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted" title="Somente o setor que anexou pode excluir.">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header" style="background:#dff2d8;">
        <h5 class="mb-0 text-success">
            <i class="bi bi-chat-left-text"></i> Observações Adicionadas
        </h5>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Observação</th>
                        <th>Tipo</th>
                        <th>Setor</th>
                        <th>Data do Registro</th>
                        <th>Nome da pessoa</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Observacoes.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">Nenhuma observação adicionada.</td>
                    </tr>
                }
                else
                {
                    foreach (var obs in Model.Observacoes)
                    {
                        <tr>
                            <td>@obs.Observacao</td>
                            <td>@obs.Tipo</td>
                            <td>@obs.Setor</td>
                            <td>@obs.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@obs.UsuarioNome</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background:#dff2d8;">
        <h5 class="mb-0 text-success">
            <i class="bi bi-clock-history"></i> Histórico de Movimentações
        </h5>
    </div>

    <div class="card-body">
        @if (Model.Tramitacoes.Count == 0)
        {
            <div class="text-muted">Nenhuma movimentação registrada.</div>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var t in Model.Tramitacoes)
                {
                    <li class="list-group-item">
                        <div class="fw-semibold">
                            @t.DataTramitacao.ToString("dd/MM/yyyy HH:mm:ss")
                            -
                            @t.Acao
                        </div>

                        <div class="small">
                            <strong>De:</strong> @(t.SetorOrigem ?? "-")
                            <strong class="ms-2">Para:</strong> @(t.SetorDestino ?? "-")
                            <strong class="ms-2">Usuário:</strong> @(t.UsuarioNome ?? "-")
                        </div>

                        @if (!string.IsNullOrWhiteSpace(t.Despacho))
                        {
                            <div class="mt-1"><strong>Despacho:</strong> @t.Despacho</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(t.Observacao))
                        {
                            <div class="mt-1"><strong>Observação:</strong> @t.Observacao</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(t.Justificativa))
                        {
                            <div class="mt-1"><strong>Justificativa:</strong> @t.Justificativa</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(t.StatusAnterior) || !string.IsNullOrWhiteSpace(t.StatusNovo))
                        {
                            <div class="small text-muted mt-1">
                                Status: @(t.StatusAnterior ?? "-") → @(t.StatusNovo ?? "-")
                            </div>
                        }
                    </li>
                }
            </ul>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-light border">
        <i class="bi bi-arrow-left"></i> Voltar para o grid
    </a>
</div>
