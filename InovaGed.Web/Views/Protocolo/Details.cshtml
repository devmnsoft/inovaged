@model InovaGed.Web.Models.Protocolo.ProtocoloDetailsVM
@{ ViewData["Title"] = "Protocolo " + Model.Numero; }
<div class="d-flex justify-content-between mb-3"><div><h4>@Model.Numero</h4><div class="text-muted">@Model.Assunto</div></div><a asp-action="Index" class="btn btn-outline-secondary">Voltar</a></div>
@if (TempData["ok"] != null){<div class="alert alert-success">@TempData["ok"]</div>} @if (TempData["erro"] != null){<div class="alert alert-danger">@TempData["erro"]</div>}
<div class="row g-3 mb-3"><div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Status</div><b>@Model.Status</b></div></div></div><div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Setor atual</div><b>@Model.SetorAtual</b></div></div></div><div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Emissão</div><b>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</b></div></div></div><div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Anexos</div><b>@Model.Documentos.Count</b></div></div></div></div>
<ul class="nav nav-tabs mb-3"><li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#dados" type="button">Dados</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#anexos" type="button">Anexos</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tram" type="button">Tramitação</button></li><li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#obs" type="button">Observações</button></li>@if(Model.PodeOperar){<li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#acoes" type="button">Ações</button></li>}</ul>
<div class="tab-content"><div class="tab-pane fade show active" id="dados"><div class="card border-0 shadow-sm"><div class="card-body row g-3"><div class="col-md-3"><small class="text-muted">Espécie</small><div>@Model.Especie</div></div><div class="col-md-3"><small class="text-muted">Tipo</small><div>@Model.TipoSolicitacao</div></div><div class="col-md-3"><small class="text-muted">Procedência</small><div>@Model.Procedencia</div></div><div class="col-md-3"><small class="text-muted">Origem</small><div>@Model.OrigemPedido</div></div><div class="col-md-4"><small class="text-muted">Solicitante</small><div>@Model.SolicitanteNome</div></div><div class="col-md-4"><small class="text-muted">Interessado</small><div>@Model.Interessado</div></div><div class="col-md-4"><small class="text-muted">Contato</small><div>@Model.Email @Model.Telefone</div></div><div class="col-md-12"><small class="text-muted">Descrição</small><div class="border rounded p-3 bg-light">@Model.Descricao</div></div><div class="col-md-12"><small class="text-muted">Informações complementares</small><div class="border rounded p-3 bg-light">@Model.InformacoesComplementares</div></div></div></div></div>
<div class="tab-pane fade" id="anexos">@if(Model.PodeAnexar){<div class="card border-0 shadow-sm mb-3"><div class="card-body"><form asp-action="Anexar" method="post" enctype="multipart/form-data" class="row g-2">@Html.AntiForgeryToken()<input type="hidden" name="protocoloId" value="@Model.Id" /><div class="col-md-3"><select name="tipoDocumentoId" asp-items="Model.TiposDocumento" class="form-select"><option value="">Tipo</option></select></div><div class="col-md-4"><input name="descricao" class="form-control" placeholder="Descrição" /></div><div class="col-md-4"><input type="file" name="arquivos" multiple class="form-control" /></div><div class="col-md-1"><button class="btn btn-primary w-100">+</button></div></form></div></div>}<div class="card border-0 shadow-sm"><table class="table mb-0"><thead><tr><th>Arquivo</th><th>Tipo</th><th>Setor</th><th>Data</th><th></th></tr></thead><tbody>@foreach(var d in Model.Documentos){<tr><td>@d.NomeArquivo<br /><small>@d.ContentType - @d.TamanhoBytes bytes</small></td><td>@d.TipoDocumento</td><td>@d.SetorNome</td><td>@d.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td><td class="text-end"><a asp-action="VisualizarDocumento" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary">Ver</a>@if(d.PodeExcluir){<form asp-action="ExcluirDocumento" method="post" class="d-inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@d.Id" /><input type="hidden" name="motivo" value="Exclusão pelo setor responsável" /><button class="btn btn-sm btn-outline-danger">Excluir</button></form>}</td></tr>}@if(!Model.Documentos.Any()){<tr><td colspan="5" class="text-center text-muted">Nenhum anexo.</td></tr>}</tbody></table></div></div>
<div class="tab-pane fade" id="tram"><div class="card border-0 shadow-sm"><div class="card-body">@foreach(var t in Model.Tramitacoes){<div class="border-bottom py-2"><b>@t.Acao</b> <span class="text-muted small">@t.DataTramitacao.ToString("dd/MM/yyyy HH:mm")</span><div class="small text-muted">@t.SetorOrigemNome → @t.SetorDestinoNome | @t.UsuarioNome</div><div>@t.Despacho @t.Observacao @t.Justificativa</div></div>}@if(!Model.Tramitacoes.Any()){<div class="text-muted">Nenhuma tramitação.</div>}</div></div></div>
<div class="tab-pane fade" id="obs">@if(Model.PodeOperar){<div class="card border-0 shadow-sm mb-3"><div class="card-body"><form asp-action="AdicionarObservacao" method="post" class="row g-2">@Html.AntiForgeryToken()<input type="hidden" name="protocoloId" value="@Model.Id" /><div class="col-md-3"><select name="tipo" class="form-select"><option value="PUBLICA">Pública</option><option value="DESPACHO">Despacho</option><option value="INTERNA_SETOR">Interna do Setor</option></select></div><div class="col-md-8"><input name="observacao" class="form-control" /></div><div class="col-md-1"><button class="btn btn-primary w-100">+</button></div></form></div></div>}<div class="card border-0 shadow-sm"><div class="card-body">@foreach(var o in Model.Observacoes){<div class="border-bottom py-2"><b>@o.Tipo</b> <span class="text-muted small">@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span><div class="small text-muted">@o.SetorNome | @o.UsuarioNome</div><div>@o.Observacao</div></div>}@if(!Model.Observacoes.Any()){<div class="text-muted">Nenhuma observação.</div>}</div></div></div>
@if(Model.PodeOperar){<div class="tab-pane fade" id="acoes"><div class="row g-3"><div class="col-md-6"><div class="card border-0 shadow-sm"><div class="card-header bg-white">Tramitar</div><div class="card-body"><form asp-action="Tramitar" method="post">@Html.AntiForgeryToken()<input type="hidden" name="protocoloId" value="@Model.Id" /><select name="setorDestinoId" asp-items="Model.SetoresDestino" class="form-select mb-2"></select><textarea name="despacho" class="form-control mb-2" placeholder="Despacho"></textarea><textarea name="observacao" class="form-control mb-2" placeholder="Observação"></textarea><button class="btn btn-primary">Tramitar</button></form></div></div></div><div class="col-md-6"><div class="card border-0 shadow-sm"><div class="card-header bg-white">Decisão</div><div class="card-body">@foreach(var a in new[]{"Deferir","Indeferir","Finalizar","Arquivar"}){<form asp-action="@a" method="post" class="mb-2">@Html.AntiForgeryToken()<input type="hidden" name="protocoloId" value="@Model.Id" /><textarea name="justificativa" class="form-control mb-1" placeholder="Justificativa obrigatória"></textarea><button class="btn btn-secondary">@a</button></form>}</div></div></div></div></div>}</div>
