@model InovaGed.Web.Models.Protocolo.ProtocoloSetorFormVM
@{
    ViewData["Title"] = "Editar Setor";
}

<div class="container-fluid py-3">
    <h2>Editar Setor</h2>
    <form asp-action="EditarSetor" method="post" class="card card-body">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Sigla" class="form-label"></label>
                <input asp-for="Sigla" class="form-control" />
            </div>
            <div class="col-md-12">
                <label asp-for="Descricao" class="form-label"></label>
                <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-12">
                <div class="form-check">
                    <input asp-for="Ativo" class="form-check-input" />
                    <label asp-for="Ativo" class="form-check-label">Ativo</label>
                </div>
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary">Salvar</button>
            <a asp-action="Setores" class="btn btn-outline-secondary">Voltar</a>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
