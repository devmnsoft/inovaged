{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DocumentUpload": {
    "MaxFileSizeMb": 100,
    "MaxBatchFiles": 500,
    "MaxConcurrentUploadsGlobal": 8,
    "MaxConcurrentUploadsPerUser": 2,
    "MaxConcurrentUploadsPerBatch": 2,
    "UploadTimeoutSeconds": 300,
    "AllowLegacyUploadFallback": false,
    "AllowedExtensions": [
      ".pdf",
      ".jpg",
      ".jpeg",
      ".png",
      ".tif",
      ".tiff",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".txt"
    ]
  }
}
