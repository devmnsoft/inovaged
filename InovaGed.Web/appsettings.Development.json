{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DocumentUpload": {
    "MaxFileSizeMb": 2048,
    "MaxBatchFiles": 200,
    "MaxConcurrentUploadsGlobal": 30,
    "MaxConcurrentUploadsPerUser": 2,
    "MaxConcurrentUploadsPerTenant": 10,
    "MaxConcurrentUploadsPerBatch": 2,
    "UploadTimeoutSeconds": 1800,
    "AllowLegacyUploadFallback": false,
    "AllowedExtensions": [
      ".pdf",
      ".png",
      ".jpg",
      ".jpeg",
      ".tif",
      ".tiff",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".ppt",
      ".pptx",
      ".txt"
    ],
    "ChunkSizeMb": 10,
    "ChunkedThresholdMb": 50,
    "UseChunkedUpload": true
  },
  "SystemSeed": {
    "Enabled": true,
    "FailFastOnSeedError": false,
    "UpdateExistingPasswords": false,
    "NormalizeLegacyRoles": true
  },
  "DigitalSignature": {
    "Enabled": false,
    "Mode": "AgentCms",
    "AllowServerSidePfxUpload": false,
    "SessionTtlSeconds": 300,
    "ContentTokenTtlSeconds": 120,
    "MaxDocumentSizeMb": 100,
    "RequireLoopbackHttps": true,
    "AgentBaseUrl": "https://127.0.0.1:17891",
    "AllowedAgentOrigins": [],
    "AllowInternalTestCertificates": false
  }
}
